{
  "_comment": "Dev profile 'Dev: Simulated (offline)' (DOTNET_ENVIRONMENT=DevSim). Skips login and runs a fully-offline synthetic random-walk feed. No broker, no network, no Docker.",
  "Dev": {
    "BypassLogin": true,
    "AutoConnectBrokers": [ "Simulated" ]
  },
  "SimulatedBroker": {
    "Mode": "Synthetic",
    "SpeedMultiplier": 1.0,
    "SyntheticTickIntervalMs": 250,
    "SyntheticBarIntervalMs": 2000,
    "SyntheticStartPrice": 100.0,
    "SyntheticVolatility": 0.0015,
    "Instruments": [ "AAPL", "MSFT", "ES", "NQ", "BTCUSD" ]
  },
  "MarketDataStore": {
    "Provider": "Sqlite",
    "PersistLiveData": false
  }
}
