<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Must match the host: DaxAlgo Terminal's Windows tree is net9.0-windows7.0. -->
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <Deterministic>true</Deterministic>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    <PathMap>$(MSBuildProjectDirectory)=/_/daxalgo-strategy-windows</PathMap>
    <!--#if (ui) -->
    <!-- A live-window plugin ships WPF views. -->
    <UseWPF>true</UseWPF>
    <!--#endif -->
  </PropertyGroup>

  <ItemGroup>
    <!-- Canonical strategy math compiles once into the WPF-free Engine assembly. This project is
         presentation / legacy-host registration only; dependency direction is Windows -> Engine. -->
    <Compile Remove="Engine\**\*.cs" />
    <ProjectReference Include="Engine\DaxNewStrategy.Engine.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- COMPILE-TIME surface only (ExcludeAssets=runtime): at runtime the host shares its own
         contract assemblies into the plugin's load context, so the plugin folder must NEVER ship
         TradingTerminal.*/DaxAlgo.Sdk* copies — a shipped copy breaks type identity with the host
         and the strategy silently stops matching. This also keeps bin/ = exactly the files that
         belong in the plugin package.
         The SDK is pre-1.0: the host requires an EXACT major.minor match, so bumping this version
         means rebuilding against the matching host. -->
    <!--#if (ui) -->
    <!-- DaxAlgo.Sdk.Wpf bundles DaxAlgo.Sdk + the WPF strategy-window base (LiveSignalStrategyViewModelBase,
         the shared controls, MahApps) — everything a live window needs. -->
    <PackageReference Include="DaxAlgo.Sdk.Wpf" Version="0.2.0-alpha" ExcludeAssets="runtime" />
    <!--#else -->
    <PackageReference Include="DaxAlgo.Sdk" Version="0.2.0-alpha" ExcludeAssets="runtime" />
    <!--#endif -->
  </ItemGroup>

  <ItemGroup>
    <!-- The host reads plugin.json BEFORE loading any code (SDK-version gate + provenance). -->
    <None Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
