{
  "description": "Codex lifecycle hooks use one adapter over the canonical .claude hook chain.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/.codex/hooks/adapter.ps1\" -Event SessionStart",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/adapter.ps1') -Event 'SessionStart' }\"",
            "timeout": 20,
            "statusMessage": "Loading repository orientation"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$(git rev-parse --show-toplevel)/.codex/hooks/adapter.ps1\" -Event Stop",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/adapter.ps1') -Event 'Stop' }\"",
            "timeout": 180,
            "statusMessage": "Running repository verification"
          }
        ]
      }
    ]
  }
}
