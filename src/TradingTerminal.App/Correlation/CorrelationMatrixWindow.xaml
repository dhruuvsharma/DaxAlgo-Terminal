<mah:MetroWindow x:Class="TradingTerminal.App.Correlation.CorrelationMatrixWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="Correlation matrix"
                 Width="960" Height="680"
                 MinWidth="720" MinHeight="480"
                 TitleCharacterCasing="Normal"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 d:DesignHeight="680" d:DesignWidth="960">

    <Window.Resources>
        <!-- Horizontal stack for the matrix rows / column headers. -->
        <ItemsPanelTemplate x:Key="HorizontalPanel">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- title -->
            <RowDefinition Height="Auto" />   <!-- controls -->
            <RowDefinition Height="*" />      <!-- body: picker + matrix -->
            <RowDefinition Height="Auto" />   <!-- legend -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Correlation matrix" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Pearson correlation of bar-to-bar log returns across the selected instruments, over the chosen timeframe and lookback. Green = move together, red = move apart. Series are aligned on their common timestamps before correlating."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Control bar -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- timeframe lbl -->
                    <ColumnDefinition Width="100" />    <!-- timeframe cb  -->
                    <ColumnDefinition Width="Auto" />   <!-- lookback lbl  -->
                    <ColumnDefinition Width="110" />    <!-- lookback cb   -->
                    <ColumnDefinition Width="Auto" />   <!-- compute       -->
                    <ColumnDefinition Width="Auto" />   <!-- busy ring     -->
                    <ColumnDefinition Width="*" />      <!-- status        -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="1"
                           ItemsSource="{Binding Timeframes}"
                           SelectedItem="{Binding SelectedTimeframe}"
                           DisplayMemberPath="Label"
                           Margin="0,0,14,0" />

                <TextBlock Grid.Column="2" Text="Lookback" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="3"
                           ItemsSource="{Binding Lookbacks}"
                           SelectedItem="{Binding SelectedLookback}"
                           DisplayMemberPath="Label"
                           Margin="0,0,14,0" />

                <Button Grid.Column="4" Content="Compute"
                        Command="{Binding ComputeCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,10,0" />

                <mah:ProgressRing Grid.Column="5"
                                  IsActive="{Binding IsBusy}"
                                  Width="18" Height="18" Margin="0,0,10,0" />

                <TextBlock Grid.Column="6" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />   <!-- instrument picker -->
                <ColumnDefinition Width="*" />     <!-- matrix -->
            </Grid.ColumnDefinitions>

            <!-- Instrument checklist -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Instruments" FontWeight="SemiBold" Margin="2,0,0,6" />

                    <TextBox Grid.Row="1"
                             Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             mah:TextBoxHelper.Watermark="filter symbols…"
                             mah:TextBoxHelper.ClearTextButton="True"
                             Margin="0,0,0,6" />

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Instruments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              Content="{Binding DisplayName}"
                                              Margin="2,2,0,2" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Select visible" Command="{Binding SelectAllVisibleCommand}"
                                Padding="8,3" Margin="0,0,6,0" />
                        <Button Content="Clear" Command="{Binding ClearSelectionCommand}"
                                Padding="8,3" />
                        <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} picked'}"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Matrix -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Padding="10">
                    <StackPanel>
                        <!-- Column headers (rotated), offset by the row-header width -->
                        <StackPanel Orientation="Horizontal">
                            <Border Width="92" Height="74" />
                            <ItemsControl ItemsSource="{Binding Labels}"
                                          ItemsPanel="{StaticResource HorizontalPanel}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="40" Height="74" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding}" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                       Margin="0,0,0,4">
                                                <TextBlock.LayoutTransform>
                                                    <RotateTransform Angle="-90" />
                                                </TextBlock.LayoutTransform>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Matrix rows -->
                        <ItemsControl ItemsSource="{Binding MatrixRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="92" Height="30" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Header}" FontSize="11"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,8,0" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding Cells}"
                                                      ItemsPanel="{StaticResource HorizontalPanel}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Width="40" Height="30"
                                                            BorderBrush="{DynamicResource Background.Primary}"
                                                            BorderThickness="1"
                                                            Background="{Binding Value, Converter={StaticResource CorrelationToBrushConverter}}">
                                                        <Border.ToolTip>
                                                            <MultiBinding StringFormat="{}{0} ↔ {1}: {2}">
                                                                <Binding Path="RowLabel" />
                                                                <Binding Path="ColLabel" />
                                                                <Binding Path="Display" />
                                                            </MultiBinding>
                                                        </Border.ToolTip>
                                                        <TextBlock Text="{Binding Display}" FontSize="10"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Legend -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="Correlation" Foreground="{DynamicResource Text.Secondary}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <Border Width="34" Height="16" Background="#C62828" />
            <TextBlock Text="-1" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="11" />
            <Border Width="34" Height="16" Background="#2D2D30" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" />
            <TextBlock Text="0" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="11" />
            <Border Width="34" Height="16" Background="#2E7D32" />
            <TextBlock Text="+1" VerticalAlignment="Center" Margin="3,0,0,0" FontSize="11" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
