<UserControl x:Class="TradingTerminal.App.Archive.ArchiveSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}"
             d:DesignHeight="700" d:DesignWidth="640">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="680" HorizontalAlignment="Left">

            <TextBlock Text="Market data archive"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Offload stored quotes / bars to your Telegram account on a schedule so the local store stays small. Telegram allows up to 2 GB per file; larger weeks are split into parts and reassembled on restore."
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <!-- Telegram login -->
            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1" CornerRadius="3" Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Telegram login" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <TextBlock Text="API id  (from my.telegram.org / Apps)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ApiId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" Margin="0,0,0,8" />

                    <TextBlock Text="API hash" Margin="0,0,0,4" />
                    <TextBox Text="{Binding ApiHash, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" Margin="0,0,0,8" />

                    <TextBlock Text="Phone number  (international, e.g. +9198…)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Login to Telegram"
                                Command="{Binding LoginToTelegramCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                Padding="14,4" Margin="0,0,12,0" />
                        <TextBlock Text="{Binding TelegramStatus}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text.Secondary}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Schedule -->
            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1" CornerRadius="3" Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Schedule" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <CheckBox Content="Enabled — auto-offload at the end of every period"
                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Period" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding PeriodOptions}"
                                      SelectedItem="{Binding Period, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Daily check hour (UTC, 0–23)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding DailyCheckHourUtc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Tables to include" Margin="0,8,0,4" />
                    <StackPanel Orientation="Horizontal">
                        <CheckBox Content="Quotes" IsChecked="{Binding IncludeQuotes, Mode=TwoWay}" Margin="0,0,12,0" />
                        <CheckBox Content="Bars" IsChecked="{Binding IncludeBars, Mode=TwoWay}" Margin="0,0,12,0" />
                        <CheckBox Content="Trades" IsChecked="{Binding IncludeTrades, Mode=TwoWay}" Margin="0,0,12,0" />
                        <CheckBox Content="Depth (L2)" IsChecked="{Binding IncludeDepth, Mode=TwoWay}"
                                  ToolTip="Only persisted/archived on the QuestDB backend." />
                    </StackPanel>

                    <TextBlock Text="Max part bytes  (Telegram caps at ~2 GB; keep some headroom)"
                               Margin="0,12,0,4" />
                    <TextBox Text="{Binding MaxPartBytes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas" Margin="0,0,0,12" />

                    <CheckBox Content="Verify each part by re-downloading + sha256 before deletion"
                              IsChecked="{Binding VerifyAfterUpload, Mode=TwoWay}"
                              Margin="0,0,0,8" />
                    <CheckBox Content="Delete local rows after verified upload"
                              IsChecked="{Binding DeleteLocalAfterArchive, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!-- Default target -->
            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1" CornerRadius="3" Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Default destination" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <TextBlock Text="Where the scheduled archive goes (Saved Messages by default)" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding TargetKindOptions}"
                                  SelectedItem="{Binding DefaultTargetKind, Mode=TwoWay}" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding DefaultTargetChatRef, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding DefaultTargetIsChat}"
                                 FontFamily="Consolas" />
                    </Grid>
                    <TextBlock Text="Chat ref: username (@channel) or numeric chat id. Leave blank for Saved Messages."
                               Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Manual offload -->
            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1" CornerRadius="3" Padding="16">
                <StackPanel>
                    <TextBlock Text="Offload now" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="From (UTC)" Margin="0,0,0,4" />
                            <DatePicker SelectedDate="{Binding ManualFromUtc, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="To (UTC, exclusive)" Margin="0,0,0,4" />
                            <DatePicker SelectedDate="{Binding ManualToUtc, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Destination" Margin="0,8,0,4" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding TargetKindOptions}"
                                  SelectedItem="{Binding ManualTargetKind, Mode=TwoWay}" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding ManualTargetChatRef, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding ManualTargetIsChat}"
                                 FontFamily="Consolas" />
                    </Grid>

                    <Button Content="Offload now"
                            Command="{Binding OffloadNowCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                            HorizontalAlignment="Left"
                            Padding="16,6" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="16,6" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
