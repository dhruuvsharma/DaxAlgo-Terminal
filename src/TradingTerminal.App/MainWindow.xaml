<mah:MetroWindow x:Class="TradingTerminal.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:dock="https://github.com/Dirkster99/AvalonDock"
                 xmlns:local="clr-namespace:TradingTerminal.App"
                 mc:Ignorable="d"
                 Title="Trading Terminal"
                 Height="800" Width="1280"
                 WindowStartupLocation="CenterScreen"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Disconnect banner -->
        <Border Grid.Row="0"
                Background="{DynamicResource Danger.Brush}"
                Padding="12,6"
                Visibility="{Binding IsDisconnected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Disconnected from Interactive Brokers"
                           Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="Reconnect"
                        Margin="16,0,0,0"
                        Command="{Binding ReconnectCommand}" />
            </StackPanel>
        </Border>

        <!-- AvalonDock layout -->
        <dock:DockingManager Grid.Row="1"
                             x:Name="Dock"
                             AllowMixedOrientation="True"
                             DocumentsSource="{Binding OpenTabs}"
                             ActiveContent="{Binding ActiveTab, Mode=TwoWay}"
                             Background="{DynamicResource Background.Primary}">

            <dock:DockingManager.DocumentHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
            </dock:DockingManager.DocumentHeaderTemplate>

            <dock:DockingManager.LayoutItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding View}" />
                </DataTemplate>
            </dock:DockingManager.LayoutItemTemplate>

            <dock:DockingManager.LayoutItemContainerStyle>
                <Style TargetType="{x:Type dock:LayoutItem}">
                    <Setter Property="Title" Value="{Binding Model.DisplayName}" />
                </Style>
            </dock:DockingManager.LayoutItemContainerStyle>

            <dock:LayoutRoot>
                <dock:LayoutPanel Orientation="Horizontal">

                    <!-- Left: Strategies -->
                    <dock:LayoutAnchorablePaneGroup DockWidth="240">
                        <dock:LayoutAnchorablePane>
                            <dock:LayoutAnchorable Title="Strategies" CanClose="False" CanHide="False">
                                <Grid>
                                    <ListBox x:Name="StrategiesList"
                                             ItemsSource="{Binding Strategies}"
                                             SelectedItem="{Binding SelectedStrategy}"
                                             MouseDoubleClick="StrategiesList_MouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource Text.Secondary}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open"
                                                          Click="OpenStrategy_Click" />
                                                <MenuItem Header="Open in new tab"
                                                          Click="OpenStrategy_Click" />
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                    </ListBox>
                                </Grid>
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>
                    </dock:LayoutAnchorablePaneGroup>

                    <!-- Center: documents (strategy tabs) -->
                    <dock:LayoutDocumentPaneGroup>
                        <dock:LayoutDocumentPane />
                    </dock:LayoutDocumentPaneGroup>

                    <!-- Right placeholder: empty for v1 (kept for future panes) -->

                </dock:LayoutPanel>

                <!-- Bottom: Logs -->
                <dock:LayoutRoot.BottomSide>
                    <dock:LayoutAnchorSide>
                        <dock:LayoutAnchorGroup>
                            <dock:LayoutAnchorable Title="Logs"
                                                   ContentId="logs"
                                                   AutoHideMinHeight="180"
                                                   CanClose="False"
                                                   CanHide="False">
                                <ListBox ItemsSource="{Binding LogSink.Entries}"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         Background="{DynamicResource Background.Surface}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding TimestampUtc, StringFormat='HH:mm:ss'}"
                                                           Foreground="{DynamicResource Text.Secondary}"
                                                           Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Level}"
                                                           Width="50"
                                                           Foreground="{DynamicResource Accent.Brush}" />
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorGroup>
                    </dock:LayoutAnchorSide>
                </dock:LayoutRoot.BottomSide>
            </dock:LayoutRoot>
        </dock:DockingManager>

        <!-- Status bar -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource Danger.Brush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Connected">
                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Reconnecting">
                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Connecting">
                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionState}" />
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding CurrentTime}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Tabs:" />
                    <Run Text="{Binding OpenTabs.Count, Mode=OneWay}" />
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
