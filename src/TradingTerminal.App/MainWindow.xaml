<mah:MetroWindow x:Class="TradingTerminal.App.MainWindow"
                 x:Name="RootWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:dock="https://github.com/Dirkster99/AvalonDock"
                 xmlns:dockThemes="clr-namespace:AvalonDock.Themes;assembly=AvalonDock.Themes.VS2013"
                 xmlns:local="clr-namespace:TradingTerminal.App"
                 xmlns:ui="clr-namespace:TradingTerminal.UI;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="DaxAlgo Terminal"
                 Height="860" Width="1440"
                 WindowStartupLocation="CenterScreen"
                 Icon="pack://application:,,,/Icon/DaxAlgoLogo.ico"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 FontFamily="{DynamicResource Font.Mono}"
                 FontSize="12">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Bloomberg header strip -->
            <RowDefinition Height="Auto" />  <!-- Top menu -->
            <RowDefinition Height="Auto" />  <!-- Command line + ticker tape -->
            <RowDefinition Height="Auto" />  <!-- Disconnect banner -->
            <RowDefinition Height="*" />    <!-- Dock -->
            <RowDefinition Height="Auto" />  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- Bloomberg-style header strip: amber wordmark · session · broker · mode · clock -->
        <Border Grid.Row="0"
                Background="{DynamicResource Gradient.Chrome}"
                BorderBrush="{DynamicResource Accent.Brush}"
                BorderThickness="0,0,0,1"
                Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Wordmark -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="DAXALGO"
                               Foreground="{DynamicResource Accent.Brush}"
                               FontWeight="Bold"
                               FontSize="13" />
                    <TextBlock Text=" TERMINAL"
                               Foreground="{DynamicResource Text.Primary}"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,16,0" />
                    <Border Style="{StaticResource BB.FnKey}" VerticalAlignment="Center">
                        <TextBlock Text="F1 HELP" Foreground="#000000" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <Border Style="{StaticResource BB.FnKey}" VerticalAlignment="Center">
                        <TextBlock Text="F2 STRAT" Foreground="#000000" FontSize="10" FontWeight="Bold" />
                    </Border>
                    <Border Style="{StaticResource BB.FnKey}" VerticalAlignment="Center">
                        <TextBlock Text="F3 BT" Foreground="#000000" FontSize="10" FontWeight="Bold" />
                    </Border>
                </StackPanel>

                <!-- Center: broker + mode badge -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="BROKER"
                               Foreground="{DynamicResource Text.Secondary}"
                               FontSize="10"
                               Margin="0,0,4,0"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ActiveBrokerLabel}"
                               Foreground="{DynamicResource Text.Header}"
                               FontWeight="Bold"
                               FontSize="11"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center" />
                    <Border Padding="9,2" CornerRadius="9" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource Warning.Brush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLiveMode}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ModeDisplayName}"
                                   Foreground="#000000"
                                   FontWeight="Bold"
                                   FontSize="10" />
                    </Border>
                </StackPanel>

                <!-- Right: API meter chips · user · clock -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- API call meter — one chip per broker, lights amber→red as usage approaches
                         the soft per-minute cap. Tooltip carries the full breakdown. -->
                    <ItemsControl ItemsSource="{Binding ApiMeter.Chips}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="7,1"
                                        Margin="0,0,6,0"
                                        CornerRadius="8"
                                        VerticalAlignment="Center"
                                        BorderThickness="1"
                                        ToolTip="{Binding TooltipText}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <!-- Default = Untracked (neutral) -->
                                            <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Healthy">
                                                    <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Warming">
                                                    <Setter Property="Background" Value="{DynamicResource Warning.Brush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Warning.Brush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Hot">
                                                    <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Danger.Brush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="#000000"
                                                   FontWeight="Bold"
                                                   FontSize="10"
                                                   Margin="0,0,4,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding UsageDisplay}"
                                                   Foreground="#000000"
                                                   FontSize="10"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding SessionUserDisplay}"
                               Foreground="{DynamicResource Text.Secondary}"
                               FontSize="11"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center" />

                    <!-- Market session badges (approximate; no DST/holiday calendar) -->
                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,4,0" VerticalAlignment="Center"
                            Background="{DynamicResource Bullish.Soft}" BorderBrush="{DynamicResource Bullish.Brush}" BorderThickness="1">
                        <TextBlock Text="CRYPTO 24/7" Foreground="{DynamicResource Bullish.Brush}" FontSize="9" FontWeight="Bold" />
                    </Border>
                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,4,0" VerticalAlignment="Center" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1AFFFFFF" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Border.Strong}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NyseOpen}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="9" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="NYSE CLOSED" />
                                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NyseOpen}" Value="True">
                                            <Setter Property="Text" Value="NYSE OPEN" />
                                            <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Border CornerRadius="3" Padding="5,1" Margin="0,0,12,0" VerticalAlignment="Center" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#1AFFFFFF" />
                                <Setter Property="BorderBrush" Value="{DynamicResource Border.Strong}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LseOpen}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="9" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="LSE CLOSED" />
                                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LseOpen}" Value="True">
                                            <Setter Property="Text" Value="LSE OPEN" />
                                            <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- UTC + local clocks -->
                    <StackPanel VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentTimeUtc}" Foreground="{DynamicResource Accent.Brush}"
                                       FontWeight="Bold" FontSize="13" />
                            <TextBlock Text="UTC" Foreground="{DynamicResource Text.Secondary}" FontSize="9"
                                       VerticalAlignment="Bottom" Margin="3,0,0,1" />
                        </StackPanel>
                        <TextBlock Text="{Binding CurrentTime}" Foreground="{DynamicResource Text.Secondary}"
                                   FontSize="10" HorizontalAlignment="Right" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top menu -->
        <Menu Grid.Row="1"
              Background="{DynamicResource Gradient.Chrome}"
              Foreground="{DynamicResource Text.Primary}"
              BorderBrush="{DynamicResource Border.Brush}"
              BorderThickness="0,0,0,1">

            <MenuItem Header="_File">
                <MenuItem Header="_Reconnect to broker"
                          Command="{Binding ReconnectCommand}" />
                <MenuItem Header="Start _QuestDB"
                          Command="{Binding StartQuestDbCommand}"
                          ToolTip="Launch Docker Desktop (if needed) and the QuestDB container, then enable tick persistence without restarting." />
                <Separator />
                <MenuItem Header="E_xit"
                          Command="{Binding ExitCommand}"
                          InputGestureText="Alt+F4" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="_Strategies"
                          IsCheckable="True"
                          IsChecked="{Binding IsStrategiesVisible, Mode=TwoWay}" />
                <MenuItem Header="_Logs"
                          IsCheckable="True"
                          IsChecked="{Binding IsLogsVisible, Mode=TwoWay}" />
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="_Backtest…"
                          Command="{Binding OpenBacktestCommand}" />
                <MenuItem Header="_Record live ticks…"
                          Command="{Binding OpenRecorderCommand}" />
                <MenuItem Header="_Market regime…"
                          Command="{Binding OpenRegimeCommand}" />
                <MenuItem Header="_Instrument regime…"
                          Command="{Binding OpenInstrumentRegimeCommand}" />
                <MenuItem Header="Mar_kov regime…"
                          Command="{Binding OpenMarkovRegimeCommand}" />
                <MenuItem Header="_Advanced market regime…"
                          Command="{Binding OpenAdvancedRegimeCommand}" />
                <MenuItem Header="_Correlation matrix…"
                          Command="{Binding OpenCorrelationCommand}" />
                <MenuItem Header="_Live correlation matrix…"
                          Command="{Binding OpenLiveCorrelationCommand}" />
            </MenuItem>

            <MenuItem Header="_Charts">
                <MenuItem Header="C_harts…"
                          Command="{Binding OpenChartsCommand}" />
                <MenuItem Header="_Order book…"
                          Command="{Binding OpenOrderBookCommand}" />
                <MenuItem Header="_Volume footprint…"
                          Command="{Binding OpenFootprintCommand}" />
                <MenuItem Header="_Heatmaps">
                    <MenuItem Header="_Depth (Bookmap-style)…"
                              Command="{Binding OpenHeatmapCommand}" />
                    <MenuItem Header="Order-book _imbalance…"
                              Command="{Binding OpenImbalanceHeatmapCommand}" />
                    <MenuItem Header="_Volume-at-price…"
                              Command="{Binding OpenVolumeHeatmapCommand}" />
                    <MenuItem Header="Volume _bubbles…"
                              Command="{Binding OpenVolumeBubbleHeatmapCommand}" />
                    <MenuItem Header="Cross-asset vola_tility…"
                              Command="{Binding OpenVolatilityHeatmapCommand}" />
                    <MenuItem Header="Rolling _correlation…"
                              Command="{Binding OpenCorrelationHeatmapCommand}" />
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Machine learning">
                <MenuItem Header="_Stationarity &amp; differencing…"
                          Command="{Binding OpenStationarityCommand}" />
                <MenuItem Header="_ARIMA &amp; GARCH…"
                          Command="{Binding OpenArimaGarchCommand}" />
                <MenuItem Header="_Kalman filter…"
                          Command="{Binding OpenKalmanFilterCommand}" />
            </MenuItem>

            <MenuItem Header="_QuantConnect / LEAN">
                <MenuItem Header="_Backtest runner…"
                          Command="{Binding OpenQuantConnectBacktestCommand}" />
                <MenuItem Header="_Projects…"
                          Command="{Binding OpenQuantConnectProjectsCommand}" />
                <MenuItem Header="_Data sync…"
                          Command="{Binding OpenQuantConnectDataCommand}" />
                <Separator />
                <MenuItem Header="_Settings &amp; status…"
                          Command="{Binding OpenQuantConnectSettingsCommand}" />
            </MenuItem>

            <MenuItem Header="_AI tools">
                <MenuItem Header="_Factor research…"
                          Command="{Binding OpenResearchCommand}" />
                <MenuItem Header="_ML features…"
                          Command="{Binding OpenMlFeaturesCommand}" />
                <MenuItem Header="_Backtest analysis…"
                          Command="{Binding OpenBacktestAnalysisCommand}" />
                <Separator />
                <MenuItem Header="_Market analyst…"
                          Command="{Binding OpenAiAnalystCommand}" />
            </MenuItem>

            <MenuItem Header="_Data">
                <MenuItem Header="_Market data archive…"
                          Command="{Binding OpenArchiveSettingsCommand}" />
                <MenuItem Header="Archive _history…"
                          Command="{Binding OpenArchiveActivityCommand}" />
                <Separator />
                <MenuItem Header="_Instant offload (all pending)…"
                          Command="{Binding InstantOffloadCommand}" />
            </MenuItem>

            <MenuItem Header="_Settings">
                <MenuItem Header="_Notifications…"
                          Command="{Binding OpenNotificationsSettingsCommand}" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_Support the developer…"
                          Command="{Binding OpenSupportCommand}"
                          ToolTip="Send feedback to the developer and learn how to support the project." />
                <MenuItem Header="_About DaxAlgo Terminal…"
                          Command="{Binding OpenSupportCommand}" />
            </MenuItem>
        </Menu>

        <!-- Command line + live ticker tape -->
        <Border Grid.Row="2"
                Background="{DynamicResource Gradient.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="0,0,0,1"
                Padding="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Bloomberg-style command line -->
                <Border Grid.Column="0" Background="{DynamicResource Background.Primary}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,1,0"
                        Padding="8,3">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&gt;" Foreground="{DynamicResource Accent.Brush}" FontWeight="Bold"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBox Width="240" BorderThickness="0" Background="Transparent"
                                 Foreground="{DynamicResource Text.Highlight}" FontFamily="{DynamicResource Font.Mono}"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Type a command (charts · book · backtest · regime · qc · analyst · help) or a ticker, then Enter"
                                 Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding RunCommandLineCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                        <TextBlock Text="GO" Foreground="{DynamicResource Text.Secondary}" FontSize="9" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="4,0,2,0" />
                    </StackPanel>
                </Border>

                <!-- Scrolling ticker tape -->
                <Border Grid.Column="1" ClipToBounds="True" Padding="0">
                    <Grid>
                        <TextBlock Text="◴  Connect a broker to stream live prices…" VerticalAlignment="Center"
                                   Margin="12,0,0,0" Foreground="{DynamicResource Text.Secondary}" FontSize="11"
                                   Visibility="{Binding Ticker.HasItems, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <ItemsControl ItemsSource="{Binding Ticker.Items}" VerticalAlignment="Center"
                                      Visibility="{Binding Ticker.HasItems, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.RenderTransform>
                                <TranslateTransform X="1400" />
                            </ItemsControl.RenderTransform>
                            <ItemsControl.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                From="1400" To="-2600" Duration="0:0:45" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ItemsControl.Triggers>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,18,2">
                                        <TextBlock Text="{Binding Symbol}" Foreground="{DynamicResource Text.Header}"
                                                   FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding Last, StringFormat=N2}" Foreground="{DynamicResource Text.Primary}"
                                                   FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <TextBlock FontSize="11" VerticalAlignment="Center"
                                                   Text="{Binding ChangePercent, StringFormat=+0.00;-0.00;0.00}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="1">
                                                            <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Direction}" Value="-1">
                                                            <Setter Property="Foreground" Value="{DynamicResource Danger.Brush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock FontSize="10" VerticalAlignment="Center" Margin="2,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="%" />
                                                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Direction}" Value="1">
                                                            <Setter Property="Text" Value="▲" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Direction}" Value="-1">
                                                            <Setter Property="Text" Value="▼" />
                                                            <Setter Property="Foreground" Value="{DynamicResource Danger.Brush}" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Disconnect banner -->
        <Border Grid.Row="3"
                Background="{DynamicResource Danger.Brush}"
                Padding="12,6"
                Visibility="{Binding IsDisconnected, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DisconnectBannerText}"
                           Foreground="White" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Content="Reconnect"
                        Margin="16,0,0,0"
                        Command="{Binding ReconnectCommand}" />
            </StackPanel>
        </Border>

        <!-- AvalonDock layout -->
        <dock:DockingManager Grid.Row="4"
                             x:Name="Dock"
                             AllowMixedOrientation="True"
                             DocumentsSource="{Binding OpenTabs}"
                             ActiveContent="{Binding ActiveTab, Mode=TwoWay}"
                             Background="{DynamicResource Background.Primary}">

            <dock:DockingManager.Theme>
                <dockThemes:Vs2013DarkTheme />
            </dock:DockingManager.Theme>

            <dock:DockingManager.DocumentHeaderTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}" />
                </DataTemplate>
            </dock:DockingManager.DocumentHeaderTemplate>

            <!-- Map DockTab POCO → LayoutDocument wrapper properties. The selector keeps
                 the style off of LayoutAnchorableItem containers (Strategies / Logs panes),
                 which don't share the DockTab data shape. -->
            <dock:DockingManager.LayoutItemContainerStyleSelector>
                <ui:DockTabStyleSelector>
                    <ui:DockTabStyleSelector.DocumentStyle>
                        <Style TargetType="{x:Type dock:LayoutDocumentItem}">
                            <Setter Property="Title"     Value="{Binding Model.Title}" />
                            <Setter Property="ContentId" Value="{Binding Model.ContentId}" />
                            <Setter Property="CanClose"  Value="{Binding Model.CanClose}" />
                        </Style>
                    </ui:DockTabStyleSelector.DocumentStyle>
                </ui:DockTabStyleSelector>
            </dock:DockingManager.LayoutItemContainerStyleSelector>

            <dock:DockingManager.LayoutItemTemplate>
                <DataTemplate>
                    <ContentControl Content="{Binding Content}" />
                </DataTemplate>
            </dock:DockingManager.LayoutItemTemplate>

            <dock:LayoutRoot>
                <!-- Horizontal at the root so Strategies spans the full window height. -->
                <dock:LayoutPanel Orientation="Horizontal">

                    <!-- Left: Strategies (full height, wider) -->
                    <dock:LayoutAnchorablePaneGroup DockWidth="360">
                        <dock:LayoutAnchorablePane>
                            <dock:LayoutAnchorable x:Name="StrategiesPane"
                                                   Title="STRATEGIES"
                                                   ContentId="strategies"
                                                   CanClose="True"
                                                   CanHide="True"
                                                   IsVisibleChanged="StrategiesPane_IsVisibleChanged">
                                <Grid Background="{DynamicResource Background.Surface}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Bloomberg-style section header inside the pane -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource Gradient.Elevated}"
                                            BorderBrush="{DynamicResource Border.Brush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="8,7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="3" Height="13" Background="{DynamicResource Accent.Brush}" Margin="0,0,8,0" />
                                                <TextBlock Text="STRATEGY CATALOG"
                                                           Foreground="{DynamicResource Text.Header}"
                                                           FontWeight="Bold"
                                                           FontSize="11"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource Text.Secondary}"
                                                       FontSize="10"
                                                       VerticalAlignment="Center">
                                                <Run Text="N=" />
                                                <Run Text="{Binding Strategies.Count, Mode=OneWay}" />
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <ListBox x:Name="StrategiesList"
                                             Grid.Row="1"
                                             BorderThickness="0"
                                             Background="{DynamicResource Background.Surface}"
                                             ItemsSource="{Binding ElementName=RootWindow, Path=DataContext.Strategies}"
                                             SelectedItem="{Binding ElementName=RootWindow, Path=DataContext.SelectedStrategy, Mode=TwoWay}"
                                             HorizontalContentAlignment="Stretch"
                                             MouseDoubleClick="StrategiesList_MouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,4">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="▸ "
                                                                   Foreground="{DynamicResource Accent.Brush}"
                                                                   FontWeight="Bold" />
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   Foreground="{DynamicResource Text.Header}"
                                                                   FontWeight="Bold" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Id}"
                                                               Foreground="{DynamicResource Text.Highlight}"
                                                               FontSize="10"
                                                               Margin="12,0,0,2" />
                                                    <TextBlock Text="{Binding Description}"
                                                               Foreground="{DynamicResource Text.Secondary}"
                                                               TextWrapping="Wrap"
                                                               FontSize="11"
                                                               Margin="12,0,0,0" />
                                                    <!-- Data-requirement pills (L1 / BAR / L2 / TAPE) via the shared
                                                         StrategyTagsConverter — reads the strategy's DataRequirement. -->
                                                    <ItemsControl ItemsSource="{Binding Converter={StaticResource StrategyTagsConverter}}"
                                                                  Margin="12,4,0,0">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel Orientation="Horizontal" />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding Background}"
                                                                        CornerRadius="3"
                                                                        Padding="5,1"
                                                                        Margin="0,0,3,0"
                                                                        VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Text}"
                                                                               Foreground="{Binding Foreground}"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold" />
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open"
                                                          Click="OpenStrategy_Click" />
                                                <MenuItem Header="Open in new tab"
                                                          Click="OpenStrategy_Click" />
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                    </ListBox>
                                </Grid>
                            </dock:LayoutAnchorable>
                        </dock:LayoutAnchorablePane>
                    </dock:LayoutAnchorablePaneGroup>

                    <!-- Right column: documents on top, logs pinned at the bottom -->
                    <dock:LayoutPanel Orientation="Vertical">

                        <dock:LayoutDocumentPaneGroup>
                            <dock:LayoutDocumentPane />
                        </dock:LayoutDocumentPaneGroup>

                        <dock:LayoutAnchorablePaneGroup DockHeight="200">
                            <dock:LayoutAnchorablePane>
                                <dock:LayoutAnchorable x:Name="LogsPane"
                                                       Title="ACTIVITY LOG"
                                                       ContentId="logs"
                                                       CanClose="True"
                                                       CanHide="True"
                                                       IsVisibleChanged="LogsPane_IsVisibleChanged">
                                    <Grid Background="{DynamicResource Background.Surface}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!-- Filter strip: matches source / level / message, live. -->
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource Gradient.Elevated}"
                                                BorderBrush="{DynamicResource Border.Brush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="6,5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Filter"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,8,0"
                                                           Foreground="{DynamicResource Text.Secondary}"
                                                           FontSize="11" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding ElementName=RootWindow, Path=DataContext.LogFilter, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                         FontFamily="{DynamicResource Font.Mono}"
                                                         FontSize="11"
                                                         ToolTip="Filter by source, level, or message" />
                                            </Grid>
                                        </Border>

                                        <ListBox x:Name="LogList"
                                                 Grid.Row="1"
                                                 ItemsSource="{Binding ElementName=RootWindow, Path=DataContext.ActivityLog}"
                                                 SelectionMode="Extended"
                                                 FontFamily="{DynamicResource Font.Mono}"
                                                 FontSize="11"
                                                 BorderThickness="0"
                                                 Background="{DynamicResource Background.Surface}">
                                            <ListBox.InputBindings>
                                                <!-- Ctrl+C copies the selected rows (or all visible rows if none selected). -->
                                                <KeyBinding Key="C" Modifiers="Control"
                                                            Command="{Binding ElementName=RootWindow, Path=DataContext.CopyLogCommand}"
                                                            CommandParameter="{Binding ElementName=LogList, Path=SelectedItems}" />
                                            </ListBox.InputBindings>
                                            <ListBox.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Copy"
                                                              Command="{Binding PlacementTarget.DataContext.CopyLogCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                              CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    <MenuItem Header="Copy all"
                                                              Command="{Binding PlacementTarget.DataContext.CopyAllLogsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                </ContextMenu>
                                            </ListBox.ContextMenu>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding TimestampUtc, StringFormat='HH:mm:ss'}"
                                                                   Foreground="{DynamicResource Text.Secondary}"
                                                                   Margin="0,0,8,0" VerticalAlignment="Center" />
                                                        <!-- colour-coded level pill -->
                                                        <Border CornerRadius="3" Padding="5,0" Margin="0,0,8,0" MinWidth="46"
                                                                VerticalAlignment="Center">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#22FFFFFF" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                            <Setter Property="Background" Value="{DynamicResource Bearish.Soft}" /></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                                            <Setter Property="Background" Value="{DynamicResource Bearish.Soft}" /></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                            <Setter Property="Background" Value="{DynamicResource Warning.Soft}" /></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                                            <Setter Property="Background" Value="{DynamicResource Warning.Soft}" /></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Level}" Value="ENTRY">
                                                                            <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" /></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Level}" FontSize="9.5" FontWeight="Bold"
                                                                       TextAlignment="Center" HorizontalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Danger.Brush}" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Danger.Brush}" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Warning.Brush}" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Warning.Brush}" /></DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="ENTRY">
                                                                                <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" /></DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <TextBlock Text="{Binding Source}"
                                                                   Width="140"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Text.Header}" />
                                                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Text.Primary}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </dock:LayoutAnchorable>
                            </dock:LayoutAnchorablePane>
                        </dock:LayoutAnchorablePaneGroup>

                    </dock:LayoutPanel>

                </dock:LayoutPanel>
            </dock:LayoutRoot>
        </dock:DockingManager>

        <!-- Empty-state hint: shown over the document area when no tabs are open. -->
        <StackPanel Grid.Row="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                    IsHitTestVisible="False"
                    Visibility="{Binding HasNoOpenTabs, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock HorizontalAlignment="Center" FontFamily="Consolas" FontSize="13" LineHeight="15"
                       Foreground="{DynamicResource Accent.Dim.Brush}" Opacity="0.7">
                <Run Text="&#x2588;&#x2588;&#x2588;&#x2557; &#x2588;&#x2588;&#x2557; &#x2588;&#x2588;&#x2588;&#x2588;&#x2588;&#x2557; &#x2588;&#x2557;&#x2588;&#x2557;" />
                <LineBreak />
                <Run Text="D A X A L G O   T E R M I N A L" />
            </TextBlock>
            <TextBlock Text="No documents open" HorizontalAlignment="Center" Margin="0,16,0,4"
                       Foreground="{DynamicResource Text.Secondary}" FontSize="14" FontWeight="SemiBold" />
            <TextBlock HorizontalAlignment="Center" Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextAlignment="Center">
                <Run Text="Double-click a strategy · open a tool from the menu" /><LineBreak />
                <Run Text="or type a command in the " /><Run Text="&gt;" Foreground="{DynamicResource Accent.Brush}" FontWeight="Bold" /><Run Text=" line above (charts · backtest · qc · analyst · help)" />
            </TextBlock>
        </StackPanel>

        <!-- Status bar -->
        <StatusBar Grid.Row="5">
            <!-- Connection state dot + label -->
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource Danger.Brush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Connected">
                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Reconnecting">
                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ConnectionState}" Value="Connecting">
                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectionState}"
                               Foreground="{DynamicResource Accent.Brush}"
                               FontWeight="Bold" />
                </StackPanel>
            </StatusBarItem>
            <Separator />

            <StatusBarItem>
                <TextBlock>
                    <Run Text="BROKER " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding ActiveBrokerLabel, Mode=OneWay}" Foreground="{DynamicResource Text.Primary}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />

            <StatusBarItem>
                <TextBlock>
                    <Run Text="USER " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding SessionUserDisplay, Mode=OneWay}" Foreground="{DynamicResource Text.Primary}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />

            <StatusBarItem>
                <TextBlock>
                    <Run Text="TABS " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding OpenTabs.Count, Mode=OneWay}" Foreground="{DynamicResource Text.Highlight}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />

            <StatusBarItem>
                <TextBlock>
                    <Run Text="LIVE " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding ConnectedBrokerCount, Mode=OneWay}" Foreground="{DynamicResource Bullish.Brush}" />
                    <Run Text=" brokers" Foreground="{DynamicResource Text.Secondary}" />
                </TextBlock>
            </StatusBarItem>
            <Separator />

            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding CurrentTime}"
                           Foreground="{DynamicResource Accent.Brush}"
                           FontWeight="Bold" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</mah:MetroWindow>
