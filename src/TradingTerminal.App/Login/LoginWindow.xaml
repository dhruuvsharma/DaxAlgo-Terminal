<mah:MetroWindow x:Class="TradingTerminal.App.Login.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:TradingTerminal.App.Login"
                 xmlns:brokers="clr-namespace:TradingTerminal.Core.Brokers;assembly=TradingTerminal.Core"
                 mc:Ignorable="d"
                 Title="Trading Terminal — Sign in"
                 Height="780" Width="600"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterScreen"
                 ShowMaxRestoreButton="False"
                 ShowMinButton="False"
                 Icon="pack://application:,,,/Icon/DaxAlgoLogo.ico"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <!-- VM → View mapping for the per-broker forms is defined in App.xaml so the implicit
             DataTemplate lookup uses application-level resources. The ContentControl below
             resolves the matching UserControl via that lookup. -->

        <!-- Broker-tile button — selected state via DataTrigger on per-tile binding. -->
        <Style x:Key="BrokerTileButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate for a broker tile inside the ItemsControl below. The tile's command
             dispatches to LoginViewModel.SelectFormCommand with the per-item IBrokerLoginForm. -->
        <DataTemplate x:Key="BrokerTileTemplate" DataType="{x:Type brokers:IBrokerLoginForm}">
            <Button Command="{Binding DataContext.SelectFormCommand,
                                       RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding}"
                    IsEnabled="{Binding DataContext.IsConnecting,
                                        RelativeSource={RelativeSource AncestorType=ItemsControl},
                                        Converter={StaticResource InverseBooleanConverter}}"
                    Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource BrokerTileButton}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Broker}" Value="InteractiveBrokers">
                                <Setter Property="Tag" Value="#D32F2F" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Broker}" Value="NinjaTrader">
                                <Setter Property="Tag" Value="#1B5E20" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Broker}" Value="CTrader">
                                <Setter Property="Tag" Value="#0277BD" />
                            </DataTrigger>
                            <!-- Highlight the active form's tile. -->
                            <DataTrigger Value="True">
                                <DataTrigger.Binding>
                                    <MultiBinding Converter="{StaticResource ReferenceEqualsConverter}">
                                        <Binding Path="." />
                                        <Binding Path="DataContext.ActiveForm"
                                                 RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                    </MultiBinding>
                                </DataTrigger.Binding>
                                <Setter Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="4"
                            Background="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="{Binding Broker, Converter={StaticResource BrokerInitialsConverter}}"
                                   Foreground="White"
                                   FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" />
                        <TextBlock Text="{Binding Broker, Converter={StaticResource BrokerSubtitleConverter}}"
                                   Foreground="{DynamicResource Text.Secondary}" FontSize="10" />
                    </StackPanel>
                </StackPanel>
            </Button>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <Grid Margin="32,16,32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Brand -->
            <RowDefinition Height="Auto" />  <!-- Broker selector (ItemsControl over forms) -->
            <RowDefinition Height="Auto" />  <!-- Mode badge -->
            <RowDefinition Height="*" />     <!-- Active form (ContentPresenter) -->
            <RowDefinition Height="Auto" />  <!-- Status -->
            <RowDefinition Height="Auto" />  <!-- Buttons -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Logo + brand -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Image Source="pack://application:,,,/Icon/DaxAlgoLogo.png"
                   Width="64" Height="64"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <TextBlock Text="DaxAlgo Terminal"
                       HorizontalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,6,0,0" />
            <TextBlock Text="{Binding SubtitleText}"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Text.Secondary}"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Broker tiles — one per IBrokerLoginForm registered in DI -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding AvailableForms}"
                      ItemTemplate="{StaticResource BrokerTileTemplate}"
                      Margin="0,8,0,8">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Mode badge -->
        <Border Grid.Row="2"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                CornerRadius="3"
                Padding="10,6"
                Margin="0,4,0,12"
                HorizontalAlignment="Stretch">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource Warning.Brush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLiveMode}" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{Binding ModeDisplayName}"
                           FontWeight="Bold"
                           Foreground="#1E1E1E" />
                <TextBlock Text="{Binding ModeDescription}"
                           TextWrapping="Wrap"
                           FontSize="11"
                           Foreground="#1E1E1E" />
            </StackPanel>
        </Border>

        <!-- Active broker form — three ContentControls, populated from code-behind with the
             real UserControl instances. We can't reference them via clr-namespace in XAML
             because WPF's MarkupCompilePass1 doesn't see same-project XAML-generated
             UserControl partial classes during the LoginWindow.xaml compile. The names
             below let the code-behind look them up and assign Content. -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0"
                      IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBooleanConverter}}">
            <Grid>
                <ContentControl x:Name="IbFormHost"
                                Visibility="{Binding IsIbBrokerSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ContentControl x:Name="NinjaFormHost"
                                Visibility="{Binding IsNinjaBrokerSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <ContentControl x:Name="CTraderFormHost"
                                Visibility="{Binding IsCTraderBrokerSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </ScrollViewer>

        <!-- Status / error / live state -->
        <StackPanel Grid.Row="4" Margin="0,12,0,4">

            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentState}" Value="Connected">
                                    <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding CurrentState}" Value="Failed">
                                    <Setter Property="Fill" Value="{DynamicResource Danger.Brush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding CurrentState}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" />
                <TextBlock Text=" · " Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Border Background="{DynamicResource Bullish.Brush}"
                    Padding="10,6"
                    Margin="0,8,0,0"
                    Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="OK" FontSize="14" FontWeight="Bold"
                               Foreground="#1E1E1E" Margin="0,0,8,0" />
                    <TextBlock Text="Signed in successfully"
                               FontWeight="SemiBold"
                               Foreground="#1E1E1E" />
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource Danger.Brush}"
                    Padding="10,6"
                    Margin="0,8,0,0"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="White" />
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         IsIndeterminate="{Binding IsConnecting}"
                         Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Height="4"
                         VerticalAlignment="Center"
                         Margin="0,0,16,0" />

            <Button Grid.Column="1"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBooleanConverter}}"
                    Margin="0,0,8,0"
                    MinWidth="80" />
            <Button Grid.Column="2"
                    Content="Sign in"
                    Command="{Binding ConnectCommand}"
                    IsEnabled="{Binding IsConnecting, Converter={StaticResource InverseBooleanConverter}}"
                    IsDefault="True"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    MinWidth="100" />
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="6"
                   Text="DaxAlgo Terminal · MIT licensed"
                   Foreground="{DynamicResource Text.Secondary}"
                   FontSize="10"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0" />
    </Grid>
</mah:MetroWindow>
