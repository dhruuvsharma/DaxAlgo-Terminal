<UserControl x:Class="TradingTerminal.App.Login.Forms.CTraderLoginForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:TradingTerminal.App.Login.Forms"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="500">
    <StackPanel>

        <TextBlock Text="Display name (optional)" Margin="0,0,0,4" />
        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 mah:TextBoxHelper.Watermark="Shown in the status bar after sign-in"
                 Margin="0,0,0,12" />

        <TextBlock Text="OAuth client id" Margin="0,0,0,4" />
        <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                 mah:TextBoxHelper.Watermark="From connect.spotware.com/apps"
                 Margin="0,0,0,12" />

        <TextBlock Text="OAuth client secret" Margin="0,0,0,4" />
        <PasswordBox x:Name="ClientSecretBox"
                     PasswordChanged="ClientSecretBox_PasswordChanged"
                     mah:TextBoxHelper.Watermark="Stored DPAPI-encrypted on this machine"
                     Margin="0,0,0,12" />

        <TextBlock Text="Access token" Margin="0,0,0,4" />
        <PasswordBox x:Name="AccessTokenBox"
                     PasswordChanged="AccessTokenBox_PasswordChanged"
                     mah:TextBoxHelper.Watermark="From the cTrader OAuth flow (refresh as needed)"
                     Margin="0,0,0,12" />

        <TextBlock Text="ctidTraderAccountId" Margin="0,0,0,4" />
        <DockPanel Margin="0,0,0,4" LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    Content="Discover"
                    Command="{Binding DiscoverAccountsCommand}"
                    MinWidth="90"
                    Margin="6,0,0,0"
                    ToolTip="Look up the trading accounts attached to your access token (uses the Live/Demo selection below)." />
            <ProgressBar DockPanel.Dock="Right"
                         IsIndeterminate="{Binding IsDiscovering}"
                         Visibility="{Binding IsDiscovering, Converter={StaticResource BooleanToVisibilityConverter}}"
                         Width="60" Height="4" VerticalAlignment="Center" Margin="6,0,0,0" />
            <TextBox Text="{Binding AccountId, UpdateSourceTrigger=PropertyChanged}"
                     mah:TextBoxHelper.Watermark="Numeric trading-account id (or click Discover)" />
        </DockPanel>

        <!-- Discovery status / error message (shown after a Discover click) -->
        <TextBlock Text="{Binding DiscoveryMessage}"
                   Visibility="{Binding DiscoveryMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"
                   Foreground="{DynamicResource Text.Secondary}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,6" />

        <!-- Multi-account picker — only shown when Discover returned more than one candidate. -->
        <ComboBox ItemsSource="{Binding DiscoveredAccounts}"
                  SelectedItem="{Binding SelectedDiscoveredAccount}"
                  Visibility="{Binding HasDiscoveredAccounts, Converter={StaticResource BooleanToVisibilityConverter}}"
                  Margin="0,0,0,12">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="#" />
                        <TextBlock Text="{Binding AccountId}" FontWeight="SemiBold" />
                        <TextBlock Text=" · " Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Foreground="{DynamicResource Text.Secondary}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Demo" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLive}" Value="True">
                                            <Setter Property="Text" Value="Live" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <!-- Top up the bottom margin to match the other fields when the picker is collapsed. -->
        <Grid Height="6"
              Visibility="{Binding HasDiscoveredAccounts, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

        <CheckBox Content="Use live endpoint (live.ctraderapi.com) — uncheck for demo"
                  IsChecked="{Binding IsLive}"
                  Margin="0,0,0,8" />

        <Border Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                Padding="10,6"
                Margin="0,12,0,0">
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource Text.Secondary}">
                <Run FontWeight="SemiBold" Text="Heads up:" />
                <Run Text="Access tokens expire (default ~30 days). When the token expires you'll need to re-run the OAuth refresh and paste the new token here." />
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
