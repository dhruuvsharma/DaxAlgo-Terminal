<UserControl x:Class="TradingTerminal.App.Login.Forms.AlpacaLoginForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:local="clr-namespace:TradingTerminal.App.Login.Forms"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="500">
    <StackPanel>

        <TextBlock Text="Display name (optional)" Margin="0,0,0,4" />
        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                 mah:TextBoxHelper.Watermark="Shown in the status bar after sign-in"
                 Margin="0,0,0,12" />

        <TextBlock Text="API key id" Margin="0,0,0,4" />
        <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                 mah:TextBoxHelper.Watermark="PK... (paper) or AK... (live) from app.alpaca.markets"
                 Margin="0,0,0,12" />

        <TextBlock Text="API secret" Margin="0,0,0,4" />
        <PasswordBox x:Name="ApiSecretBox"
                     PasswordChanged="ApiSecretBox_PasswordChanged"
                     mah:TextBoxHelper.Watermark="Stored DPAPI-encrypted on this machine"
                     Margin="0,0,0,12" />

        <TextBlock Text="Stock data feed" Margin="0,0,0,4" />
        <ComboBox SelectedValue="{Binding StockDataFeed, UpdateSourceTrigger=PropertyChanged}"
                  SelectedValuePath="Content"
                  Margin="0,0,0,12">
            <ComboBoxItem Content="iex" />
            <ComboBoxItem Content="sip" />
        </ComboBox>

        <CheckBox Content="Use live endpoint (api.alpaca.markets) — uncheck for paper"
                  IsChecked="{Binding IsLive}"
                  Margin="0,0,0,8" />

        <Border Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                Padding="10,6"
                Margin="0,12,0,0">
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource Text.Secondary}">
                <Run FontWeight="SemiBold" Text="Heads up:" />
                <Run Text="The 'iex' feed is free; 'sip' requires a paid market-data subscription. Crypto and options ignore this setting." />
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
