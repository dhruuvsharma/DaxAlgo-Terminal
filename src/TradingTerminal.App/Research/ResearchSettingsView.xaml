<UserControl x:Class="TradingTerminal.App.Research.ResearchSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}"
             d:DesignHeight="520" d:DesignWidth="600">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Research (Paper Lab)"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Paper Lab reproduces quant research papers: it resolves a paper → repo via a local Python sidecar, then runs the code in a deny-by-default sandbox and bridges the result into the backtester as a paper-tagged strategy. Enable the sidecar here to use the window."
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Paper-resolution sidecar"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="The same local daxalgo-ml Python sidecar used by the AI analyst, with the research endpoints enabled. Static analysis + paper→repo resolution only; it binds 127.0.0.1 (loopback) and is never exposed to the network."
                               Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <CheckBox Content="Enabled"
                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                              Margin="0,0,0,8" />

                    <CheckBox Content="Auto-launch the sidecar on startup (no manual command)"
                              IsChecked="{Binding AutoLaunchSidecar, Mode=TwoWay}"
                              Margin="0,0,0,12"
                              ToolTip="When on, the app starts the local daxalgo-ml sidecar itself when AI/Research is enabled, and stops it on exit. Turn off to manage it yourself." />

                    <TextBlock Text="Sidecar base URL  (loopback only — e.g. http://127.0.0.1:8765)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding SidecarBaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Per-call timeout (seconds)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding SidecarTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Job retention (days, 0 = forever)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding RetentionDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="Running a reproduction (after a paper resolves) also needs Docker Desktop running — the sandbox backend. Resolving a paper only needs the sidecar above."
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0" />

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="16,6" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
