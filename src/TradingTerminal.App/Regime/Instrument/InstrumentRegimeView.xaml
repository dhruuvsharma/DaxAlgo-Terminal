<UserControl x:Class="TradingTerminal.App.Regime.Instrument.InstrumentRegimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="900"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Instrument regime" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Per-instrument bullish/bearish composite blended from five OHLCV signals (trend, momentum, RSI, mean-reversion, volume) plus three L2 signals (cumulative imbalance, OBI shallow, OBI deep) when the active broker exposes depth. Signed -100..+100 — negative is bearish, positive is bullish."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Controls row -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- search label  -->
                    <ColumnDefinition Width="160" />    <!-- search box    -->
                    <ColumnDefinition Width="Auto" />   <!-- "Instrument"  -->
                    <ColumnDefinition Width="*" />      <!-- dropdown      -->
                    <ColumnDefinition Width="Auto" />   <!-- timeframe lbl -->
                    <ColumnDefinition Width="80" />     <!-- timeframe cb  -->
                    <ColumnDefinition Width="Auto" />   <!-- bars lbl      -->
                    <ColumnDefinition Width="60" />     <!-- bars tb       -->
                    <ColumnDefinition Width="Auto" />   <!-- Analyze       -->
                    <ColumnDefinition Width="Auto" />   <!-- Cancel        -->
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBox Grid.Column="1"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter symbols..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="Instrument" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="3"
                           ItemsSource="{Binding Instruments}"
                           SelectedItem="{Binding SelectedInstrument}"
                           DisplayMemberPath="DisplayName"
                           MaxDropDownHeight="420"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="4" Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="5"
                           ItemsSource="{Binding Timeframes}"
                           SelectedItem="{Binding SelectedTimeframe}"
                           DisplayMemberPath="Label"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="6" Text="Bars" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox   Grid.Column="7"
                           Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                           Margin="0,0,12,0" />

                <Button Grid.Column="8" Content="Analyze"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="14,4" Margin="0,0,6,0" />
                <Button Grid.Column="9" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsAnalyzing}"
                        Padding="14,4" />
            </Grid>
        </Border>

        <!-- Composite gauge -->
        <Border Grid.Row="2" Margin="0,14,0,0" Padding="16,12"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding CompositeScore, StringFormat='+0.0;-0.0;0.0'}"
                               FontSize="46" FontWeight="Bold"
                               Foreground="{Binding ScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                    <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{Binding ScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}"
                                 Height="16"
                                 Foreground="{Binding ScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                    <Grid Margin="0,4,0,0">
                        <TextBlock Text="-100 — Strong Sell" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource Bearish.Brush}" FontSize="11" />
                        <TextBlock Text="0 — Neutral" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="Strong Buy — +100" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Bullish.Brush}" FontSize="11" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Headline metrics -->
        <WrapPanel Grid.Row="3" Margin="0,12,0,0">
            <WrapPanel.Resources>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource Background.Elevated}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="Margin" Value="0,0,8,8" />
                </Style>
            </WrapPanel.Resources>
            <Border><StackPanel><TextBlock Text="Last close"  Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding LastClose}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="ATR %"      Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding AtrPercent}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="Vol rank"   Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding VolatilityRank}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="Bars"       Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding BarsStatus}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="Depth"      Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding DepthStatus}" FontWeight="SemiBold" /></StackPanel></Border>
        </WrapPanel>

        <!-- Signals breakdown -->
        <DataGrid Grid.Row="4" Margin="0,12,0,0"
                  ItemsSource="{Binding Signals}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  CanUserResizeRows="False" RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  Background="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Signal"   Binding="{Binding Name}"             Width="160" />
                <DataGridTextColumn Header="Score"    Binding="{Binding ScoreText}"        Width="68" />
                <DataGridTemplateColumn Header=""     Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ProgressBar Minimum="0" Maximum="100"
                                         Value="{Binding BarValue, Mode=OneWay}"
                                         Height="12" Margin="2,0"
                                         Foreground="{Binding BarColor, Converter={StaticResource StringToBrushConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Weight"       Binding="{Binding WeightPct}"        Width="64" />
                <DataGridTextColumn Header="Contribution" Binding="{Binding ContributionText}" Width="90" />
                <DataGridTextColumn Header="Detail"       Binding="{Binding Detail}"           Width="280" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="{DynamicResource Danger.Brush}"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Column="1" Foreground="{DynamicResource Text.Secondary}">
                <Run Text="Updated:" />
                <Run Text="{Binding LastUpdated}" />
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
