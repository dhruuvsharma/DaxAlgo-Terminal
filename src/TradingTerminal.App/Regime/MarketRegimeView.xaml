<UserControl x:Class="TradingTerminal.App.Regime.MarketRegimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="820"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Market regime" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="A 0–100 risk-on/risk-off composite blended from ten weighted sub-signals (volatility, positioning, trend, breadth, momentum, credit, liquidity, macro, sentiment, cross-asset). Sources: Yahoo Finance, FRED, CNN, AAII — any missing source degrades that category to neutral."
                           Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}"
                    VerticalAlignment="Top" Padding="16,4" Margin="8,0,0,0"
                    IsEnabled="{Binding IsRefreshing, Converter={StaticResource InverseBooleanConverter}}" />
        </Grid>

        <!-- Composite gauge -->
        <Border Grid.Row="1" Margin="0,14,0,0" Padding="16,12"
                Background="{DynamicResource Background.Secondary}" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{Binding CompositeScore, StringFormat=F1}" FontSize="46" FontWeight="Bold"
                               Foreground="{Binding ScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Label}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{Binding ScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                        <TextBlock Text="{Binding Trend}" Margin="8,0,0,0" FontSize="13"
                                   Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <ProgressBar Minimum="0" Maximum="100" Value="{Binding CompositeScore, Mode=OneWay}"
                                 Height="16"
                                 Foreground="{Binding ScoreColor, Converter={StaticResource StringToBrushConverter}}" />
                    <Grid Margin="0,4,0,0">
                        <TextBlock Text="0 — Extreme Fear" HorizontalAlignment="Left"
                                   Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="Extreme Greed — 100" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Header metrics -->
        <WrapPanel Grid.Row="2" Margin="0,12,0,0">
            <WrapPanel.Resources>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource Background.Secondary}" />
                    <Setter Property="CornerRadius" Value="4" />
                    <Setter Property="Padding" Value="10,6" />
                    <Setter Property="Margin" Value="0,0,8,8" />
                </Style>
            </WrapPanel.Resources>
            <Border><StackPanel><TextBlock Text="VIX" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding Vix}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="CNN F&amp;G" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding CnnFearGreed}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="HY spread" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding HySpread}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="10y yield" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding Yield10y}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="Fed funds" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding FedRate}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="Put/Call" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding PutCall}" FontWeight="SemiBold" /></StackPanel></Border>
            <Border><StackPanel><TextBlock Text="Stress index" Foreground="{DynamicResource Text.Secondary}" FontSize="11" /><TextBlock Text="{Binding FinancialStress}" FontWeight="SemiBold" /></StackPanel></Border>
        </WrapPanel>

        <!-- Category breakdown -->
        <DataGrid Grid.Row="3" Margin="0,12,0,0"
                  ItemsSource="{Binding Categories}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  CanUserResizeRows="False" RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal" Background="Transparent">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Category" Binding="{Binding Name}" Width="120" />
                <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="56" />
                <DataGridTemplateColumn Header="" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding BarWidth, Mode=OneWay}"
                                         Height="12" Margin="2,0"
                                         Foreground="{Binding BarColor, Converter={StaticResource StringToBrushConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Weight" Binding="{Binding WeightPct}" Width="64" />
                <DataGridTextColumn Header="Contribution" Binding="{Binding Contribution, StringFormat=F1}" Width="90" />
                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="200" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="{DynamicResource Text.Secondary}"
                       Visibility="{Binding Unavailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Text="Waiting for first refresh — pulling data from Yahoo / FRED / CNN / AAII…" />
            <TextBlock Grid.Column="1" Foreground="{DynamicResource Text.Secondary}">
                <Run Text="Updated:" />
                <Run Text="{Binding LastUpdated}" />
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
