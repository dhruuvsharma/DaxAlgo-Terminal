<mah:MetroWindow x:Class="TradingTerminal.Strategies.CumulativeDelta.CumulativeDeltaWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.CumulativeDelta"
                 mc:Ignorable="d"
                 Title="Cumulative Delta Scalper"
                 Height="780" Width="1180"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <CollectionViewSource x:Key="GroupedInstruments" Source="{Binding Instruments}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!-- Style for label cell of a dashboard row: dim, left-aligned. -->
        <Style x:Key="DashLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="Margin" Value="0,2,8,2" />
        </Style>
        <!-- Style for value cell of a dashboard row: monospaced, semibold, right-aligned. -->
        <Style x:Key="DashValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm the algo. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ===== Setup form ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="520"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    Padding="24"
                    Margin="0,24">
                <StackPanel>
                    <TextBlock Text="Configure Cumulative Delta Scalper"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Bid-tick rule on each tick → bar deltas → sliding-window cumulative delta. Trigger on cross of ±threshold."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Text.Secondary}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Source={StaticResource GroupedInstruments}}"
                              SelectedItem="{Binding SelectedInstrument}"
                              DisplayMemberPath="DisplayName"
                              MaxDropDownHeight="420"
                              Margin="0,0,0,12">
                        <ComboBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Background.Elevated}"
                                                BorderBrush="{DynamicResource Border.Brush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,4,8,4">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Accent.Brush}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ComboBox.GroupStyle>
                    </ComboBox>

                    <TextBlock Text="Chart timeframe (drives ATR + bar deltas)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding TimeframeOptions}"
                              SelectedItem="{Binding SelectedTimeframe}"
                              Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Window size (bars)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Delta threshold (±)" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0"
                                   Text="{Binding WindowSize, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding DeltaThreshold, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="4,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Min ATR" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Max ATR" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0"
                                   Text="{Binding MinAtr, UpdateSourceTrigger=PropertyChanged, StringFormat=F5}"
                                   Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding MaxAtr, UpdateSourceTrigger=PropertyChanged, StringFormat=F5}"
                                   Margin="4,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Max daily signals" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Cooldown (min)" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0"
                                   Text="{Binding MaxDailyTrades, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding CooldownMinutes, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="4,0,0,0" />
                    </Grid>

                    <CheckBox Content="Use HTF filter (15m EMA(50))"
                              IsChecked="{Binding UseHtfFilter}" Margin="0,0,0,4" />
                    <CheckBox Content="Use session filter (London 08-12 GMT, NY 13-17 GMT)"
                              IsChecked="{Binding UseSessionFilter}" Margin="0,0,0,16" />

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ===== Chart + dashboard ===== -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Left column: header + plots -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="160" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                        <TextBlock Text="TF:" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding SelectedTimeframe}" Margin="6,0,16,0" />
                        <TextBlock Text="Window:" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding WindowSize}" Margin="6,0,16,0" />
                        <TextBlock Text="Threshold ±" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding DeltaThreshold}" Margin="6,0,16,0" />
                        <TextBlock Margin="20,0,0,0"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   Text="{Binding Status}" />
                    </StackPanel>
                </Border>

                <scottplot:WpfPlot x:Name="PricePlot" Grid.Row="1" />

                <scottplot:WpfPlot x:Name="DeltaPlot" Grid.Row="2" />
            </Grid>

            <!-- Right column: live dashboard + signal log -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Elevated}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Live"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Accent.Brush}"
                                   Margin="0,0,0,6" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Bid" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastBid, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Ask" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastAsk, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Spread" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastSpreadPoints, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Live Δ (bar)" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LiveDelta}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Σ cumΔ (window)" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding CumulativeDelta}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="ATR(14)" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastAtr, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="EMA(50) 15m" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastEmaHtf, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Signals today" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding TodaySignalCount}" />
                        </Grid>

                        <Border Background="{DynamicResource Background.Surface}"
                                Padding="8,4" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Guard:"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           Margin="0,0,6,0" />
                                <TextBlock Text="{Binding GuardReason, FallbackValue=—}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Warning.Brush}"
                                Padding="8,4" Margin="0,8,0,0"
                                Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="● ALGO ARMED" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </StackPanel>

                    <Separator Grid.Row="1" Margin="0,12,0,8" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Recent signals"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Accent.Brush}"
                                   Margin="0,0,0,4" />
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding RecentSignals}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
