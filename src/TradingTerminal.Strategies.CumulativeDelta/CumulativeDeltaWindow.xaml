<mah:MetroWindow x:Class="TradingTerminal.Strategies.CumulativeDelta.CumulativeDeltaWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.CumulativeDelta"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Cumulative Delta Scalper"
                 Height="780" Width="1180"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <!-- Style for label cell of a dashboard row: dim, left-aligned. -->
        <Style x:Key="DashLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="Margin" Value="0,2,8,2" />
        </Style>
        <!-- Style for value cell of a dashboard row: monospaced, semibold, right-aligned. -->
        <Style x:Key="DashValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm the algo. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ===== Setup form ===== -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="560"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    Padding="24"
                    Margin="0,24">
                <StackPanel>
                    <TextBlock Text="Configure Cumulative Delta Scalper (Sniper)"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Tick uptick/downtick → bar deltas → sliding-window cumulative delta. Trigger on cross of ±threshold gated by up to five confirmations (momentum, HTF EMA, EMA slope, ADX, dynamic spread)."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Text.Secondary}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,12" />

                    <TextBlock Text="Chart timeframe (drives ATR + bar deltas)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding TimeframeOptions}"
                              SelectedItem="{Binding SelectedTimeframe}"
                              Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Window size (bars)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Delta threshold (±)" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0"
                                   Text="{Binding WindowSize, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding DeltaThreshold, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="4,0,0,0" />
                    </Grid>

                    <!-- Sniper filters -->
                    <Expander Header="Sniper filters (5-confirmation gate)"
                              IsExpanded="True"
                              Margin="0,0,0,12">
                        <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Min confirmations (0–5)" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="EMA slope bars" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding MinConfirmations, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding EmaSlopeBars, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ADX threshold" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Spread avg ×" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding AdxThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding SpreadAvgMultiplier, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Spread history size" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Max spread (price)" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding SpreadHistorySize, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding MaxSpread, UpdateSourceTrigger=PropertyChanged, StringFormat=F5}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <CheckBox Content="Use HTF filter (15m EMA(50) — needed for confirmations 2 &amp; 3)"
                                      IsChecked="{Binding UseHtfFilter}" />
                        </StackPanel>
                    </Expander>

                    <!-- Volatility -->
                    <Expander Header="Volatility (ATR gate)"
                              Margin="0,0,0,12">
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Min ATR" Margin="0,0,4,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Max ATR" Margin="4,0,0,4" />
                            <TextBox   Grid.Row="1" Grid.Column="0"
                                       Text="{Binding MinAtr, UpdateSourceTrigger=PropertyChanged, StringFormat=F5}"
                                       Margin="0,0,4,0" />
                            <TextBox   Grid.Row="1" Grid.Column="1"
                                       Text="{Binding MaxAtr, UpdateSourceTrigger=PropertyChanged, StringFormat=F5}"
                                       Margin="4,0,0,0" />
                        </Grid>
                    </Expander>

                    <!-- Sessions -->
                    <Expander Header="Sessions (GMT)"
                              IsExpanded="True"
                              Margin="0,0,0,12">
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox Content="Use session filter"
                                      IsChecked="{Binding UseSessionFilter}" Margin="0,0,0,6" />
                            <CheckBox Content="Overlap only (London / NY overlap)"
                                      IsChecked="{Binding OverlapOnly}" Margin="0,0,0,8" />

                            <TextBlock Text="Overlap window" Foreground="{DynamicResource Text.Secondary}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding OverlapStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding OverlapStartMin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="2" Text="{Binding OverlapEndHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="3" Text="{Binding OverlapEndMin, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Content="Asia"
                                      IsChecked="{Binding UseAsiaSession}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding AsiaStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding AsiaEndHour, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Content="London"
                                      IsChecked="{Binding UseLondonSession}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding LondonStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding LondonEndHour, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Content="New York"
                                      IsChecked="{Binding UseNewYorkSession}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewYorkStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding NewYorkStartMin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="2" Text="{Binding NewYorkEndHour, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Risk caps -->
                    <Expander Header="Risk caps"
                              Margin="0,0,0,16">
                        <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Max daily signals" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Max signals / session" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding MaxDailySignals, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding MaxSignalsPerSession, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <TextBlock Text="Min seconds between signals" Margin="0,0,0,4" />
                            <TextBox Text="{Binding MinSecondsBetweenSignals, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ===== Chart + dashboard ===== -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live tuning strip. Every Cumulative Delta parameter is read fresh on each closed
                 bar, so all of these take effect immediately while streaming — no restart needed. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TUNING" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Window (bars)" Minimum="2" Maximum="50" Step="1" StringFormat="0"
                                          Value="{Binding WindowSize, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="Delta thr ±" Minimum="1" Maximum="5000" Step="10" StringFormat="0"
                                          SpinnerWidth="84" Value="{Binding DeltaThreshold, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="Min conf" Minimum="0" Maximum="5" Step="1" StringFormat="0"
                                          Value="{Binding MinConfirmations, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="ADX ≥" Minimum="0" Maximum="100" Step="0.5" StringFormat="0.0"
                                          Value="{Binding AdxThreshold, Mode=TwoWay}" />

                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Bars shown" Minimum="30" Maximum="300" Step="10" StringFormat="0"
                                          Value="{Binding ChartBarsShown, Mode=TwoWay}" />
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Price Y" FontSize="10" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                            <CheckBox Content="Auto" IsChecked="{Binding PriceAutoScale, Mode=TwoWay}" VerticalAlignment="Center" />
                        </StackPanel>
                        <uic:ParamSpinner Label="Y min" Minimum="0" Maximum="1000000" Step="0.0001" StringFormat="0.#####"
                                          SpinnerWidth="92" Value="{Binding PriceAxisMin, Mode=TwoWay}"
                                          IsEnabled="{Binding PriceAutoScale, Converter={StaticResource InverseBooleanConverter}}" />
                        <uic:ParamSpinner Label="Y max" Minimum="0" Maximum="1000000" Step="0.0001" StringFormat="0.#####"
                                          SpinnerWidth="92" Value="{Binding PriceAxisMax, Mode=TwoWay}"
                                          IsEnabled="{Binding PriceAutoScale, Converter={StaticResource InverseBooleanConverter}}" />

                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <ToggleButton x:Name="MoreToggle" Content="More ▾" VerticalAlignment="Center" Padding="10,3" />
                        <Popup IsOpen="{Binding IsChecked, ElementName=MoreToggle}"
                               PlacementTarget="{Binding ElementName=MoreToggle}" Placement="Bottom"
                               StaysOpen="False" AllowsTransparency="True">
                            <Border Style="{StaticResource Strategy.ParamPopout}">
                                <StackPanel>
                                    <TextBlock Text="Advanced filters — all live" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <WrapPanel>
                                        <uic:ParamSpinner Label="EMA slope bars" Minimum="1" Maximum="50" Step="1" StringFormat="0"
                                                          Value="{Binding EmaSlopeBars, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Spread avg ×" Minimum="0.5" Maximum="10" Step="0.1" StringFormat="0.00"
                                                          Value="{Binding SpreadAvgMultiplier, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Spread hist" Minimum="1" Maximum="200" Step="1" StringFormat="0"
                                                          Value="{Binding SpreadHistorySize, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max spread" Minimum="0" Maximum="1" Step="0.00001" StringFormat="0.#####"
                                                          SpinnerWidth="92" Value="{Binding MaxSpread, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Min ATR" Minimum="0" Maximum="1" Step="0.00001" StringFormat="0.#####"
                                                          SpinnerWidth="92" Value="{Binding MinAtr, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max ATR" Minimum="0" Maximum="1" Step="0.00001" StringFormat="0.#####"
                                                          SpinnerWidth="92" Value="{Binding MaxAtr, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max daily" Minimum="1" Maximum="100" Step="1" StringFormat="0"
                                                          Value="{Binding MaxDailySignals, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max / session" Minimum="1" Maximum="100" Step="1" StringFormat="0"
                                                          Value="{Binding MaxSignalsPerSession, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Cooldown (s)" Minimum="0" Maximum="7200" Step="30" StringFormat="0"
                                                          SpinnerWidth="84" Value="{Binding MinSecondsBetweenSignals, Mode=TwoWay}" />
                                    </WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox Content="HTF filter" IsChecked="{Binding UseHtfFilter}" Margin="0,0,12,0" />
                                        <CheckBox Content="Session filter" IsChecked="{Binding UseSessionFilter}" Margin="0,0,12,0" />
                                        <CheckBox Content="Overlap only" IsChecked="{Binding OverlapOnly}" Margin="0,0,12,0" />
                                        <CheckBox Content="Asia" IsChecked="{Binding UseAsiaSession}" Margin="0,0,12,0" />
                                        <CheckBox Content="London" IsChecked="{Binding UseLondonSession}" Margin="0,0,12,0" />
                                        <CheckBox Content="New York" IsChecked="{Binding UseNewYorkSession}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Left column: header + plots -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="160" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                        <TextBlock Text="TF:" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding SelectedTimeframe}" Margin="6,0,16,0" />
                        <TextBlock Text="Window:" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding WindowSize}" Margin="6,0,16,0" />
                        <TextBlock Text="Threshold ±" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding DeltaThreshold}" Margin="6,0,16,0" />
                        <TextBlock Margin="20,0,0,0"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   Text="{Binding Status}" />
                    </StackPanel>
                </Border>

                <scottplot:WpfPlot x:Name="PricePlot" Grid.Row="1" />

                <scottplot:WpfPlot x:Name="DeltaPlot" Grid.Row="2" />
            </Grid>

            <!-- Right column: live dashboard + signal log -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Elevated}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1,0,0,0"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Live"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Accent.Brush}"
                                   Margin="0,0,0,6" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Bid" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastBid, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Ask" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastAsk, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Spread" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastSpread, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Avg spread" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding AvgSpread, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Live Δ (bar)" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LiveDelta}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Σ cumΔ (window)" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding CumulativeDelta}" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="ATR(14)" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastAtr, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="EMA(50) 15m" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastEmaHtf, StringFormat=F5, FallbackValue=—}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="ADX(14) 15m" />
                            <TextBlock Grid.Row="8" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastAdx, StringFormat=F1, FallbackValue=—}" />

                            <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Session" />
                            <TextBlock Grid.Row="9" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding ActiveSession}" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Last conf" />
                            <TextBlock Grid.Row="10" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding LastConfirmationScore, StringFormat='{}{0}/5'}" />

                            <TextBlock Grid.Row="11" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Signals today" />
                            <TextBlock Grid.Row="11" Grid.Column="1" Style="{StaticResource DashValueStyle}"
                                       Text="{Binding TodaySignalCount}" />
                        </Grid>

                        <Border Background="{DynamicResource Background.Surface}"
                                Padding="8,4" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Guard:"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           Margin="0,0,6,0" />
                                <TextBlock Text="{Binding GuardReason, FallbackValue=—}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Warning.Brush}"
                                Padding="8,4" Margin="0,8,0,0"
                                Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="● ALGO ARMED" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </StackPanel>

                    <Separator Grid.Row="1" Margin="0,12,0,8" />

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="Recent signals"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Accent.Brush}"
                                   Margin="0,0,0,4" />
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding RecentSignals}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Border>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
