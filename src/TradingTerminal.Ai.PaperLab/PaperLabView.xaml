<UserControl x:Class="TradingTerminal.Ai.PaperLab.PaperLabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="860" d:DesignWidth="1180"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <!-- URL input + Resolve strip -->
            <RowDefinition Height="Auto" />
            <!-- Resolved paper info + repo picker + Submit -->
            <RowDefinition Height="Auto" />
            <!-- Status / error bar -->
            <RowDefinition Height="Auto" />
            <!-- Job list (fills remaining space) -->
            <RowDefinition Height="*" />
            <!-- Replication confidence readout (shown after a successful save) -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: URL + Resolve ════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10" Margin="0,0,0,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="Paper URL"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <Button DockPanel.Dock="Right"
                        Content="Cancel"
                        Command="{Binding CancelResolveCommand}"
                        IsEnabled="{Binding IsResolving}"
                        Padding="10,4" Margin="6,0,0,0" />

                <Button DockPanel.Dock="Right"
                        Content="Resolve"
                        Command="{Binding ResolveCommand}"
                        Padding="12,4" Margin="6,0,0,0"
                        ToolTip="Resolve the arXiv / GitHub URL to a paper + candidate repos." />

                <TextBox Text="{Binding PaperUrl, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         ToolTip="Paste an arXiv URL (e.g. https://arxiv.org/abs/2507.22712) or GitHub repo URL." />
            </DockPanel>
        </Border>

        <!-- ═══ Row 1: Resolved info + repo picker + Submit ════════════════════ -->
        <Border Grid.Row="1"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10" Margin="0,0,0,6"
                Visibility="{Binding PaperResolved, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Paper title + arXiv id -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ResolvedPaperTitle}"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Foreground="{DynamicResource Text.Secondary}" FontSize="11">
                        <Run Text="arXiv:" />
                        <Run Text="{Binding ResolvedPaperArxivId}" />
                    </TextBlock>
                </StackPanel>

                <!-- Repo picker -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0">
                    <TextBlock Text="Repo" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox ItemsSource="{Binding CandidateRepos}"
                              SelectedItem="{Binding SelectedRepo}"
                              MinWidth="240"
                              ToolTip="Select the candidate repository to reproduce.">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding GitUrl}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="200" />
                                    <TextBlock Text="{Binding Commit, StringFormat=' @ {0}'}"
                                               Foreground="{DynamicResource Text.Secondary}"
                                               Margin="4,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Submit -->
                <Button Grid.Column="2"
                        Content="Submit Reproduction"
                        Command="{Binding SubmitCommand}"
                        Padding="14,6"
                        ToolTip="Queue a reproduction job for the selected repo. Returns immediately if a cached result exists." />
            </Grid>
        </Border>

        <!-- ═══ Row 2: Status / error bar ══════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="8,6" Margin="0,0,0,6">
            <DockPanel>
                <mah:ProgressRing DockPanel.Dock="Right"
                                  Width="22" Height="22"
                                  IsActive="{Binding IsBusy}"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0" />

                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource Danger.Brush}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                           TextWrapping="Wrap"
                           Margin="0,0,8,0" />

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Text.Secondary}"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <!-- ═══ Row 3: Job list ══════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Reproduction Jobs"
                           FontWeight="SemiBold" FontSize="13"
                           Margin="10,8,10,6" />

                <!-- Column headers -->
                <Grid DockPanel.Dock="Top" Margin="10,0,10,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="160" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="60" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Paper" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Grid.Column="1" Text="Repo" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Grid.Column="2" Text="Status" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Grid.Column="3" Text="Cache Key" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Grid.Column="4" Text="Cache Hit" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Grid.Column="5" Text="Error" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Grid.Column="6" />
                    <TextBlock Grid.Column="7" />
                </Grid>

                <Separator DockPanel.Dock="Top" Margin="0,0,0,2" />

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Jobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource Border.Brush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="10,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="160" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <!-- Save as strategy button — fixed width -->
                                            <ColumnDefinition Width="110" />
                                            <!-- Cancel button -->
                                            <ColumnDefinition Width="60" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Paper title -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding PaperTitle}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PaperTitle}"
                                                   VerticalAlignment="Center" />

                                        <!-- Repo URL (short) -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RepoUrl}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding RepoUrl}"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0" />

                                        <!-- Status badge -->
                                        <Border Grid.Column="2"
                                                CornerRadius="3"
                                                Padding="6,2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="4,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource Background.Elevated}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Succeeded">
                                                            <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Background" Value="{DynamicResource Text.Secondary}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Text.Primary}" />
                                        </Border>

                                        <!-- Cache key short hash -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding CacheKey}"
                                                   FontFamily="Consolas, Courier New"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0" />

                                        <!-- Cache-hit badge -->
                                        <Border Grid.Column="4"
                                                CornerRadius="3" Padding="5,2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="4,0"
                                                Background="{DynamicResource Accent.Brush}"
                                                Visibility="{Binding IsCacheHit, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="CACHED" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="#1E1E1E" />
                                        </Border>

                                        <!-- Error (truncated) -->
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding Error}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Error}"
                                                   Foreground="{DynamicResource Danger.Brush}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0"
                                                   Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}" />

                                        <!-- Save as strategy button (visible only for succeeded jobs with a result) -->
                                        <Button Grid.Column="6"
                                                Content="Save as strategy"
                                                FontSize="11" Padding="6,2"
                                                VerticalAlignment="Center"
                                                Margin="4,0"
                                                ToolTip="Bridge this reproduction into the Backtest Studio strategy catalog."
                                                Command="{Binding DataContext.SaveAsStrategyCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding CanSaveAsStrategy,
                                                             Converter={StaticResource BooleanToVisibilityConverter}}" />

                                        <!-- Cancel button (hidden for terminal jobs) -->
                                        <Button Grid.Column="7"
                                                Content="Cancel"
                                                FontSize="11" Padding="6,2"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.CancelJobCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding JobId}"
                                                Visibility="{Binding IsTerminal,
                                                             Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
        <!-- ═══ Row 4: Replication confidence readout ════════════════════════════ -->
        <!-- Visible only after a successful "Save as strategy" call. No converter needed:
             HasConfidence is a bool property; ProgressBar.Value is bound to a 0..1 double and
             Maximum is set to 1.0 so no scaling converter is required. -->
        <Border Grid.Row="4"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10,8" Margin="0,6,0,0"
                Visibility="{Binding HasConfidence, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <!-- Header: overall score -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock DockPanel.Dock="Left"
                               Text="Replication Confidence"
                               FontWeight="SemiBold" FontSize="13" />
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding ConfidenceLabel}"
                               Foreground="{DynamicResource Accent.Brush}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <ProgressBar Minimum="0" Maximum="1"
                                 Value="{Binding ConfidenceScore, Mode=OneWay}"
                                 Height="8"
                                 VerticalAlignment="Center"
                                 Margin="12,0" />
                </DockPanel>

                <!-- Per-component breakdown -->
                <ItemsControl ItemsSource="{Binding ConfidenceComponents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Each row: component name | progress bar (0..1) | score label -->
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="48" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Name}"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Name}" />

                                <ProgressBar Grid.Column="1"
                                             Minimum="0" Maximum="1"
                                             Value="{Binding Score, Mode=OneWay}"
                                             Height="6"
                                             VerticalAlignment="Center"
                                             Margin="8,0" />

                                <TextBlock Grid.Column="2"
                                           Text="{Binding ScoreLabel}"
                                           Foreground="{DynamicResource Text.Secondary}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
