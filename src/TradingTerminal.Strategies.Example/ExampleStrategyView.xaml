<UserControl x:Class="TradingTerminal.Strategies.Example.ExampleStrategyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}"
             d:DesignHeight="500" d:DesignWidth="900">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Parameter panel -->
        <Border Grid.Row="0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Symbol" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="100" Margin="0,0,16,0" />

                <TextBlock Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox ItemsSource="{Binding TimeframeOptions}"
                          SelectedItem="{Binding SelectedTimeframe}"
                          MinWidth="80" Margin="0,0,16,0" />

                <Button Content="Apply"
                        Command="{Binding ApplyCommand}"
                        MinWidth="80" />

                <TextBlock Margin="20,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource Text.Secondary}"
                           Text="{Binding Status}" />
            </StackPanel>
        </Border>

        <!-- Chart -->
        <scottplot:WpfPlot x:Name="Plot" Grid.Row="1" />

        <!-- Footer info -->
        <Border Grid.Row="2"
                Background="{DynamicResource Background.Elevated}"
                Padding="12,4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Last:" Foreground="{DynamicResource Text.Secondary}" />
                <TextBlock Text="{Binding LastPrice, StringFormat=F2, FallbackValue=—}"
                           Margin="6,0,0,0" />
                <TextBlock Text="  |  Bars:" Foreground="{DynamicResource Text.Secondary}" Margin="20,0,0,0" />
                <TextBlock Text="{Binding Bars.Count}" Margin="6,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
