<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.VolumeFootprint.AvaloniaUi.VolumeFootprintAvaloniaWindow"
        Width="620" Height="560"
        Background="{StaticResource Background.Primary}"
        Title="Volume Footprint">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Volume Footprint" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox MinWidth="220" ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox MinWidth="80" ItemsSource="{Binding Intervals}" SelectedItem="{Binding SelectedInterval}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Label}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Width="70" Watermark="Tick" Text="{Binding TickSizeText}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <CheckBox Content="Imbalances" IsChecked="{Binding ShowImbalances}"/>
        <CheckBox Content="Value area" IsChecked="{Binding ShowValueArea}"/>
        <CheckBox Content="Vol profile" IsChecked="{Binding ShowVolumeProfile}"/>
      </StackPanel>
      <TextBlock Text="{Binding Status}" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
    </StackPanel>

    <Border Margin="0,8,0,0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3" Padding="10">
      <StackPanel Spacing="4">
        <TextBlock Text="Live microstructure" FontWeight="SemiBold" Foreground="{StaticResource Text.Header}"/>
        <UniformGrid Columns="2">
          <TextBlock Text="{Binding CurrentPocText, StringFormat='POC: {0}'}" Foreground="{StaticResource Text.Primary}"/>
          <TextBlock Text="{Binding PocSlopeText, StringFormat='POC slope: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
          <TextBlock Text="{Binding BuySellText, StringFormat='Buy/Sell: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
          <TextBlock Text="{Binding SessionDelta, StringFormat='Session Δ: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
          <TextBlock Text="{Binding VisibleVolumeText, StringFormat='Visible vol: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
          <TextBlock Text="{Binding StackedText, StringFormat='Stacked: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
          <TextBlock Text="{Binding TicksPerSecondText, StringFormat='Ticks/s: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
          <TextBlock Text="{Binding TradesSeen, StringFormat='Trades: {0}'}" Foreground="{StaticResource Text.Secondary}"/>
        </UniformGrid>
        <TextBlock Text="{Binding Bars.Count, StringFormat='Footprint columns streaming: {0} (faithful cell grid = WPF; Avalonia grid render is a polish pass)'}"
                   Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap" Margin="0,8,0,0"/>
      </StackPanel>
    </Border>
  </DockPanel>
</Window>
