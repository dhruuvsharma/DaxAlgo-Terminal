<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.MarkovRegime.AvaloniaUi.MarkovRegimeAvaloniaWindow"
        Width="760" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="Markov regime">
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Markov regime — Gaussian HMM" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox MinWidth="150" ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <ComboBox ItemsSource="{Binding Timeframes}" SelectedItem="{Binding SelectedTimeframe}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Label}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="States" VerticalAlignment="Center"/>
        <ComboBox ItemsSource="{Binding StateCounts}" SelectedItem="{Binding StateCount}"/>
        <TextBlock Text="Bars" VerticalAlignment="Center"/>
        <NumericUpDown Width="110" Value="{Binding BarCount}" Minimum="50"/>
        <Button Content="Fit" Command="{Binding FitCommand}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Text="{Binding CurrentLabel, StringFormat='Regime: {0}'}" Foreground="{DynamicResource Accent.Brush}"/>
        <TextBlock Text="{Binding CurrentProbability, StringFormat='p={0}'}" Foreground="{DynamicResource Text.Secondary}"/>
        <TextBlock Text="{Binding FitStatus}" Foreground="{DynamicResource Text.Secondary}"/>
        <TextBlock Text="{Binding BarsStatus}" Foreground="{DynamicResource Text.Secondary}"/>
      </StackPanel>
      <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
      <DockPanel Grid.Column="0" Margin="0,0,8,0">
        <TextBlock DockPanel.Dock="Top" Text="States" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
          <ListBox ItemsSource="{Binding States}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
        </Border>
      </DockPanel>
      <DockPanel Grid.Column="1" Margin="8,0,0,0">
        <TextBlock DockPanel.Dock="Top" Text="Transition matrix" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3" Padding="8">
          <TextBlock Text="{Binding TransitionMatrixText}" FontFamily="{DynamicResource Font.Mono}" FontSize="12"/>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
