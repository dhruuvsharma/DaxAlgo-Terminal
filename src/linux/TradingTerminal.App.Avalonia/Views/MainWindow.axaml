<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TradingTerminal.App.Avalonia.ViewModels"
        x:Class="TradingTerminal.App.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="820" Height="620"
        Title="DaxAlgo Terminal (Avalonia)">
  <DockPanel Margin="20">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="{Binding Greeting}" FontSize="22" FontWeight="Bold"/>
      <TextBlock Text="{Binding RuntimeInfo}" Opacity="0.7" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding CoreStatus}" Foreground="#4FC3F7" Margin="0,8,0,0"/>
    </StackPanel>

    <!-- Activity Log: bound to the SAME InMemoryLogSink type the WPF shell uses (now WPF-free). -->
    <Grid DockPanel.Dock="Bottom" RowDefinitions="Auto,140" Margin="0,12,0,0">
      <TextBlock Grid.Row="0" Text="Activity Log (shared InMemoryLogSink)" FontWeight="SemiBold" Margin="0,0,0,4"/>
      <Border Grid.Row="1" BorderBrush="#333" BorderThickness="1" CornerRadius="3">
        <ListBox ItemsSource="{Binding ActivityLog.Entries}" FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Message}"/>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>
    </Grid>

    <DockPanel>
      <TextBlock DockPanel.Dock="Top" Text="Brokers wired in the portable core:" Margin="0,12,0,4" FontWeight="SemiBold"/>
      <ListBox ItemsSource="{Binding Brokers}"/>
    </DockPanel>
  </DockPanel>
</Window>
