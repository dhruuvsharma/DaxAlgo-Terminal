<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Shared Avalonia UI primitives for the cross-platform heads — the counterpart to the WPF
         TradingTerminal.UI (StrategyWindowBase, shared controls). net9.0 (runs on Windows + Linux +
         ARM64); overrides the net9.0-windows7.0 default from Directory.Build.props. Strategy projects
         reference this only on their net9.0 leg so their WPF leg stays Avalonia-free. -->
    <TargetFramework>net9.0</TargetFramework>
    <Description>Shared Avalonia UI primitives (generic strategy window, controls) for the cross-platform heads.</Description>
  </PropertyGroup>

  <ItemGroup>
    <!-- Portable VM layer (LiveSignalStrategyViewModelBase, ViewModelBase). -->
    <ProjectReference Include="..\TradingTerminal.UI.Core\TradingTerminal.UI.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.2.1" />
  </ItemGroup>

</Project>
