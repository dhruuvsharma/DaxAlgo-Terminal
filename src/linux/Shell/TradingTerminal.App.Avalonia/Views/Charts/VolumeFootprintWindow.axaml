<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TradingTerminal.App.Avalonia.ViewModels"
        xmlns:ch="using:TradingTerminal.App.Avalonia.Charts"
        x:Class="TradingTerminal.App.Avalonia.Views.Charts.VolumeFootprintWindow"
        x:DataType="vm:VolumeFootprintViewModel"
        Width="980" Height="720"
        Background="{StaticResource Background.Primary}"
        Title="Volume Footprint">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="VOLUME FOOTPRINT" Classes="header" FontSize="15" VerticalAlignment="Center" />
        <Border Classes="card" Background="{StaticResource Accent.Soft}"
                BorderBrush="{StaticResource Accent.Brush}" Padding="6,1" VerticalAlignment="Center">
          <TextBlock Text="BID × ASK · IMBALANCE · POC" Foreground="{StaticResource Accent.Brush}" FontSize="9" />
        </Border>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Classes="muted mono" FontSize="11" Text="{Binding Status}" />
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="6">
      <ch:FootprintControl Bars="{Binding Bars}" />
    </ScrollViewer>
  </DockPanel>
</Window>
