<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Global control styling so the Avalonia shell matches the Windows (WPF) terminal look:
       black canvas, amber headers/accents, monospace data, thin grey borders. -->

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource Background.Primary}" />
    <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
  </Style>
  <!-- Convention classes used in the views -->
  <Style Selector="TextBlock.header">
    <Setter Property="Foreground" Value="{StaticResource Text.Header}" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>
  <Style Selector="TextBlock.section">
    <Setter Property="Foreground" Value="{StaticResource Accent.Brush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{StaticResource Text.Secondary}" />
  </Style>
  <Style Selector="TextBlock.mono">
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, monospace" />
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{StaticResource Background.Elevated}" />
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Strong}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Padding" Value="12,6" />
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Surface.Hover}" />
    <Setter Property="BorderBrush" Value="{StaticResource Accent.Brush}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource Accent.Hover.Brush}" />
  </Style>
  <!-- Primary action button: amber-filled -->
  <Style Selector="Button.accent">
    <Setter Property="Background" Value="{StaticResource Accent.Brush}" />
    <Setter Property="Foreground" Value="#000000" />
    <Setter Property="BorderBrush" Value="{StaticResource Accent.Brush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{StaticResource Background.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
  </Style>
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{StaticResource Background.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Brush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="{StaticResource Background.Surface}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Brush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
    <Setter Property="Padding" Value="8,5" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Accent.Soft}" />
    <Setter Property="TextBlock.Foreground" Value="{StaticResource Accent.Hover.Brush}" />
  </Style>
  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource Surface.Hover}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource Background.Elevated}" />
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Strong}" />
    <Setter Property="CaretBrush" Value="{StaticResource Accent.Brush}" />
  </Style>
  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource Background.Elevated}" />
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Strong}" />
  </Style>
  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="{StaticResource Background.Elevated}" />
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
    <Setter Property="BorderBrush" Value="{StaticResource Border.Strong}" />
  </Style>
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{StaticResource Text.Primary}" />
  </Style>
</Styles>
