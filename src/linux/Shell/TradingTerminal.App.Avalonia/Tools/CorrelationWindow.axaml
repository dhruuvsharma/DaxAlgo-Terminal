<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tools="using:TradingTerminal.App.Avalonia.Tools"
        x:Class="TradingTerminal.App.Avalonia.Tools.CorrelationWindow"
        x:DataType="tools:CorrelationViewModel"
        Width="760" Height="560"
        Background="{StaticResource Background.Primary}"
        Title="Correlation Matrix">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="CORRELATION MATRIX" Classes="header" FontSize="15" VerticalAlignment="Center" />
        <Border Classes="card" Background="{StaticResource Accent.Soft}" BorderBrush="{StaticResource Accent.Brush}"
                Padding="6,1" VerticalAlignment="Center">
          <TextBlock Text="GREEN +1 · RED −1" Foreground="{StaticResource Accent.Brush}" FontSize="9" />
        </Border>
        <Button Content="Recompute" Command="{Binding RunCommand}" />
      </StackPanel>
    </Border>
    <Border DockPanel.Dock="Bottom" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Classes="muted mono" FontSize="11" Text="{Binding Status}" />
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Padding="10">
      <tools:CorrelationHeatmapControl Matrix="{Binding Matrix}" />
    </ScrollViewer>
  </DockPanel>
</Window>
