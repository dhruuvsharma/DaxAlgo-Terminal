<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.App.Avalonia.Settings.ArchiveActivityWindow"
        Width="720" Height="560"
        Background="{StaticResource Background.Primary}"
        Title="Archive history">
  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Archive history" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text.Header}"/>
      <TextBlock Text="{Binding CoverageSummary}" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
        <Button Content="Restore selected" Command="{Binding RestoreSelectedCommand}"/>
        <TextBlock Text="{Binding PendingCount, StringFormat='Pending: {0}'}" VerticalAlignment="Center" Foreground="{StaticResource Text.Secondary}"/>
      </StackPanel>
      <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
    </StackPanel>
    <Border Margin="0,8,0,0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
      <ListBox ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
               Background="{StaticResource Background.Surface}" FontSize="11"/>
    </Border>
  </DockPanel>
</Window>
