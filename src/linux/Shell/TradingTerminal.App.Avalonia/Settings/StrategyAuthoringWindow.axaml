<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.App.Avalonia.Settings.StrategyAuthoringWindow"
        Width="820" Height="640"
        Background="{StaticResource Background.Primary}"
        Title="Strategy authoring">
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Strategy authoring (Roslyn)" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Width="160" Watermark="Strategy id" Text="{Binding StrategyId}"/>
        <TextBox Width="220" Watermark="Display name" Text="{Binding DisplayName}"/>
        <Button Classes="accent" Content="Compile" Command="{Binding CompileCommand}"/>
      </StackPanel>
      <TextBlock Text="{Binding Status}" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
    </StackPanel>

    <Border DockPanel.Dock="Bottom" Height="140" Margin="0,8,0,0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
      <ListBox ItemsSource="{Binding Diagnostics}" Background="{StaticResource Background.Surface}" FontSize="11"/>
    </Border>

    <Border Margin="0,8,0,0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
      <TextBox Text="{Binding SourceCode}" AcceptsReturn="True" AcceptsTab="True"
               FontFamily="{StaticResource Font.Mono}" FontSize="12"
               TextWrapping="NoWrap" />
    </Border>
  </DockPanel>
</Window>
