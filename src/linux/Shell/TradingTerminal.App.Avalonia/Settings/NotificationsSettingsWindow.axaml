<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.App.Avalonia.Settings.NotificationsSettingsWindow"
        Width="560" Height="480"
        Background="{StaticResource Background.Primary}"
        Title="Notifications">
  <ScrollViewer Margin="16">
    <StackPanel Spacing="8">
      <TextBlock Text="Notifications" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text.Header}"/>

      <TextBlock Text="Telegram" Classes="section" Margin="0,8,0,0"/>
      <CheckBox Content="Enabled" IsChecked="{Binding TelegramEnabled}"/>
      <TextBox Watermark="Bot token" Text="{Binding TelegramBotToken}"/>
      <TextBox Watermark="Chat id" Text="{Binding TelegramChatId}"/>

      <TextBlock Text="Discord" Classes="section" Margin="0,8,0,0"/>
      <CheckBox Content="Enabled" IsChecked="{Binding DiscordEnabled}"/>
      <TextBox Watermark="Webhook URL" Text="{Binding DiscordWebhookUrl}"/>

      <CheckBox Content="Include idle/no-signal notifications" IsChecked="{Binding IncludeIdleSignals}" Margin="0,8,0,0"/>

      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Classes="accent" Content="Save" Command="{Binding SaveCommand}"/>
      </StackPanel>
      <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</Window>
