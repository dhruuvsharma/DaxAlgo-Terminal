<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ou="using:TradingTerminal.Strategies.OrnsteinUhlenbeck"
        x:Class="TradingTerminal.App.Avalonia.Strategies.OrnsteinUhlenbeckWindow"
        x:DataType="ou:OrnsteinUhlenbeckStrategyViewModel"
        Width="780" Height="600"
        Title="Ornstein-Uhlenbeck mean reversion (Avalonia)">
  <DockPanel Margin="14">

    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="{Binding StrategyDisplayName}" FontSize="18" FontWeight="Bold"/>
      <TextBlock Text="{Binding Status}" Opacity="0.8" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding ValidationError}" Foreground="#E57373" TextWrapping="Wrap"/>
    </StackPanel>

    <!-- Action bar -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Continue" Command="{Binding ContinueCommand}"/>
      <Button Content="Start stream" Command="{Binding StartCommand}"/>
      <Button Content="Arm / disarm" Command="{Binding ToggleAlgoCommand}"/>
      <Button Content="Stop" Command="{Binding StopCommand}"/>
      <Button Content="Clear signals" Command="{Binding ClearSignalsCommand}"/>
    </StackPanel>

    <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">

      <!-- Left: instrument + parameters (bound to the real, shared VM) -->
      <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,10,0">
        <TextBlock Text="Instrument" FontWeight="SemiBold"/>
        <TextBox Watermark="Search…" Text="{Binding InstrumentSearchText}"/>
        <ComboBox ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}"
                  HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayName}"/>
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Parameters" FontWeight="SemiBold" Margin="0,10,0,0"/>
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Lookback" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Lookback}" Minimum="1" Increment="10"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Refit every" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding RefitEvery}" Minimum="1"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Entry z" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding EntryZ}" Increment="0.1"/>
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Exit z" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding ExitZ}" Increment="0.1"/>
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Stop z" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding StopZ}" Increment="0.1"/>
          <TextBlock Grid.Row="5" Grid.Column="0" Text="Quantity" VerticalAlignment="Center"/>
          <NumericUpDown Grid.Row="5" Grid.Column="1" Value="{Binding Quantity}" Minimum="1"/>
        </Grid>
      </StackPanel>

      <!-- Right: live signals -->
      <DockPanel Grid.Column="1">
        <TextBlock DockPanel.Dock="Top" Text="Signals" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border BorderBrush="#333" BorderThickness="1" CornerRadius="3">
          <ListBox ItemsSource="{Binding Signals}" FontFamily="Cascadia Mono,Consolas,monospace" FontSize="12">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding}"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
