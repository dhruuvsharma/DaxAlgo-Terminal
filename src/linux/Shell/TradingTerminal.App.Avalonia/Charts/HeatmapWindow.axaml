<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ch="using:TradingTerminal.App.Avalonia.Charts"
        x:Class="TradingTerminal.App.Avalonia.Charts.HeatmapWindow"
        x:DataType="ch:HeatmapViewModel"
        Width="1040" Height="680"
        Background="{StaticResource Background.Primary}"
        Title="Liquidity Heatmap (Bookmap)">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="LIQUIDITY HEATMAP" Classes="header" FontSize="15" VerticalAlignment="Center" />
        <Border Classes="card" Background="{StaticResource Accent.Soft}"
                BorderBrush="{StaticResource Accent.Brush}" Padding="6,1" VerticalAlignment="Center">
          <TextBlock Text="RESTING DEPTH · BID/ASK TRACE" Foreground="{StaticResource Accent.Brush}" FontSize="9" />
        </Border>
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Classes="muted mono" FontSize="11" Text="{Binding Status}" />
    </Border>

    <ch:LiquidityHeatmapControl Columns="{Binding Columns}" Margin="6" />
  </DockPanel>
</Window>
