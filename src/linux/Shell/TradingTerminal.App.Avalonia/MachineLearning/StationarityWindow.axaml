<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ml="using:TradingTerminal.App.Avalonia.MachineLearning"
        xmlns:ch="using:TradingTerminal.App.Avalonia.Charts"
        x:Class="TradingTerminal.App.Avalonia.MachineLearning.StationarityWindow"
        x:DataType="ml:StationarityViewModel"
        Width="900" Height="640"
        Background="{StaticResource Background.Primary}"
        Title="Stationarity &amp; Differencing">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
      <StackPanel Orientation="Horizontal" Spacing="10">
        <TextBlock Text="STATIONARITY &amp; DIFFERENCING" Classes="header" FontSize="15" VerticalAlignment="Center" />
        <TextBlock Text="ADF · KPSS" Classes="section" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Bottom" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Classes="muted mono" FontSize="11" Text="{Binding Status}" />
    </Border>

    <!-- Controls + verdicts -->
    <Border DockPanel.Dock="Right" Classes="card" Width="300" Margin="0,10,10,10" Padding="14">
      <StackPanel Spacing="10">
        <TextBlock Classes="section" Text="TRANSFORM" />
        <ComboBox ItemsSource="{Binding Transforms}" SelectedItem="{Binding SelectedTransform}"
                  HorizontalAlignment="Stretch" />
        <Button Classes="accent" Content="RUN" Command="{Binding RunCommand}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />

        <TextBlock Classes="section" Text="ADF TEST" Margin="0,8,0,0" />
        <TextBlock Classes="mono" FontSize="20" Text="{Binding Adf}" Foreground="{StaticResource Text.Header}" />
        <TextBlock Classes="mono muted" Text="{Binding AdfVerdict}" TextWrapping="Wrap" />

        <TextBlock Classes="section" Text="KPSS TEST" Margin="0,8,0,0" />
        <TextBlock Classes="mono" FontSize="20" Text="{Binding Kpss}" Foreground="{StaticResource Text.Header}" />
        <TextBlock Classes="mono muted" Text="{Binding KpssVerdict}" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <!-- Transformed series plot -->
    <Border Classes="card" Margin="10" Padding="6">
      <ch:LineChartControl Series="{Binding Series}" />
    </Border>
  </DockPanel>
</Window>
