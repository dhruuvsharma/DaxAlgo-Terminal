<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ml="using:TradingTerminal.App.Avalonia.MachineLearning"
        xmlns:ch="using:TradingTerminal.App.Avalonia.Charts"
        x:Class="TradingTerminal.App.Avalonia.MachineLearning.KalmanWindow"
        x:DataType="ml:KalmanViewModel"
        Width="940" Height="640"
        Background="{StaticResource Background.Primary}"
        Title="Kalman Filter">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
      <TextBlock Text="KALMAN FILTER" Classes="header" FontSize="15" />
    </Border>
    <Border DockPanel.Dock="Bottom" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Classes="muted mono" FontSize="11" Text="{Binding Status}" />
    </Border>

    <Border DockPanel.Dock="Right" Classes="card" Width="300" Margin="0,10,10,10" Padding="14">
      <StackPanel Spacing="8">
        <TextBlock Classes="section" Text="q / r RATIO" />
        <Slider Minimum="0.001" Maximum="0.5" Value="{Binding QOverR}" />
        <TextBlock Classes="mono muted" Text="{Binding QOverR, StringFormat='q/r = {0:0.###}'}" />
        <CheckBox Content="Local linear trend" IsChecked="{Binding UseTrend}" />

        <TextBlock Classes="section" Text="DIAGNOSTICS" Margin="0,8,0,0" />
        <TextBlock Classes="mono muted" Text="{Binding LogLik, StringFormat='log-likelihood {0}'}" />
        <TextBlock Classes="mono muted" Text="{Binding ObsNoise, StringFormat='obs noise R {0}'}" />
        <TextBlock Classes="mono muted" Text="{Binding ProcNoise, StringFormat='proc noise Q {0}'}" />

        <TextBlock Classes="muted" FontSize="10" Margin="0,8,0,0"
                   Text="Amber = observed · Cyan = filtered state" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Classes="card" Margin="10" Padding="6">
      <ch:LineChartControl Series="{Binding Series}" Series2="{Binding Filtered}" />
    </Border>
  </DockPanel>
</Window>
