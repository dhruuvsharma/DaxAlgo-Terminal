<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ml="using:TradingTerminal.App.Avalonia.MachineLearning"
        xmlns:ch="using:TradingTerminal.App.Avalonia.Charts"
        x:Class="TradingTerminal.App.Avalonia.MachineLearning.ArimaGarchWindow"
        x:DataType="ml:ArimaGarchViewModel"
        Width="940" Height="640"
        Background="{StaticResource Background.Primary}"
        Title="ARIMA &amp; GARCH">
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
      <TextBlock Text="ARIMA &amp; GARCH" Classes="header" FontSize="15" />
    </Border>
    <Border DockPanel.Dock="Bottom" Background="{StaticResource Gradient.Chrome}"
            BorderBrush="{StaticResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,4">
      <TextBlock Classes="muted mono" FontSize="11" Text="{Binding Status}" />
    </Border>

    <Border DockPanel.Dock="Right" Classes="card" Width="300" Margin="0,10,10,10" Padding="14">
      <StackPanel Spacing="8">
        <TextBlock Classes="section" Text="ORDER (p, d, q)" />
        <Grid ColumnDefinitions="*,*,*">
          <NumericUpDown Grid.Column="0" Value="{Binding P}" Minimum="0" Maximum="5" Margin="0,0,4,0" />
          <NumericUpDown Grid.Column="1" Value="{Binding D}" Minimum="0" Maximum="2" Margin="2,0" />
          <NumericUpDown Grid.Column="2" Value="{Binding Q}" Minimum="0" Maximum="5" Margin="4,0,0,0" />
        </Grid>
        <Button Classes="accent" Content="FIT" Command="{Binding RunCommand}"
                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />

        <TextBlock Classes="section" Text="ARIMA (mean)" Margin="0,8,0,0" />
        <TextBlock Classes="mono" Text="{Binding Arima}" TextWrapping="Wrap" Foreground="{StaticResource Text.Header}" />
        <TextBlock Classes="mono muted" Text="{Binding Aic, StringFormat='AIC {0}'}" />

        <TextBlock Classes="section" Text="GARCH (vol)" Margin="0,8,0,0" />
        <TextBlock Classes="mono" Text="{Binding Garch}" TextWrapping="Wrap" Foreground="{StaticResource Text.Highlight}" />
        <TextBlock Classes="mono muted" Text="{Binding Persistence, StringFormat='persistence {0}'}" />

        <TextBlock Classes="muted" FontSize="10" Margin="0,8,0,0"
                   Text="Amber = price · Cyan tail = ARIMA forecast" TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Classes="card" Margin="10" Padding="6">
      <ch:LineChartControl Series="{Binding Series}" Series2="{Binding Forecast}" />
    </Border>
  </DockPanel>
</Window>
