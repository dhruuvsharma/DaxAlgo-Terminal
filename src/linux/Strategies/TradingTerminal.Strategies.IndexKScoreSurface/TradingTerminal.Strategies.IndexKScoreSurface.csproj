<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target: portable VM + descriptor on net9.0 (Avalonia view); the WPF HelixToolkit 3D
         surface window stays on the windows leg. The faithful cross-platform 3D surface lands with
         the Step-5 GPU control. See Strategies.CumulativeDelta for the template. -->
    <TargetFramework>net9.0</TargetFramework>
    <Description>Index K-Score Surface â€” multi-stock K-score aggregator with 3D surface visualization. Computes 15 directional indicators per component, derives a weighted K, and emits index-level entries when enough components pierce the per-weight threshold surface.</Description>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\linux\Core\TradingTerminal.Core\TradingTerminal.Core.csproj" />
    <ProjectReference Include="..\..\..\linux\UI\TradingTerminal.UI.Core\TradingTerminal.UI.Core.csproj" />
  </ItemGroup>

  <!-- HelixToolkit 3D surface + MahApps window only on the Windows leg. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <ProjectReference Include="..\..\Shell\TradingTerminal.UI\TradingTerminal.UI.csproj" />
    <PackageReference Include="HelixToolkit.Wpf" Version="2.27.0" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0-windows7.0'">
    <PackageReference Include="Avalonia" Version="11.2.1" />
    <PackageReference Include="ScottPlot.Avalonia" Version="5.0.55" />
    <Compile Remove="IndexKScoreSurfaceWindow.xaml.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
