<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="TradingTerminal.Strategies.IndexKScoreSurface.AvaloniaUi.IndexKScoreSurfaceAvaloniaWindow"
        Width="820" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="Index K-Score Surface">
  <!-- Cross-platform view: the WPF window draws a HelixToolkit 3D K surface; here the same
       [component × time] K grid renders as a ScottPlot.Avalonia heatmap (no GPU). A true 3D surface
       can replace this later via the GPU control. -->
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="Index K-Score Surface" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding ValidationError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Continue" Command="{Binding ContinueCommand}"/>
      <Button Content="Start" Command="{Binding StartCommand}"/>
      <Button Content="Arm / disarm" Command="{Binding ToggleAlgoCommand}"/>
      <Button Content="Stop" Command="{Binding StopCommand}"/>
    </StackPanel>

    <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
      <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,10,0">
        <TextBlock Text="Index family" FontWeight="SemiBold"/>
        <ComboBox ItemsSource="{Binding Families}" SelectedItem="{Binding SelectedFamily}" HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Text="Bar size" FontWeight="SemiBold" Margin="0,8,0,0"/>
        <ComboBox ItemsSource="{Binding BarSizes}" SelectedItem="{Binding SelectedBarSize}" HorizontalAlignment="Stretch"/>

        <TextBlock Text="Thresholds" FontWeight="SemiBold" Margin="0,8,0,0"/>
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="T min" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" Value="{Binding TMin}" Increment="0.05"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="T max" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" Value="{Binding TMax}" Increment="0.05"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Min pierce" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,0,0,4" Value="{Binding MinPierceCount}" Minimum="1"/>
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Cum-K" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding CumKThreshold}" Increment="0.5"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
          <TextBlock Text="{Binding PiercingUpCount, StringFormat='Pierce ↑ {0}'}" Foreground="{DynamicResource Bullish.Brush}"/>
          <TextBlock Text="{Binding PiercingDownCount, StringFormat='Pierce ↓ {0}'}" Foreground="{DynamicResource Bearish.Brush}"/>
        </StackPanel>
      </StackPanel>

      <DockPanel Grid.Column="1">
        <TextBlock DockPanel.Dock="Top" Text="K-score surface" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
          <sp:AvaPlot x:Name="SurfacePlot"/>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
