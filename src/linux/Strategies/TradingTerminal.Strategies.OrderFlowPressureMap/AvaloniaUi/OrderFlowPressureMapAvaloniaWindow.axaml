<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.Strategies.OrderFlowPressureMap.AvaloniaUi.OrderFlowPressureMapAvaloniaWindow"
        Width="760" Height="560"
        Background="{DynamicResource Background.Primary}"
        Title="Order Flow Pressure Map">
  <!-- Functional cross-platform view binding the portable VM (filters + status + pinned detail). The
       faithful ticker×time heatmap matrix (a custom WPF control) is a later parity pass alongside the
       Step-4 chart work; this opens the strategy and is operable on Windows and Linux. -->
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="1-Minute Order Flow Pressure Map" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
    </StackPanel>

    <Border DockPanel.Dock="Bottom" Background="{DynamicResource Background.Surface}"
            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3"
            Padding="12" Margin="0,10,0,0" IsVisible="{Binding IsPinned}">
      <StackPanel Spacing="2">
        <TextBlock Text="{Binding PinnedTitle}" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
        <StackPanel Orientation="Horizontal" Spacing="16">
          <TextBlock Text="{Binding PinnedPrice, StringFormat='Price: {0}'}"/>
          <TextBlock Text="{Binding PinnedRelVol, StringFormat='RelVol: {0}'}"/>
          <TextBlock Text="{Binding PinnedImbalance, StringFormat='Imbalance: {0}'}"/>
        </StackPanel>
        <TextBlock Text="{Binding PinnedSignal, StringFormat='Signal: {0}'}" Foreground="{DynamicResource Accent.Brush}"/>
      </StackPanel>
    </Border>

    <!-- Filter bar -->
    <StackPanel Spacing="8" Margin="0,12,0,0">
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Universe" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" HorizontalAlignment="Stretch"
                  SelectedItem="{Binding SelectedUniverse}"/>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Min rel. volume" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,0,0,6" Value="{Binding MinRelVol}" Increment="0.1" Minimum="0"/>
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Signal filter" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,0,0,6" HorizontalAlignment="Stretch"
                  SelectedItem="{Binding SelectedSignalFilter}"/>
        <CheckBox Grid.Row="3" Grid.Column="1" Content="Show only active" IsChecked="{Binding ShowOnlyActive}"/>
      </Grid>
      <TextBlock Text="Live heatmap matrix renders here in a later parity pass (custom matrix control / ScottPlot)."
                 Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,8,0,0"/>
    </StackPanel>
  </DockPanel>
</Window>
