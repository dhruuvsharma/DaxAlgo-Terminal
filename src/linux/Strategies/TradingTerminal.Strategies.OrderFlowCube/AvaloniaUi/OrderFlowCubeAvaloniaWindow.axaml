<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="TradingTerminal.Strategies.OrderFlowCube.AvaloniaUi.OrderFlowCubeAvaloniaWindow"
        Width="900" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="Order-Flow Cube">
  <!-- Faithful cross-platform view: the WPF window draws the 2D phase-space trail in a HelixToolkit
       cube; here it is a ScottPlot.Avalonia 2D scatter (Aggressor × CVD) — the same data, no GPU. -->
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="Order-Flow Cube" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding ValidationError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Continue" Command="{Binding ContinueCommand}"/>
      <Button Content="Arm / disarm" Command="{Binding ToggleAlgoCommand}"/>
      <Button Content="Stop" Command="{Binding StopCommand}"/>
    </StackPanel>

    <Grid ColumnDefinitions="280,*" Margin="0,12,0,0">
      <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,12,0">
        <TextBlock Text="Instrument" FontWeight="SemiBold"/>
        <TextBox Watermark="Search…" Text="{Binding InstrumentSearchText}"/>
        <ComboBox ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}" HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Live" FontWeight="SemiBold" Margin="0,10,0,0"/>
        <TextBlock Text="{Binding RegimeLabel, StringFormat='Regime: {0}'}" Foreground="{DynamicResource Accent.Brush}"/>
        <TextBlock Text="{Binding CurrentCvd, StringFormat='CVD: {0:0.000}'}"/>
        <TextBlock Text="{Binding CurrentAggressor, StringFormat='Aggressor: {0:0.000}'}"/>
        <TextBlock Text="{Binding CurrentSizeRatio, StringFormat='Size ratio: {0:0.00}'}"/>
        <TextBlock Text="{Binding TradesSeen, StringFormat='Trades: {0}'}" Foreground="{DynamicResource Text.Secondary}"/>
      </StackPanel>

      <Border Grid.Column="1" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <sp:AvaPlot x:Name="CubePlot"/>
      </Border>
    </Grid>
  </DockPanel>
</Window>
