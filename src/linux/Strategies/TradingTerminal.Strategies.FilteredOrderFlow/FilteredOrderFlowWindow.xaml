<ui:StrategyWindowBase x:Class="TradingTerminal.Strategies.FilteredOrderFlow.FilteredOrderFlowWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                       xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                       xmlns:ui="clr-namespace:TradingTerminal.UI;assembly=TradingTerminal.UI"
                       xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                       mc:Ignorable="d"
                       Title="{Binding StrategyDisplayName}"
                       Height="700" Width="1120"
                       WindowStartupLocation="CenterOwner"
                       Background="{DynamicResource Background.Primary}"
                       Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}" Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource Strategy.RunStopButton}" />
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ── Setup form ───────────────────────────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Strategy.SetupCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Strategy.SetupTitle}" Text="Configure Filtered Order-Flow Imbalance" />
                    <TextBlock Style="{StaticResource Strategy.SetupDescription}"
                               Text="Trade-based OBI(T) — net signed-trade count over a rolling window — regime-classified on a 9-bin grid. Signal fires on strong same-sign regimes. Tracks filtered vs unfiltered OBI(T) to show whether filtering fleeting flow sharpens the signal (arXiv:2507.22712). Needs a signed trade tape (IB / Simulated)." />

                    <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Instrument" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Window (s)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Min trade size" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Strong regime (1-4)" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding WindowSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding MinTradeSize, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding StrongRegime, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Hold (s)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Quantity" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding HoldSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <Border Style="{StaticResource Strategy.SetupErrorBanner}" Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue" Command="{Binding ContinueCommand}" HorizontalAlignment="Right" IsDefault="True" MinWidth="120" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ── Runtime dashboard ────────────────────────────────────────────────────────────── -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="PARAMS (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Window (s)" Minimum="1" Maximum="600" Step="1" StringFormat="0"
                                              Value="{Binding WindowSeconds, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Min size" Minimum="0" Maximum="1000" Step="1" StringFormat="0"
                                              Value="{Binding MinTradeSize, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Strong regime" Minimum="1" Maximum="4" Step="1" StringFormat="0"
                                              Value="{Binding StrongRegime, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Hold (s)" Minimum="0.1" Maximum="600" Step="0.5" StringFormat="0.0"
                                              Value="{Binding HoldSeconds, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Quantity" Minimum="1" Maximum="1000" Step="1" StringFormat="0"
                                              Value="{Binding Quantity, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Strategy.HeaderBar}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Symbol:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                        <TextBlock Text="Window:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding WindowSeconds, StringFormat=F0}" Margin="6,0,2,0" /><TextBlock Text="s" Margin="0,0,16,0" />
                        <TextBlock Text="Strong ≥:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding StrongRegime}" Margin="6,0,16,0" />
                        <TextBlock Text="Tape:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding TradeTapeAvailable}" Margin="6,0,16,0" FontWeight="SemiBold" />
                        <TextBlock Margin="12,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                    </StackPanel>
                </Border>

                <scottplot:WpfPlot x:Name="ObiPlot" Grid.Row="1" />

                <Border Grid.Row="2" Style="{StaticResource Strategy.FooterBar}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Filtered OBI:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding FilteredObi, StringFormat=F3, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                        <TextBlock Text="  |  Regime:" Style="{StaticResource Strategy.DashLabel}" Margin="16,0,0,0" /><TextBlock Text="{Binding FilteredRegimeLabel}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                        <TextBlock Text="  |  Unfiltered OBI:" Style="{StaticResource Strategy.DashLabel}" Margin="16,0,0,0" /><TextBlock Text="{Binding UnfilteredObi, StringFormat=F3, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                        <TextBlock Text="  |  Trades (filt/all):" Style="{StaticResource Strategy.DashLabel}" Margin="16,0,0,0" /><TextBlock Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}"><Run Text="{Binding FilteredTradesInWindow, Mode=OneWay}" />/<Run Text="{Binding UnfilteredTradesInWindow, Mode=OneWay}" /></TextBlock>
                        <TextBlock Text="  |  Signals:" Style="{StaticResource Strategy.DashLabel}" Margin="16,0,0,0" /><TextBlock Text="{Binding Signals.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                        <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}" Text="● ALGO ARMED" />
                    </StackPanel>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</ui:StrategyWindowBase>
