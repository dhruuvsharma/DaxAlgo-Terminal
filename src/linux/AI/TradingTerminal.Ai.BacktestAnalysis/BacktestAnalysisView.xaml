<UserControl x:Class="TradingTerminal.Ai.BacktestAnalysis.BacktestAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="950"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Backtest analysis" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Walk-forward optimisation (rolling train/test windows) and trade-bootstrap Monte Carlo. Same Core/Infrastructure types the daxalgo-backtest walkforward and mc subcommands use."
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
        </StackPanel>

        <TabControl Grid.Row="1">

            <!-- Walk-forward -->
            <TabItem Header="Walk-forward">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- File picker -->
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Data" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox   Grid.Column="1" Text="{Binding DataPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />
                        <Button    Grid.Column="2" Content="Browse…" Command="{Binding BrowseDataCommand}" Padding="12,4" Margin="8,0,0,0" />
                        <Button    Grid.Column="3" Content="Run" Command="{Binding RunWalkForwardCommand}"
                                   IsEnabled="{Binding IsWalkForwardRunning, Converter={StaticResource InverseBooleanConverter}}"
                                   Padding="20,4" Margin="8,0,0,0" />
                    </Grid>

                    <!-- Top params row -->
                    <Grid Grid.Row="1" Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"  Text="Strategy"      VerticalAlignment="Center" Margin="0,0,4,0" />
                        <ComboBox  Grid.Column="1"  ItemsSource="{Binding StrategyChoices}" SelectedItem="{Binding SelectedStrategy, Mode=TwoWay}" />
                        <TextBlock Grid.Column="3"  Text="Symbol"        VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="4"  Text="{Binding Symbol, Mode=TwoWay}" />
                        <TextBlock Grid.Column="6"  Text="Windows"       VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="7"  Text="{Binding Windows, Mode=TwoWay}" />
                        <TextBlock Grid.Column="9"  Text="TrainFraction" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="10" Text="{Binding TrainFraction, Mode=TwoWay}" />
                        <TextBlock Grid.Column="12" Text="Quantity"      VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="13" Text="{Binding Quantity, Mode=TwoWay}" />
                    </Grid>

                    <!-- Grid params -->
                    <Expander Grid.Row="2" Header="Parameter grid (comma-separated lists)" Margin="0,0,0,8">
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Lookbacks"  VerticalAlignment="Center" />
                            <TextBox   Grid.Row="0" Grid.Column="1" Text="{Binding Lookbacks, Mode=TwoWay}" Margin="0,2" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Entries"    VerticalAlignment="Center" />
                            <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Entries, Mode=TwoWay}" Margin="0,2" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Stops"      VerticalAlignment="Center" />
                            <TextBox   Grid.Row="2" Grid.Column="1" Text="{Binding Stops, Mode=TwoWay}" Margin="0,2" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Trails"     VerticalAlignment="Center" />
                            <TextBox   Grid.Row="3" Grid.Column="1" Text="{Binding Trails, Mode=TwoWay}" Margin="0,2" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Thresholds" VerticalAlignment="Center" />
                            <TextBox   Grid.Row="4" Grid.Column="1" Text="{Binding Thresholds, Mode=TwoWay}" Margin="0,2" />
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Holds"      VerticalAlignment="Center" />
                            <TextBox   Grid.Row="5" Grid.Column="1" Text="{Binding Holds, Mode=TwoWay}" Margin="0,2" />
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="EntryZ"     VerticalAlignment="Center" />
                            <TextBox   Grid.Row="6" Grid.Column="1" Text="{Binding EntryZ, Mode=TwoWay}" Margin="0,2" />
                        </Grid>
                    </Expander>

                    <!-- Results table -->
                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding WalkForwardRows}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserResizeRows="False"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="W"               Binding="{Binding Window}" Width="40" />
                            <DataGridTextColumn Header="Train from"      Binding="{Binding TrainFromUtc, StringFormat='yyyy-MM-dd HH:mm'}" Width="130" />
                            <DataGridTextColumn Header="Train to"        Binding="{Binding TrainToUtc,   StringFormat='yyyy-MM-dd HH:mm'}" Width="130" />
                            <DataGridTextColumn Header="Best params"     Binding="{Binding BestParams}" Width="180" />
                            <DataGridTextColumn Header="Train Sharpe"    Binding="{Binding TrainSharpe, StringFormat=F2}" Width="100" />
                            <DataGridTextColumn Header="OOS trades"      Binding="{Binding OosTrades}" Width="80" />
                            <DataGridTextColumn Header="OOS return"      Binding="{Binding OosReturn, StringFormat=P2}" Width="100" />
                            <DataGridTextColumn Header="OOS Sharpe"      Binding="{Binding OosSharpe, StringFormat=F2}" Width="100" />
                            <DataGridTextColumn Header="OOS max DD"      Binding="{Binding OosMaxDrawdown, StringFormat=P2}" Width="100" />
                            <DataGridTextColumn Header="OOS ending $"    Binding="{Binding OosEndingCash, StringFormat=F2}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Status -->
                    <Grid Grid.Row="4" Margin="0,8,0,0">
                        <TextBlock Text="{Binding WalkForwardStatus}" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding WalkForwardError}"
                                   Foreground="#E06C75"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding WalkForwardError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Monte Carlo -->
            <TabItem Header="Monte Carlo">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Trades CSV" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox   Grid.Column="1" Text="{Binding TradesCsvPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas" />
                        <Button    Grid.Column="2" Content="Browse…" Command="{Binding BrowseTradesCsvCommand}" Padding="12,4" Margin="8,0,0,0" />
                        <Button    Grid.Column="3" Content="Run" Command="{Binding RunMonteCarloCommand}"
                                   IsEnabled="{Binding IsMonteCarloRunning, Converter={StaticResource InverseBooleanConverter}}"
                                   Padding="20,4" Margin="8,0,0,0" />
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Simulations" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="1" Text="{Binding Simulations, Mode=TwoWay}" />
                        <TextBlock Grid.Column="3" Text="Starting cash" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="4" Text="{Binding StartingCash, Mode=TwoWay}" />
                        <TextBlock Grid.Column="6" Text="Seed" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox   Grid.Column="7" Text="{Binding Seed, Mode=TwoWay}" />
                    </Grid>

                    <TextBox Grid.Row="2"
                             Text="{Binding MonteCarloSummary, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource Background.Surface}" />

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <TextBlock Text="{Binding MonteCarloStatus}" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBlock Text="{Binding MonteCarloError}"
                                   Foreground="#E06C75"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding MonteCarloError, Converter={StaticResource StringToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
