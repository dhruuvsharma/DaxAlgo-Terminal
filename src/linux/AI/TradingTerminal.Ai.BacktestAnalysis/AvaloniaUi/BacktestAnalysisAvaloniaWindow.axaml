<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.Ai.BacktestAnalysis.AvaloniaUi.BacktestAnalysisAvaloniaWindow"
        Width="820" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="Backtest analysis">
  <DockPanel Margin="14">
    <TextBlock DockPanel.Dock="Top" Text="Backtest analysis — walk-forward &amp; Monte-Carlo" FontSize="18"
               FontWeight="Bold" Foreground="{DynamicResource Text.Header}" Margin="0,0,0,8"/>

    <Grid ColumnDefinitions="*,*">
      <!-- Walk-forward -->
      <DockPanel Grid.Column="0" Margin="0,0,8,0">
        <StackPanel DockPanel.Dock="Top" Spacing="6">
          <TextBlock Text="Walk-forward" FontWeight="SemiBold" Foreground="{DynamicResource Text.Header}"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox Width="200" Watermark="Parquet…" Text="{Binding DataPath}"/>
            <Button Content="Browse…" Command="{Binding BrowseDataCommand}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <ComboBox ItemsSource="{Binding StrategyChoices}" SelectedItem="{Binding SelectedStrategy}"/>
            <TextBlock Text="Windows" VerticalAlignment="Center"/>
            <NumericUpDown Width="90" Value="{Binding Windows}" Minimum="2"/>
            <Button Content="Run" Command="{Binding RunWalkForwardCommand}"/>
          </StackPanel>
          <TextBlock Text="{Binding WalkForwardStatus}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding WalkForwardError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
        </StackPanel>
        <Border Margin="0,8,0,0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
          <ListBox ItemsSource="{Binding WalkForwardRows}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
        </Border>
      </DockPanel>

      <!-- Monte Carlo -->
      <DockPanel Grid.Column="1" Margin="8,0,0,0">
        <StackPanel DockPanel.Dock="Top" Spacing="6">
          <TextBlock Text="Trade-bootstrap Monte Carlo" FontWeight="SemiBold" Foreground="{DynamicResource Text.Header}"/>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBox Width="200" Watermark="trades.csv…" Text="{Binding TradesCsvPath}"/>
            <Button Content="Browse…" Command="{Binding BrowseTradesCsvCommand}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="Sims" VerticalAlignment="Center"/>
            <NumericUpDown Width="120" Value="{Binding Simulations}" Minimum="100" Increment="1000"/>
            <Button Content="Run" Command="{Binding RunMonteCarloCommand}"/>
          </StackPanel>
          <TextBlock Text="{Binding MonteCarloStatus}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
          <TextBlock Text="{Binding MonteCarloError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
        </StackPanel>
        <Border Margin="0,8,0,0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3" Padding="8">
          <TextBlock Text="{Binding MonteCarloSummary}" FontFamily="{DynamicResource Font.Mono}" FontSize="11" TextWrapping="NoWrap"/>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
