<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Monochrome (B&W dark) palette. A true ink-on-black terminal: grayscale chrome, a cool
         white/silver accent, and FULLY monochrome P&L — direction is shown by brightness, not hue
         (up = bright white, down = dim grey). Defines exactly the same key set as Brushes.xaml so
         ThemeManager can hot-swap one for the other. -->

    <!-- Backgrounds -->
    <Color x:Key="Background.Primary.Color">#000000</Color>
    <Color x:Key="Background.Surface.Color">#0B0B0B</Color>
    <Color x:Key="Background.Elevated.Color">#161616</Color>
    <Color x:Key="Border.Color">#2A2A2A</Color>

    <!-- Text -->
    <Color x:Key="Text.Primary.Color">#ECECEC</Color>
    <Color x:Key="Text.Secondary.Color">#8A8A8A</Color>
    <Color x:Key="Text.Header.Color">#FFFFFF</Color>
    <Color x:Key="Text.Highlight.Color">#FFFFFF</Color>

    <!-- Semantic — silver accent; P&L is brightness-coded (white up / grey down) -->
    <Color x:Key="Accent.Color">#E8E8E8</Color>
    <Color x:Key="Accent.Dim.Color">#9A9A9A</Color>
    <Color x:Key="Bullish.Color">#FFFFFF</Color>
    <Color x:Key="Bearish.Color">#6E6E6E</Color>
    <!-- Danger stays a mid-dark grey so white-on-danger error banners remain legible. -->
    <Color x:Key="Danger.Color">#444444</Color>
    <Color x:Key="Warning.Color">#B8B8B8</Color>

    <!-- SolidColorBrush wrappers -->
    <SolidColorBrush x:Key="Background.Primary"  Color="{StaticResource Background.Primary.Color}" />
    <SolidColorBrush x:Key="Background.Surface"  Color="{StaticResource Background.Surface.Color}" />
    <SolidColorBrush x:Key="Background.Elevated" Color="{StaticResource Background.Elevated.Color}" />
    <SolidColorBrush x:Key="Border.Brush"        Color="{StaticResource Border.Color}" />
    <SolidColorBrush x:Key="Text.Primary"        Color="{StaticResource Text.Primary.Color}" />
    <SolidColorBrush x:Key="Text.Secondary"      Color="{StaticResource Text.Secondary.Color}" />
    <SolidColorBrush x:Key="Text.Header"         Color="{StaticResource Text.Header.Color}" />
    <SolidColorBrush x:Key="Text.Highlight"      Color="{StaticResource Text.Highlight.Color}" />
    <SolidColorBrush x:Key="Accent.Brush"        Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="Accent.Dim.Brush"    Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="Bullish.Brush"       Color="{StaticResource Bullish.Color}" />
    <SolidColorBrush x:Key="Bearish.Brush"       Color="{StaticResource Bearish.Color}" />
    <SolidColorBrush x:Key="Danger.Brush"        Color="{StaticResource Danger.Color}" />
    <SolidColorBrush x:Key="Warning.Brush"       Color="{StaticResource Warning.Color}" />

    <!-- Extra flat colours -->
    <Color x:Key="Surface.Hover.Color">#1E1E1E</Color>
    <Color x:Key="Border.Strong.Color">#3C3C3C</Color>
    <Color x:Key="Accent.Hover.Color">#FFFFFF</Color>

    <SolidColorBrush x:Key="Surface.Hover" Color="{StaticResource Surface.Hover.Color}" />
    <SolidColorBrush x:Key="Border.Strong" Color="{StaticResource Border.Strong.Color}" />
    <SolidColorBrush x:Key="Accent.Hover.Brush" Color="{StaticResource Accent.Hover.Color}" />

    <!-- Soft (alpha) semantic fills — for pills / chips / cell washes -->
    <SolidColorBrush x:Key="Accent.Soft"    Color="#26E8E8E8" />
    <SolidColorBrush x:Key="Bullish.Soft"   Color="#26FFFFFF" />
    <SolidColorBrush x:Key="Bearish.Soft"   Color="#266E6E6E" />
    <SolidColorBrush x:Key="Warning.Soft"   Color="#26B8B8B8" />
    <SolidColorBrush x:Key="Highlight.Soft" Color="#26FFFFFF" />

    <!-- Vertical surface gradients (chrome bars, panels, cards) -->
    <LinearGradientBrush x:Key="Gradient.Chrome" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#181818" Offset="0" />
        <GradientStop Color="#0C0C0C" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Elevated" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E1E1E" Offset="0" />
        <GradientStop Color="#121212" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Surface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#121212" Offset="0" />
        <GradientStop Color="#080808" Offset="1" />
    </LinearGradientBrush>

    <!-- Neutral header gradient (left→right) for card/section headers -->
    <LinearGradientBrush x:Key="Gradient.Header" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#222222" Offset="0" />
        <GradientStop Color="#101010" Offset="1" />
    </LinearGradientBrush>

    <!-- Silver gradients for primary buttons / active states -->
    <LinearGradientBrush x:Key="Gradient.Accent" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F2F2F2" Offset="0" />
        <GradientStop Color="#D2D2D2" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.AccentHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#E2E2E2" Offset="1" />
    </LinearGradientBrush>

    <!-- Typographic constants -->
    <FontFamily x:Key="Font.Mono">Consolas, Cascadia Mono, Lucida Console</FontFamily>

    <!-- ===================================================================================
         MahApps accent override (silver). The accent is near-white, so we also pin the MahApps
         "ideal foreground" to black — otherwise MahApps-native selections (combo dropdowns, etc.)
         would render white text on a light-grey accent and become unreadable.
         =================================================================================== -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"  Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent2" Color="#D6D6D6" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent3" Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent4" Color="#80E8E8E8" />
    <SolidColorBrush x:Key="MahApps.Brushes.Highlight" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource Accent.Color}" />
    <Color x:Key="MahApps.Colors.Accent">#E8E8E8</Color>
    <Color x:Key="MahApps.Colors.Highlight">#FFFFFF</Color>
    <Color x:Key="MahApps.Colors.IdealForeground">#000000</Color>
    <SolidColorBrush x:Key="MahApps.Brushes.IdealForeground" Color="#000000" />

</ResourceDictionary>
