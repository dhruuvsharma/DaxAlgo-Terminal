<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================================
         Reusable "premium terminal" window chrome. Generic App.* / Pill.* keys so EVERY tool
         and strategy window gets the same polished header bars, cards, footers and status pills.
         Pure styles — drop them on a Border/TextBlock/Button; no code-behind required.
         =================================================================================== -->

    <!-- ===== Bars & surfaces ===== -->

    <!-- Top toolbar / header bar: gradient chrome with an accent-dim hairline under it. -->
    <Style x:Key="App.HeaderBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.Chrome}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="12,7" />
    </Style>

    <!-- Footer bar (top hairline). -->
    <Style x:Key="App.FooterBar" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.Chrome}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <!-- Elevated panel header (vertical gradient + bottom rule). -->
    <Style x:Key="App.PanelHeader" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.Elevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="14,9" />
    </Style>

    <!-- Rounded, shadowed content card. -->
    <Style x:Key="App.Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" BlurRadius="34" ShadowDepth="0" Opacity="0.55" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Amber-tinted card header (rounded top corners). -->
    <Style x:Key="App.CardHeader" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.Header}" />
        <Setter Property="CornerRadius" Value="10,10,0,0" />
        <Setter Property="Padding" Value="22,16" />
    </Style>

    <!-- Thin amber rule, e.g. directly under a card header. -->
    <Style x:Key="App.AccentRule" TargetType="Border">
        <Setter Property="Height" Value="2" />
        <Setter Property="Background" Value="{DynamicResource Accent.Brush}" />
        <Setter Property="Opacity" Value="0.55" />
    </Style>

    <!-- ===== Typography ===== -->

    <Style x:Key="App.Brand" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Text.Header}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Small caps group caption ("STREAM", "VIEW", "HORIZON"). -->
    <Style x:Key="App.GroupLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,10,0" />
    </Style>

    <!-- Section header: amber caps preceded by an accent tick. Put inside a horizontal panel
         with an "App.SectionBar" border for the left rule. -->
    <Style x:Key="App.SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="App.SectionBar" TargetType="Border">
        <Setter Property="Width" Value="3" />
        <Setter Property="Background" Value="{DynamicResource Accent.Brush}" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!-- Vertical divider between toolbar groups. -->
    <Style x:Key="App.ParamDivider" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Border.Brush}" />
        <Setter Property="Margin" Value="4,2,12,2" />
    </Style>

    <!-- ===== Toolbar buttons (flat, rounded, accent on hover) ===== -->
    <Style x:Key="App.ToolButton" TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="Background" Value="#1C1C1C" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" CornerRadius="4" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{DynamicResource Accent.Soft}" />
                            <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="App.IconButton" TargetType="Button" BasedOn="{StaticResource App.ToolButton}">
        <Setter Property="Width" Value="28" />
        <Setter Property="Padding" Value="0,2" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <!-- ===== Status pills / chips ===== -->
    <Style x:Key="Pill.Base" TargetType="Border">
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Padding" Value="9,2" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Background" Value="{DynamicResource Background.Elevated}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="Pill.Bull" TargetType="Border" BasedOn="{StaticResource Pill.Base}">
        <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" />
    </Style>
    <Style x:Key="Pill.Bear" TargetType="Border" BasedOn="{StaticResource Pill.Base}">
        <Setter Property="Background" Value="{DynamicResource Bearish.Soft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Bearish.Brush}" />
    </Style>
    <Style x:Key="Pill.Accent" TargetType="Border" BasedOn="{StaticResource Pill.Base}">
        <Setter Property="Background" Value="{DynamicResource Accent.Soft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
    </Style>
    <Style x:Key="Pill.Warn" TargetType="Border" BasedOn="{StaticResource Pill.Base}">
        <Setter Property="Background" Value="{DynamicResource Warning.Soft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Warning.Brush}" />
    </Style>

    <!-- Live/armed pill: amber wash that gently pulses forever once loaded. -->
    <Style x:Key="Pill.Live" TargetType="Border" BasedOn="{StaticResource Pill.Accent}">
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.5" Duration="0:0:1.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
