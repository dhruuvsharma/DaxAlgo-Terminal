<UserControl x:Class="TradingTerminal.BacktestStudio.BacktestStudioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="1200"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: setup -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Setup" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,6" />

                <TextBlock Text="Strategy" />
                <ComboBox ItemsSource="{Binding Strategies}"
                          SelectedItem="{Binding SelectedStrategy}"
                          DisplayMemberPath="Name"
                          IsEnabled="{Binding IsNotRunning}"
                          Margin="0,2,0,8" />
                <TextBlock Text="{Binding SelectedStrategy.Description}"
                           Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"
                           FontSize="11" Margin="0,0,0,8" />

                <TextBlock Text="Parameters" FontWeight="SemiBold" Margin="0,4,0,2" />
                <ItemsControl ItemsSource="{Binding Parameters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding DataContext.IsNotRunning, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Starting cash" Margin="0,8,0,0" />
                <TextBox Text="{Binding StartingCash}" IsEnabled="{Binding IsNotRunning}" Margin="0,2,0,8" />

                <TextBlock Text="Synthetic ticks" />
                <TextBox Text="{Binding SyntheticTicks}" IsEnabled="{Binding IsNotRunning}" Margin="0,2,0,8" />

                <TextBlock Text="Seed" />
                <TextBox Text="{Binding Seed}" IsEnabled="{Binding IsNotRunning}" Margin="0,2,0,8" />

                <CheckBox Content="Record visual replay" IsChecked="{Binding RecordVisual}"
                          IsEnabled="{Binding IsNotRunning}" Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Run" Command="{Binding RunCommand}"
                            IsEnabled="{Binding IsNotRunning}" Padding="14,4" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}" Padding="12,4" Margin="6,0,0,0" />
                </StackPanel>

                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}"
                           TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Right: results -->
        <TabControl Grid.Column="1" Margin="0">
            <!-- Report -->
            <TabItem Header="Report">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,6"
                            Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" Padding="8">
                        <UniformGrid Columns="6" Rows="1">
                            <StackPanel>
                                <TextBlock Text="Net P&amp;L" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding NetProfit, StringFormat=C2}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Sharpe" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding Sharpe, StringFormat=F2}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Max DD" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding MaxDrawdown, StringFormat=P2}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Win rate" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding WinRate, StringFormat=P1}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Profit factor" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding ProfitFactor, StringFormat=F2}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Trades" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                                <TextBlock Text="{Binding TradeCount}" />
                            </StackPanel>
                        </UniformGrid>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                        <sp:WpfPlot x:Name="EquityPlot" />
                    </Border>

                    <DataGrid Grid.Row="2" Margin="0,6,0,0"
                              ItemsSource="{Binding Trades}" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Entry (UTC)" Binding="{Binding EntryUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                            <DataGridTextColumn Header="Exit (UTC)" Binding="{Binding ExitUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                            <DataGridTextColumn Header="Side" Binding="{Binding Side}" />
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" />
                            <DataGridTextColumn Header="Entry" Binding="{Binding EntryPrice, StringFormat=F4}" />
                            <DataGridTextColumn Header="Exit" Binding="{Binding ExitPrice, StringFormat=F4}" />
                            <DataGridTextColumn Header="Net P&amp;L" Binding="{Binding NetPnl, StringFormat=F2}" />
                            <DataGridTextColumn Header="MFE" Binding="{Binding MaxFavorableExcursion, StringFormat=F2}" />
                            <DataGridTextColumn Header="MAE" Binding="{Binding MaxAdverseExcursion, StringFormat=F2}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Visual replay -->
            <TabItem Header="Visual replay">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                        <sp:WpfPlot x:Name="ReplayPlot" />
                    </Border>

                    <Border Grid.Row="1" Margin="0,6,0,0"
                            Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Content="⏮" Command="{Binding RewindCommand}"
                                    IsEnabled="{Binding HasVisual}" MinWidth="34" />
                            <Button Grid.Column="1" Content="⏯" Command="{Binding PlayPauseCommand}"
                                    IsEnabled="{Binding HasVisual}" MinWidth="34" Margin="6,0,0,0" />

                            <Slider Grid.Column="2" Margin="10,0"
                                    Minimum="0" Maximum="{Binding BarCount}"
                                    Value="{Binding CurrentBar}" IsEnabled="{Binding HasVisual}"
                                    VerticalAlignment="Center" />

                            <TextBlock Grid.Column="3" Text="{Binding CurrentBarText}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Text.Secondary}" Margin="0,0,10,0" />

                            <TextBlock Grid.Column="4" Text="Speed" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <Slider Grid.Column="5" Minimum="1" Maximum="40" Value="{Binding PlaybackSpeed}"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
