<ui:StrategyWindowBase x:Class="TradingTerminal.Strategies.Twap.TwapStrategyWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                       xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                       xmlns:ui="clr-namespace:TradingTerminal.UI;assembly=TradingTerminal.UI"
                       xmlns:sys="clr-namespace:System;assembly=mscorlib"
                       xmlns:trading="clr-namespace:TradingTerminal.Core.Trading;assembly=TradingTerminal.Core"
                       mc:Ignorable="d" Title="{Binding StrategyDisplayName}" Height="680" Width="1100" WindowStartupLocation="CenterOwner"
                       Background="{DynamicResource Background.Primary}" Foreground="{DynamicResource Text.Primary}">
    <mah:MetroWindow.Resources>
        <CollectionViewSource x:Key="GroupedInstruments" Source="{Binding Instruments}"><CollectionViewSource.GroupDescriptions><PropertyGroupDescription PropertyName="Category" /></CollectionViewSource.GroupDescriptions></CollectionViewSource>
        <x:Array x:Key="OrderSides" Type="{x:Type trading:OrderSide}">
            <trading:OrderSide>Buy</trading:OrderSide>
            <trading:OrderSide>Sell</trading:OrderSide>
        </x:Array>
    </mah:MetroWindow.Resources>
    <mah:MetroWindow.LeftWindowCommands><mah:WindowCommands><Button Command="{Binding ToggleAlgoCommand}" Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource Strategy.RunStopButton}" /></mah:WindowCommands></mah:MetroWindow.LeftWindowCommands>
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Strategy.SetupCard}"><StackPanel>
                <TextBlock Style="{StaticResource Strategy.SetupTitle}" Text="Configure TWAP execution" />
                <TextBlock Style="{StaticResource Strategy.SetupDescription}" Text="Split parent quantity into N equal market child orders over the strategy horizon. Execution baseline; no alpha." />
                <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Instrument" />
                <ComboBox ItemsSource="{Binding Source={StaticResource GroupedInstruments}}" SelectedItem="{Binding SelectedInstrument}" DisplayMemberPath="DisplayName" MaxDropDownHeight="420" Margin="0,0,0,12">
                    <ComboBox.GroupStyle><GroupStyle><GroupStyle.HeaderTemplate><DataTemplate><Border Background="{DynamicResource Background.Elevated}" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="8,4,8,4"><TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" Foreground="{DynamicResource Accent.Brush}" /></Border></DataTemplate></GroupStyle.HeaderTemplate></GroupStyle></ComboBox.GroupStyle>
                </ComboBox>
                <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Side" />
                <ComboBox ItemsSource="{StaticResource OrderSides}" SelectedItem="{Binding Side}" Margin="0,0,0,12" />
                <Grid Margin="0,0,0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Parent quantity" Margin="0,0,4,4" /><TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Slices" Margin="4,0,0,4" />
                    <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding ParentQuantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" /><TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Slices, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                </Grid>
                <Border Style="{StaticResource Strategy.SetupErrorBanner}" Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"><TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" /></Border>
                <Button Content="Continue" Command="{Binding ContinueCommand}" HorizontalAlignment="Right" IsDefault="True" MinWidth="120" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
            </StackPanel></Border>
        </ScrollViewer>
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource Strategy.HeaderBar}"><StackPanel Orientation="Horizontal">
                <TextBlock Text="Symbol:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                <TextBlock Text="Side:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding Side}" Margin="6,0,16,0" />
                <TextBlock Text="Qty/Slices:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding ParentQuantity}" Margin="6,0,4,0" /><TextBlock Text="/" /><TextBlock Text="{Binding Slices}" Margin="4,0,16,0" />
                <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
            </StackPanel></Border>
            <scottplot:WpfPlot x:Name="PricePlot" Grid.Row="1" />
            <Border Grid.Row="2" Style="{StaticResource Strategy.FooterBar}"><StackPanel Orientation="Horizontal">
                <TextBlock Text="Bid:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding LastBid, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Text="  |  Ask:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" /><TextBlock Text="{Binding LastAsk, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Text="  |  Bars:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" /><TextBlock Text="{Binding Bars.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Text="  |  Signals:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" /><TextBlock Text="{Binding Signals.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}" Text="● ALGO ARMED" />
            </StackPanel></Border>
        </Grid>
    </Grid>
</ui:StrategyWindowBase>
