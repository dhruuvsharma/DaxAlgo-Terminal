<mah:MetroWindow x:Class="TradingTerminal.Strategies.Rsi.RsiStrategyWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.Rsi"
                 xmlns:cm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
                 mc:Ignorable="d"
                 Title="RSI Strategy"
                 Height="640" Width="980"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <CollectionViewSource x:Key="GroupedInstruments" Source="{Binding Instruments}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="Category" />
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <!-- Run / Stop button. Only visible after the user finishes setup. -->
            <Button x:Name="RunStopButton"
                    Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm the RSI algo. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- Setup form -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="420"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Configure RSI strategy"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Pick the instrument and tune the thresholds. Defaults follow Wilder (period 14, OB 70, OS 30)."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Text.Secondary}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <TextBox Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                              mah:TextBoxHelper.Watermark="Search symbols..."
                              mah:TextBoxHelper.ClearTextButton="True"
                              Margin="0,0,0,6" />
                    <ComboBox ItemsSource="{Binding Source={StaticResource GroupedInstruments}}"
                              SelectedItem="{Binding SelectedInstrument}"
                              DisplayMemberPath="DisplayName"
                              MaxDropDownHeight="420"
                              Margin="0,0,0,16">
                        <ComboBox.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource Background.Elevated}"
                                                BorderBrush="{DynamicResource Border.Brush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="8,4,8,4"
                                                Margin="0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource Accent.Brush}" />
                                        </Border>
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ComboBox.GroupStyle>
                    </ComboBox>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Overbought" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Oversold"   Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Overbought, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding Oversold, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="4,0,0,0" />
                    </Grid>

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Chart view -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="Period:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="14" Margin="6,0,16,0" />
                    <TextBlock Text="OB:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding Overbought, StringFormat=F0}" Margin="6,0,16,0" />
                    <TextBlock Text="OS:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding Oversold, StringFormat=F0}" Margin="6,0,16,0" />
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Text.Secondary}"
                               Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <scottplot:WpfPlot x:Name="Plot" Grid.Row="1" />

            <Border Grid.Row="2"
                    Background="{DynamicResource Background.Elevated}"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Last:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding LastPrice, StringFormat=F2, FallbackValue=—}" Margin="6,0,0,0" />
                    <TextBlock Text="  |  RSI:" Foreground="{DynamicResource Text.Secondary}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding LastRsi, StringFormat=F2, FallbackValue=—}" Margin="6,0,0,0" />
                    <TextBlock Text="  |  Bars:" Foreground="{DynamicResource Text.Secondary}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding Bars.Count}" Margin="6,0,0,0" />
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Warning.Brush}"
                               FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
