<UserControl x:Class="TradingTerminal.LseBacktest.LseBacktestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: configuration panel -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="LSE backtester" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,2" />
                <TextBlock Text="Pulls historical OHLCV straight from London Strategic Edge — no local data file needed."
                           Foreground="{DynamicResource Text.Secondary}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,8" />

                <TextBlock Text="Strategy" />
                <!-- StrategyTagsConverter is registered in app-level resources by the view ctor
                     (StrategyDataRequirementConverter.EnsureConverterRegistered), same as BacktestView. -->
                <ComboBox ItemsSource="{Binding Strategies}"
                          SelectedItem="{Binding SelectedStrategy}"
                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                          Margin="0,2,0,8">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel LastChildFill="True">
                                <ItemsControl DockPanel.Dock="Right" VerticalAlignment="Center"
                                              ItemsSource="{Binding DataRequirement, Converter={StaticResource StrategyTagsConverter}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Background}" CornerRadius="3"
                                                    Padding="5,1" Margin="3,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                                           FontSize="10" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                           Margin="0,0,8,0" TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Symbol (LSE)" />
                <TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                         ToolTip="An LSE catalog symbol — e.g. AAPL, EUR/USD, BTC/USD."
                         Margin="0,2,0,8" />

                <TextBlock Text="Timeframe" />
                <ComboBox ItemsSource="{Binding BarSizes}"
                          SelectedItem="{Binding SelectedBarSize}"
                          IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                          Margin="0,2,0,8" />

                <TextBlock Text="Lookback (bars, max 5000)" />
                <TextBox Text="{Binding LookbackBars}"
                         IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                         Margin="0,2,0,8" />

                <TextBlock Text="Tick size" />
                <TextBox Text="{Binding TickSize}" Margin="0,2,0,8" />

                <TextBlock Text="Slippage (ticks)" />
                <TextBox Text="{Binding SlippageTicks}" Margin="0,2,0,8" />

                <TextBlock Text="Contract multiplier" />
                <TextBox Text="{Binding ContractMultiplier}" Margin="0,2,0,8" />

                <TextBlock Text="Starting cash" />
                <TextBox Text="{Binding StartingCash}" Margin="0,2,0,12" />

                <StackPanel Orientation="Horizontal">
                    <Button Content="Run"
                            Command="{Binding RunCommand}"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                            Padding="12,4" />
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsEnabled="{Binding IsRunning}"
                            Padding="12,4" Margin="6,0,0,0" />
                </StackPanel>

                <TextBlock Text="{Binding Status}"
                           Foreground="{DynamicResource Text.Secondary}"
                           TextWrapping="Wrap"
                           Margin="0,8,0,0" />

                <TextBlock Text="Bar data only — synthetic one-tick spread, no real prints or depth. Best for L1/bar strategies."
                           Foreground="{DynamicResource Text.Secondary}" FontSize="10"
                           TextWrapping="Wrap" Margin="0,10,0,0" />
            </StackPanel>
        </ScrollViewer>

        <!-- Right: equity chart + stats + trades -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="240" />
            </Grid.RowDefinitions>

            <!-- Equity curve -->
            <Border Grid.Row="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <sp:WpfPlot x:Name="EquityPlot" />
            </Border>

            <!-- Stats strip -->
            <Border Grid.Row="1" Margin="0,6,0,6"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                    Padding="8">
                <UniformGrid Columns="6" Rows="1">
                    <StackPanel>
                        <TextBlock Text="P&amp;L" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="{Binding TotalPnl, StringFormat=C2}" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Sharpe" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="{Binding Stats.Sharpe, StringFormat=F2, FallbackValue=—}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Sortino" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="{Binding Stats.Sortino, StringFormat=F2, FallbackValue=—}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Max DD" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="{Binding Stats.MaxDrawdown, StringFormat=P2, FallbackValue=—}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Win rate" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="{Binding Stats.WinRate, StringFormat=P1, FallbackValue=—}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Profit factor" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                        <TextBlock Text="{Binding Stats.ProfitFactor, StringFormat=F2, FallbackValue=—}" />
                    </StackPanel>
                </UniformGrid>
            </Border>

            <!-- Trades grid -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding Trades}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Entry (UTC)"   Binding="{Binding EntryUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                    <DataGridTextColumn Header="Exit (UTC)"    Binding="{Binding ExitUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                    <DataGridTextColumn Header="Side"          Binding="{Binding Side}" />
                    <DataGridTextColumn Header="Qty"           Binding="{Binding Quantity}" />
                    <DataGridTextColumn Header="Entry price"   Binding="{Binding EntryPrice, StringFormat=F4}" />
                    <DataGridTextColumn Header="Exit price"    Binding="{Binding ExitPrice, StringFormat=F4}" />
                    <DataGridTextColumn Header="Gross P&amp;L" Binding="{Binding GrossPnl, StringFormat=F4}" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
