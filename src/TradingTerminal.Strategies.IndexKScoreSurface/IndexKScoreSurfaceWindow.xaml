<mah:MetroWindow x:Class="TradingTerminal.Strategies.IndexKScoreSurface.IndexKScoreSurfaceWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:helix="http://helix-toolkit.org/wpf"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.IndexKScoreSurface"
                 mc:Ignorable="d"
                 Title="Index K-Score Surface"
                 Height="820" Width="1400"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- Setup form -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="640"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Configure Index K-Score Surface"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="Multi-stock K-score aggregator. Each component scores 15 directional indicators into a composite K ∈ [-1.5, +1.5]; the threshold surface scales inversely with index weight."
                               TextWrapping="Wrap" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,16" />

                    <TextBlock Text="Index Family" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding Families}"
                              SelectedItem="{Binding SelectedFamily}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,0,12" />

                    <TextBlock Text="Bar Timeframe" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding BarSizes}"
                              SelectedItem="{Binding SelectedBarSize}"
                              Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="T_min" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="T_max" Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Min pierce" Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="ΣK threshold" Margin="4,0,0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding TMin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding TMax, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding MinPierceCount, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding CumKThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                    </Grid>

                    <TextBlock Text="Indicator Windows" FontWeight="SemiBold" Margin="0,8,0,6" Foreground="{DynamicResource Text.Secondary}" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="RSI len"   Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="MACD fast" Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="MACD slow" Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="MACD sig"  Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="ATR len"   Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="ATR reg"   Margin="4,0,0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding RsiLength, UpdateSourceTrigger=PropertyChanged}"  Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding MacdFast, UpdateSourceTrigger=PropertyChanged}"   Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding MacdSlow, UpdateSourceTrigger=PropertyChanged}"   Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding MacdSignal, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="4" Text="{Binding AtrLength, UpdateSourceTrigger=PropertyChanged}"  Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="5" Text="{Binding AtrRegLength, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0"/>
                    </Grid>

                    <Border Background="{DynamicResource Danger.Brush}" Padding="10,6" Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right" IsDefault="True" MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Surface view -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Index:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding SelectedFamily.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Bar:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding SelectedBarSize}" Margin="6,0,16,0"/>
                    <TextBlock Text="T:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Margin="6,0,2,0"><Run Text="[" /><Run Text="{Binding TMin, StringFormat=F2}" /><Run Text=",  " /><Run Text="{Binding TMax, StringFormat=F2}" /><Run Text="]" /></TextBlock>
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="440" />
                </Grid.ColumnDefinitions>

                <helix:HelixViewport3D x:Name="View3D"
                                       Grid.Column="0"
                                       ZoomExtentsWhenLoaded="True"
                                       ShowFrameRate="False"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="True"
                                       Background="#1E1E1E"
                                       CameraRotationMode="Trackball"
                                       IsHeadLightEnabled="True" />

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{DynamicResource Border.Brush}" />

                <Grid Grid.Column="2" Background="{DynamicResource Background.Surface}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="10,6">
                        <TextBlock Text="COMPONENTS" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource Accent.Brush}" />
                    </Border>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Components}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              FontFamily="Consolas, Cascadia Mono, monospace"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Sym"  Binding="{Binding Symbol}" Width="60" />
                            <DataGridTextColumn Header="Wt"   Binding="{Binding IndexWeight, StringFormat=F3}" Width="56" />
                            <DataGridTextColumn Header="K"    Binding="{Binding KFinal, StringFormat=+0.00;-0.00;0.00}" Width="70" />
                            <DataGridTextColumn Header="Thr"  Binding="{Binding Threshold, StringFormat=F2}" Width="56" />
                            <DataGridTextColumn Header="Dir"  Binding="{Binding PierceDirection}" Width="40" />
                            <DataGridTextColumn Header="Conf" Binding="{Binding Confidence, StringFormat=F2}" Width="50" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,1,0,1" Padding="10,6">
                        <TextBlock Text="LIVE LOG" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{DynamicResource Accent.Brush}" />
                    </Border>
                    <ScrollViewer Grid.Row="3" x:Name="LogScroller"
                                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding LogEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}"
                                               FontFamily="Consolas, Cascadia Mono, monospace"
                                               FontSize="11" TextWrapping="Wrap" Padding="8,1"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource Background.Elevated}" Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Components:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Margin="6,0,16,0"><Run Text="{Binding ComponentsReady}" /><Run Text="/" /><Run Text="{Binding ComponentsTotal}" /></TextBlock>
                    <TextBlock Text="Up:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding PiercingUpCount}" Margin="6,0,4,0" Foreground="{DynamicResource Bullish.Brush}"/>
                    <TextBlock Text="(ΣK=" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding CumulativeKUp, StringFormat=F2}" Margin="2,0,0,0"/>
                    <TextBlock Text=")" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,16,0"/>
                    <TextBlock Text="Down:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding PiercingDownCount}" Margin="6,0,4,0" Foreground="{DynamicResource Danger.Brush}"/>
                    <TextBlock Text="(ΣK=" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding CumulativeKDown, StringFormat=F2}" Margin="2,0,0,0"/>
                    <TextBlock Text=")" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,16,0"/>
                    <TextBlock Text="● LONG SIGNAL" Foreground="{DynamicResource Bullish.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding LongSignalActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Text="● SHORT SIGNAL" Foreground="{DynamicResource Danger.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding ShortSignalActive, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Accent.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding IsWarmingUp, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="◌ LOADING HISTORY…" />
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
