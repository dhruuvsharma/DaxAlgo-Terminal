<mah:MetroWindow x:Class="TradingTerminal.Heatmap.VolumeProfileHeatmapWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 mc:Ignorable="d"
                 Title="Volume-at-price heatmap"
                 Width="1040" Height="700"
                 MinWidth="780" MinHeight="500"
                 TitleCharacterCasing="Normal"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 d:DesignHeight="700" d:DesignWidth="1040">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Volume-at-price heatmap" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="A time-evolving volume profile: price on Y, time buckets on X, colour = traded volume in each price bucket per interval (brighter = more volume). The pale line tracks the last trade. Built from the trade tape — IB only; other brokers leave it empty."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Instrument" FontWeight="SemiBold" Margin="2,0,0,6" />
                    <TextBox Grid.Row="1"
                             Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             mah:TextBoxHelper.Watermark="filter symbols…"
                             mah:TextBoxHelper.ClearTextButton="True"
                             Margin="0,0,0,6" />
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Instruments}"
                             SelectedItem="{Binding SelectedInstrument}"
                             DisplayMemberPath="DisplayName"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <sp:WpfPlot x:Name="HeatmapPlot" Margin="4" />
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,10,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,0,16,0">
                    <Run Text="Last " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding LastPrice, StringFormat=N2, TargetNullValue=—}" />
                </TextBlock>
                <TextBlock Grid.Column="1" Margin="0,0,16,0">
                    <Run Text="Vol " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding TotalVolume, StringFormat=N0}" />
                </TextBlock>
                <TextBlock Grid.Column="2" Margin="0,0,16,0">
                    <Run Text="Cols " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding ColumnsFilled}" />
                </TextBlock>
                <TextBlock Grid.Column="3" Text="{Binding Status}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
