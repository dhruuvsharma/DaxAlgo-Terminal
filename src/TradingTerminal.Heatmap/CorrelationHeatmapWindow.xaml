<mah:MetroWindow x:Class="TradingTerminal.Heatmap.CorrelationHeatmapWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 mc:Ignorable="d"
                 Title="Rolling correlation heatmap"
                 Width="1040" Height="700"
                 MinWidth="820" MinHeight="520"
                 TitleCharacterCasing="Normal"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 d:DesignHeight="700" d:DesignWidth="1040">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Rolling correlation heatmap" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="NxN grid of the selected instruments coloured by live pairwise Pearson correlation of mid log-returns, recomputed every sample over the rolling window. Red = move together, blue = move apart, white = uncorrelated."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Control bar -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Sample" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="1" ItemsSource="{Binding Steps}" SelectedItem="{Binding SelectedStep}"
                           DisplayMemberPath="Label" Margin="0,0,14,0" />
                <TextBlock Grid.Column="2" Text="Window" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="3" ItemsSource="{Binding Windows}" SelectedItem="{Binding SelectedWindow}"
                           DisplayMemberPath="Label" Margin="0,0,14,0" />
                <Button Grid.Column="4" Content="Start" Command="{Binding StartCommand}"
                        IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,8,0" />
                <Button Grid.Column="5" Content="Stop" Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsStreaming}" Padding="16,4" Margin="0,0,10,0" />
                <mah:ProgressRing Grid.Column="6" IsActive="{Binding IsStreaming}" Width="18" Height="18" Margin="0,0,10,0" />
                <TextBlock Grid.Column="7" Text="{Binding StatusMessage}" Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Instrument checklist -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Instruments" FontWeight="SemiBold" Margin="2,0,0,6" />
                    <ComboBox Grid.Row="1" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                              mah:TextBoxHelper.Watermark="category…" Margin="0,0,0,6" />
                    <TextBox Grid.Row="2"
                             Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             mah:TextBoxHelper.Watermark="filter symbols…"
                             mah:TextBoxHelper.ClearTextButton="True" Margin="0,0,0,6" />
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InstrumentsView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}" />
                                        <Border Grid.Column="1" Margin="6,0,4,0"
                                                Background="{DynamicResource Background.Primary}"
                                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                                                CornerRadius="3" Padding="4,0" VerticalAlignment="Center" ToolTip="Source broker">
                                            <TextBlock Text="{Binding BrokerAbbrev}" FontSize="10" Foreground="{DynamicResource Text.Secondary}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,6,0,2" Padding="0,0,0,2"
                                                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Text.Primary}" />
                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}" Foreground="{DynamicResource Text.Secondary}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </ScrollViewer>
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Select visible" Command="{Binding SelectAllVisibleCommand}" Padding="8,3" Margin="0,0,6,0" />
                        <Button Content="Clear" Command="{Binding ClearSelectionCommand}" Padding="8,3" />
                        <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} picked'}"
                                   Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Heatmap -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <sp:WpfPlot x:Name="HeatmapPlot" Margin="4" />
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
