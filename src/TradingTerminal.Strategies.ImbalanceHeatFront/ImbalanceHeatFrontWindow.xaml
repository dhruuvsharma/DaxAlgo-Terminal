<mah:MetroWindow x:Class="TradingTerminal.Strategies.ImbalanceHeatFront.ImbalanceHeatFrontWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:helix="http://helix-toolkit.org/wpf"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.ImbalanceHeatFront"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Imbalance Heat Front"
                 Height="780" Width="1240"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- Setup form -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="620"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Configure Imbalance Heat Front"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Per-distance L2 imbalance ratio surface over a rolling time window. Coherent ridges across multiple levels signal one-sided book pressure; trade with (momentum) or against (mean-reversion) the ridge. Requires L2 depth — IB or cTrader."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Text.Secondary}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Levels (X)"    Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Slices (Y)"    Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Events/slice"  Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Ticks/slice"   Margin="4,0,0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding NumLevels, UpdateSourceTrigger=PropertyChanged}"     Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding NumSlices, UpdateSourceTrigger=PropertyChanged}"     Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding EventsPerSlice, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding TicksPerSlice, UpdateSourceTrigger=PropertyChanged}"  Margin="4,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ridge thr"    Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Ridge width"  Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Confirm"      Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="SL"           Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="TP"           Margin="4,0,0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding RidgeThreshold, UpdateSourceTrigger=PropertyChanged}"     Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding RidgeWidth, UpdateSourceTrigger=PropertyChanged}"         Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding ConfirmationSlices, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding StopLossPips, UpdateSourceTrigger=PropertyChanged}"       Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="4" Text="{Binding TakeProfitPips, UpdateSourceTrigger=PropertyChanged}"     Margin="4,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Quantity" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <CheckBox Content="Momentum mode (enter WITH ridge; uncheck for Mean-Reversion)"
                                      IsChecked="{Binding MomentumMode}"
                                      Foreground="{DynamicResource Text.Primary}" />
                        </StackPanel>
                    </Grid>

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Surface view -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live tuning strip. The ridge-detection params are baked into the engine + calculator
                 at build time, so they are locked while the stream runs; Stop to edit them, then
                 Start to rebuild with the new values. The surface Z-scale is render-only and live. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSlider Label="Z height ×" Minimum="0.4" Maximum="4" Step="0.1"
                                         SliderWidth="130" Value="{Binding SurfaceHeightScale, Mode=TwoWay}" />

                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <!-- Ridge params: locked while streaming (rebuild the engine on Start). -->
                        <StackPanel Orientation="Horizontal"
                                    IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="RIDGE (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Levels (X)" Minimum="1" Maximum="20" Step="1" StringFormat="0"
                                              Value="{Binding NumLevels, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Slices (Y)" Minimum="2" Maximum="120" Step="1" StringFormat="0"
                                              Value="{Binding NumSlices, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Ridge thr" Minimum="0.05" Maximum="1" Step="0.05" StringFormat="0.00"
                                              Value="{Binding RidgeThreshold, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Ridge width" Minimum="1" Maximum="20" Step="1" StringFormat="0"
                                              Value="{Binding RidgeWidth, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Confirm" Minimum="1" Maximum="20" Step="1" StringFormat="0"
                                              Value="{Binding ConfirmationSlices, Mode=TwoWay}" />

                            <Border Style="{StaticResource Strategy.ParamDivider}" />
                            <ToggleButton x:Name="MoreToggle" Content="More ▾" VerticalAlignment="Center" Padding="10,3" />
                            <Popup IsOpen="{Binding IsChecked, ElementName=MoreToggle}"
                                   PlacementTarget="{Binding ElementName=MoreToggle}" Placement="Bottom"
                                   StaysOpen="False" AllowsTransparency="True">
                                <Border Style="{StaticResource Strategy.ParamPopout}">
                                    <StackPanel>
                                        <TextBlock Text="More ridge params (applied on Start)" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <WrapPanel>
                                            <uic:ParamSpinner Label="Events/slice" Minimum="1" Maximum="200" Step="1" StringFormat="0"
                                                              Value="{Binding EventsPerSlice, Mode=TwoWay}" />
                                            <uic:ParamSpinner Label="Ticks/slice" Minimum="1" Maximum="200" Step="1" StringFormat="0"
                                                              Value="{Binding TicksPerSlice, Mode=TwoWay}" />
                                            <uic:ParamSpinner Label="Quantity" Minimum="1" Maximum="1000" Step="1" StringFormat="0"
                                                              Value="{Binding Quantity, Mode=TwoWay}" />
                                            <uic:ParamSpinner Label="SL (pips)" Minimum="0.1" Maximum="200" Step="0.5" StringFormat="0.0"
                                                              Value="{Binding StopLossPips, Mode=TwoWay}" />
                                            <uic:ParamSpinner Label="TP (pips)" Minimum="0.1" Maximum="200" Step="0.5" StringFormat="0.0"
                                                              Value="{Binding TakeProfitPips, Mode=TwoWay}" />
                                        </WrapPanel>
                                        <CheckBox Content="Momentum mode (enter WITH ridge; uncheck for Mean-Reversion)"
                                                  IsChecked="{Binding MomentumMode}" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Surface:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding NumLevels}" Margin="6,0,2,0"/>
                    <TextBlock Text="× " Margin="0,0,2,0"/>
                    <TextBlock Text="{Binding NumSlices}" Margin="0,0,16,0"/>
                    <TextBlock Text="Ridge ≥" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding RidgeThreshold, StringFormat=F2}" Margin="6,0,2,0"/>
                    <TextBlock Text="× w=" Margin="0,0,2,0"/>
                    <TextBlock Text="{Binding RidgeWidth}" Margin="0,0,16,0"/>
                    <TextBlock Text="Mode:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Margin="6,0,16,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Mean-Reversion" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MomentumMode}" Value="True">
                                        <Setter Property="Text" Value="Momentum" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Text.Secondary}"
                               Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <helix:HelixViewport3D x:Name="View3D"
                                       Grid.Column="0"
                                       ZoomExtentsWhenLoaded="True"
                                       ShowFrameRate="False"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="True"
                                       Background="#1E1E1E"
                                       CameraRotationMode="Trackball"
                                       IsHeadLightEnabled="True" />

            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource Background.Elevated}"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Depth events:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding DepthEventsSeen}" Margin="6,0,16,0"/>
                    <TextBlock Text="Touch imbalance:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding NearTouchImbalance, StringFormat=+0.00;-0.00; 0.00}" Margin="6,0,16,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Ridge:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding RidgeLabel}" Margin="6,0,16,0"/>
                    <TextBlock Text="Ticks:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding TicksSeen}" Margin="6,0,16,0"/>
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Warning.Brush}"
                               FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                </StackPanel>
            </Border>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
