<mah:MetroWindow x:Class="TradingTerminal.Correlation.LiveCorrelationMatrixWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="Live correlation matrix"
                 Width="960" Height="680"
                 MinWidth="720" MinHeight="480"
                 TitleCharacterCasing="Normal"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 d:DesignHeight="680" d:DesignWidth="960">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- title -->
            <RowDefinition Height="Auto" />   <!-- controls -->
            <RowDefinition Height="*" />      <!-- body: picker + matrix -->
            <RowDefinition Height="Auto" />   <!-- legend -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Live correlation matrix" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Real-time Pearson correlation of mid-price log returns across the selected instruments. Each instrument's live quote is sampled onto a shared time grid; the matrix recomputes every sample over a rolling window. Green = move together, red = move apart."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Control bar -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- sample lbl  -->
                    <ColumnDefinition Width="100" />    <!-- sample cb   -->
                    <ColumnDefinition Width="Auto" />   <!-- window lbl  -->
                    <ColumnDefinition Width="120" />    <!-- window cb   -->
                    <ColumnDefinition Width="Auto" />   <!-- start       -->
                    <ColumnDefinition Width="Auto" />   <!-- stop        -->
                    <ColumnDefinition Width="Auto" />   <!-- live ring   -->
                    <ColumnDefinition Width="*" />      <!-- status      -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Sample" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="1"
                           ItemsSource="{Binding SampleIntervals}"
                           SelectedItem="{Binding SelectedSampleInterval}"
                           DisplayMemberPath="Label"
                           Margin="0,0,14,0" />

                <TextBlock Grid.Column="2" Text="Window" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="3"
                           ItemsSource="{Binding Windows}"
                           SelectedItem="{Binding SelectedWindow}"
                           DisplayMemberPath="Label"
                           Margin="0,0,14,0" />

                <Button Grid.Column="4" Content="Start"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,8,0" />

                <Button Grid.Column="5" Content="Stop"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsStreaming}"
                        Padding="16,4" Margin="0,0,10,0" />

                <mah:ProgressRing Grid.Column="6"
                                  IsActive="{Binding IsStreaming}"
                                  Width="18" Height="18" Margin="0,0,10,0" />

                <TextBlock Grid.Column="7" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />   <!-- instrument picker -->
                <ColumnDefinition Width="*" />     <!-- matrix -->
            </Grid.ColumnDefinitions>

            <!-- Instrument checklist -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />   <!-- title -->
                        <RowDefinition Height="Auto" />   <!-- category filter -->
                        <RowDefinition Height="Auto" />   <!-- search -->
                        <RowDefinition Height="*" />      <!-- grouped list -->
                        <RowDefinition Height="Auto" />   <!-- buttons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Instruments" FontWeight="SemiBold" Margin="2,0,0,6" />

                    <ComboBox Grid.Row="1"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              mah:TextBoxHelper.Watermark="category…"
                              Margin="0,0,0,6" />

                    <TextBox Grid.Row="2"
                             Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             mah:TextBoxHelper.Watermark="filter symbols…"
                             mah:TextBoxHelper.ClearTextButton="True"
                             Margin="0,0,0,6" />

                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding InstrumentsView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  Content="{Binding DisplayName}" />
                                        <Border Grid.Column="1" Margin="6,0,4,0"
                                                Background="{DynamicResource Background.Primary}"
                                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                                                CornerRadius="3" Padding="4,0" VerticalAlignment="Center"
                                                ToolTip="Source broker">
                                            <TextBlock Text="{Binding BrokerAbbrev}" FontSize="10"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,6,0,2" Padding="0,0,0,2"
                                                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource Text.Primary}" />
                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                                               Foreground="{DynamicResource Text.Secondary}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ItemsControl.GroupStyle>
                        </ItemsControl>
                    </ScrollViewer>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
                        <Button Content="Select visible" Command="{Binding SelectAllVisibleCommand}"
                                Padding="8,3" Margin="0,0,6,0" />
                        <Button Content="Clear" Command="{Binding ClearSelectionCommand}"
                                Padding="8,3" />
                        <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} picked'}"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Matrix -->
            <Border Grid.Column="1"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                              Padding="10">
                    <!-- Hosts the CorrelationMatrixControl (injected from code-behind — same-project
                         element types don't survive MarkupCompilePass2, same quirk as LoginWindow).
                         One retained-mode element redraws the whole heat grid per update instead of
                         re-templating N² cell elements per sample tick. -->
                    <ContentControl x:Name="MatrixHost"
                                    HorizontalAlignment="Left" VerticalAlignment="Top" />
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Legend -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
            <TextBlock Text="Correlation" Foreground="{DynamicResource Text.Secondary}"
                       VerticalAlignment="Center" Margin="0,0,8,0" />
            <Border Width="34" Height="16" Background="#C62828" />
            <TextBlock Text="-1" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="11" />
            <Border Width="34" Height="16" Background="#2D2D30" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" />
            <TextBlock Text="0" VerticalAlignment="Center" Margin="3,0,8,0" FontSize="11" />
            <Border Width="34" Height="16" Background="#2E7D32" />
            <TextBlock Text="+1" VerticalAlignment="Center" Margin="3,0,0,0" FontSize="11" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
