<mah:MetroWindow x:Class="TradingTerminal.App.Login.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:TradingTerminal.App.Login"
                 xmlns:conv="clr-namespace:TradingTerminal.UI.Converters;assembly=TradingTerminal.UI"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Trading Terminal — Sign in"
                 Height="780" Width="640"
                 WindowStartupLocation="CenterScreen"
                 ShowMaxRestoreButton="False"
                 ShowMinButton="True"
                 Icon="pack://application:,,,/Icon/DaxAlgoLogo.ico"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <conv:StringToBrushConverter x:Key="StringToBrush" />

        <!-- Status-pill colours follow the connection state. Default = neutral; green = Connected;
             amber = Connecting/Reconnecting. -->
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- ── Group header: one per category, with a "Connect all" action ─────────────────────── -->
        <DataTemplate x:Key="CategoryGroupHeader">
            <DockPanel Margin="2,10,2,4" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                           Foreground="{DynamicResource Text.Secondary}"
                           FontSize="10" FontWeight="SemiBold">
                    <Run Text="{Binding Name, Mode=OneWay}" />
                    <Run Text="{Binding ItemCount, Mode=OneWay, StringFormat=({0})}"
                         Foreground="{DynamicResource Text.Secondary}" />
                </TextBlock>
                <Button DockPanel.Dock="Right" Content="Connect all"
                        FontSize="10" Padding="8,1" MinWidth="0"
                        Command="{Binding DataContext.ConnectGroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding Name}"
                        ToolTip="Connect every broker in this group that has saved settings." />
            </DockPanel>
        </DataTemplate>

        <!-- ── One broker row (item = BrokerLoginFormBase) ─────────────────────────────────────── -->
        <DataTemplate x:Key="BrokerRowTemplate">
            <Border Margin="0,0,0,6" CornerRadius="4" BorderThickness="1"
                    BorderBrush="{DynamicResource Border.Brush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- Keyless rows get a subtle teal accent so the zero-credential path stands out. -->
                            <DataTrigger Binding="{Binding IsKeyless}" Value="True">
                                <Setter Property="BorderBrush" Value="#5526A69A" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}" Background="Transparent">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="500">
                            <!-- Coloured square badge -->
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Margin="0,0,10,0"
                                    Background="{Binding BadgeColor, Converter={StaticResource StringToBrush}}">
                                <TextBlock Text="{Binding Badge}" FontWeight="Bold" FontSize="12"
                                           Foreground="{Binding BadgeForeground, Converter={StaticResource StringToBrush}}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <!-- Name + subtitle -->
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <!-- "no key" pill for the keyless brokers -->
                                    <Border CornerRadius="7" Padding="6,0" Margin="8,0,0,0"
                                            Background="#2226A69A" VerticalAlignment="Center"
                                            Visibility="{Binding IsKeyless, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="no key" FontSize="9" Foreground="#26A69A" VerticalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Subtitle}" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>

                            <!-- Status pill -->
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>

                    <!-- Expanded body: the broker's credential form + connect controls -->
                    <StackPanel Margin="10,8,10,10">
                        <ContentControl uic:InjectedFormHost.Form="{Binding}" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding IsConnecting}"
                                         Visibility="{Binding IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>
            </Border>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <Grid Margin="28,16,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Brand -->
            <RowDefinition Height="Auto" />  <!-- Summary banner -->
            <RowDefinition Height="Auto" />  <!-- Search box -->
            <RowDefinition Height="*" />     <!-- Grouped broker accordion -->
            <RowDefinition Height="Auto" />  <!-- Launch bar -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Logo + brand -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Image Source="pack://application:,,,/Icon/DaxAlgoLogo.png"
                   Width="52" Height="52"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <TextBlock Text="DaxAlgo Terminal"
                       HorizontalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,6,0,0" />
            <TextBlock Text="Connect one or more brokers — each provides its own data feeds."
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Text.Secondary}"
                       FontSize="11"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Aggregate summary banner (+ QuestDB warm-up when applicable) -->
        <Border Grid.Row="1"
                Margin="0,8,0,8"
                Padding="12,8"
                CornerRadius="3"
                BorderThickness="1"
                BorderBrush="{DynamicResource Border.Brush}"
                Background="{DynamicResource Background.Surface}">
            <DockPanel LastChildFill="False">
                <Ellipse DockPanel.Dock="Left" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanLaunch}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ConnectedSummary}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text.Primary}" />

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding ShowQuestDb, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource StatusPill}" VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QuestDbReady}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsQuestDbBusy}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding QuestDbStatus}" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Text.Primary}" />
                        </StackPanel>
                    </Border>
                    <ProgressBar IsIndeterminate="{Binding IsQuestDbBusy}"
                                 Visibility="{Binding IsQuestDbBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Width="80" Height="4" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="Start QuestDB"
                            Command="{Binding StartQuestDbCommand}"
                            MinWidth="100" Padding="8,2" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Search / filter -->
        <TextBox Grid.Row="2" Margin="0,0,0,4"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                 mah:TextBoxHelper.Watermark="Search brokers…"
                 mah:TextBoxHelper.ClearTextButton="True" />

        <!-- Grouped, accordion broker list -->
        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,4,4,0">
            <ItemsControl ItemsSource="{Binding FormsView}"
                          ItemTemplate="{StaticResource BrokerRowTemplate}">
                <ItemsControl.GroupStyle>
                    <GroupStyle HeaderTemplate="{StaticResource CategoryGroupHeader}" />
                </ItemsControl.GroupStyle>
            </ItemsControl>
        </ScrollViewer>

        <!-- Launch bar -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="Connect at least one broker, then launch the terminal."
                           Foreground="{DynamicResource Text.Secondary}"
                           FontSize="11" />
                <CheckBox Content="Auto Connect — connect all brokers on startup"
                          IsChecked="{Binding AutoConnect}"
                          FontSize="11"
                          Margin="0,6,0,0"
                          ToolTip="On the next launch, every broker with saved settings connects automatically — no clicking each Connect button." />
            </StackPanel>

            <Button Grid.Column="1" Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    MinWidth="80" Margin="0,0,8,0" />

            <Button Grid.Column="2" Content="Launch terminal"
                    Command="{Binding LaunchCommand}"
                    IsEnabled="{Binding CanLaunch}"
                    IsDefault="True"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    MinWidth="140" />
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="5"
                   Text="DaxAlgo Terminal · MIT licensed"
                   Foreground="{DynamicResource Text.Secondary}"
                   FontSize="10"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0" />
    </Grid>
</mah:MetroWindow>
