<mah:MetroWindow x:Class="TradingTerminal.App.Login.LoginWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:TradingTerminal.App.Login"
                 xmlns:brokers="clr-namespace:TradingTerminal.Core.Brokers;assembly=TradingTerminal.Core"
                 mc:Ignorable="d"
                 Title="Trading Terminal — Sign in"
                 Height="820" Width="620"
                 WindowStartupLocation="CenterScreen"
                 ShowMaxRestoreButton="False"
                 ShowMinButton="True"
                 Icon="pack://application:,,,/Icon/DaxAlgoLogo.ico"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <!-- Status-pill colours follow the connection state. The dot reuses the same brush so the
             pill and the dot stay in lockstep. Default = neutral (Disconnected/Failed); green =
             Connected; amber = Connecting/Reconnecting. -->
        <Style x:Key="StatusPill" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="28,16,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Brand -->
            <RowDefinition Height="Auto" />  <!-- Summary banner -->
            <RowDefinition Height="*" />     <!-- Broker form expanders (scrollable) -->
            <RowDefinition Height="Auto" />  <!-- Launch bar -->
            <RowDefinition Height="Auto" />  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Logo + brand -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,8">
            <Image Source="pack://application:,,,/Icon/DaxAlgoLogo.png"
                   Width="56" Height="56"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <TextBlock Text="DaxAlgo Terminal"
                       HorizontalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,6,0,0" />
            <TextBlock Text="Connect one or more brokers — each provides its own data feeds."
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource Text.Secondary}"
                       FontSize="11"
                       Margin="0,2,0,0" />
        </StackPanel>

        <!-- Aggregate summary banner -->
        <Border Grid.Row="1"
                Margin="0,8,0,8"
                Padding="12,8"
                CornerRadius="3"
                BorderThickness="1"
                BorderBrush="{DynamicResource Border.Brush}"
                Background="{DynamicResource Background.Surface}">
            <DockPanel LastChildFill="False">
                <Ellipse DockPanel.Dock="Left" Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CanLaunch}" Value="True">
                                    <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ConnectedSummary}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Text.Primary}" />

                <!-- QuestDB warm-up: status pill + start/retry button. Hidden unless QuestDB is the
                     configured tick backend; auto-starts in the background while the user signs in. -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding ShowQuestDb, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource StatusPill}" VerticalAlignment="Center" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding QuestDbReady}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsQuestDbBusy}" Value="True">
                                                <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding QuestDbStatus}" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Text.Primary}" />
                        </StackPanel>
                    </Border>
                    <ProgressBar IsIndeterminate="{Binding IsQuestDbBusy}"
                                 Visibility="{Binding IsQuestDbBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Width="80" Height="4" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="Start QuestDB"
                            Command="{Binding StartQuestDbCommand}"
                            MinWidth="100" Padding="8,2" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Per-broker expanders. Each form's UserControl is injected from code-behind into the
             named ContentControl below; we can't <forms:IbLoginForm/> directly in XAML because
             WPF's MarkupCompilePass1 doesn't see same-project XAML-generated UserControl partial
             classes during the LoginWindow.xaml compile. -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,0,4,0">
            <StackPanel>
                <!-- IB -->
                <Expander Margin="0,0,0,8"
                          IsExpanded="False"
                          Visibility="{Binding HasIb, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="510">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Background="#D32F2F" Margin="0,0,10,0">
                                <TextBlock Text="IB" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IbForm.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="TWS API · localhost socket" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <Border.Background>
                                    <SolidColorBrush Color="{DynamicResource MahApps.Colors.Gray8}" />
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IbForm.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IbForm.IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding IbForm.StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <ContentControl x:Name="IbFormHost" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding IbForm.ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding IbForm.DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding IbForm.IsConnecting}"
                                         Visibility="{Binding IbForm.IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding IbForm.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding IbForm.ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- NinjaTrader -->
                <Expander Margin="0,0,0,8"
                          IsExpanded="False"
                          Visibility="{Binding HasNinja, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="510">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Background="#1B5E20" Margin="0,0,10,0">
                                <TextBlock Text="NT" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding NinjaForm.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="NTDirect · futures, AT Interface" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NinjaForm.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NinjaForm.IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding NinjaForm.StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <ContentControl x:Name="NinjaFormHost" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding NinjaForm.ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding NinjaForm.DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding NinjaForm.IsConnecting}"
                                         Visibility="{Binding NinjaForm.IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding NinjaForm.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding NinjaForm.ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- cTrader -->
                <Expander Margin="0,0,0,8"
                          IsExpanded="False"
                          Visibility="{Binding HasCTrader, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="510">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Background="#0277BD" Margin="0,0,10,0">
                                <TextBlock Text="CT" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CTraderForm.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="Spotware OAuth · FX + CFD, L2 depth" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CTraderForm.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CTraderForm.IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding CTraderForm.StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <ContentControl x:Name="CTraderFormHost" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding CTraderForm.ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding CTraderForm.DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding CTraderForm.IsConnecting}"
                                         Visibility="{Binding CTraderForm.IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding CTraderForm.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding CTraderForm.ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- Alpaca -->
                <Expander Margin="0,0,0,8"
                          IsExpanded="False"
                          Visibility="{Binding HasAlpaca, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="510">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Background="#FFB300" Margin="0,0,10,0">
                                <TextBlock Text="AL" Foreground="White" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AlpacaForm.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="REST + WebSocket · stocks + crypto" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AlpacaForm.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlpacaForm.IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding AlpacaForm.StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <ContentControl x:Name="AlpacaFormHost" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding AlpacaForm.ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding AlpacaForm.DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding AlpacaForm.IsConnecting}"
                                         Visibility="{Binding AlpacaForm.IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding AlpacaForm.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding AlpacaForm.ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- IronBeam -->
                <Expander Margin="0,0,0,8"
                          IsExpanded="False"
                          Visibility="{Binding HasIronBeam, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="510">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Background="#D84315" Margin="0,0,10,0">
                                <TextBlock Text="IRB" Foreground="White" FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding IronBeamForm.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="REST + WebSocket · futures, L1/L2 + trade tape" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IronBeamForm.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IronBeamForm.IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding IronBeamForm.StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <ContentControl x:Name="IronBeamFormHost" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding IronBeamForm.ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding IronBeamForm.DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding IronBeamForm.IsConnecting}"
                                         Visibility="{Binding IronBeamForm.IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding IronBeamForm.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding IronBeamForm.ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>

                <!-- Binance (public market data — no login). Expanded by default so the zero-credential
                     "try it with real data" path is the first thing a new user sees. -->
                <Expander Margin="0,0,0,8"
                          IsExpanded="True"
                          Visibility="{Binding HasBinance, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Expander.Header>
                        <DockPanel LastChildFill="False" MinWidth="510">
                            <Border DockPanel.Dock="Left" Width="32" Height="32" CornerRadius="4"
                                    Background="#F0B90B" Margin="0,0,10,0">
                                <TextBlock Text="BN" Foreground="#1E2026" FontWeight="Bold" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                <TextBlock Text="{Binding BinanceForm.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="Public WebSocket · live crypto, L2 depth · no API key" FontSize="10"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource StatusPill}"
                                    VerticalAlignment="Center" Margin="8,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource Text.Secondary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BinanceForm.IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding BinanceForm.IsConnecting}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource Warning.Brush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding BinanceForm.StatusText}" FontSize="11"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource Text.Primary}" />
                                </StackPanel>
                            </Border>
                        </DockPanel>
                    </Expander.Header>
                    <StackPanel Margin="0,8,0,0">
                        <ContentControl x:Name="BinanceFormHost" />
                        <DockPanel Margin="0,8,0,0" LastChildFill="False">
                            <Button DockPanel.Dock="Right" Content="Connect"
                                    Command="{Binding BinanceForm.ConnectCommand}"
                                    MinWidth="100"
                                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                            <Button DockPanel.Dock="Right" Content="Disconnect"
                                    Command="{Binding BinanceForm.DisconnectCommand}"
                                    MinWidth="100" Margin="0,0,8,0" />
                            <ProgressBar DockPanel.Dock="Left"
                                         IsIndeterminate="{Binding BinanceForm.IsConnecting}"
                                         Visibility="{Binding BinanceForm.IsConnecting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         Width="120" Height="4" VerticalAlignment="Center" Margin="0,0,12,0" />
                        </DockPanel>
                        <Border Background="{DynamicResource Danger.Brush}"
                                Padding="8,4" Margin="0,6,0,0"
                                Visibility="{Binding BinanceForm.ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding BinanceForm.ErrorMessage}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- Launch bar -->
        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                <TextBlock Text="Connect at least one broker, then launch the terminal."
                           Foreground="{DynamicResource Text.Secondary}"
                           FontSize="11" />
                <CheckBox Content="Auto Connect — connect all brokers on startup"
                          IsChecked="{Binding AutoConnect}"
                          FontSize="11"
                          Margin="0,6,0,0"
                          ToolTip="On the next launch, every broker with saved settings connects automatically — no clicking each Connect button." />
            </StackPanel>

            <Button Grid.Column="1" Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    MinWidth="80" Margin="0,0,8,0" />

            <Button Grid.Column="2" Content="Launch terminal"
                    Command="{Binding LaunchCommand}"
                    IsEnabled="{Binding CanLaunch}"
                    IsDefault="True"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                    MinWidth="140" />
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="4"
                   Text="DaxAlgo Terminal · MIT licensed"
                   Foreground="{DynamicResource Text.Secondary}"
                   FontSize="10"
                   HorizontalAlignment="Center"
                   Margin="0,12,0,0" />
    </Grid>
</mah:MetroWindow>
