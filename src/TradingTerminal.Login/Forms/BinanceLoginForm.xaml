<UserControl x:Class="TradingTerminal.App.Login.Forms.BinanceLoginForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:TradingTerminal.App.Login.Forms"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="500">
    <StackPanel>
        <TextBlock TextWrapping="Wrap"
                   Foreground="{DynamicResource Text.Primary}"
                   Margin="0,0,0,8">
            <Run FontWeight="SemiBold" Text="No login required." />
            <Run Text="Binance market data is public — just click Connect to stream a real, live crypto feed (bars, L1, L2 depth and the trade tape) with no API key and no account." />
        </TextBlock>

        <Border Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                Padding="10,6">
            <TextBlock TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource Text.Secondary}">
                <Run FontWeight="SemiBold" Text="Heads up:" />
                <Run Text="This is data only — no orders are placed. Default symbols include BTC, ETH, SOL and other major pairs (configurable under the Binance section of appsettings.json). If Binance is geo-blocked where you are, repoint the hosts to Binance.US or the data-api.binance.vision mirror." />
            </TextBlock>
        </Border>
    </StackPanel>
</UserControl>
