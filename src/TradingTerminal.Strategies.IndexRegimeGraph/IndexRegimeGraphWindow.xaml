<mah:MetroWindow x:Class="TradingTerminal.Strategies.IndexRegimeGraph.IndexRegimeGraphWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="Index Regime Graph"
                 Height="900" Width="1560"
                 WindowStartupLocation="CenterOwner"
                 Focusable="True"
                 GlowBrush="{DynamicResource Accent.Brush}"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>

        <!-- Graph-paper background so pan/zoom is visually obvious. -->
        <DrawingBrush x:Key="GraphGridBrush" TileMode="Tile" Viewport="0,0,44,44"
                      ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <GeometryDrawing Geometry="M0,0 L0,44 M0,0 L44,0">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#12FFB000" Thickness="0.6" />
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Radial vignette behind the net — gives the canvas depth. -->
        <RadialGradientBrush x:Key="ViewportBackdrop" GradientOrigin="0.5,0.42" Center="0.5,0.42"
                             RadiusX="0.85" RadiusY="0.95">
            <GradientStop Color="#15171F" Offset="0" />
            <GradientStop Color="#0B0C11" Offset="0.6" />
            <GradientStop Color="#050608" Offset="1" />
        </RadialGradientBrush>

        <!-- Glossy specular highlight laid over each node so it reads as a 3-D orb. -->
        <RadialGradientBrush x:Key="NodeGloss" GradientOrigin="0.34,0.28" Center="0.34,0.28"
                             RadiusX="0.85" RadiusY="0.85">
            <GradientStop Color="#70FFFFFF" Offset="0" />
            <GradientStop Color="#20FFFFFF" Offset="0.35" />
            <GradientStop Color="#00FFFFFF" Offset="0.75" />
        </RadialGradientBrush>

        <!-- Chrome surface gradients. -->
        <LinearGradientBrush x:Key="ChromeBar" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1A1A1A" Offset="0" />
            <GradientStop Color="#0E0E0E" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardHeader" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#241A06" Offset="0" />
            <GradientStop Color="#120D03" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelHeader" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#161616" Offset="0" />
            <GradientStop Color="#0C0C0C" Offset="1" />
        </LinearGradientBrush>

        <!-- Toolbar button: flat, rounded, accent on hover. -->
        <Style x:Key="GraphToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Background" Value="#1C1C1C" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="4" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2A2206" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon-ish square button (zoom +/-). -->
        <Style x:Key="GraphIconButton" TargetType="Button" BasedOn="{StaticResource GraphToolButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Status chip in the footer. -->
        <Style x:Key="FooterChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="9,2" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#161616" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- DataGrid chrome. -->
        <Style x:Key="ConstituentHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource PanelHeader}" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style x:Key="ConstituentRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#0A0A0A" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1505" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ConstituentCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A2206" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Band → foreground for the score/contrib numbers (no converter needed). -->
        <Style x:Key="BandNumber" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Band}" Value="StrongUp">
                    <Setter Property="Foreground" Value="#16C784" /></DataTrigger>
                <DataTrigger Binding="{Binding Band}" Value="Up">
                    <Setter Property="Foreground" Value="#3FB37A" /></DataTrigger>
                <DataTrigger Binding="{Binding Band}" Value="Down">
                    <Setter Property="Foreground" Value="#E0555A" /></DataTrigger>
                <DataTrigger Binding="{Binding Band}" Value="StrongDown">
                    <Setter Property="Foreground" Value="#E6383C" /></DataTrigger>
            </Style.Triggers>
        </Style>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="Arm or disarm signal publishing. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Padding" Value="14,4" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Arm" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Disarm" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ── Setup form ───────────────────────────────────────────────────────────────── -->
        <Grid Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border MaxWidth="640" VerticalAlignment="Center" CornerRadius="10"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="36" ShadowDepth="0" Opacity="0.6" />
                </Border.Effect>
                <StackPanel>
                    <!-- gradient header with accent rule -->
                    <Border CornerRadius="10,10,0,0" Background="{StaticResource CardHeader}" Padding="24,18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="◳" FontSize="22" Foreground="{DynamicResource Accent.Brush}"
                                           Margin="0,0,10,0" VerticalAlignment="Center" />
                                <TextBlock Text="Configure Index Regime Graph" FontSize="19" FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource Text.Secondary}" Margin="0,8,0,0"
                                       Text="Runs the Advanced Market Regime indicator stack on every constituent across all eight timeframes, blends each stock for the chosen horizon, weights by index membership, and sums to a composite up/down direction." />
                        </StackPanel>
                    </Border>
                    <Border Height="2" Background="{DynamicResource Accent.Brush}" Opacity="0.55" />

                    <StackPanel Margin="24,18,24,22">
                        <TextBlock Text="INDEX FAMILY" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Families}" SelectedItem="{Binding SelectedFamily}"
                                  DisplayMemberPath="DisplayName" Margin="0,0,0,14" />

                        <TextBlock Text="HORIZON (t)" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Horizons}" SelectedItem="{Binding SelectedHorizon}" Margin="0,0,0,3" />
                        <TextBlock Text="{Binding HorizonDescription}" Foreground="{DynamicResource Text.Secondary}"
                                   FontSize="11" Margin="0,0,0,14" />

                        <TextBlock Text="DATA BROKER" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Brokers}" SelectedItem="{Binding SelectedBroker}" Margin="0,0,0,3" />
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"
                                   Text="Every constituent is fetched from this broker. Pick Simulated to run fully offline with synthetic data for all names; pick a live broker (e.g. IB) if each constituent has a market-data line." />

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="REFRESH INTERVAL (s)" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                                <TextBox Text="{Binding RefreshSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
                                <CheckBox Content="Auto-refresh" IsChecked="{Binding AutoRefresh}" Margin="0,0,0,6" />
                            </StackPanel>
                        </Grid>

                        <Border CornerRadius="5" Background="{DynamicResource Danger.Brush}" Padding="10,6" Margin="0,0,0,14"
                                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                        </Border>

                        <Button Content="Continue  →" Command="{Binding ContinueCommand}"
                                HorizontalAlignment="Right" IsDefault="True" MinWidth="130"
                                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ── Main view ────────────────────────────────────────────────────────────────── -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource ChromeBar}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="12,7">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="◳" FontSize="16" Foreground="{DynamicResource Accent.Brush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="INDEX REGIME GRAPH" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource Text.Header}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <Button Content="■ Stop" Command="{Binding StopCommand}" Style="{StaticResource GraphToolButton}"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="▶ Start" Command="{Binding StartCommand}" Style="{StaticResource GraphToolButton}"
                            Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource GraphToolButton}" />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <TextBlock Text="HORIZON" Style="{StaticResource Strategy.ParamGroupLabel}" />
                    <ComboBox ItemsSource="{Binding Horizons}" SelectedItem="{Binding SelectedHorizon}"
                              VerticalAlignment="Center" Width="116" Margin="0,0,8,0" />
                    <CheckBox Content="Auto" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <TextBlock Text="VIEW" Style="{StaticResource Strategy.ParamGroupLabel}" />
                    <Button Content="−" Click="ZoomOut_Click" Style="{StaticResource GraphIconButton}" ToolTip="Zoom out (−)" />
                    <Border CornerRadius="4" Background="#161616" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="0,3" Margin="0,0,3,0" VerticalAlignment="Center">
                        <TextBlock x:Name="ZoomReadout" Text="100%" Width="46" TextAlignment="Center"
                                   Foreground="{DynamicResource Text.Highlight}" FontWeight="SemiBold" />
                    </Border>
                    <Button Content="+" Click="ZoomIn_Click" Style="{StaticResource GraphIconButton}" ToolTip="Zoom in (+)" />
                    <Button Content="⤢ Fit" Click="Fit_Click" Style="{StaticResource GraphToolButton}" ToolTip="Fit graph to view (Home)" />
                    <Button Content="Clear focus" Command="{Binding ClearFocusCommand}" Style="{StaticResource GraphToolButton}" />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource ChromeBar}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <!-- composite pill -->
                    <Border CornerRadius="9" Padding="11,3" Margin="0,0,12,0" VerticalAlignment="Center"
                            Background="{Binding CompositeColorHex, Converter={StaticResource StringToBrushConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="COMPOSITE" Foreground="#CC000000" FontSize="9.5" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock FontWeight="Bold" Foreground="White" VerticalAlignment="Center"
                                       Text="{Binding CompositePercent, StringFormat=+0.0;-0.0;0.0}" />
                            <TextBlock Text="%" Foreground="White" VerticalAlignment="Center" Margin="1,0,8,0" />
                            <TextBlock FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"
                                       Text="{Binding CompositeDirection}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource FooterChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▲" Foreground="{DynamicResource Bullish.Brush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding BullishCount}" Foreground="{DynamicResource Bullish.Brush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FooterChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▼" Foreground="{DynamicResource Danger.Brush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding BearishCount}" Foreground="{DynamicResource Danger.Brush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FooterChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="READY" Foreground="{DynamicResource Text.Secondary}" FontSize="9.5" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Foreground="{DynamicResource Text.Primary}" FontWeight="SemiBold"><Run Text="{Binding ConstituentsReady}" /><Run Text="/" /><Run Text="{Binding ConstituentsTotal}" /></TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" Margin="6,0,12,0" VerticalAlignment="Center"
                               Visibility="{Binding UsingSyntheticData, Converter={StaticResource BooleanToVisibilityConverter}}"
                               ToolTip="One or more constituents had no live/stored history (markets likely closed); showing synthetic history until real data arrives."
                               Text="◷ SYNTHETIC (offline)" />
                    <TextBlock Foreground="{DynamicResource Accent.Brush}" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Center"
                               Visibility="{Binding IsRefreshing, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="◌ ANALYSING…" />
                    <TextBlock Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" VerticalAlignment="Center"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ARMED" />
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="460" />
                </Grid.ColumnDefinitions>

                <!-- Node-graph viewport. Pan/zoom handlers on the viewport border. -->
                <Border Grid.Column="0" x:Name="GraphViewport" ClipToBounds="True"
                        Background="{StaticResource ViewportBackdrop}"
                        Focusable="True"
                        MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
                        MouseMove="Viewport_MouseMove"
                        MouseLeftButtonUp="Viewport_MouseLeftButtonUp"
                        MouseWheel="Viewport_MouseWheel">

                    <Grid>
                        <Canvas x:Name="GraphRoot" RenderTransformOrigin="0,0">
                            <Canvas.RenderTransform>
                                <MatrixTransform x:Name="GraphTransform" />
                            </Canvas.RenderTransform>

                            <!-- graph-paper backdrop (also a big hit surface that bubbles to pan) -->
                            <Rectangle Canvas.Left="-4000" Canvas.Top="-4000" Width="9000" Height="9000"
                                       Fill="{StaticResource GraphGridBrush}" />

                            <!-- synapses (behind) -->
                            <ItemsControl ItemsSource="{Binding GraphEdges}" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding From.CenterX}" Y1="{Binding From.CenterY}"
                                              X2="{Binding To.CenterX}" Y2="{Binding To.CenterY}"
                                              Stroke="{Binding ColorHex, Converter={StaticResource StringToBrushConverter}}"
                                              StrokeThickness="{Binding Thickness}" Opacity="{Binding Opacity}"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- neurons (front) -->
                            <ItemsControl ItemsSource="{Binding GraphNodes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Size}" Height="{Binding Size}" Cursor="Hand"
                                              MouseLeftButtonDown="Node_MouseLeftButtonDown"
                                              MouseMove="Node_MouseMove"
                                              MouseLeftButtonUp="Node_MouseLeftButtonUp">
                                            <Grid.ToolTip>
                                                <ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding SubLabel}" />
                                                    </StackPanel>
                                                </ToolTip>
                                            </Grid.ToolTip>

                                            <!-- coloured glow (blurred halo); fades out for no-data nodes -->
                                            <Ellipse Margin="-9" Fill="{Binding ColorHex, Converter={StaticResource StringToBrushConverter}}">
                                                <Ellipse.Effect>
                                                    <BlurEffect Radius="16" />
                                                </Ellipse.Effect>
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Opacity" Value="0.45" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                                                <Setter Property="Opacity" Value="0.0" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!-- selection ring -->
                                            <Ellipse Stroke="{DynamicResource Accent.Brush}" StrokeThickness="2.5" Margin="-5"
                                                     Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#FF8C00" BlurRadius="14" ShadowDepth="0" Opacity="0.9" />
                                                </Ellipse.Effect>
                                            </Ellipse>

                                            <!-- body -->
                                            <Ellipse Fill="{Binding ColorHex, Converter={StaticResource StringToBrushConverter}}"
                                                     Stroke="#55000000" StrokeThickness="1">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasData}" Value="False">
                                                                <Setter Property="Opacity" Value="0.28" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <!-- glossy specular highlight -->
                                            <Ellipse Fill="{StaticResource NodeGloss}" IsHitTestVisible="False" />
                                            <!-- thin rim light -->
                                            <Ellipse Stroke="#33FFFFFF" StrokeThickness="1" IsHitTestVisible="False" />

                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Label}" Foreground="White" TextAlignment="Center"
                                                           FontWeight="SemiBold" FontSize="{Binding LabelFontSize}">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0.8" Opacity="0.8" />
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="{Binding SubLabel}" Foreground="#E6FFFFFF" TextAlignment="Center"
                                                           FontSize="8.5">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SubLabel}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>

                        <!-- Fixed layer caption + focus banner overlay (not transformed). -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="14,12"
                                Background="#B3000000" CornerRadius="6" Padding="12,8" IsHitTestVisible="False"
                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="companies → indicators → timeframes → output → ×weight → signal"
                                           Foreground="{DynamicResource Text.Header}" FontSize="11.5" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FocusLabel}" Foreground="{DynamicResource Text.Highlight}" FontSize="10.5" Margin="0,3,0,0" />
                                <TextBlock Text="drag = pan · wheel = zoom · drag a node = move · click a company = focus"
                                           Foreground="{DynamicResource Text.Secondary}" FontSize="9.5" Margin="0,3,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                              Background="{DynamicResource Border.Brush}" />

                <!-- Right panel -->
                <Grid Grid.Column="2" Background="{DynamicResource Background.Surface}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- composite headline -->
                    <Border Grid.Row="0" Background="{StaticResource PanelHeader}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="16,14">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedFamily.DisplayName}" FontWeight="SemiBold" FontSize="13"
                                       Foreground="{DynamicResource Text.Header}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{Binding CompositePercent, StringFormat=+0.0;-0.0;0.0}"
                                           FontSize="34" FontWeight="Bold"
                                           Foreground="{Binding CompositeColorHex, Converter={StaticResource StringToBrushConverter}}">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="0" Opacity="0.6" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="%" FontSize="18" VerticalAlignment="Bottom" Margin="2,0,14,6"
                                           Foreground="{DynamicResource Text.Secondary}" />
                                <Border CornerRadius="10" Padding="11,4" VerticalAlignment="Center"
                                        Background="{Binding CompositeColorHex, Converter={StaticResource StringToBrushConverter}}">
                                    <TextBlock Text="{Binding CompositeDirection}" FontSize="13" FontWeight="Bold" Foreground="White" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="3" Background="{DynamicResource Accent.Brush}" Margin="0,0,8,0" />
                            <TextBlock Text="CONSTITUENTS · BY CONTRIBUTION" FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource Accent.Brush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2" ItemsSource="{Binding ConstituentScores}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="None"
                              Background="Transparent" RowBackground="Transparent" BorderThickness="0"
                              AlternationCount="2"
                              ColumnHeaderStyle="{StaticResource ConstituentHeader}"
                              RowStyle="{StaticResource ConstituentRow}"
                              CellStyle="{StaticResource ConstituentCell}"
                              FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11.5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SYM"  Binding="{Binding Symbol}" Width="58">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="WT"   Binding="{Binding IndexWeight, StringFormat=P1}" Width="58">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SCORE" Binding="{Binding StockScore, StringFormat=+0.00;-0.00;0.00}" Width="64"
                                                ElementStyle="{StaticResource BandNumber}" />
                            <DataGridTextColumn Header="CONTRIB" Binding="{Binding Contribution, StringFormat=+0.000;-0.000;0.000}" Width="76"
                                                ElementStyle="{StaticResource BandNumber}" />
                            <DataGridTemplateColumn Header="DIR" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="7,1" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#22FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Band}" Value="StrongUp">
                                                            <Setter Property="Background" Value="#2616C784" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Band}" Value="Up">
                                                            <Setter Property="Background" Value="#203FB37A" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Band}" Value="Down">
                                                            <Setter Property="Background" Value="#26E0555A" /></DataTrigger>
                                                        <DataTrigger Binding="{Binding Band}" Value="StrongDown">
                                                            <Setter Property="Background" Value="#30E6383C" /></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Band}" FontSize="10" FontWeight="SemiBold"
                                                       Style="{StaticResource BandNumber}" HorizontalAlignment="Left" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
