<ui:StrategyWindowBase x:Class="TradingTerminal.Strategies.ApexScalper.ApexScalperStrategyWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                       xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                       xmlns:ui="clr-namespace:TradingTerminal.UI;assembly=TradingTerminal.UI"
                       xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                       mc:Ignorable="d" Title="{Binding StrategyDisplayName}" Height="860" Width="1440" WindowStartupLocation="CenterOwner"
                       Background="{DynamicResource Background.Primary}" Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="6,2,0,0" />
        </Style>
        <Style x:Key="DashSection" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style x:Key="DashKey" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,8,2" />
        </Style>
        <Style x:Key="DashValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
        <Style x:Key="MonoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Style="{StaticResource Strategy.RunStopButton}" />
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ── Setup form ──────────────────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Strategy.SetupCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Strategy.SetupTitle}" Text="Configure APEX microstructure scalper v2" />
                    <TextBlock Style="{StaticResource Strategy.SetupDescription}"
                               Text="Tape-primary composite: Delta, VPIN, Footprint stacked imbalance, Tape Speed, Kyle-λ residual, initiative/control/wedge/value (triple regression lines), CVD divergence, OBI (live depth). Σ⁻¹·IC weighting; calibrated g(C) entry gate. Bootstrap mode active until isotonic calibration is warm." />

                    <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Instrument" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Kelly fraction" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Bootstrap threshold |C|" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Max chart candles" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource Strategy.SetupFieldLabel}" Text="FP bars visible" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding KellyFraction, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding BootstrapThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding MaxChartCandles, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding FootprintBarsVisible, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Candle interval" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Tick size (instrument)" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Tick-size override (0 = auto derive from ATR)" Margin="4,0,0,4" />
                        <ComboBox  Grid.Row="1" Grid.Column="0" ItemsSource="{Binding CandleIntervals}"
                                   SelectedItem="{Binding SelectedCandleInterval}" DisplayMemberPath="Label" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding FootprintTickSizeText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding TickSizeOverrideText, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Allowed sessions (UTC)" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox IsChecked="{Binding TradeAsian}" Content="Asian" Margin="0,0,16,0" />
                        <CheckBox IsChecked="{Binding TradeLondon}" Content="London" Margin="0,0,16,0" />
                        <CheckBox IsChecked="{Binding TradeNewYork}" Content="New York" Margin="0,0,16,0" />
                        <CheckBox IsChecked="{Binding TradeLondonNy}" Content="London/NY overlap" />
                    </StackPanel>

                    <Border Style="{StaticResource Strategy.SetupErrorBanner}"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>
                    <Button Content="Continue" Command="{Binding ContinueCommand}" HorizontalAlignment="Right"
                            IsDefault="True" MinWidth="120" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ── Running layout ─────────────────────────────────────────────────────────── -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live-tuning strip -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Max candles" Minimum="10" Maximum="500" Step="10" StringFormat="0"
                                          Value="{Binding MaxChartCandles, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="FP bars" Minimum="4" Maximum="24" Step="1" StringFormat="0"
                                          Value="{Binding FootprintBarsVisible, Mode=TwoWay}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="PARAMS (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Kelly frac" Minimum="0.01" Maximum="1" Step="0.01" StringFormat="0.00"
                                              Value="{Binding KellyFraction, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Bootstrap |C|" Minimum="0.1" Maximum="3" Step="0.05" StringFormat="0.00"
                                              Value="{Binding BootstrapThreshold, Mode=TwoWay}" />
                            <Border Style="{StaticResource Strategy.ParamDivider}" />
                            <ToggleButton x:Name="MoreToggle" Content="More ▾" VerticalAlignment="Center" Padding="10,3" />
                            <Popup IsOpen="{Binding IsChecked, ElementName=MoreToggle}"
                                   PlacementTarget="{Binding ElementName=MoreToggle}" Placement="Bottom"
                                   StaysOpen="False" AllowsTransparency="True">
                                <Border Style="{StaticResource Strategy.ParamPopout}">
                                    <StackPanel>
                                        <TextBlock Text="More params (applied on Start)" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="Candle interval" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <ComboBox Width="72" ItemsSource="{Binding CandleIntervals}"
                                                      SelectedItem="{Binding SelectedCandleInterval}" DisplayMemberPath="Label" />
                                            <TextBlock Text="Instrument tick" VerticalAlignment="Center" Margin="14,0,6,0" />
                                            <TextBox Width="72" Text="{Binding FootprintTickSizeText, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Tick override (0=auto)" VerticalAlignment="Center" Margin="14,0,6,0" />
                                            <TextBox Width="72" Text="{Binding TickSizeOverrideText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox Content="Asian" IsChecked="{Binding TradeAsian}" Margin="0,0,12,0" />
                                            <CheckBox Content="London" IsChecked="{Binding TradeLondon}" Margin="0,0,12,0" />
                                            <CheckBox Content="New York" IsChecked="{Binding TradeNewYork}" Margin="0,0,12,0" />
                                            <CheckBox Content="London/NY" IsChecked="{Binding TradeLondonNy}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="200" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0" Style="{StaticResource Strategy.HeaderBar}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="Kelly:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding KellyFraction, StringFormat=F2}" Margin="6,0,16,0" />
                    <TextBlock Text="Bootstrap |C|:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding BootstrapThreshold, StringFormat=F2}" Margin="6,0,16,0" />
                    <!-- Feed-quality badge (updated by code-behind) -->
                    <TextBlock x:Name="FeedQualityBadge"
                               Text="—" FontWeight="Bold" FontSize="10"
                               VerticalAlignment="Center" Margin="8,0,6,0" />
                    <!-- Bootstrap mode badge (shown/hidden by code-behind) -->
                    <Border x:Name="BootstrapBadge"
                            Background="#FF8F00" CornerRadius="3" Padding="5,1" Margin="4,0,0,0"
                            Visibility="Collapsed" VerticalAlignment="Center">
                        <TextBlock Text="BOOTSTRAP" FontSize="9" FontWeight="Bold" Foreground="Black" />
                    </Border>
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <!-- Main content: charts (left 3*) + dashboard (right 1*) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" MinWidth="280" />
                </Grid.ColumnDefinitions>

                <!-- Charts pane -->
                <Grid Grid.Column="0" Margin="4,4,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" MinWidth="320" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*"  MinWidth="200" />
                    </Grid.ColumnDefinitions>

                    <!-- Left column: 5-pair signal grid, footprint cluster, gauge -->
                    <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"   MinHeight="200" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="190" MinHeight="110" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="60"  MinHeight="40" />
                    </Grid.RowDefinitions>

                    <!-- 5 rows × 2 cols: Delta/VPIN, Initiative/Control, Footprint/Kyle, Wedge/TapeSpeed, CVD/OBI -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="60" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="60" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="60" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="60" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" MinHeight="60" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  MinWidth="80" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*"  MinWidth="80" />
                        </Grid.ColumnDefinitions>

                        <GridSplitter Grid.Column="1" Grid.RowSpan="9" Width="4"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="False" />

                        <!-- Row 0: Delta / VPIN -->
                        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Delta" />
                                <scottplot:WpfPlot x:Name="DeltaPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="VPIN" />
                                <scottplot:WpfPlot x:Name="VpinPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <!-- Row 2: Initiative / Control -->
                        <Border Grid.Row="2" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Initiative (β_b−β_s)" />
                                <scottplot:WpfPlot x:Name="InitiativePlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Control ρ" />
                                <scottplot:WpfPlot x:Name="ControlPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <GridSplitter Grid.Row="3" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <!-- Row 4: Footprint / Kyle -->
                        <Border Grid.Row="4" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Footprint imbalance" />
                                <scottplot:WpfPlot x:Name="FootprintPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="4" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Kyle-λ residual" />
                                <scottplot:WpfPlot x:Name="KylePlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <GridSplitter Grid.Row="5" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <!-- Row 6: Wedge / Tape Speed -->
                        <Border Grid.Row="6" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Wedge dynamics" />
                                <scottplot:WpfPlot x:Name="WedgePlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="6" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Tape speed" />
                                <scottplot:WpfPlot x:Name="TapeSpeedPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <GridSplitter Grid.Row="7" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <!-- Row 8: CVD / OBI -->
                        <Border Grid.Row="8" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="CVD divergence" />
                                <scottplot:WpfPlot x:Name="CvdPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="8" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="OBI (live depth)" />
                                <scottplot:WpfPlot x:Name="ObiPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="4"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="{DynamicResource Border.Brush}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                    <!-- Footprint cluster (Core FootprintBar/FootprintFeatureRow — rendered in code-behind) -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Background="{DynamicResource Background.Surface}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource Background.Elevated}"
                                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1"
                                    Padding="6,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FOOTPRINT CLUSTER"
                                               Foreground="{DynamicResource Text.Header}"
                                               FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" x:Name="FootprintStatus"
                                               Margin="8,0,0,0" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource Text.Secondary}"
                                               FontSize="10" VerticalAlignment="Center"
                                               Text="awaiting ticks" />
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" x:Name="FootprintScroll"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Canvas x:Name="ApexFootprintCanvas"
                                        Background="{DynamicResource Background.Surface}"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" />
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="3" Height="4"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="{DynamicResource Border.Brush}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                    <!-- Composite sentiment gauge -->
                    <Border Grid.Row="4" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Background="{DynamicResource Background.Surface}">
                        <Grid Margin="6,4,6,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="SHORT"
                                           Foreground="{DynamicResource Bearish.Brush}"
                                           FontWeight="Bold" FontSize="10" />
                                <TextBlock Grid.Column="1" x:Name="GaugeLabel"
                                           Text="composite —"
                                           Foreground="{DynamicResource Text.Header}"
                                           FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="LONG"
                                           Foreground="{DynamicResource Bullish.Brush}"
                                           FontWeight="Bold" FontSize="10" />
                            </Grid>
                            <Grid Grid.Row="1" x:Name="GaugeTrackHost" VerticalAlignment="Center" Height="20" ClipToBounds="True">
                                <Border CornerRadius="3" Height="16" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#FF1744" Offset="0" />
                                            <GradientStop Color="#5A2A2A" Offset="0.40" />
                                            <GradientStop Color="#3A3A3A" Offset="0.5" />
                                            <GradientStop Color="#2A5A4A" Offset="0.60" />
                                            <GradientStop Color="#00C853" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Canvas x:Name="GaugeTicks" Background="Transparent" />
                                <Canvas x:Name="GaugeNeedleHost" Background="Transparent">
                                    <Polygon x:Name="GaugeNeedle"
                                             Points="-6,0 6,0 0,12"
                                             Fill="White"
                                             Stroke="Black" StrokeThickness="1"
                                             Canvas.Top="2" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>
                    </Grid>   <!-- end chart stack -->

                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="{DynamicResource Border.Brush}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="False" />

                    <!-- Order book -->
                    <Grid Grid.Column="2">
                        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                                Background="{DynamicResource Background.Surface}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0"
                                        Background="{DynamicResource Background.Elevated}"
                                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1"
                                        Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ORDER BOOK"
                                                   Foreground="{DynamicResource Text.Header}"
                                                   FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" x:Name="OrderBookStatus"
                                                   Margin="8,0,0,0" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Text="awaiting depth" />
                                    </Grid>
                                </Border>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="OrderBookLadder" Orientation="Vertical" />
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ── Dashboard panel ── -->
                <Border Grid.Column="1" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                        Background="{DynamicResource Background.Elevated}" Margin="0,4,4,4" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <!-- Composite -->
                            <TextBlock Style="{StaticResource DashSection}" Text="COMPOSITE" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Score C" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding CompositeText, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="Direction" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding CompositeDirectionText, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="Trade OK" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.TradeAllowed, FallbackValue=—}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashKey}" Text="Kill switch" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.KillSwitch, FallbackValue=—}" />
                            </Grid>

                            <!-- g(C) / calibration -->
                            <TextBlock Style="{StaticResource DashSection}" Text="CALIBRATION" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="g(C) exp. return" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding GcText, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="Cond. slippage" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding CostHurdleText, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="Bootstrap mode" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding BootstrapMode, FallbackValue=—}" />
                            </Grid>

                            <!-- Regime / feed -->
                            <TextBlock Style="{StaticResource DashSection}" Text="REGIME / FEED" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Regime" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding RegimeText, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="Feed quality" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding FeedQualityText, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="Session P&amp;L" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding SessionPnlText, FallbackValue=—}" />
                            </Grid>

                            <!-- Kyle / epsilon -->
                            <TextBlock Style="{StaticResource DashSection}" Text="KYLE / EPSILON" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="λ̂ (price impact)" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding KyleLambdaText, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="ε_cum" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding EpsilonCumText, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="ε_cum z" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding EpsilonCumZText, FallbackValue=—}" />
                            </Grid>

                            <!-- Line fits / geometry -->
                            <TextBlock Style="{StaticResource DashSection}" Text="LINE FITS / GEOMETRY" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                                           Style="{StaticResource DashKey}" Text="    slope  R²"
                                           Margin="0,0,0,2" HorizontalAlignment="Right" FontSize="10" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="Buy line β" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding BuyLineSlopeText, FallbackValue=—}" Margin="0,0,6,2" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource MonoValue}" Text="{Binding BuyLineR2Text, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="Sell line β" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding SellLineSlopeText, FallbackValue=—}" Margin="0,0,6,2" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource MonoValue}" Text="{Binding SellLineR2Text, FallbackValue=—}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashKey}" Text="POC line β" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding PocLineSlopeText, FallbackValue=—}" Margin="0,0,6,2" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource MonoValue}" Text="{Binding PocLineR2Text, FallbackValue=—}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashKey}" Text="Control ρ / dρ" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding ControlRhoText, FallbackValue=—}" Margin="0,0,6,2" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource MonoValue}" Text="{Binding ControlVelocityText, FallbackValue=—}" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DashKey}" Text="Wedge w / dw" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource MonoValue}" Text="{Binding WedgeWidthText, FallbackValue=—}" Margin="0,0,6,2" />
                                <TextBlock Grid.Row="5" Grid.Column="2" Style="{StaticResource MonoValue}" Text="{Binding WedgeVelocityText, FallbackValue=—}" />
                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DashKey}" Text="Value dev z_p" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource MonoValue}" Text="{Binding ValueDeviationZText, FallbackValue=—}" />
                            </Grid>

                            <!-- Signals list (per-row from engine's SignalNames order) -->
                            <TextBlock Style="{StaticResource DashSection}" Text="SIGNALS" />
                            <!-- Header row -->
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource DashKey}" Text="Name" Margin="0,0,4,0" />
                                <TextBlock Grid.Column="1" Style="{StaticResource DashKey}" Text="Score" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="2" Style="{StaticResource DashKey}" Text="Conf" HorizontalAlignment="Right" />
                                <TextBlock Grid.Column="3" Style="{StaticResource DashKey}" Text="TTL%" HorizontalAlignment="Right" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding SignalStates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="38" />
                                                <ColumnDefinition Width="30" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="10" FontFamily="Consolas"
                                                       Text="{Binding Name}"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                            <TextBlock Grid.Column="1" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding Score, StringFormat=+0.00;-0.00;0.00}"
                                                       Foreground="{DynamicResource Text.Primary}" />
                                            <TextBlock Grid.Column="2" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding Confidence, StringFormat=F2}"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                            <TextBlock Grid.Column="3" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding TtlRemaining, StringFormat=P0}"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Weight vector -->
                            <TextBlock Style="{StaticResource DashSection}" Text="WEIGHTS (Σ⁻¹·IC)" />
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="60" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource DashKey}" Text="Signal" />
                                <TextBlock Grid.Column="1" Style="{StaticResource DashKey}" Text="Weight" HorizontalAlignment="Right" />
                            </Grid>
                            <ItemsControl ItemsSource="{Binding SignalWeights}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" /><ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontSize="10" FontFamily="Consolas"
                                                       Text="{Binding SignalName}"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                            <TextBlock Grid.Column="1" FontSize="10" FontFamily="Consolas"
                                                       HorizontalAlignment="Right"
                                                       Text="{Binding Weight, StringFormat=+0.000;-0.000;0.000}"
                                                       Foreground="{DynamicResource Text.Primary}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Position -->
                            <TextBlock Style="{StaticResource DashSection}" Text="POSITION" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Net qty" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Position, FallbackValue=—}" />
                            </Grid>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="2" Style="{StaticResource Strategy.FooterBar}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Bid:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding LastBid, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Ask:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding LastAsk, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Ticks:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding TicksSeen}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Bars:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding Bars.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Signals:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding Signals.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                </StackPanel>
            </Border>
            </Grid>
        </DockPanel>
    </Grid>
</ui:StrategyWindowBase>
