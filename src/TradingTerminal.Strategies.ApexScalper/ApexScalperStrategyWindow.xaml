<ui:StrategyWindowBase x:Class="TradingTerminal.Strategies.ApexScalper.ApexScalperStrategyWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                       xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                       xmlns:ui="clr-namespace:TradingTerminal.UI;assembly=TradingTerminal.UI"
                       xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                       mc:Ignorable="d" Title="{Binding StrategyDisplayName}" Height="820" Width="1380" WindowStartupLocation="CenterOwner"
                       Background="{DynamicResource Background.Primary}" Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <Style x:Key="PaneTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="6,2,0,0" />
        </Style>
        <Style x:Key="DashSection" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style x:Key="DashKey" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,0,8,2" />
        </Style>
        <Style x:Key="DashValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </mah:MetroWindow.Resources>
    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Style="{StaticResource Strategy.RunStopButton}" />
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ── Setup form ─────────────────────────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <Border Style="{StaticResource Strategy.SetupCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Strategy.SetupTitle}" Text="Configure APEX microstructure scalper" />
                    <TextBlock Style="{StaticResource Strategy.SetupDescription}"
                               Text="Weighted composite of 8 order-flow signals (Delta, VPIN, OBI×2, Footprint, Absorption, HVP, Tape Speed) with regime-adaptive weights. Trades fire only when |composite| ≥ threshold AND ≥ N signals agree AND no Delta/VPIN conflict." />

                    <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Instrument" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Window (bars)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Composite threshold" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Min signals agree" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Max chart candles" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding WindowSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding CompositeThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding MinSignalsAgree, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding MaxChartCandles, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Risk %" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Daily loss %" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Max spread (price)" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Fixed qty" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding RiskPercent, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding MaxDailyLossPercent, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding MaxSpreadPriceUnits, UpdateSourceTrigger=PropertyChanged, StringFormat=F4}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding FixedQuantity, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <CheckBox IsChecked="{Binding UseDynamicSizing}" Content="Use dynamic sizing (risk %)" Margin="0,0,0,8" />

                    <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Allowed sessions (UTC)" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <CheckBox IsChecked="{Binding TradeAsian}" Content="Asian" Margin="0,0,16,0" />
                        <CheckBox IsChecked="{Binding TradeLondon}" Content="London" Margin="0,0,16,0" />
                        <CheckBox IsChecked="{Binding TradeNewYork}" Content="New York" Margin="0,0,16,0" />
                        <CheckBox IsChecked="{Binding TradeLondonNy}" Content="London/NY overlap" />
                    </StackPanel>

                    <Border Style="{StaticResource Strategy.SetupErrorBanner}"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>
                    <Button Content="Continue" Command="{Binding ContinueCommand}" HorizontalAlignment="Right"
                            IsDefault="True" MinWidth="120" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ── Running layout: param strip + chart grid + dashboard + data log + footer ────── -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live tuning strip. The composite weights / risk gates are baked into the engine at
                 build time, so those are locked while streaming (Stop to edit, Start to rebuild).
                 "Max candles" is render-only (how many internal candles each pane draws) — live. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Max candles" Minimum="10" Maximum="500" Step="10" StringFormat="0"
                                          Value="{Binding MaxChartCandles, Mode=TwoWay}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="PARAMS (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Window (bars)" Minimum="5" Maximum="500" Step="1" StringFormat="0"
                                              Value="{Binding WindowSize, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Composite thr" Minimum="0.1" Maximum="3" Step="0.05" StringFormat="0.00"
                                              Value="{Binding CompositeThreshold, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Min agree" Minimum="1" Maximum="8" Step="1" StringFormat="0"
                                              Value="{Binding MinSignalsAgree, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Risk %" Minimum="0.1" Maximum="100" Step="0.1" StringFormat="0.0"
                                              Value="{Binding RiskPercent, Mode=TwoWay}" />
                            <Border Style="{StaticResource Strategy.ParamDivider}" />
                            <ToggleButton x:Name="MoreToggle" Content="More ▾" VerticalAlignment="Center" Padding="10,3" />
                            <Popup IsOpen="{Binding IsChecked, ElementName=MoreToggle}"
                                   PlacementTarget="{Binding ElementName=MoreToggle}" Placement="Bottom"
                                   StaysOpen="False" AllowsTransparency="True">
                                <Border Style="{StaticResource Strategy.ParamPopout}">
                                    <StackPanel>
                                        <TextBlock Text="More params (applied on Start)" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <WrapPanel>
                                            <uic:ParamSpinner Label="Daily loss %" Minimum="0.1" Maximum="100" Step="0.1" StringFormat="0.0"
                                                              Value="{Binding MaxDailyLossPercent, Mode=TwoWay}" />
                                            <uic:ParamSpinner Label="Max spread" Minimum="0" Maximum="1" Step="0.0001" StringFormat="0.####" SpinnerWidth="92"
                                                              Value="{Binding MaxSpreadPriceUnits, Mode=TwoWay}" />
                                            <uic:ParamSpinner Label="Fixed qty" Minimum="1" Maximum="1000" Step="1" StringFormat="0"
                                                              Value="{Binding FixedQuantity, Mode=TwoWay}" />
                                        </WrapPanel>
                                        <CheckBox Content="Use dynamic sizing (risk %)" IsChecked="{Binding UseDynamicSizing}" Margin="0,8,0,4" />
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox Content="Asian" IsChecked="{Binding TradeAsian}" Margin="0,0,12,0" />
                                            <CheckBox Content="London" IsChecked="{Binding TradeLondon}" Margin="0,0,12,0" />
                                            <CheckBox Content="New York" IsChecked="{Binding TradeNewYork}" Margin="0,0,12,0" />
                                            <CheckBox Content="London/NY" IsChecked="{Binding TradeLondonNy}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />                <!-- Header bar     -->
                <RowDefinition Height="*"    MinHeight="200" /><!-- Charts + dash  -->
                <RowDefinition Height="Auto" />                <!-- Footer bar     -->
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Strategy.HeaderBar}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="Threshold:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding CompositeThreshold, StringFormat=F2}" Margin="6,0,16,0" />
                    <TextBlock Text="Agree:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding MinSignalsAgree}" Margin="6,0,16,0" />
                    <TextBlock Text="Window:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding MaxChartCandles}" Margin="6,0,16,0" />
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1*" MinWidth="260" />
                </Grid.ColumnDefinitions>

                <!-- Chart pane: 3 columns now — left holds the price / composite / signals stack
                     (each pane separated by a GridSplitter, same as before), a vertical splitter
                     in the middle, and the live order-book ladder on the right. All splitters are
                     4 px and share the theme's border brush. -->
                <Grid Grid.Column="0" Margin="4,4,4,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" MinWidth="320" />  <!-- Charts stack    -->
                        <ColumnDefinition Width="Auto" />               <!-- VSplit          -->
                        <ColumnDefinition Width="*"  MinWidth="200" />  <!-- Order book      -->
                    </Grid.ColumnDefinitions>

                    <!-- Left column: signals grid stacked above the composite sentiment gauge. -->
                    <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"  MinHeight="200" />   <!-- Signals grid       -->
                        <RowDefinition Height="Auto" />                 <!-- HSplit             -->
                        <RowDefinition Height="60" MinHeight="40" />    <!-- Sentiment gauge    -->
                    </Grid.RowDefinitions>

                    <!-- Signals sub-grid: 4 rows × 2 cols of indicators with splitters in every gap. -->
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"   MinHeight="60" />  <!-- Delta / VPIN           -->
                            <RowDefinition Height="Auto" />                <!-- HSplit                 -->
                            <RowDefinition Height="*"   MinHeight="60" />  <!-- OBI shallow / deep     -->
                            <RowDefinition Height="Auto" />                <!-- HSplit                 -->
                            <RowDefinition Height="*"   MinHeight="60" />  <!-- Footprint / Absorption -->
                            <RowDefinition Height="Auto" />                <!-- HSplit                 -->
                            <RowDefinition Height="*"   MinHeight="60" />  <!-- HVP / Tape speed       -->
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"  MinWidth="80" />
                            <ColumnDefinition Width="Auto" />              <!-- VSplit (all 4 rows)     -->
                            <ColumnDefinition Width="*"  MinWidth="80" />
                        </Grid.ColumnDefinitions>

                        <!-- Vertical splitter spans all signal rows so the column boundary stays
                             consistent across pairs. Declared first so the row-splitters render
                             on top at the crossing points and remain draggable.                  -->
                        <GridSplitter Grid.Column="1" Grid.RowSpan="7" Width="4"
                                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="False" />

                        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Delta" />
                                <scottplot:WpfPlot x:Name="DeltaPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="VPIN" />
                                <scottplot:WpfPlot x:Name="VpinPlot" Grid.Row="1" />
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="1" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <Border Grid.Row="2" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="OBI (shallow)" />
                                <scottplot:WpfPlot x:Name="ObiShallowPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="2" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="OBI (deep)" />
                                <scottplot:WpfPlot x:Name="ObiDeepPlot" Grid.Row="1" />
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="3" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <Border Grid.Row="4" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Footprint" />
                                <scottplot:WpfPlot x:Name="FootprintPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="4" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Absorption" />
                                <scottplot:WpfPlot x:Name="AbsorptionPlot" Grid.Row="1" />
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="5" Grid.ColumnSpan="3" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <Border Grid.Row="6" Grid.Column="0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="HVP slope" />
                                <scottplot:WpfPlot x:Name="HvpPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                        <Border Grid.Row="6" Grid.Column="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Style="{StaticResource PaneTitle}" Text="Tape speed" />
                                <scottplot:WpfPlot x:Name="TapeSpeedPlot" Grid.Row="1" />
                            </Grid>
                        </Border>
                    </Grid>

                    <GridSplitter Grid.Row="1" Height="4"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="{DynamicResource Border.Brush}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                    <!-- Composite sentiment gauge: a horizontal slider with red on the left
                         (short bias), grey at centre (neutral), green on the right (long bias).
                         The triangle marker tracks the latest composite score; tick marks denote
                         the user's CompositeThreshold so it's visible where the trade gate sits. -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Background="{DynamicResource Background.Surface}">
                        <Grid Margin="6,4,6,4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="SHORT"
                                           Foreground="{DynamicResource Bearish.Brush}"
                                           FontWeight="Bold" FontSize="10" />
                                <TextBlock Grid.Column="1" x:Name="GaugeLabel"
                                           Text="composite —"
                                           Foreground="{DynamicResource Text.Header}"
                                           FontWeight="Bold" FontSize="11"
                                           HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="LONG"
                                           Foreground="{DynamicResource Bullish.Brush}"
                                           FontWeight="Bold" FontSize="10" />
                            </Grid>

                            <Grid Grid.Row="1" x:Name="GaugeTrackHost" VerticalAlignment="Center" Height="20" ClipToBounds="True">
                                <Border CornerRadius="3" Height="16" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#FF1744" Offset="0" />
                                            <GradientStop Color="#5A2A2A" Offset="0.40" />
                                            <GradientStop Color="#3A3A3A" Offset="0.5" />
                                            <GradientStop Color="#2A5A4A" Offset="0.60" />
                                            <GradientStop Color="#00C853" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Threshold tick marks (painted in code-behind so they track CompositeThreshold). -->
                                <Canvas x:Name="GaugeTicks" Background="Transparent" />

                                <!-- Needle: a triangle pinned at the bottom; X position set in code-behind. -->
                                <Canvas x:Name="GaugeNeedleHost" Background="Transparent">
                                    <Polygon x:Name="GaugeNeedle"
                                             Points="-6,0 6,0 0,12"
                                             Fill="White"
                                             Stroke="Black" StrokeThickness="1"
                                             Canvas.Top="2" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>
                    </Grid>   <!-- end chart stack (Col 0) -->

                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Center" VerticalAlignment="Stretch"
                                  Background="{DynamicResource Border.Brush}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="False" />

                    <!-- Right column: order book (top) + live candle (bottom), separated by a
                         horizontal splitter so the user can rebalance them. -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"  MinHeight="120" />  <!-- Order book      -->
                            <RowDefinition Height="Auto" />                <!-- HSplit          -->
                            <RowDefinition Height="*"  MinHeight="120" />  <!-- Live candle     -->
                        </Grid.RowDefinitions>

                        <!-- Live order book — 10 ask levels (tightest at the bottom), spread row,
                             10 bid levels (tightest at the top). Volume bars are proportional;
                             the largest level on each side is highlighted. Rendered from
                             code-behind so we update Rectangle widths in place rather than
                             rebuilding the visual tree on every tick. -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                                Background="{DynamicResource Background.Surface}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource Background.Elevated}"
                                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1"
                                        Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="ORDER BOOK"
                                                   Foreground="{DynamicResource Text.Header}"
                                                   FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" x:Name="OrderBookStatus"
                                                   Margin="8,0,0,0" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Text="awaiting depth" />
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel x:Name="OrderBookLadder" Orientation="Vertical" />
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <GridSplitter Grid.Row="1" Height="4"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      Background="{DynamicResource Border.Brush}"
                                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                        <!-- Live candle: the in-progress internal candle the engine is currently
                             building. Body + wick on the left, OHLC / volume / delta stats on the
                             right. Resets visually when the engine rolls into a new candle. -->
                        <Border Grid.Row="2"
                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                                Background="{DynamicResource Background.Surface}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource Background.Elevated}"
                                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1"
                                        Padding="6,3">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="LIVE CANDLE"
                                                   Foreground="{DynamicResource Text.Header}"
                                                   FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" x:Name="LiveCandleStatus"
                                                   Margin="8,0,0,0" HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   Text="awaiting tick" />
                                    </Grid>
                                </Border>

                                <Grid Grid.Row="1" Margin="6,6,6,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60" />     <!-- candle drawing -->
                                        <ColumnDefinition Width="*" />      <!-- stats          -->
                                    </Grid.ColumnDefinitions>

                                    <!-- The candle itself: wick line + body rectangle, positioned
                                         in code-behind so the body height tracks |Close-Open| and
                                         vertical position tracks Low..High. -->
                                    <Canvas Grid.Column="0" x:Name="LiveCandleCanvas" Background="{DynamicResource Background.Surface}" />

                                    <!-- Stats column: O/H/L/C, volume, delta, buy/sell, efficiency. -->
                                    <Grid Grid.Column="1" Margin="6,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="O" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="LiveOpen"  Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="H" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="LiveHigh"  Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="L" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="LiveLow"   Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashKey}" Text="C" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="LiveClose" Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashKey}" Text="Vol" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="LiveVolume" Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DashKey}" Text="Δ" />
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="LiveDelta"  Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DashKey}" Text="B / S" />
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="LiveBuySell" Style="{StaticResource DashValue}" Text="—" />
                                        <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource DashKey}" Text="Δ eff" />
                                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="LiveDeltaEff" Style="{StaticResource DashValue}" Text="—" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Dashboard panel: mirrors the MT5 on-chart dashboard sections. -->
                <Border Grid.Column="1" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                        Background="{DynamicResource Background.Elevated}" Margin="0,4,4,4" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DashSection}" Text="COMPOSITE" Margin="0,0,0,4" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Score" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Composite, StringFormat=F3, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="Direction" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.CompositeDirection, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="Agree / 8" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.SignalsAgree, FallbackValue=—}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashKey}" Text="Conflict" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.ConflictFlag, FallbackValue=—}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashKey}" Text="Trade OK" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.TradeAllowed, FallbackValue=—}" />
                            </Grid>

                            <TextBlock Style="{StaticResource DashSection}" Text="REGIME" />
                            <TextBlock Style="{StaticResource DashValue}" HorizontalAlignment="Left" Text="{Binding LatestSnapshot.Regime, FallbackValue=—}" />

                            <TextBlock Style="{StaticResource DashSection}" Text="SIGNALS" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Delta" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Delta.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Delta.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="VPIN" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Vpin.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Vpin.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="OBI (shallow)" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.ObiShallow.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.ObiShallow.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashKey}" Text="OBI (deep)" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.ObiDeep.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.ObiDeep.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashKey}" Text="Footprint" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Footprint.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Footprint.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DashKey}" Text="Absorption" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Absorption.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="5" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Absorption.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DashKey}" Text="HVP" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Hvp.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="6" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Hvp.IsValid, FallbackValue=—}" />
                                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource DashKey}" Text="Tape speed" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.TapeSpeed.Score, StringFormat=F2, FallbackValue=—}" Margin="0,0,8,2" />
                                <TextBlock Grid.Row="7" Grid.Column="2" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.TapeSpeed.IsValid, FallbackValue=—}" />
                            </Grid>

                            <TextBlock Style="{StaticResource DashSection}" Text="RISK" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Kill switch" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.KillSwitch, FallbackValue=—}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashKey}" Text="Daily PnL" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.DailyPnl, StringFormat=F2, FallbackValue=—}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashKey}" Text="Balance" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Balance, StringFormat=F2, FallbackValue=—}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashKey}" Text="Peak equity" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.PeakEquity, StringFormat=F2, FallbackValue=—}" />
                            </Grid>

                            <TextBlock Style="{StaticResource DashSection}" Text="POSITION" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashKey}" Text="Net qty" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DashValue}" Text="{Binding LatestSnapshot.Position, FallbackValue=—}" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>


            <Border Grid.Row="2" Style="{StaticResource Strategy.FooterBar}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Bid:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding LastBid, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Ask:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding LastAsk, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Ticks:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding TicksSeen}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Bars:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding Bars.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Text="  |  Signals:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" />
                    <TextBlock Text="{Binding Signals.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                </StackPanel>
            </Border>
            </Grid>
        </DockPanel>
    </Grid>
</ui:StrategyWindowBase>
