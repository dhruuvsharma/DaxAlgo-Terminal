<mah:MetroWindow x:Class="TradingTerminal.Strategies.OrderFlowPressureMap.OrderFlowPressureMapWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 mc:Ignorable="d"
                 Title="1-Minute Order Flow Pressure Map"
                 Height="860" Width="1280"
                 WindowStartupLocation="CenterOwner"
                 Background="#0B0F14"
                 Foreground="#E6EDF3">
    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </mah:MetroWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <Border Grid.Row="0" Background="#111820" BorderBrush="#263241" BorderThickness="0,0,0,1" Padding="10,7">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Universe" VerticalAlignment="Center" Foreground="#8A94A6" FontSize="11" Margin="0,0,6,0" />
                <ComboBox Width="90" ItemsSource="{Binding Universes}" SelectedItem="{Binding SelectedUniverse}"
                          Margin="0,0,18,0" />

                <TextBlock Text="Min RelVol" VerticalAlignment="Center" Foreground="#8A94A6" FontSize="11" Margin="0,0,6,0" />
                <mah:NumericUpDown Width="78" Minimum="0" Maximum="20" Interval="0.5" StringFormat="0.0"
                                   Value="{Binding MinRelVol}" Margin="0,0,18,0" />

                <TextBlock Text="Signal" VerticalAlignment="Center" Foreground="#8A94A6" FontSize="11" Margin="0,0,6,0" />
                <ComboBox Width="120" ItemsSource="{Binding SignalFilters}" SelectedItem="{Binding SelectedSignalFilter}"
                          Margin="0,0,18,0" />

                <CheckBox Content="Active signals only" IsChecked="{Binding ShowOnlyActive}"
                          VerticalAlignment="Center" Foreground="#E6EDF3" />
            </StackPanel>
        </Border>

        <!-- Matrix + overlays -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="Scroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          Background="#0B0F14">
                <Canvas x:Name="PressureCanvas" Background="Transparent"
                        MouseMove="OnCanvasMouseMove" MouseLeave="OnCanvasMouseLeave"
                        MouseLeftButtonDown="OnCanvasMouseDown" />
            </ScrollViewer>

            <!-- Pinned-row inline detail overlay -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,12,0,0"
                    Background="#111820" Opacity="0.97" BorderBrush="#263241" BorderThickness="1"
                    CornerRadius="4" Padding="12,9" MinWidth="240"
                    Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Grid>
                        <TextBlock Text="{Binding PinnedTitle}" FontWeight="SemiBold" FontSize="12"
                                   Foreground="#E6EDF3" TextTrimming="CharacterEllipsis" Margin="0,0,20,6" />
                        <Button Content="✕" Command="{Binding UnpinCommand}" HorizontalAlignment="Right"
                                VerticalAlignment="Top" Background="Transparent" BorderThickness="0"
                                Foreground="#8A94A6" Padding="2,0" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Last price" Foreground="#8A94A6" FontSize="11" Margin="0,1,14,1" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PinnedPrice}" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="11" Margin="0,1,0,1" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="1m candle" Foreground="#8A94A6" FontSize="11" Margin="0,1,14,1" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PinnedCandle}" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="11" Margin="0,1,0,1" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Rel volume" Foreground="#8A94A6" FontSize="11" Margin="0,1,14,1" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PinnedRelVol}" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="11" Margin="0,1,0,1" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Book imbalance" Foreground="#8A94A6" FontSize="11" Margin="0,1,14,1" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PinnedImbalance}" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="11" Margin="0,1,0,1" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Last signal" Foreground="#8A94A6" FontSize="11" Margin="0,1,14,1" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding PinnedSignal}" Foreground="#E6EDF3" FontSize="11" Margin="0,1,6,1" />
                            <TextBlock Text="{Binding PinnedSignalTime}" Foreground="#8A94A6" FontFamily="Consolas" FontSize="11" Margin="0,1,0,1" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Floating hover tooltip (moved in code-behind) -->
            <Border x:Name="TooltipBorder" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Background="#111820" BorderBrush="#263241" BorderThickness="1" CornerRadius="3"
                    Padding="8,6" Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock x:Name="TooltipText" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="11" />
            </Border>
        </Grid>

        <!-- Legend + status -->
        <Border Grid.Row="2" Background="#111820" BorderBrush="#263241" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Width="11" Height="11" Background="#00E5FF" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Bull Absorption" FontSize="11" Foreground="#8A94A6" Margin="0,0,12,0" />
                    <Border Width="11" Height="11" Background="#B388FF" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Bear Absorption" FontSize="11" Foreground="#8A94A6" Margin="0,0,12,0" />
                    <Border Width="11" Height="11" Background="#00C853" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Bull Breakthrough" FontSize="11" Foreground="#8A94A6" Margin="0,0,12,0" />
                    <Border Width="11" Height="11" Background="#FF1744" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Bear Breakdown" FontSize="11" Foreground="#8A94A6" Margin="0,0,12,0" />
                    <Border Width="11" Height="11" Background="#1C2530" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="Neutral" FontSize="11" Foreground="#8A94A6" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="11" Foreground="#8A94A6"
                           VerticalAlignment="Center" TextAlignment="Right" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
