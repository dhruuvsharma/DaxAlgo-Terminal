<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls">

    <!-- ===================================================================================
         Structural style layer — theme-agnostic. Every brush/colour/gradient/font key it
         references is supplied by the active PALETTE dictionary (Themes/Brushes.xaml,
         Themes/Monochrome.xaml, …), which App.xaml merges *before* this file and which
         ThemeManager hot-swaps at runtime. All palette references here are DynamicResource so a
         swap re-skins live. The MahApps accent override now lives in each palette too.
         =================================================================================== -->

    <!-- Window / shell defaults -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{DynamicResource Background.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="{x:Type UserControl}">
        <Setter Property="Background" Value="{DynamicResource Background.Primary}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
    </Style>

    <!-- Rounded, accent-focus text input (based on MahApps so CornerRadius + clear button work). -->
    <Style TargetType="{x:Type TextBox}" BasedOn="{StaticResource MahApps.Styles.TextBox}">
        <Setter Property="mah:ControlsHelper.CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Accent.Brush}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="MinHeight" Value="26" />
    </Style>

    <!-- Same treatment for password / numeric MahApps inputs. -->
    <Style TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource MahApps.Styles.PasswordBox}">
        <Setter Property="mah:ControlsHelper.CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="MinHeight" Value="26" />
    </Style>

    <!-- Base on the MahApps dark ComboBox style so we inherit its ControlTemplate (and themed
         item containers). A bare implicit style here would otherwise OVERRIDE the MahApps style
         (Dark.xaml is merged after Controls.xaml) and fall back to the default WPF template, whose
         toggle chrome renders white regardless of the Background setter. -->
    <Style TargetType="{x:Type ComboBox}" BasedOn="{StaticResource MahApps.Styles.ComboBox}">
        <Setter Property="mah:ControlsHelper.CornerRadius" Value="4" />
        <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="MinHeight" Value="26" />
    </Style>

    <!-- Amber checkbox (MahApps tick now reads amber via the accent override). -->
    <Style TargetType="{x:Type CheckBox}" BasedOn="{StaticResource MahApps.Styles.CheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
    </Style>
    <Style TargetType="{x:Type RadioButton}" BasedOn="{StaticResource MahApps.Styles.RadioButton}">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
    </Style>

    <!-- ===== Button: rounded, gradient, amber hover-wash that animates in/out ===== -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Background" Value="{DynamicResource Gradient.Elevated}" />
        <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Strong}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- amber wash overlay, faded in on hover -->
                            <Border x:Name="wash" CornerRadius="4" Background="{DynamicResource Accent.Brush}" Opacity="0" />
                            <ContentPresenter x:Name="cp" Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="wash" Storyboard.TargetProperty="Opacity"
                                                         To="0.16" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="wash" Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="wash" Property="Opacity" Value="0.30" />
                            <Setter TargetName="cp" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="cp" Property="RenderTransformOrigin" Value="0.5,0.5" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.42" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== ListBox + rounded, accent-rail items with smooth hover ===== -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Margin" Value="3,1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bd" CornerRadius="4" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="2,0,0,0"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Surface.Hover}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent.Dim.Brush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent.Soft}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{DynamicResource Border.Brush}" />
    </Style>

    <Style TargetType="{x:Type StatusBar}">
        <Setter Property="Background" Value="{DynamicResource Gradient.Chrome}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Menus: ride the MahApps templates (now amber) + our mono font. -->
    <Style TargetType="{x:Type Menu}" BasedOn="{StaticResource MahApps.Styles.Menu}">
        <Setter Property="Background" Value="{DynamicResource Gradient.Chrome}" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource MahApps.Styles.MenuItem}">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
    </Style>

    <!-- Dark, rounded tooltip. -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border CornerRadius="5" Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Accent.Dim.Brush}" BorderThickness="1"
                            Padding="9,6" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.55" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Bloomberg-style section header label (amber, uppercase, dense) -->
    <Style x:Key="BB.SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Text.Header}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="8,5" />
    </Style>

    <!-- Bloomberg-style "function key" tile: amber background, black text, monospace label -->
    <Style x:Key="BB.FnKey" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.Accent}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="Margin" Value="0,0,4,0" />
    </Style>

</ResourceDictionary>
