<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target: net9.0 = portable (Linux/ARM64), net9.0-windows7.0 = Windows WPF build.
         Clears the singular TargetFramework inherited from Directory.Build.props so the SDK
         honors TargetFrameworks (plural) and does an outer multi-target build. -->
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Description>Domain models and abstractions. No UI or IB dependencies.</Description>
  </PropertyGroup>

  <!-- NuGet contract package in the plugin-SDK dependency chain (DaxAlgo.Sdk depends on this).
       Versioned in lockstep with the SDK (DaxAlgoSdkVersion), NOT the app release version.
       AGPL-3.0 — only the DaxAlgo.Sdk* facades are MIT. -->
  <PropertyGroup>
    <Version>$(DaxAlgoSdkVersion)</Version>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageTags>daxalgo;trading;plugin;sdk;contract</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Reactive" Version="6.0.1" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="TradingTerminal.Tests" />
    <InternalsVisibleTo Include="TradingTerminal.Tests.Headless" />
  </ItemGroup>

</Project>
