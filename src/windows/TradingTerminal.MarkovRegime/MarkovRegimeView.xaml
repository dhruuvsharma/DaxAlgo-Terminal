<UserControl x:Class="TradingTerminal.MarkovRegime.MarkovRegimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="1040"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Markov regime detection" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Fits a Gaussian hidden Markov model to the instrument's per-bar log returns and labels the latent states by mean return (bearish / neutral / bullish). The chart shades each bar by its decoded regime; the panel shows each state's drift, expected duration, the transition matrix, and the current regime with its probability. Offline analysis over stored/historical bars — pure statistics, no live execution."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Controls row -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="60" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBox Grid.Column="1"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter symbols..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="Instrument" VerticalAlignment="Center" Margin="0,0,6,0" />
                <uic:InstrumentPicker Grid.Column="3"
                           ShowSearch="False"
                           ItemsSource="{Binding Instruments}"
                           SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                           MaxDropDownHeight="420"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="4" Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="5"
                           ItemsSource="{Binding Timeframes}"
                           SelectedItem="{Binding SelectedTimeframe}"
                           DisplayMemberPath="Label"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="6" Text="States" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="7"
                           ItemsSource="{Binding StateCounts}"
                           SelectedItem="{Binding StateCount}"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="8" Text="Bars" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox   Grid.Column="9"
                           Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                           Margin="0,0,12,0" />

                <Button Grid.Column="10" Content="Fit"
                        Command="{Binding FitCommand}"
                        IsEnabled="{Binding IsFitting, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,6,0" />
                <Button Grid.Column="11" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsFitting}"
                        Padding="14,4" />
            </Grid>
        </Border>

        <!-- Main: chart + analysis panel -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Price + regime-ribbon chart -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <sp:WpfPlot x:Name="RegimePlot" />
            </Border>

            <!-- Right analysis panel -->
            <ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Current regime -->
                    <Border Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="CURRENT REGIME" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <TextBlock Text="{Binding CurrentLabel}" FontSize="30" FontWeight="Bold"
                                       Foreground="{Binding CurrentColor, Converter={StaticResource StringToBrushConverter}}" />
                            <TextBlock Text="{Binding CurrentProbability}" FontSize="14"
                                       Foreground="{DynamicResource Text.Secondary}" />
                        </StackPanel>
                    </Border>

                    <!-- State summary -->
                    <TextBlock Text="States" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <DataGrid ItemsSource="{Binding States}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              CanUserResizeRows="False" RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Regime" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="10" Height="10" CornerRadius="2" Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding Color, Converter={StaticResource StringToBrushConverter}}" />
                                            <TextBlock Text="{Binding Label}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="μ/bar" Binding="{Binding MeanPct}" Width="70" />
                            <DataGridTextColumn Header="Dur"   Binding="{Binding DurationBars}" Width="48" />
                            <DataGridTextColumn Header="Occ"   Binding="{Binding OccupancyPct}" Width="56" />
                            <DataGridTextColumn Header="Stat"  Binding="{Binding StationaryPct}" Width="56" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Transition matrix -->
                    <TextBlock Text="Transition matrix" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <Border Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="10,8">
                        <TextBlock Text="{Binding TransitionMatrixText}"
                                   FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12"
                                   Foreground="{DynamicResource Text.Primary}" />
                    </Border>

                    <TextBlock Text="{Binding FitStatus}" Margin="0,12,0,0"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding BarsStatus}"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0"
                   Foreground="{DynamicResource Danger.Brush}"
                   Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
