<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <UseWPF>false</UseWPF>
    <IsPackable>true</IsPackable>
    <PackageId>DaxAlgo.Strategy.Bundle</PackageId>
    <Version>$(DaxAlgoSdkVersion)</Version>
    <Description>Portable, signed DaxAlgo strategy bundle format and verifier.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\..\..\docs\strategy-bundles.md" Pack="true" PackagePath="README.md" Link="README.md" />
    <InternalsVisibleTo Include="TradingTerminal.Tests.Headless" />
  </ItemGroup>

</Project>
