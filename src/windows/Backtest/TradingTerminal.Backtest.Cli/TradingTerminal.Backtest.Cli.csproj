<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <!-- Multi-target so daxalgo-backtest runs on Linux/ARM64 (net9.0) and Windows (see Core.csproj). -->
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TradingTerminal.Backtest.Cli</RootNamespace>
    <AssemblyName>daxalgo-backtest</AssemblyName>
    <Description>Headless backtest runner over the TradingTerminal engine.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Core\TradingTerminal.Core\TradingTerminal.Core.csproj" />
    <ProjectReference Include="..\..\Pipeline\TradingTerminal.Infrastructure\TradingTerminal.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The CLI is a composition host: it builds a ServiceCollection to load strategy plugins via
         PluginLoader (which registers through IServiceCollection). DaxAlgo.Sdk + the loader flow
         transitively from Infrastructure. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.0" />
  </ItemGroup>

</Project>
