<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.Ai.MlFeatures.AvaloniaUi.MlFeaturesAvaloniaWindow"
        Width="720" Height="560"
        Background="{DynamicResource Background.Primary}"
        Title="ML features">
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="ML features — triple-barrier labelling" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Width="340" Watermark="Parquet tick file…" Text="{Binding DataPath}"/>
        <Button Content="Browse…" Command="{Binding BrowseDataCommand}"/>
        <Button Content="Compute" Command="{Binding ComputeCommand}"/>
        <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="Bar ticks" VerticalAlignment="Center"/>
        <NumericUpDown Width="100" Value="{Binding BarTicks}" Minimum="2"/>
        <TextBlock Text="Upper" VerticalAlignment="Center"/>
        <NumericUpDown Width="100" Value="{Binding UpperBarrier}" Increment="0.01"/>
        <TextBlock Text="Lower" VerticalAlignment="Center"/>
        <NumericUpDown Width="100" Value="{Binding LowerBarrier}" Increment="0.01"/>
        <TextBlock Text="Timeout" VerticalAlignment="Center"/>
        <NumericUpDown Width="100" Value="{Binding TimeoutBars}" Minimum="1"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Text="{Binding PositiveCount, StringFormat='+1: {0}'}" Foreground="{DynamicResource Bullish.Brush}"/>
        <TextBlock Text="{Binding NeutralCount, StringFormat='0: {0}'}" Foreground="{DynamicResource Text.Secondary}"/>
        <TextBlock Text="{Binding NegativeCount, StringFormat='-1: {0}'}" Foreground="{DynamicResource Bearish.Brush}"/>
      </StackPanel>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding ValidationError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <Border Margin="0,10,0,0" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
      <ListBox ItemsSource="{Binding Preview}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
    </Border>
  </DockPanel>
</Window>
