<UserControl x:Class="TradingTerminal.Ml.Stationarity.StationarityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="1040"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Stationarity &amp; differencing" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Tests whether a series is statistically modellable: ADF (null = unit root) and KPSS (null = stationary) on the chosen transform — raw price, log price, first difference, log returns, or fractional differencing (keeps memory while killing the trend). The top chart shows the transformed series with its rolling mean ± 2σ (drifting moments = non-stationary); the bottom chart is the autocorrelation function with the white-noise band. Offline analysis over stored/historical bars."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Controls row -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="55" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="55" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBox Grid.Column="1"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter symbols..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="Instrument" VerticalAlignment="Center" Margin="0,0,6,0" />
                <uic:InstrumentPicker Grid.Column="3"
                           ShowSearch="False"
                           ItemsSource="{Binding Instruments}"
                           SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                           MaxDropDownHeight="420"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="4" Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="5"
                           ItemsSource="{Binding Timeframes}"
                           SelectedItem="{Binding SelectedTimeframe}"
                           DisplayMemberPath="Label"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="6" Text="Transform" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="7"
                           ItemsSource="{Binding Transforms}"
                           SelectedItem="{Binding SelectedTransform}"
                           DisplayMemberPath="Label"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="8" Text="d" VerticalAlignment="Center" Margin="0,0,6,0"
                           Visibility="{Binding IsFracDVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBox   Grid.Column="9"
                           Text="{Binding FracD, UpdateSourceTrigger=PropertyChanged}"
                           Visibility="{Binding IsFracDVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Margin="0,0,12,0" />

                <TextBlock Grid.Column="10" Text="Bars" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox   Grid.Column="11"
                           Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                           Margin="0,0,12,0" />

                <Button Grid.Column="12" Content="Run"
                        Command="{Binding RunCommand}"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,6,0" />
                <Button Grid.Column="13" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Padding="14,4" />

                <StackPanel Grid.Column="14" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                            ToolTip="Save a PNG snapshot of this window" />
                    <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                                  Margin="0" ToolTip="What am I looking at?" />
                    <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
                           HorizontalOffset="-330" VerticalOffset="6">
                        <Border Style="{StaticResource App.Card}" Width="390" Padding="16"
                                Background="{DynamicResource Background.Elevated}">
                            <StackPanel>
                                <TextBlock Text="READING STATIONARITY &amp; DIFFERENCING" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                    <Run FontWeight="SemiBold" Text="Why" /><Run Text=" — most models assume a stationary series; raw prices aren't. This window shows what a transform (returns, log-diff, fractional d) does to stationarity and how much memory it destroys." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="ADF" /><Run Text=" — null: unit root (non-stationary). p &lt; 0.05 rejects it — good." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="KPSS" /><Run Text=" — null flipped: stationary. p &gt; 0.05 keeps it — good. ADF and KPSS agreeing is the strong read." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Fractional d" /><Run Text=" — differencing between 0 and 1: find the smallest d that passes ADF while the ACF still shows memory — that's the López-de-Prado sweet spot." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="ACF" /><Run Text=" — bars outside the band are significant autocorrelation (memory a model can use)." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main: charts + analysis panel -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Transformed series + ACF, stacked -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                    <sp:WpfPlot x:Name="SeriesPlot" />
                </Border>
                <Border Grid.Row="1" Margin="0,8,0,0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                    <sp:WpfPlot x:Name="AcfPlot" />
                </Border>
            </Grid>

            <!-- Right analysis panel -->
            <ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- ADF card -->
                    <Border Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="ADF — AUGMENTED DICKEY-FULLER" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding AdfStatistic}" FontSize="28" FontWeight="Bold" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding AdfVerdict}" FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding AdfVerdictColor, Converter={StaticResource StringToBrushConverter}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding AdfDetail}" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- KPSS card -->
                    <Border Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="16,12" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="KPSS — LEVEL STATIONARITY" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding KpssStatistic}" FontSize="28" FontWeight="Bold" Margin="0,0,10,0" />
                                <TextBlock Text="{Binding KpssVerdict}" FontSize="16" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{Binding KpssVerdictColor, Converter={StaticResource StringToBrushConverter}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding KpssDetail}" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Agreement + recommendation -->
                    <TextBlock Text="Verdict" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <Border Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="10,8">
                        <TextBlock Text="{Binding AgreementText}" TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <TextBlock Text="Differencing recommendation" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <Border Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="10,8">
                        <TextBlock Text="{Binding RecommendationText}" TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <TextBlock Text="{Binding RunStatus}" Margin="0,12,0,0"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0"
                   Foreground="{DynamicResource Danger.Brush}"
                   Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
