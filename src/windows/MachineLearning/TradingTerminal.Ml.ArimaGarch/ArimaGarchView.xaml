<UserControl x:Class="TradingTerminal.Ml.ArimaGarch.ArimaGarchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="1040"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="ARIMA &amp; GARCH" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Fits ARIMA(p,d,q) to log prices for point forecasting (auto mode searches (p,q) by AIC at the chosen d) and GARCH(1,1) to log returns for conditional volatility. The top chart shows price history with the h-bar forecast and its 95% band (log-normal, so asymmetric); the bottom chart tracks the fitted per-bar volatility against its long-run level — clustering is what GARCH exists to capture. Offline analysis over stored/historical bars; forecasts are statistical extrapolations, not signals."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Controls row -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBox Grid.Column="1"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,10,0" />

                <TextBlock Grid.Column="2" Text="Instrument" VerticalAlignment="Center" Margin="0,0,6,0" />
                <uic:InstrumentPicker Grid.Column="3"
                           ShowSearch="False"
                           ItemsSource="{Binding Instruments}"
                           SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                           MaxDropDownHeight="420"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="4" Text="TF" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="5"
                           ItemsSource="{Binding Timeframes}"
                           SelectedItem="{Binding SelectedTimeframe}"
                           DisplayMemberPath="Label"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="6" Text="p" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox  Grid.Column="7" ItemsSource="{Binding Orders}" SelectedItem="{Binding P}"
                           IsEnabled="{Binding AutoOrder, Converter={StaticResource InverseBooleanConverter}}"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Column="8" Text="d" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox  Grid.Column="9" ItemsSource="{Binding DiffOrders}" SelectedItem="{Binding D}"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Column="10" Text="q" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox  Grid.Column="11" ItemsSource="{Binding Orders}" SelectedItem="{Binding Q}"
                           IsEnabled="{Binding AutoOrder, Converter={StaticResource InverseBooleanConverter}}"
                           Margin="0,0,8,0" />

                <CheckBox Grid.Column="12" Content="Auto (AIC)" IsChecked="{Binding AutoOrder}"
                          VerticalAlignment="Center" Margin="0,0,10,0" />

                <TextBlock Grid.Column="13" Text="Bars" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Column="14" Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                           Margin="0,0,8,0" />
                <TextBlock Grid.Column="15" Text="Fcst" VerticalAlignment="Center" Margin="0,0,4,0"
                           ToolTip="Forecast horizon (bars ahead)" />
                <TextBox   Grid.Column="16" Text="{Binding Horizon, UpdateSourceTrigger=PropertyChanged}"
                           Margin="0,0,10,0" />

                <Button Grid.Column="17" Content="Fit"
                        Command="{Binding FitCommand}"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,6,0" />
                <Button Grid.Column="18" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Padding="14,4" />

                <StackPanel Grid.Column="19" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                            ToolTip="Save a PNG snapshot of this window" />
                    <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                                  Margin="0" ToolTip="What am I looking at?" />
                    <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
                           HorizontalOffset="-330" VerticalOffset="6">
                        <Border Style="{StaticResource App.Card}" Width="390" Padding="16"
                                Background="{DynamicResource Background.Elevated}">
                            <StackPanel>
                                <TextBlock Text="READING ARIMA + GARCH" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                    <Run FontWeight="SemiBold" Text="ARIMA(p,d,q)" /><Run Text=" — fits the conditional mean of the (differenced) series; the forecast fan is the mean path with its widening confidence band." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="GARCH(1,1)" /><Run Text=" — fits the conditional variance: volatility clustering. The vol panel is the annualised conditional σ — regime spikes show as ridges." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Order search" /><Run Text=" — the grid ranks (p,q) combinations by information criterion (lower is better); prefer the simplest order within ~2 of the best." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Honesty" /><Run Text=" — a mean forecast on liquid markets is weak by construction; the value is mostly in the variance model and residual diagnostics." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main: charts + analysis panel -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="370" />
            </Grid.ColumnDefinitions>

            <!-- Forecast + volatility, stacked -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                    <sp:WpfPlot x:Name="ForecastPlot" />
                </Border>
                <Border Grid.Row="1" Margin="0,8,0,0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                    <sp:WpfPlot x:Name="VolPlot" />
                </Border>
            </Grid>

            <!-- Right analysis panel -->
            <ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- ARIMA card -->
                    <Border Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="ARIMA MODEL" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <TextBlock Text="{Binding ArimaTitle}" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="{Binding ArimaCoefficients}" FontSize="11" TextWrapping="Wrap"
                                       FontFamily="Consolas, Cascadia Mono, monospace" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding ArimaCriteria}" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Forecast summary -->
                    <TextBlock Text="Forecast" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <Border Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="10,8">
                        <TextBlock Text="{Binding ForecastSummary}" TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <!-- Order search table -->
                    <TextBlock Text="Order search (by AIC)" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <DataGrid ItemsSource="{Binding OrderSearchRows}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              CanUserResizeRows="False" RowHeaderWidth="0"
                              GridLinesVisibility="Horizontal" Background="Transparent">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="(p,d,q)" Binding="{Binding Order}" Width="90" />
                            <DataGridTextColumn Header="AIC" Binding="{Binding AicText}" Width="90" />
                            <DataGridTextColumn Header="BIC" Binding="{Binding BicText}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- GARCH card -->
                    <Border Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="16,12" Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="GARCH(1,1) — VOLATILITY" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding GarchPersistence}" FontSize="28" FontWeight="Bold" Margin="0,0,10,0"
                                           Foreground="{Binding GarchPersistenceColor, Converter={StaticResource StringToBrushConverter}}" />
                                <TextBlock Text="persistence (α+β)" FontSize="12" VerticalAlignment="Center"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </StackPanel>
                            <TextBlock Text="{Binding GarchParams}" FontSize="11" TextWrapping="Wrap"
                                       FontFamily="Consolas, Cascadia Mono, monospace" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding GarchVolSummary}" FontSize="11" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Text.Secondary}" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding RunStatus}" Margin="0,12,0,0"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0"
                   Foreground="{DynamicResource Danger.Brush}"
                   Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
