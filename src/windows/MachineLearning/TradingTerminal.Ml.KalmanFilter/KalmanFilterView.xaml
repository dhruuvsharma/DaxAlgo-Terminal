<UserControl x:Class="TradingTerminal.Ml.KalmanFilter.KalmanFilterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="1040"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Kalman filter" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Recursive state estimation over historical bars. Local level smooths price adaptively (an EWMA whose gain follows the signal-to-noise ratio); local linear trend adds a slope state so drifting prices track without lag; dynamic hedge ratio runs the time-varying pairs regression yₜ = αₜ + βₜ·xₜ on two instruments' log prices — the spread's standardized innovation is the classic mean-reversion z-score. The Q/R knob trades smoothness against responsiveness; the bottom chart's innovations should hug ±2 if the model is honest. Offline analysis over stored/historical bars."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Controls row -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="64" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBox Grid.Column="1"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,10,0" />

                <TextBlock Grid.Column="2" Text="Instrument" VerticalAlignment="Center" Margin="0,0,6,0" />
                <uic:InstrumentPicker Grid.Column="3"
                           ShowSearch="False"
                           ItemsSource="{Binding Instruments}"
                           SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                           MaxDropDownHeight="420"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="4" Text="vs" VerticalAlignment="Center" Margin="0,0,6,0"
                           Visibility="{Binding IsPairsMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <uic:InstrumentPicker Grid.Column="5"
                           ShowSearch="False"
                           ItemsSource="{Binding Instruments}"
                           SelectedInstrument="{Binding SecondInstrument, Mode=TwoWay}"
                           MaxDropDownHeight="420"
                           Visibility="{Binding IsPairsMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="6" Text="TF" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="7"
                           ItemsSource="{Binding Timeframes}"
                           SelectedItem="{Binding SelectedTimeframe}"
                           DisplayMemberPath="Label"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="8" Text="Model" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox  Grid.Column="9"
                           ItemsSource="{Binding Modes}"
                           SelectedItem="{Binding SelectedMode}"
                           DisplayMemberPath="Label"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="10" Text="Q/R" VerticalAlignment="Center" Margin="0,0,6,0"
                           ToolTip="Process/observation noise ratio — bigger tracks faster, noisier" />
                <ComboBox  Grid.Column="11"
                           ItemsSource="{Binding QrRatios}"
                           SelectedItem="{Binding QrRatio}"
                           Margin="0,0,10,0" />

                <TextBlock Grid.Column="12" Text="Bars" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Column="13" Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}"
                           Margin="0,0,10,0" />

                <Button Grid.Column="14" Content="Run"
                        Command="{Binding RunCommand}"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,4" Margin="0,0,6,0" />
                <Button Grid.Column="15" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Padding="14,4" />

                <StackPanel Grid.Column="16" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                            ToolTip="Save a PNG snapshot of this window" />
                    <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                                  Margin="0" ToolTip="What am I looking at?" />
                    <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
                           HorizontalOffset="-330" VerticalOffset="6">
                        <Border Style="{StaticResource App.Card}" Width="390" Padding="16"
                                Background="{DynamicResource Background.Elevated}">
                            <StackPanel>
                                <TextBlock Text="READING THE KALMAN FILTER" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                    <Run FontWeight="SemiBold" Text="State" /><Run Text=" — a local-level(+trend) model: the filter tracks the latent 'true' price/trend through noisy observations, weighting each tick by the ratio of process to observation noise." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Q / R" /><Run Text=" — process vs observation noise: higher Q/R trusts the market more (faster, noisier); lower trusts the model (smoother, laggier)." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Innovations" /><Run Text=" — forecast errors; if they're not white noise the model is mis-specified (check the innovation ACF panel)." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Band" /><Run Text=" — the state's ±σ uncertainty; excursions of price outside it are statistically notable relative to the fitted noise." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main: charts + analysis panel -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- State + innovations, stacked -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                    <sp:WpfPlot x:Name="StatePlot" />
                </Border>
                <Border Grid.Row="1" Margin="0,8,0,0"
                        Background="{DynamicResource Background.Surface}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                    <sp:WpfPlot x:Name="InnovationPlot" />
                </Border>
            </Grid>

            <!-- Right analysis panel -->
            <ScrollViewer Grid.Column="1" Margin="12,0,0,0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Headline card -->
                    <Border Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="{Binding HeadlineLabel}" FontSize="11"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <TextBlock Text="{Binding HeadlineValue}" FontSize="30" FontWeight="Bold" />
                            <TextBlock Text="{Binding HeadlineDetail}" FontSize="12" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Text.Secondary}" />
                        </StackPanel>
                    </Border>

                    <!-- Model card -->
                    <TextBlock Text="Model" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <Border Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="10,8">
                        <TextBlock Text="{Binding ModelSummary}" TextWrapping="Wrap" FontSize="12"
                                   FontFamily="Consolas, Cascadia Mono, monospace" />
                    </Border>

                    <!-- Innovation diagnostics -->
                    <TextBlock Text="Innovation diagnostics" FontWeight="SemiBold" Margin="0,14,0,4" />
                    <Border Background="{DynamicResource Background.Elevated}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                            Padding="10,8">
                        <TextBlock Text="{Binding InnovationSummary}" TextWrapping="Wrap" FontSize="12" />
                    </Border>

                    <TextBlock Text="{Binding RunStatus}" Margin="0,12,0,0"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="3" Margin="0,8,0,0"
                   Foreground="{DynamicResource Danger.Brush}"
                   Text="{Binding ErrorMessage}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
