<UserControl x:Class="TradingTerminal.Recording.TickRecorderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="900"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Live tick recorder" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Grid.Row="0" Margin="0,28,0,0"
                   Text="Streams ticks from the active broker to a parquet file. Use the resulting file as input for `daxalgo-backtest run --data ...`."
                   Foreground="{DynamicResource Text.Secondary}"
                   TextWrapping="Wrap" />

        <!-- Instrument + output -->
        <Grid Grid.Row="1" Margin="0,16,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Instrument" VerticalAlignment="Center" Margin="0,0,8,0" />
            <uic:InstrumentPicker Grid.Column="1"
                      ShowSearch="True"
                      ItemsSource="{Binding Instruments}"
                      SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                      SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                      IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}" />
            <TextBlock Grid.Column="3" Text="Output" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="4"
                     Text="{Binding OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas"
                     IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}" />
            <Button Grid.Column="5" Content="Browse…"
                    Command="{Binding BrowseOutputCommand}"
                    IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="12,4" Margin="8,0,0,0" />
        </Grid>

        <!-- Controls -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Start"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding IsRecording, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="20,6" Margin="0,0,8,0" />
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    IsEnabled="{Binding IsRecording}"
                    Padding="20,6" />
        </StackPanel>

        <!-- Stats row -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Status" Foreground="{DynamicResource Text.Secondary}" FontSize="10" />
                    <TextBlock Text="{Binding Status}" FontFamily="Consolas" TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Elapsed" Foreground="{DynamicResource Text.Secondary}" FontSize="10" />
                    <TextBlock Text="{Binding Elapsed}" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Ticks written" Foreground="{DynamicResource Text.Secondary}" FontSize="10" />
                    <TextBlock Text="{Binding TicksWritten}" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="Bid" Foreground="{DynamicResource Text.Secondary}" FontSize="10" />
                    <TextBlock Text="{Binding LastBid, StringFormat=F5}" FontFamily="Consolas" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Ask" Foreground="{DynamicResource Text.Secondary}" FontSize="10" />
                    <TextBlock Text="{Binding LastAsk, StringFormat=F5}" FontFamily="Consolas" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Recent ticks -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding RecentTicks}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserResizeRows="False"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"      Binding="{Binding TimeText}" Width="130" />
                <DataGridTextColumn Header="Bid"       Binding="{Binding Bid, StringFormat=F5}" Width="110" />
                <DataGridTextColumn Header="Ask"       Binding="{Binding Ask, StringFormat=F5}" Width="110" />
                <DataGridTextColumn Header="BidSize"   Binding="{Binding BidSize}" Width="80" />
                <DataGridTextColumn Header="AskSize"   Binding="{Binding AskSize}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="5"
                   Text="{Binding ValidationError}"
                   Foreground="#E06C75"
                   Margin="0,8,0,0"
                   Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}" />
    </Grid>
</UserControl>
