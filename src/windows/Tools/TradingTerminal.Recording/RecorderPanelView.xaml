<UserControl x:Class="TradingTerminal.Recording.RecorderPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             xmlns:uiconv="clr-namespace:TradingTerminal.UI.Converters;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="560" d:DesignWidth="460"
             Foreground="{DynamicResource Text.Primary}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <uiconv:InverseBooleanToVisibilityConverter x:Key="InvBoolToVis" />

        <!-- One watched instrument: translucent card, same fill family as the header chrome. -->
        <Style x:Key="RowCard" TargetType="Border">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <!-- Serving-broker pill; hidden until recording resolves one. -->
        <Style x:Key="BrokerPill" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="Serving broker" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ActiveBroker}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Stream chips ─────────────────────────────────────────────────────────────────
             Dim by default; a chip lights green only while its stream is actually being
             captured. Colour is state here, never decoration. -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="3" />
            <Setter Property="Padding" Value="5,1" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Opacity" Value="0.5" />
        </Style>
        <Style x:Key="ChipLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="ChipCount" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Visibility" Value="Collapsed" />
        </Style>

        <!-- L1 / BARS: every broker serves these, so they light on IsLive alone. -->
        <Style x:Key="Chip.OnLive" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLive}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" />
                    <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChipLabel.OnLive" TargetType="TextBlock" BasedOn="{StaticResource ChipLabel}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLive}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChipCount.OnLive" TargetType="TextBlock" BasedOn="{StaticResource ChipCount}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLive}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- L2: only brokers that publish depth. Struck once the serving broker is known
             not to have it — an honest "not here", not a silent no-op. -->
        <Style x:Key="Chip.OnDepth" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="ToolTip" Value="L2 depth — order-book levels" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsDepth}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" />
                    <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsLive}" Value="True" />
                        <Condition Binding="{Binding SupportsDepth}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="ToolTip" Value="This broker publishes no L2 depth" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChipLabel.OnDepth" TargetType="TextBlock" BasedOn="{StaticResource ChipLabel}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsDepth}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsLive}" Value="True" />
                        <Condition Binding="{Binding SupportsDepth}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChipCount.OnDepth" TargetType="TextBlock" BasedOn="{StaticResource ChipCount}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsDepth}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- TAPE: opt-in per broker (IB / Binance / Ironbeam). -->
        <Style x:Key="Chip.OnTape" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="ToolTip" Value="Trade tape — time &amp; sales" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsTape}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" />
                    <Setter Property="Background" Value="{DynamicResource Bullish.Soft}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsLive}" Value="True" />
                        <Condition Binding="{Binding SupportsTape}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="ToolTip" Value="This broker has no trade tape" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChipLabel.OnTape" TargetType="TextBlock" BasedOn="{StaticResource ChipLabel}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsTape}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsLive}" Value="True" />
                        <Condition Binding="{Binding SupportsTape}" Value="False" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="TextDecorations" Value="Strikethrough" />
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ChipCount.OnTape" TargetType="TextBlock" BasedOn="{StaticResource ChipCount}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SupportsTape}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- L3: permanently dim — no backend in this build produces market-by-order,
             and the panel says so rather than pretending. -->
        <Style x:Key="Chip.L3" TargetType="Border" BasedOn="{StaticResource Chip}">
            <Setter Property="Opacity" Value="0.35" />
            <Setter Property="ToolTip" Value="No broker in this build exposes L3 / market-by-order" />
        </Style>

        <!-- Flat rounded buttons for the add-flow (quiet + accent primary). -->
        <Style x:Key="QuietButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,3" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Accent.Soft}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource QuietButton}">
            <Setter Property="Background" Value="{DynamicResource Accent.Soft}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
            <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
        </Style>

        <!-- One recorder row. -->
        <DataTemplate x:Key="RecorderRow">
            <Border Style="{StaticResource RowCard}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- name · category/symbol · broker pill · remove -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text.Primary}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="10" Foreground="{DynamicResource Text.Secondary}" Margin="0,1,0,0">
                                <Run Text="{Binding Category, Mode=OneWay}" /><Run Text=" · " /><Run Text="{Binding Symbol, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>

                        <Border Grid.Column="1" Style="{StaticResource BrokerPill}" Margin="6,0,0,0">
                            <TextBlock Text="{Binding ActiveBroker}" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Text.Secondary}" />
                        </Border>

                        <Button Grid.Column="2" Margin="6,0,0,0" VerticalAlignment="Top" Cursor="Hand"
                                Command="{Binding DataContext.RemoveInstrumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                ToolTip="Remove from the watchlist">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent" Padding="4,1" CornerRadius="3">
                                        <TextBlock x:Name="Glyph" Text="×" FontSize="12"
                                                   Foreground="{DynamicResource Text.Secondary}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Glyph" Property="Foreground"
                                                    Value="{DynamicResource Danger.Brush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- stream chips + live counters -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,7,0,0">
                        <Border Style="{StaticResource Chip.OnLive}" ToolTip="Top-of-book quotes">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="L1" Style="{StaticResource ChipLabel.OnLive}" />
                                <TextBlock Text="{Binding Quotes, StringFormat=N0}" Style="{StaticResource ChipCount.OnLive}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Chip.OnLive}" ToolTip="1-minute bars">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="BARS" Style="{StaticResource ChipLabel.OnLive}" />
                                <TextBlock Text="{Binding Bars, StringFormat=N0}" Style="{StaticResource ChipCount.OnLive}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Chip.OnDepth}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="L2" Style="{StaticResource ChipLabel.OnDepth}" />
                                <TextBlock Text="{Binding Depth, StringFormat=N0}" Style="{StaticResource ChipCount.OnDepth}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Chip.OnTape}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="TAPE" Style="{StaticResource ChipLabel.OnTape}" />
                                <TextBlock Text="{Binding Trades, StringFormat=N0}" Style="{StaticResource ChipCount.OnTape}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Chip.L3}">
                            <TextBlock Text="L3" Style="{StaticResource ChipLabel}" />
                        </Border>
                    </StackPanel>

                    <!-- per-row note (which streams are missing, or why it isn't recording) -->
                    <TextBlock Grid.Row="2" Text="{Binding Status}" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap" Margin="0,5,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- The panel card — same idiom as the header dropdowns: rounded surface,
         chrome header strip, translucent footer strip. -->
    <Border Background="{DynamicResource Background.Surface}"
            BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
            CornerRadius="8" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.55" Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- header strip -->
            <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="12,9"
                    Background="{DynamicResource Gradient.Chrome}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Background="{DynamicResource Accent.Brush}" Margin="0,1,8,1" />
                        <TextBlock Text="MARKET DATA RECORDER" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource Text.Header}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Visibility="{Binding Service.IsRecording, Converter={StaticResource BoolToVis}}">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource Bullish.Brush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Service.IsRecording}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="HeaderPulse">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.7" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="HeaderPulse" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding Service.Elapsed}" FontFamily="{DynamicResource Font.Mono}"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Bullish.Brush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- watchlist + trailing "+ Add" row -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="12,10">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Service.Instruments}"
                                  ItemTemplate="{StaticResource RecorderRow}" />

                    <!-- empty state -->
                    <TextBlock Text="The watchlist is empty — add an instrument below to start building a tape."
                               FontSize="11" Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="8,14,8,14"
                               Visibility="{Binding Service.HasInstruments, Converter={StaticResource InvBoolToVis}}" />

                    <!-- the trailing empty item: dashed placeholder that expands into the picker -->
                    <Button Height="46" Cursor="Hand"
                            Command="{Binding BeginAddCommand}"
                            ToolTip="Add an instrument to the watchlist"
                            Visibility="{Binding IsAdding, Converter={StaticResource InvBoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Grid Background="Transparent">
                                    <Rectangle x:Name="Dash" RadiusX="8" RadiusY="8" StrokeThickness="1"
                                               Stroke="{DynamicResource Border.Strong}" StrokeDashArray="4 3"
                                               Fill="Transparent" SnapsToDevicePixels="True" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="Plus" Text="+" FontSize="15" FontWeight="Bold"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   Margin="0,0,7,1" VerticalAlignment="Center" />
                                        <TextBlock x:Name="Label" Text="Add" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Text.Secondary}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Dash" Property="Stroke" Value="{DynamicResource Accent.Brush}" />
                                        <Setter TargetName="Plus" Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                                        <Setter TargetName="Label" Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- the same row, expanded in place into the shared picker -->
                    <Border Background="{DynamicResource Gradient.Elevated}"
                            BorderBrush="{DynamicResource Border.Strong}" BorderThickness="1"
                            CornerRadius="8" Padding="10,8"
                            Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                                <Border Width="3" Background="{DynamicResource Accent.Brush}" Margin="0,1,8,1" />
                                <TextBlock Text="ADD INSTRUMENT" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource Text.Header}" VerticalAlignment="Center" />
                            </StackPanel>
                            <uic:InstrumentPicker ItemsSource="{Binding Instruments}"
                                                  SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                                  SearchText="{Binding InstrumentSearchText, Mode=TwoWay}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Add" Style="{StaticResource AccentButton}"
                                        Command="{Binding ConfirmAddCommand}" Margin="0,0,6,0" />
                                <Button Content="Cancel" Style="{StaticResource QuietButton}"
                                        Command="{Binding CancelAddCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- footer strip: record toggle · upload options · status -->
            <Border Grid.Row="2" CornerRadius="0,0,8,8" Padding="12,10" Background="#14FFFFFF"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,1,0,0">
                <StackPanel>
                    <Button Height="36" Cursor="Hand" FontSize="12" FontWeight="Bold"
                            Command="{Binding ToggleRecordingCommand}"
                            ToolTip="Start or stop recording the watchlist into the canonical store. Recording keeps running when this panel is closed.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="6" BorderThickness="1"
                                        BorderBrush="{DynamicResource Danger.Brush}" Background="#14FFFFFF">
                                    <Grid>
                                        <StackPanel x:Name="IdleFace" Orientation="Horizontal"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="●" FontSize="11" Foreground="{DynamicResource Danger.Brush}"
                                                       Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="RECORD" Foreground="{DynamicResource Danger.Brush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel x:Name="LiveFace" Orientation="Horizontal" Visibility="Collapsed"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse x:Name="LiveDot" Width="8" Height="8"
                                                     Fill="{DynamicResource Bullish.Brush}"
                                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="■ STOP" Foreground="{DynamicResource Bullish.Brush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#1AFFFFFF" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding Service.IsRecording}" Value="True">
                                        <Setter TargetName="IdleFace" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="LiveFace" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Bullish.Brush}" />
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Bullish.Soft}" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="RecordPulse">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="LiveDot"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.3" Duration="0:0:0.7" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="RecordPulse" />
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <CheckBox Content="Auto upload on Telegram" FontSize="11" Margin="0,10,0,0"
                              IsChecked="{Binding Service.AutoUploadTelegram}"
                              ToolTip="Ships recorded data to Telegram every hour." />
                    <CheckBox Content="Delete local copy after upload" FontSize="11" Margin="22,5,0,0"
                              IsChecked="{Binding Service.DeleteLocalAfterUpload}"
                              IsEnabled="{Binding Service.AutoUploadTelegram}"
                              ToolTip="Off = Telegram is a second copy; on = uploaded data is pruned locally." />

                    <TextBlock Text="{Binding Service.Status}" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
