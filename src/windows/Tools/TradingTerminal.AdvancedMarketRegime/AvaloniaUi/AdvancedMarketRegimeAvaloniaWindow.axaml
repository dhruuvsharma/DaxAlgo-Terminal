<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.AdvancedMarketRegime.AvaloniaUi.AdvancedMarketRegimeAvaloniaWindow"
        Width="780" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="Advanced market regime">
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Advanced market regime" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Width="240" Watermark="Search instrument…" Text="{Binding InstrumentSearchText}"/>
        <ComboBox MinWidth="160" ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <Button Content="Analyze" Command="{Binding AnalyzeCommand}"/>
      </StackPanel>
      <TextBlock Text="{Binding LastUpdated, StringFormat='Last updated: {0}'}" Foreground="{DynamicResource Text.Secondary}"/>
      <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <DockPanel Margin="0,10,0,0">
      <TextBlock DockPanel.Dock="Top" Text="Indicator × timeframe dashboard" FontWeight="SemiBold" Margin="0,0,0,4"/>
      <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <ListBox ItemsSource="{Binding Rows}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
      </Border>
    </DockPanel>
  </DockPanel>
</Window>
