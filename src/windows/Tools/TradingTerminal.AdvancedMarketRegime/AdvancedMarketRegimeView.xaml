<UserControl x:Class="TradingTerminal.AdvancedMarketRegime.AdvancedMarketRegimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Advanced live market regime" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Multi-timeframe indicator dashboard: 18 indicator rows × up to 8 timeframe columns (1m → 1D, including aggregated 20m/30m). Each cell shows direction + value on a signal-coloured background; the Trend row is a composite −8..+8 needle gauge (−90° strong sell .. +90° strong buy)."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Controls row -->
        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- search label   -->
                    <ColumnDefinition Width="150" />    <!-- search box     -->
                    <ColumnDefinition Width="Auto" />   <!-- "Instrument"   -->
                    <ColumnDefinition Width="*" />      <!-- dropdown       -->
                    <ColumnDefinition Width="Auto" />   <!-- auto refresh   -->
                    <ColumnDefinition Width="56" />     <!-- interval       -->
                    <ColumnDefinition Width="Auto" />   <!-- "s"            -->
                    <ColumnDefinition Width="Auto" />   <!-- Analyze        -->
                    <ColumnDefinition Width="Auto" />   <!-- Cancel         -->
                    <ColumnDefinition Width="Auto" />   <!-- presets + actions -->
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Search" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <TextBox Grid.Column="1"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter symbols..."
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="Instrument" VerticalAlignment="Center" Margin="0,0,6,0" />
                <uic:InstrumentPicker Grid.Column="3"
                           ShowSearch="False"
                           ItemsSource="{Binding Instruments}"
                           SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                           MaxDropDownHeight="420"
                           Margin="0,0,12,0" />

                <CheckBox Grid.Column="4" Content="Auto refresh" VerticalAlignment="Center"
                          IsChecked="{Binding AutoRefresh}" Margin="0,0,6,0" />
                <TextBox  Grid.Column="5" Text="{Binding RefreshSeconds, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center" />
                <TextBlock Grid.Column="6" Text="s" VerticalAlignment="Center" Margin="3,0,12,0"
                           Foreground="{DynamicResource Text.Secondary}" />

                <Button Grid.Column="7" Content="Analyze"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="14,4" Margin="0,0,6,0" />
                <Button Grid.Column="8" Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Padding="14,4" />

                <StackPanel Grid.Column="9" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <Border Style="{StaticResource App.ParamDivider}" />
                    <TextBlock Text="PRESET" Style="{StaticResource App.GroupLabel}" />
                    <ComboBox Width="120" IsEditable="True"
                              ItemsSource="{Binding PresetNames}"
                              SelectedItem="{Binding SelectedPreset}"
                              Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Pick a preset to apply it, or type a new name and press save. Presets remember the row/column layout, display toggles and refresh cadence — never the instrument." />
                    <Button Style="{StaticResource App.IconButton}" Margin="6,0,0,0" Content="💾"
                            Command="{Binding SavePresetCommand}"
                            ToolTip="Save the current dashboard layout as a named preset" />
                    <Button Style="{StaticResource App.IconButton}" Content="🗑"
                            Command="{Binding DeletePresetCommand}"
                            ToolTip="Delete the selected preset" />
                    <Button Style="{StaticResource App.IconButton}" Content="↧"
                            Command="{Binding ExportGridCsvCommand}"
                            ToolTip="Export the dashboard grid as CSV" />
                    <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                            ToolTip="Save a PNG snapshot of this window" />
                    <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                                  Margin="0" ToolTip="What am I looking at?" />
                    <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
                           HorizontalOffset="-330" VerticalOffset="6">
                        <Border Style="{StaticResource App.Card}" Width="380" Padding="16"
                                Background="{DynamicResource Background.Elevated}">
                            <StackPanel>
                                <TextBlock Text="READING THE REGIME DASHBOARD" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                    <Run FontWeight="SemiBold" Text="Grid" /><Run Text=" — 18 indicator rows × up to 8 timeframes. Cell colour is the indicator's regime call on that horizon (green bullish / red bearish / grey neutral); the glyph is direction, the small number the raw value." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Read it by column" /><Run Text=" — a column that is uniformly green from 1m to 1D is a coherent trend; mixed colours across timeframes mean the horizons disagree (chop or transition)." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Trend row" /><Run Text=" — a composite −8…+8 needle per timeframe summarising all rows above it." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Data" /><Run Text=" — computed from stored/broker bars on Analyze (or on the auto-refresh cadence); the expander tunes indicator parameters and which rows/columns show." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Row / column / display toggles + indicator settings -->
        <Expander Grid.Row="2" Margin="0,10,0,0" Header="Rows · columns · indicator settings"
                  Foreground="{DynamicResource Text.Primary}" IsExpanded="False">
            <Border Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                    Padding="10" Margin="0,6,0,0">
                <StackPanel>
                    <StackPanel.Resources>
                        <Style TargetType="CheckBox">
                            <Setter Property="Margin" Value="0,2,14,2" />
                        </Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Width" Value="44" />
                            <Setter Property="Margin" Value="4,2,16,2" />
                        </Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                        </Style>
                    </StackPanel.Resources>

                    <TextBlock Text="TIMEFRAME COLUMNS" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding ColumnOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsEnabled}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="INDICATOR ROWS" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4" />
                    <ItemsControl ItemsSource="{Binding RowOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsEnabled}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="DISPLAY" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4" />
                    <WrapPanel>
                        <CheckBox Content="Show direction" IsChecked="{Binding ShowDirection}" />
                        <CheckBox Content="Show value" IsChecked="{Binding ShowValue}" />
                    </WrapPanel>

                    <TextBlock Text="INDICATOR SETTINGS (applied on next analyze)" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4" />
                    <WrapPanel>
                        <TextBlock Text="RSI" /><TextBox Text="{Binding Settings.RsiLength}" />
                        <TextBlock Text="RSI OB" /><TextBox Text="{Binding Settings.RsiOverbought}" />
                        <TextBlock Text="RSI OS" /><TextBox Text="{Binding Settings.RsiOversold}" />
                        <TextBlock Text="MACD" /><TextBox Text="{Binding Settings.MacdFast}" /><TextBox Text="{Binding Settings.MacdSlow}" /><TextBox Text="{Binding Settings.MacdSignal}" />
                        <TextBlock Text="CCI" /><TextBox Text="{Binding Settings.CciLength}" />
                        <TextBlock Text="MA" /><TextBox Text="{Binding Settings.Ma9Length}" /><TextBox Text="{Binding Settings.Ma21Length}" /><TextBox Text="{Binding Settings.Ma50Length}" />
                        <TextBlock Text="3MA" /><TextBox Text="{Binding Settings.TripleMaFast}" /><TextBox Text="{Binding Settings.TripleMaMid}" /><TextBox Text="{Binding Settings.TripleMaSlow}" />
                        <TextBlock Text="ST factor" /><TextBox Text="{Binding Settings.SuperTrendFactor}" />
                        <TextBlock Text="ST ATR" /><TextBox Text="{Binding Settings.SuperTrendAtrLength}" />
                        <TextBlock Text="ATR" /><TextBox Text="{Binding Settings.AtrLength}" />
                        <TextBlock Text="ATR Reg" /><TextBox Text="{Binding Settings.AtrRegressionLength}" />
                        <TextBlock Text="STD" /><TextBox Text="{Binding Settings.StdLength}" />
                        <TextBlock Text="POC" /><TextBox Text="{Binding Settings.PocLookback}" />
                        <TextBlock Text="TRD" /><TextBox Text="{Binding Settings.TrendRangeLength}" />
                        <TextBlock Text="Δ lookback" /><TextBox Text="{Binding Settings.DeltaLookback}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Expander>

        <!-- Dashboard table -->
        <ScrollViewer Grid.Row="3" Margin="0,12,0,0"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel MinWidth="700">
                <!-- Header row -->
                <DockPanel>
                    <Border DockPanel.Dock="Left" Width="76" Background="#1A1D21"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,1,1"
                            Padding="6,5">
                        <TextBlock Text="Indicator" FontWeight="SemiBold" Foreground="#FFD54F" FontSize="12" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding HeaderCells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1D21"
                                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,1,1"
                                        Padding="4,5">
                                    <TextBlock Text="{Binding}" FontWeight="SemiBold" Foreground="#FFD54F"
                                               FontSize="12" HorizontalAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>

                <!-- Indicator rows -->
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel>
                                <Border DockPanel.Dock="Left" Width="76" Background="#22262B"
                                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,1,1"
                                        Padding="6,0">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="12"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ItemsControl ItemsSource="{Binding Cells}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding ColorHex, Converter={StaticResource StringToBrushConverter}}"
                                                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,1,1"
                                                    Padding="4,3" MinHeight="36">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Glyph}" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="White" HorizontalAlignment="Center"
                                                               Visibility="{Binding GlyphVisible, Converter={StaticResource BoolToVis}}" />
                                                    <TextBlock Text="{Binding ValueText}" FontSize="11"
                                                               Foreground="#DDFFFFFF" HorizontalAlignment="Center"
                                                               Visibility="{Binding ValueVisible, Converter={StaticResource BoolToVis}}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Run Analyze to populate the dashboard."
                           Foreground="{DynamicResource Text.Secondary}" Margin="0,16,0,0"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Rows.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="{DynamicResource Danger.Brush}"
                       Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Column="1" Foreground="{DynamicResource Text.Secondary}">
                <Run Text="Updated:" />
                <Run Text="{Binding LastUpdated}" />
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
