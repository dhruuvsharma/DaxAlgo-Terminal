<mah:MetroWindow x:Class="TradingTerminal.Correlation.LiveCorrelationMatrixWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="Live correlation matrix"
                 Width="1000" Height="700"
                 MinWidth="760" MinHeight="500"
                 TitleCharacterCasing="Normal"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 d:DesignHeight="700" d:DesignWidth="1000">

    <mah:MetroWindow.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Gradient.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Accent.Soft}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="7,1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="PickerRow">
            <Grid Margin="2,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}"
                          VerticalContentAlignment="Center" />
                <Border Grid.Column="1" Margin="6,0,2,0"
                        Background="{DynamicResource Background.Elevated}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                        CornerRadius="3" Padding="4,0" VerticalAlignment="Center" ToolTip="Source broker">
                    <TextBlock Text="{Binding BrokerAbbrev}" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}" />
                </Border>
            </Grid>
        </DataTemplate>

        <Style x:Key="PickerGroup" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <StackPanel>
                            <Border Margin="0,6,0,2" Padding="0,0,0,2"
                                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Text.Header}" />
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                               Foreground="{DynamicResource Text.Secondary}" />
                                </StackPanel>
                            </Border>
                            <ItemsPresenter />
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header band -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Background="{DynamicResource Gradient.Header}" Padding="0">
            <DockPanel>
                <Border DockPanel.Dock="Left" Width="4" Background="{DynamicResource Accent.Brush}"
                        CornerRadius="6,0,0,6" />
                <StackPanel Margin="14,10">
                    <TextBlock Text="Live correlation matrix" FontSize="17" FontWeight="SemiBold"
                               Foreground="{DynamicResource Text.Header}" />
                    <TextBlock Text="Real-time Pearson correlation of mid-price log returns. Each instrument's live quote is sampled onto a shared time grid; the matrix recomputes every sample over a rolling window."
                               Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"
                               FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Control bar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,10,0,0"
                Background="{DynamicResource Gradient.Elevated}" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="104" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="124" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Sample" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <ComboBox  Grid.Column="1" ItemsSource="{Binding SampleIntervals}"
                           SelectedItem="{Binding SelectedSampleInterval}" DisplayMemberPath="Label"
                           Margin="0,0,14,0" />

                <TextBlock Grid.Column="2" Text="Window" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" />
                <ComboBox  Grid.Column="3" ItemsSource="{Binding Windows}"
                           SelectedItem="{Binding SelectedWindow}" DisplayMemberPath="Label"
                           Margin="0,0,14,0" />

                <Button Grid.Column="4" Content="Start"
                        Command="{Binding StartCommand}"
                        IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="18,4" Margin="0,0,8,0" />

                <Button Grid.Column="5" Content="Stop"
                        Command="{Binding StopCommand}"
                        IsEnabled="{Binding IsStreaming}"
                        Padding="18,4" Margin="0,0,10,0" />

                <mah:ProgressRing Grid.Column="6" IsActive="{Binding IsStreaming}"
                                  Width="18" Height="18" Margin="0,0,10,0" />

                <TextBlock Grid.Column="7" Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <Button Style="{StaticResource App.IconButton}" Content="↧"
                            Command="{Binding ExportMatrixCsvCommand}"
                            ToolTip="Export the correlation matrix as CSV" />
                    <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                            ToolTip="Save a PNG snapshot of this window" />
                    <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                                  Margin="0" ToolTip="What am I looking at?" />
                    <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
                           HorizontalOffset="-330" VerticalOffset="6">
                        <Border Style="{StaticResource App.Card}" Width="380" Padding="16"
                                Background="{DynamicResource Background.Elevated}">
                            <StackPanel>
                                <TextBlock Text="READING THE LIVE CORRELATION MATRIX" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                    <Run FontWeight="SemiBold" Text="Matrix" /><Run Text=" — rolling Pearson correlation of live sampled mid-price returns between every pair of ticked instruments; it recomputes continuously at the sample cadence over the chosen window." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Warm-up" /><Run Text=" — coefficients firm up as the window fills; the sample chip shows how many aligned observations are in play." /><LineBreak />
                                    <Run FontWeight="SemiBold" Text="Watch for" /><Run Text=" — correlation regime breaks: pairs that normally track suddenly decoupling is often the first visible sign of idiosyncratic news or a liquidity event." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Instrument checklist -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left" Text="Instruments" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border DockPanel.Dock="Right" Style="{StaticResource Chip}">
                            <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} picked'}"
                                       FontSize="11" Foreground="{DynamicResource Text.Primary}" />
                        </Border>
                    </DockPanel>

                    <ComboBox Grid.Row="1" ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              mah:TextBoxHelper.Watermark="category…" Margin="0,0,0,6" />

                    <TextBox Grid.Row="2"
                             Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             mah:TextBoxHelper.Watermark="filter symbols…"
                             mah:TextBoxHelper.ClearTextButton="True" Margin="0,0,0,6" />

                    <ListBox Grid.Row="3" ItemsSource="{Binding InstrumentsView}"
                             Background="Transparent" BorderThickness="0"
                             ItemTemplate="{StaticResource PickerRow}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                             VirtualizingPanel.ScrollUnit="Pixel">
                        <ListBox.GroupStyle>
                            <GroupStyle ContainerStyle="{StaticResource PickerGroup}" />
                        </ListBox.GroupStyle>
                    </ListBox>

                    <DockPanel Grid.Row="4" Margin="0,8,0,0" LastChildFill="False">
                        <Button DockPanel.Dock="Left" Content="Select visible"
                                Command="{Binding SelectAllVisibleCommand}" Padding="8,3" Margin="0,0,6,0" />
                        <Button DockPanel.Dock="Left" Content="Clear"
                                Command="{Binding ClearSelectionCommand}" Padding="8,3" />
                        <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="10"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   Text="{Binding VisibleCount, StringFormat='showing {0}'}" />
                    </DockPanel>
                </Grid>
            </Border>

            <!-- Matrix -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <ContentControl x:Name="MatrixHost" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        </ScrollViewer>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                   TextAlignment="Center" FontSize="13"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   Text="Tick at least two instruments, then press Start.">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MatrixResult}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Correlation" Foreground="{DynamicResource Text.Secondary}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" FontSize="11" />
                        <TextBlock Text="-1" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11" />
                        <Border Width="180" Height="12" CornerRadius="2"
                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#C62828" Offset="0" />
                                    <GradientStop Color="#2D2D30" Offset="0.5" />
                                    <GradientStop Color="#2E7D32" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="+1" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="11" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
