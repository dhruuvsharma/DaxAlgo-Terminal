<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="TradingTerminal.Correlation.AvaloniaUi.LiveCorrelationAvaloniaWindow"
        Width="900" Height="640"
        Background="{DynamicResource Background.Primary}"
        Title="Live correlation matrix">
  <DockPanel Margin="14">
    <TextBlock DockPanel.Dock="Top" Text="Live correlation matrix" FontSize="18" FontWeight="Bold"
               Foreground="{DynamicResource Text.Header}" Margin="0,0,0,8"/>

    <Grid ColumnDefinitions="300,*">
      <!-- Instrument picker + controls -->
      <DockPanel Grid.Column="0" Margin="0,0,12,0">
        <StackPanel DockPanel.Dock="Top" Spacing="6">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBox Width="150" Watermark="Search…" Text="{Binding InstrumentSearchText}"/>
            <ComboBox MinWidth="120" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <ComboBox ItemsSource="{Binding SampleIntervals}" SelectedItem="{Binding SelectedSampleInterval}"/>
            <ComboBox ItemsSource="{Binding Windows}" SelectedItem="{Binding SelectedWindow}"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Classes="accent" Content="Start" Command="{Binding StartCommand}"/>
            <Button Content="Stop" Command="{Binding StopCommand}"/>
            <Button Content="Clear" Command="{Binding ClearSelectionCommand}"/>
          </StackPanel>
          <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
        </StackPanel>
        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3" Margin="0,8,0,0">
          <ListBox ItemsSource="{Binding Instruments}" Background="{DynamicResource Background.Surface}">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}" FontSize="11"/>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </DockPanel>

      <!-- Matrix heatmap -->
      <Border Grid.Column="1" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <sp:AvaPlot x:Name="MatrixPlot"/>
      </Border>
    </Grid>
  </DockPanel>
</Window>
