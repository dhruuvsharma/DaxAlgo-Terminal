<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.LseBacktest.AvaloniaUi.LseBacktestAvaloniaWindow"
        Width="820" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="LSE backtester">
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="LSE backtester" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox MinWidth="180" ItemsSource="{Binding Strategies}" SelectedItem="{Binding SelectedStrategy}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Width="120" Watermark="Symbol" Text="{Binding Symbol}"/>
        <ComboBox ItemsSource="{Binding BarSizes}" SelectedItem="{Binding SelectedBarSize}"/>
        <TextBlock Text="Lookback" VerticalAlignment="Center"/>
        <NumericUpDown Width="110" Value="{Binding LookbackBars}" Minimum="1" Maximum="5000"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Classes="accent" Content="Run" Command="{Binding RunCommand}"/>
        <Button Content="Cancel" Command="{Binding CancelCommand}"/>
        <TextBlock Text="{Binding TotalPnl, StringFormat='P&amp;L: {0:C0}'}" VerticalAlignment="Center" Foreground="{DynamicResource Accent.Brush}" FontWeight="Bold"/>
      </StackPanel>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      <TextBlock Text="Bar-sourced (synthetic 1-tick spread) — best for L1/bar strategies; no real microstructure."
                 Foreground="{DynamicResource Text.Secondary}" FontSize="11" TextWrapping="Wrap"/>
    </StackPanel>

    <DockPanel Margin="0,10,0,0">
      <TextBlock DockPanel.Dock="Top" Text="Trades" FontWeight="SemiBold" Margin="0,0,0,4"/>
      <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <ListBox ItemsSource="{Binding Trades}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
      </Border>
    </DockPanel>
  </DockPanel>
</Window>
