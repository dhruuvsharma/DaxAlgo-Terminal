<Project Sdk="Microsoft.NET.Sdk">

  <!-- `daxalgo` — the strategy-plugin dev CLI, shipped as a dotnet global tool
       (dotnet tool install -g DaxAlgo.StrategyTool). Wraps the template + dotnet + the packaging script,
       and drives the AI build loop over a scaffold via the lean DaxAlgo.Codegen assembly (no WPF/broker
       weight). Verbs: daxalgo strategy new|build|test|package|install|ai. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <RootNamespace>DaxAlgo.StrategyTool</RootNamespace>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>daxalgo</ToolCommandName>
    <PackageId>DaxAlgo.StrategyTool</PackageId>
    <Version>$(DaxAlgoSdkVersion)</Version>
    <Description>DaxAlgo Terminal strategy-plugin dev CLI: scaffold, build, test, package (.daxplugin), install, and AI-build strategy plugins.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>daxalgo;strategy;plugin;cli;dotnet-tool;ai</PackageTags>
    <IncludeSymbols>false</IncludeSymbols>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DaxAlgo.Codegen\DaxAlgo.Codegen.csproj" />
  </ItemGroup>

</Project>
