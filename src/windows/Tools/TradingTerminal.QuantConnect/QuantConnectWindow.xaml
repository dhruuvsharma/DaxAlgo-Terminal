<mah:MetroWindow x:Class="TradingTerminal.QuantConnect.QuantConnectWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="QuantConnect / LEAN"
                 Height="820" Width="1280"
                 WindowStartupLocation="CenterOwner"
                 GlowBrush="{DynamicResource Accent.Brush}"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <DockPanel>
        <!-- ── Top brand / status bar ───────────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Style="{StaticResource App.HeaderBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◳" FontSize="16" Foreground="{DynamicResource Accent.Brush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <TextBlock Text="QUANTCONNECT / LEAN" Style="{StaticResource App.Brand}" />
                    <Border Style="{StaticResource Pill.Accent}" Margin="12,0,0,0">
                        <TextBlock Text="{Binding EngineMode}" Foreground="{DynamicResource Accent.Brush}" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="9" Height="9" Margin="0,0,7,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource Danger.Brush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding AvailabilityStatus}" Foreground="{DynamicResource Text.Secondary}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="640" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" BorderThickness="0" Padding="0">

            <!-- ════════════ BACKTEST ════════════ -->
            <TabItem Header="Backtest">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- run strip -->
                    <Border Grid.Row="0" Style="{StaticResource App.PanelHeader}" CornerRadius="6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="PROJECT" Style="{StaticResource App.GroupLabel}" />
                            <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                                      DisplayMemberPath="Name" Width="240" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button Content="▶ Run backtest" Command="{Binding RunBacktestCommand}" Style="{StaticResource App.ToolButton}" />
                            <Button Content="■ Cancel" Command="{Binding CancelRunCommand}" Style="{StaticResource App.ToolButton}"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Style="{StaticResource App.IconButton}" Content="↧" Margin="8,0,0,0"
                                    Command="{Binding ExportStatsCsvCommand}"
                                    ToolTip="Export the LEAN statistics table as CSV" />
                            <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                                    ToolTip="Save a PNG snapshot of this window" />
                            <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                                  Margin="0" ToolTip="What am I looking at?" />
                            <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
                           HorizontalOffset="-300" VerticalOffset="6">
                                <Border Style="{StaticResource App.Card}" Width="390" Padding="16"
                                Background="{DynamicResource Background.Elevated}">
                                    <StackPanel>
                                        <TextBlock Text="RUNNING LEAN BACKTESTS" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                                        <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                            <Run FontWeight="SemiBold" Text="LEAN" /><Run Text=" — runs the selected QuantConnect project through the local LEAN CLI as a subprocess; the availability line says whether the CLI and Docker are ready." /><LineBreak />
                                            <Run FontWeight="SemiBold" Text="Results" /><Run Text=" — the statistics table and equity curve parse from LEAN's result JSON when the run completes; the log pane streams the CLI output live." /><LineBreak />
                                            <Run FontWeight="SemiBold" Text="Scope" /><Run Text=" — this is a research seam, not a broker: LEAN projects live in their own folder and don't see the terminal's market data." />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <Border Style="{StaticResource Pill.Live}" Margin="4,0,0,0"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="◌ RUNNING" Foreground="{DynamicResource Accent.Brush}" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{Binding BacktestStatus}" Foreground="{DynamicResource Text.Secondary}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- stats + equity -->
                    <Grid Grid.Row="1" Height="300" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="360" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- statistics -->
                        <Border Grid.Column="0" Background="{DynamicResource Background.Surface}"
                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{StaticResource App.PanelHeader}" CornerRadius="6,6,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource App.SectionBar}" Height="13" />
                                        <TextBlock Text="STATISTICS" Style="{StaticResource App.SectionHeader}" />
                                    </StackPanel>
                                </Border>
                                <DataGrid ItemsSource="{Binding Statistics}" AutoGenerateColumns="False" IsReadOnly="True"
                                          HeadersVisibility="Column" GridLinesVisibility="None" Background="Transparent"
                                          RowBackground="Transparent" BorderThickness="0"
                                          FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11.5">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="METRIC" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="VALUE" Binding="{Binding Value}" Width="Auto" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <!-- equity curve -->
                        <Border Grid.Column="1" Background="{DynamicResource Background.Surface}"
                                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="6">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Style="{StaticResource App.PanelHeader}" CornerRadius="6,6,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Style="{StaticResource App.SectionBar}" Height="13" />
                                        <TextBlock Text="EQUITY CURVE" Style="{StaticResource App.SectionHeader}" />
                                    </StackPanel>
                                </Border>
                                <Grid>
                                    <TextBlock Text="Run a backtest to plot the strategy equity curve."
                                               Foreground="{DynamicResource Text.Secondary}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasEquity, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                    <Viewbox Stretch="Fill" Margin="10"
                                             Visibility="{Binding HasEquity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <!-- 1000x260 logical space, pre-projected in the VM. -->
                                        <Canvas Width="1000" Height="260">
                                            <Polyline Points="{Binding EquityCurve}" Stroke="{DynamicResource Accent.Brush}"
                                                      StrokeThickness="2" StrokeLineJoin="Round" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- run log -->
                    <Border Grid.Row="2" Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="6">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{StaticResource App.PanelHeader}" CornerRadius="6,6,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Border Style="{StaticResource App.SectionBar}" Height="13" />
                                    <TextBlock Text="ENGINE LOG" Style="{StaticResource App.SectionHeader}" />
                                </StackPanel>
                            </Border>
                            <TextBox x:Name="RunLogBox" Text="{Binding RunLog, Mode=OneWay}" IsReadOnly="True"
                                     Background="#080808" BorderThickness="0"
                                     FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11"
                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                     TextWrapping="NoWrap" Padding="8" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ PROJECTS ════════════ -->
            <TabItem Header="Projects">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource App.PanelHeader}" CornerRadius="6" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource App.SectionBar}" Height="13" />
                            <TextBlock Text="ALGORITHM PROJECTS" Style="{StaticResource App.SectionHeader}" Margin="0,0,12,0" />
                            <Button Content="⟳ Refresh" Command="{Binding RefreshProjectsCommand}" Style="{StaticResource App.ToolButton}" />
                            <TextBlock Text="◌ scanning…" Foreground="{DynamicResource Accent.Brush}" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Visibility="{Binding IsBusyProjects, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                              AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                              GridLinesVisibility="None" Background="{DynamicResource Background.Surface}"
                              RowBackground="Transparent" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                              FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11.5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PROJECT" Binding="{Binding Name}" Width="240" />
                            <DataGridTextColumn Header="LANG" Binding="{Binding Language}" Width="80" />
                            <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ════════════ DATA ════════════ -->
            <TabItem Header="Data sync">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="6"
                            Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="lean data download" Foreground="{DynamicResource Text.Header}" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="DATASET" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding DataDataset, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="TICKERS (comma)" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding DataTickers, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="0,0,8,0" Width="120">
                                    <TextBlock Text="RESOLUTION" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                                    <ComboBox SelectedValue="{Binding DataResolution}" SelectedValuePath="Content">
                                        <ComboBoxItem Content="Tick" />
                                        <ComboBoxItem Content="Second" />
                                        <ComboBoxItem Content="Minute" />
                                        <ComboBoxItem Content="Hour" />
                                        <ComboBoxItem Content="Daily" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="⬇ Download" Command="{Binding DownloadDataCommand}" Style="{StaticResource App.ToolButton}" />
                                <Border Style="{StaticResource Pill.Live}" Margin="4,0,0,0"
                                        Visibility="{Binding IsDownloading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="◌ DOWNLOADING" Foreground="{DynamicResource Accent.Brush}" FontSize="10" FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                            <TextBlock Foreground="{DynamicResource Text.Secondary}" FontSize="10.5" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Text="Runs the LEAN downloader into your data folder. Dataset/ticker names follow QuantConnect's data library; some datasets need a Data subscription." />
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="6">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Style="{StaticResource App.PanelHeader}" CornerRadius="6,6,0,0">
                                <TextBlock Text="DOWNLOAD LOG" Style="{StaticResource App.SectionHeader}" />
                            </Border>
                            <TextBox Text="{Binding DataLog, Mode=OneWay}" IsReadOnly="True" Background="#080808" BorderThickness="0"
                                     FontFamily="Consolas, Cascadia Mono, monospace" FontSize="11"
                                     VerticalScrollBarVisibility="Auto" TextWrapping="NoWrap" Padding="8" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ════════════ SETTINGS ════════════ -->
            <TabItem Header="Settings &amp; status">
                <Grid Margin="12">
                    <Border MaxWidth="720" VerticalAlignment="Top" HorizontalAlignment="Left"
                            Background="{DynamicResource Background.Surface}"
                            BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="8" Padding="18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{DynamicResource Danger.Brush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                    <Setter Property="Fill" Value="{DynamicResource Bullish.Brush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding AvailabilityStatus}" Foreground="{DynamicResource Text.Primary}"
                                           VerticalAlignment="Center" TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock Text="ENGINE MODE" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                            <TextBlock Text="{Binding EngineMode}" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,12" />

                            <TextBlock Text="LEAN CLI PATH (blank = 'lean' on PATH)" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding CliPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                            <TextBlock Text="PROJECTS FOLDER (LEAN workspace root)" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding ProjectsFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                            <TextBlock Text="DATA FOLDER" Style="{StaticResource App.GroupLabel}" Margin="0,0,0,4" />
                            <TextBox Text="{Binding DataFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Apply &amp; re-check" Command="{Binding ApplySettingsCommand}" Style="{StaticResource App.ToolButton}" />
                                <Button Content="⟳ Re-check only" Command="{Binding CheckAvailabilityCommand}" Style="{StaticResource App.ToolButton}" />
                            </StackPanel>

                            <TextBlock Foreground="{DynamicResource Text.Secondary}" FontSize="10.5" Margin="0,14,0,0" TextWrapping="Wrap"
                                       Text="Setup: install the CLI with 'pip install lean', run 'lean init' in a workspace folder, and make sure Docker Desktop is running. Point PROJECTS FOLDER at that workspace. Edits here apply for this session; persist them in appsettings.json (QuantConnect section) to keep them." />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</mah:MetroWindow>
