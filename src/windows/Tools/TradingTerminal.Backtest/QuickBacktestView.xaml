<UserControl x:Class="TradingTerminal.Backtest.QuickBacktestView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="1000"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- header -->
            <RowDefinition Height="Auto" />  <!-- config strip -->
            <RowDefinition Height="Auto" />  <!-- status -->
            <RowDefinition Height="*" />     <!-- equity curve -->
            <RowDefinition Height="Auto" />  <!-- stats strip -->
            <RowDefinition Height="200" />   <!-- trades grid -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Border Width="3" Height="16" Background="{DynamicResource Accent.Brush}" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Text="QUICK BACKTEST" FontWeight="Bold" FontSize="12"
                       Foreground="{DynamicResource Text.Header}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding StrategyDisplayName}" FontSize="12" Margin="10,0,0,0"
                       Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- Config strip -->
        <Border Grid.Row="1"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="8" Margin="0,0,0,6">
            <StackPanel>
                <!-- Row 1: instrument · mode · lookback · data source · run -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Instrument / asset class" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBox Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                                 mah:TextBoxHelper.Watermark="Search symbols…"
                                 mah:TextBoxHelper.ClearTextButton="True"
                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                 Margin="0,2,0,0" />
                        <ComboBox ItemsSource="{Binding Instruments}"
                                  SelectedItem="{Binding SelectedInstrument}"
                                  DisplayMemberPath="DisplayName"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                  Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,8,0" MinWidth="150">
                        <TextBlock Text="Data" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <ComboBox ItemsSource="{Binding DataModes}"
                                  SelectedItem="{Binding SelectedDataMode}"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                  Margin="0,2,0,0"
                                  ToolTip="Full tape = real historical trades (Binance) for a proper backtest; Bar-synthetic = ticks faked from OHLCV (degraded for tape-primary strategies)." />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,8,0" MinWidth="120">
                        <TextBlock Text="Lookback" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <ComboBox ItemsSource="{Binding Lookbacks}"
                                  SelectedItem="{Binding SelectedLookback}"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                  Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,8,0" MinWidth="120">
                        <TextBlock Text="Data source" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <ComboBox ItemsSource="{Binding Brokers}"
                                  SelectedItem="{Binding SelectedBroker}"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                  Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <Button Content="Run"
                                Command="{Binding RunCommand}"
                                IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                Padding="14,4" />
                        <Button Content="Cancel"
                                Command="{Binding CancelCommand}"
                                IsEnabled="{Binding IsRunning}"
                                Padding="12,4" Margin="6,0,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Row 2: tick size · fee · (max trades | bar size by mode) -->
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0" MinWidth="90">
                        <TextBlock Text="Tick size" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBox Text="{Binding TickSize}"
                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                 Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0" MinWidth="90">
                        <TextBlock Text="Fee (bps/side)" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBox Text="{Binding FeeBps}"
                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                 Margin="0,2,0,0"
                                 ToolTip="Per-fill cost in basis points. Binance spot taker ≈ 7.5 bps." />
                    </StackPanel>

                    <!-- Full-tape only: max prints to pull -->
                    <StackPanel Grid.Column="2" Margin="0,0,12,0" MinWidth="110"
                                Visibility="{Binding IsFullTape, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Max prints" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <TextBox Text="{Binding MaxTrades}"
                                 IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                 Margin="0,2,0,0"
                                 ToolTip="Cap on the real prints fetched (each REST page = 1000). Higher = longer window but slower." />
                    </StackPanel>

                    <!-- Bar-synthetic only: bar size -->
                    <StackPanel Grid.Column="2" Margin="0,0,12,0" MinWidth="110"
                                Visibility="{Binding IsBarSynthetic, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Bar size" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                        <ComboBox ItemsSource="{Binding BarSizes}"
                                  SelectedItem="{Binding SelectedBarSize}"
                                  IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                  Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Status + feed quality -->
        <StackPanel Grid.Row="2" Margin="2,0,0,6">
            <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding FeedQuality}" Foreground="{DynamicResource Accent.Brush}"
                       TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0"
                       Visibility="{Binding FeedQuality, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>

        <!-- Equity curve -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
            <sp:WpfPlot x:Name="EquityPlot" />
        </Border>

        <!-- Stats strip -->
        <Border Grid.Row="4" Margin="0,6,0,6"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="8">
            <UniformGrid Columns="8" Rows="1">
                <StackPanel>
                    <TextBlock Text="P&amp;L" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding TotalPnl, StringFormat=C2}" FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Total return" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.TotalReturn, StringFormat=P2, FallbackValue=—}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Sharpe" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.Sharpe, StringFormat=F2, FallbackValue=—}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Sortino" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.Sortino, StringFormat=F2, FallbackValue=—}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Max DD" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.MaxDrawdown, StringFormat=P2, FallbackValue=—}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Win rate" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.WinRate, StringFormat=P1, FallbackValue=—}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Profit factor" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.ProfitFactor, StringFormat=F2, FallbackValue=—}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Trades" Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <TextBlock Text="{Binding Stats.TradeCount, FallbackValue=—}" />
                </StackPanel>
            </UniformGrid>
        </Border>

        <!-- Trades grid -->
        <DataGrid Grid.Row="5"
                  ItemsSource="{Binding Trades}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Entry (UTC)"   Binding="{Binding EntryUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                <DataGridTextColumn Header="Exit (UTC)"    Binding="{Binding ExitUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" />
                <DataGridTextColumn Header="Side"          Binding="{Binding Side}" />
                <DataGridTextColumn Header="Qty"           Binding="{Binding Quantity}" />
                <DataGridTextColumn Header="Entry price"   Binding="{Binding EntryPrice, StringFormat=F4}" />
                <DataGridTextColumn Header="Exit price"    Binding="{Binding ExitPrice, StringFormat=F4}" />
                <DataGridTextColumn Header="Gross P&amp;L" Binding="{Binding GrossPnl, StringFormat=F4}" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
