<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="TradingTerminal.Backtest.AvaloniaUi.BacktestAvaloniaWindow"
        Width="900" Height="640"
        Background="{StaticResource Background.Primary}"
        Title="Backtest">
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Backtest" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text.Header}"/>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox MinWidth="220" ItemsSource="{Binding Strategies}" SelectedItem="{Binding SelectedStrategy}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Width="90" Watermark="Symbol" Text="{Binding Symbol}"/>
        <CheckBox Content="Fast engine" IsChecked="{Binding UseFastEngine}" VerticalAlignment="Center"/>
        <Button Classes="accent" Content="Run" Command="{Binding RunCommand}"/>
        <Button Content="Cancel" Command="{Binding CancelCommand}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBox Width="120" Watermark="Tick size" Text="{Binding TickSize}"/>
        <TextBox Width="120" Watermark="Slippage ticks" Text="{Binding SlippageTicks}"/>
        <TextBox Width="140" Watermark="Multiplier" Text="{Binding ContractMultiplier}"/>
        <TextBox Width="140" Watermark="Starting cash" Text="{Binding StartingCash}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="{Binding Status}" Foreground="{StaticResource Text.Secondary}"/>
        <TextBlock Text="{Binding TotalPnl, StringFormat='P&amp;L: {0:0.##}'}" Foreground="{StaticResource Accent.Brush}" FontWeight="SemiBold"/>
      </StackPanel>
    </StackPanel>

    <Border DockPanel.Dock="Bottom" Height="150" Margin="0,8,0,0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
      <ListBox ItemsSource="{Binding Trades}" Background="{StaticResource Background.Surface}" FontSize="11"/>
    </Border>

    <Border Margin="0,8,0,0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
      <sp:AvaPlot x:Name="EquityPlot"/>
    </Border>
  </DockPanel>
</Window>
