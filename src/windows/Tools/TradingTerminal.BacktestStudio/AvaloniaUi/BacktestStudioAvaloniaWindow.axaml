<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.BacktestStudio.AvaloniaUi.BacktestStudioAvaloniaWindow"
        Width="900" Height="640"
        Background="{DynamicResource Background.Primary}"
        Title="Backtest Studio">
  <DockPanel Margin="14">
    <TextBlock DockPanel.Dock="Top" Text="Backtest Studio" FontSize="18" FontWeight="Bold"
               Foreground="{DynamicResource Text.Header}" Margin="0,0,0,8"/>

    <Grid ColumnDefinitions="320,*">
      <!-- Setup -->
      <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,12,0">
        <TextBlock Text="Strategy" FontWeight="SemiBold"/>
        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Strategies}" SelectedItem="{Binding SelectedStrategy}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Data source" FontWeight="SemiBold" Margin="0,8,0,0"/>
        <ComboBox HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedDataSource}"/>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Width="170" Watermark="Parquet path…" Text="{Binding ParquetPath}"/>
          <Button Content="Browse…" Command="{Binding BrowseParquetCommand}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox Width="90" Watermark="Symbol" Text="{Binding Symbol}"/>
          <TextBlock Text="Cash" VerticalAlignment="Center"/>
          <NumericUpDown Width="120" Value="{Binding StartingCash}"/>
        </StackPanel>

        <TextBlock Text="Parameters" FontWeight="SemiBold" Margin="0,8,0,0"/>
        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3" Height="140">
          <ListBox ItemsSource="{Binding Parameters}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
          <Button Classes="accent" Content="Run" Command="{Binding RunCommand}"/>
          <Button Content="Cancel" Command="{Binding CancelCommand}"/>
        </StackPanel>
        <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      </StackPanel>

      <!-- Report -->
      <DockPanel Grid.Column="1">
        <Border DockPanel.Dock="Top" Background="{DynamicResource Background.Surface}" BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1" CornerRadius="3" Padding="12" Margin="0,0,0,8">
          <WrapPanel>
            <TextBlock Text="{Binding NetProfit, StringFormat='Net P&amp;L: {0:C0}'}" Margin="0,0,18,4" Foreground="{DynamicResource Accent.Brush}" FontWeight="Bold"/>
            <TextBlock Text="{Binding Sharpe, StringFormat='Sharpe: {0:0.00}'}" Margin="0,0,18,4"/>
            <TextBlock Text="{Binding MaxDrawdown, StringFormat='MaxDD: {0:P1}'}" Margin="0,0,18,4"/>
            <TextBlock Text="{Binding WinRate, StringFormat='Win: {0:P0}'}" Margin="0,0,18,4"/>
            <TextBlock Text="{Binding ProfitFactor, StringFormat='PF: {0:0.00}'}" Margin="0,0,18,4"/>
            <TextBlock Text="{Binding TradeCount, StringFormat='Trades: {0}'}" Margin="0,0,18,4"/>
          </WrapPanel>
        </Border>
        <TextBlock DockPanel.Dock="Top" Text="Trades" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
          <ListBox ItemsSource="{Binding Trades}" Background="{DynamicResource Background.Surface}" FontSize="11"/>
        </Border>
      </DockPanel>
    </Grid>
  </DockPanel>
</Window>
