<mah:MetroWindow x:Class="TradingTerminal.Strategies.IndexRegimeGraph.IndexRegimeGraphWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:ctl="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Index Regime Graph"
                 Height="820" Width="1240"
                 WindowStartupLocation="CenterOwner"
                 GlowBrush="{DynamicResource Accent.Brush}"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>

        <!-- Chrome surface gradients. -->
        <LinearGradientBrush x:Key="ChromeBar" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1A1A1A" Offset="0" />
            <GradientStop Color="#0E0E0E" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardHeader" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#241A06" Offset="0" />
            <GradientStop Color="#120D03" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelHeader" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#161616" Offset="0" />
            <GradientStop Color="#0C0C0C" Offset="1" />
        </LinearGradientBrush>

        <!-- Toolbar button: flat, rounded, accent on hover. -->
        <Style x:Key="GraphToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
            <Setter Property="Background" Value="#1C1C1C" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="4" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2A2206" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource Accent.Brush}" />
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Status chip in the footer. -->
        <Style x:Key="FooterChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="9,2" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#161616" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Column header cell text. -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- One heatmap row. Hover highlight + thin separator; fades for no-data rows. -->
        <Style x:Key="HeatRow" TargetType="Border">
            <Setter Property="BorderBrush" Value="#15FFFFFF" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0,2" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#14FFB000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Borderless button so a whole summary row is one click target (toggles the drill-down). -->
        <Style x:Key="RowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Stretch" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    ToolTip="Arm or disarm signal publishing. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Padding" Value="14,4" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Arm" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Disarm" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <!-- ── Per-stock indicator-settings flyout (opened by the ⚙ Indicators toolbar button) ──── -->
    <mah:MetroWindow.Flyouts>
        <mah:FlyoutsControl>
            <mah:Flyout Header="INDICATOR SETTINGS" Position="Right" Width="460" Theme="Dark"
                        IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,14,18,18">
                        <StackPanel.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Width" Value="56" />
                                <Setter Property="Margin" Value="0,0,10,6" />
                            </Style>
                            <Style x:Key="FieldLabel" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                <Setter Property="FontSize" Value="10.5" />
                                <Setter Property="Margin" Value="0,0,0,2" />
                            </Style>
                            <Style x:Key="SectionLabel" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                                <Setter Property="FontSize" Value="11" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Margin" Value="0,12,0,6" />
                            </Style>
                        </StackPanel.Resources>

                        <!-- Target picker + per-stock override -->
                        <TextBlock Text="APPLY TO" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding SettingsTargets}" SelectedItem="{Binding SelectedSettingsTarget}" />
                        <CheckBox Content="Use custom settings for this stock" Margin="0,9,0,0"
                                  IsChecked="{Binding UseCustomForStock}"
                                  Visibility="{Binding IsStockTarget, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" FontSize="10.5" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Each stock inherits the default until you tick the box above. Edits apply on the next refresh — or hit Apply to re-analyse now." />

                        <!-- Indicator parameters (disabled while a stock is inheriting the default) -->
                        <StackPanel IsEnabled="{Binding SettingsFieldsEnabled}">
                            <TextBlock Text="RSI" Style="{StaticResource SectionLabel}" />
                            <WrapPanel>
                                <StackPanel><TextBlock Text="Length" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.RsiLength}" /></StackPanel>
                                <StackPanel><TextBlock Text="Overbought" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.RsiOverbought}" /></StackPanel>
                                <StackPanel><TextBlock Text="Oversold" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.RsiOversold}" /></StackPanel>
                            </WrapPanel>

                            <TextBlock Text="MACD" Style="{StaticResource SectionLabel}" />
                            <WrapPanel>
                                <StackPanel><TextBlock Text="Fast" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.MacdFast}" /></StackPanel>
                                <StackPanel><TextBlock Text="Slow" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.MacdSlow}" /></StackPanel>
                                <StackPanel><TextBlock Text="Signal" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.MacdSignal}" /></StackPanel>
                            </WrapPanel>

                            <TextBlock Text="MOVING AVERAGES" Style="{StaticResource SectionLabel}" />
                            <WrapPanel>
                                <StackPanel><TextBlock Text="CCI" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.CciLength}" /></StackPanel>
                                <StackPanel><TextBlock Text="MA 9" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.Ma9Length}" /></StackPanel>
                                <StackPanel><TextBlock Text="MA 21" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.Ma21Length}" /></StackPanel>
                                <StackPanel><TextBlock Text="MA 50" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.Ma50Length}" /></StackPanel>
                            </WrapPanel>
                            <WrapPanel>
                                <StackPanel><TextBlock Text="3MA fast" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.TripleMaFast}" /></StackPanel>
                                <StackPanel><TextBlock Text="3MA mid" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.TripleMaMid}" /></StackPanel>
                                <StackPanel><TextBlock Text="3MA slow" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.TripleMaSlow}" /></StackPanel>
                            </WrapPanel>

                            <TextBlock Text="VOLATILITY" Style="{StaticResource SectionLabel}" />
                            <WrapPanel>
                                <StackPanel><TextBlock Text="ST factor" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.SuperTrendFactor}" /></StackPanel>
                                <StackPanel><TextBlock Text="ST ATR" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.SuperTrendAtrLength}" /></StackPanel>
                                <StackPanel><TextBlock Text="ATR" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.AtrLength}" /></StackPanel>
                                <StackPanel><TextBlock Text="ATR reg" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.AtrRegressionLength}" /></StackPanel>
                                <StackPanel><TextBlock Text="STD" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.StdLength}" /></StackPanel>
                            </WrapPanel>

                            <TextBlock Text="VOLUME / RANGE" Style="{StaticResource SectionLabel}" />
                            <WrapPanel>
                                <StackPanel><TextBlock Text="POC lookback" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.PocLookback}" /></StackPanel>
                                <StackPanel><TextBlock Text="Trend range" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.TrendRangeLength}" /></StackPanel>
                                <StackPanel><TextBlock Text="Δ lookback" Style="{StaticResource FieldLabel}" /><TextBox Text="{Binding EditingSettings.DeltaLookback}" /></StackPanel>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button Content="Apply &amp; re-analyse" Command="{Binding ApplySettingsCommand}" Style="{StaticResource GraphToolButton}" />
                            <Button Content="Reset" Command="{Binding ResetSettingsCommand}" Style="{StaticResource GraphToolButton}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </mah:Flyout>
        </mah:FlyoutsControl>
    </mah:MetroWindow.Flyouts>

    <Grid>
        <!-- ── Setup form ───────────────────────────────────────────────────────────────── -->
        <ctl:StrategySetupHost Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               Title="Index Regime Graph"
                               Subtitle="REGIME · INDEX GRAPH"
                               Tags="L1, Bars"
                               Description="Runs the Advanced Market Regime indicator stack on every constituent across all eight timeframes, blends each stock for the chosen horizon, weights by index membership, and sums to a composite up/down direction.">
                    <StackPanel>
                        <TextBlock Text="INDEX FAMILY" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Families}" SelectedItem="{Binding SelectedFamily}"
                                  DisplayMemberPath="DisplayName" Margin="0,0,0,14" />

                        <TextBlock Text="HORIZON (t)" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Horizons}" SelectedItem="{Binding SelectedHorizon}" Margin="0,0,0,3" />
                        <TextBlock Text="{Binding HorizonDescription}" Foreground="{DynamicResource Text.Secondary}"
                                   FontSize="11" Margin="0,0,0,14" />

                        <TextBlock Text="DATA BROKER" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                        <ComboBox ItemsSource="{Binding Brokers}" SelectedItem="{Binding SelectedBroker}" Margin="0,0,0,3" />
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" FontSize="11" Margin="0,0,0,14" TextWrapping="Wrap"
                                   Text="Every constituent is fetched from this broker. Pick Simulated to run fully offline with synthetic data for all names; pick a live broker (e.g. IB) if each constituent has a market-data line." />

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="REFRESH INTERVAL (s)" Style="{StaticResource Strategy.ParamGroupLabel}" Margin="0,0,0,5" />
                                <TextBox Text="{Binding RefreshSeconds, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom">
                                <CheckBox Content="Auto-refresh" IsChecked="{Binding AutoRefresh}" Margin="0,0,0,6" />
                            </StackPanel>
                        </Grid>

                        <Border CornerRadius="5" Background="{DynamicResource Danger.Brush}" Padding="10,6" Margin="0,0,0,14"
                                Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                        </Border>

                        <Button Content="Continue  →" Command="{Binding ContinueCommand}"
                                HorizontalAlignment="Right" IsDefault="True" MinWidth="130"
                                Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                    </StackPanel>
        </ctl:StrategySetupHost>

        <!-- ── Main view ────────────────────────────────────────────────────────────────── -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Toolbar -->
            <Border DockPanel.Dock="Top" Background="{StaticResource ChromeBar}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="12,7">
                <DockPanel>
                    <ctl:StrategyChromeBar DockPanel.Dock="Right" SnapshotName="index-regime-graph"
                                           ShowBarsCsv="False" ShowSignalsCsv="False"
                                           HelpTitle="READING THE REGIME GRAPH">
                        <ctl:StrategyChromeBar.ExtraActions>
                            <Button Style="{StaticResource App.IconButton}" Content="↧"
                                    Command="{Binding ExportTableCsvCommand}"
                                    ToolTip="Export the constituent table (score, weight, contribution, band) as CSV" />
                        </ctl:StrategyChromeBar.ExtraActions>
                        <ctl:StrategyChromeBar.HelpContent>
                            <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                <Run FontWeight="SemiBold" Text="Matrix" /><Run Text=" — one row per index constituent, one cell per timeframe; cell colour is that stock's regime call on that horizon (green bullish, red bearish). Expand a row for its full indicator breakdown." /><LineBreak />
                                <Run FontWeight="SemiBold" Text="Composite" /><Run Text=" — the hero strip aggregates every constituent's score, weighted by index weight; STRONG UP / STRONG DOWN fires when breadth and magnitude align." /><LineBreak />
                                <Run FontWeight="SemiBold" Text="Contrib" /><Run Text=" — each stock's weighted push on the composite; sort mentally by this column to see who is driving the index call." /><LineBreak />
                                <Run FontWeight="SemiBold" Text="⚙ Indicators" /><Run Text=" — per-stock RSI / MACD / ATR parameter overrides; ◷ marks rows padded with synthetic history until real bars arrive." />
                            </TextBlock>
                        </ctl:StrategyChromeBar.HelpContent>
                    </ctl:StrategyChromeBar>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="▦" FontSize="16" Foreground="{DynamicResource Accent.Brush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="INDEX REGIME GRAPH" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource Text.Header}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <Button Content="■ Stop" Command="{Binding StopCommand}" Style="{StaticResource GraphToolButton}"
                            Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Content="▶ Start" Command="{Binding StartCommand}" Style="{StaticResource GraphToolButton}"
                            Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <Button Content="⟳ Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource GraphToolButton}" />
                    <Button Content="⚙ Indicators" Command="{Binding ToggleSettingsCommand}" Style="{StaticResource GraphToolButton}"
                            ToolTip="Per-stock indicator parameters (RSI / MACD / ATR / …)." />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <TextBlock Text="HORIZON" Style="{StaticResource Strategy.ParamGroupLabel}" />
                    <ComboBox ItemsSource="{Binding Horizons}" SelectedItem="{Binding SelectedHorizon}"
                              VerticalAlignment="Center" Width="116" Margin="0,0,8,0" />
                    <CheckBox Content="Auto" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Border Style="{StaticResource Strategy.ParamDivider}" />

                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                </StackPanel>
                </DockPanel>
            </Border>

            <!-- Footer -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource ChromeBar}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,1,0,0" Padding="12,6">
                <StackPanel Orientation="Horizontal">
                    <Border Style="{StaticResource FooterChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▲" Foreground="{DynamicResource Bullish.Brush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding BullishCount}" Foreground="{DynamicResource Bullish.Brush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FooterChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▼" Foreground="{DynamicResource Danger.Brush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding BearishCount}" Foreground="{DynamicResource Danger.Brush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource FooterChip}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="READY" Foreground="{DynamicResource Text.Secondary}" FontSize="9.5" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Foreground="{DynamicResource Text.Primary}" FontWeight="SemiBold"><Run Text="{Binding ConstituentsReady}" /><Run Text="/" /><Run Text="{Binding ConstituentsTotal}" /></TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" Margin="6,0,12,0" VerticalAlignment="Center"
                               Visibility="{Binding UsingSyntheticData, Converter={StaticResource BooleanToVisibilityConverter}}"
                               ToolTip="One or more constituents had no live/stored history (markets likely closed); showing synthetic history until real data arrives."
                               Text="◷ SYNTHETIC (offline)" />
                    <TextBlock Foreground="{DynamicResource Accent.Brush}" FontWeight="SemiBold" Margin="0,0,12,0" VerticalAlignment="Center"
                               Visibility="{Binding IsRefreshing, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="◌ ANALYSING…" />
                    <TextBlock Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" VerticalAlignment="Center"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ARMED" />
                    <Border Style="{StaticResource Pill.Warn}" Margin="12,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="⏸ PAUSED" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Heatmap table ──────────────────────────────────────────────────────────── -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Composite hero strip -->
                <Border Grid.Row="0" Background="{StaticResource PanelHeader}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="18,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CompositePercent, StringFormat=+0.0;-0.0;0.0}"
                                       FontSize="34" FontWeight="Bold"
                                       Foreground="{Binding CompositeColorHex, Converter={StaticResource StringToBrushConverter}}" />
                            <TextBlock Text="%" FontSize="17" VerticalAlignment="Bottom" Margin="2,0,14,6"
                                       Foreground="{DynamicResource Text.Secondary}" />
                            <Border CornerRadius="10" Padding="12,4" VerticalAlignment="Center" Margin="0,0,16,0"
                                    Background="{Binding CompositeColorHex, Converter={StaticResource StringToBrushConverter}}">
                                <TextBlock Text="{Binding CompositeDirection}" FontSize="13" FontWeight="Bold" Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedFamily.DisplayName}" FontWeight="SemiBold" FontSize="13"
                                           Foreground="{DynamicResource Text.Header}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding HorizonDescription}" Foreground="{DynamicResource Text.Secondary}" FontSize="10.5" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                   Foreground="{DynamicResource Text.Secondary}" FontSize="10.5"
                                   Text="green = bullish · red = bearish · columns are timeframes (fast → slow)" />
                    </Grid>
                </Border>

                <!-- Column header -->
                <Border Grid.Row="1" Background="{DynamicResource Background.Elevated}"
                        BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1" Padding="12,7">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22" />
                            <ColumnDefinition Width="76" />
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="84" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="SYMBOL" Style="{StaticResource HeaderText}" />
                        <TextBlock Grid.Column="2" Text="WEIGHT" Style="{StaticResource HeaderText}" TextAlignment="Right" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="3" Text="SCORE" Style="{StaticResource HeaderText}" TextAlignment="Right" Margin="0,0,8,0" />
                        <TextBlock Grid.Column="4" Text="DIRECTION" Style="{StaticResource HeaderText}" Margin="6,0,0,0" />
                        <ItemsControl Grid.Column="5" ItemsSource="{Binding TimeframeHeaders}" Margin="2,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource HeaderText}"
                                               TextAlignment="Center" HorizontalAlignment="Stretch" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Grid.Column="6" Text="CONTRIB" Style="{StaticResource HeaderText}" TextAlignment="Right" Margin="0,0,4,0" />
                    </Grid>
                </Border>

                <!-- Rows -->
                <!-- Rows. Virtualization only works when the ScrollViewer lives INSIDE the
                     ItemsControl template (CanContentScroll) so the VirtualizingStackPanel is
                     the scroll host — an outer ScrollViewer hands the panel infinite height and
                     silently realizes all 500 rows. -->
                <ItemsControl Grid.Row="2" ItemsSource="{Binding ConstituentRows}"
                              Background="{DynamicResource Background.Surface}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <Border Background="{TemplateBinding Background}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="True" Focusable="False">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </ControlTemplate>
                    </ItemsControl.Template>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><VirtualizingStackPanel /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Summary row — click anywhere to toggle the drill-down. -->
                                    <Button Style="{StaticResource RowButton}"
                                            Command="{Binding DataContext.ToggleRowCommand, RelativeSource={RelativeSource AncestorType={x:Type mah:MetroWindow}}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Click to show each indicator's result on every timeframe.">
                                        <Border Style="{StaticResource HeatRow}" Opacity="{Binding RowOpacity}">
                                            <Grid Margin="12,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="22" />
                                                    <ColumnDefinition Width="76" />
                                                    <ColumnDefinition Width="58" />
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="104" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="84" />
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0">
                                                    <!-- Expand caret — hidden while this row is still loading. -->
                                                    <TextBlock FontSize="10" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource Text.Secondary}" Text="▸"
                                                               Visibility="{Binding IsBusy, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Text" Value="▾" />
                                                                        <Setter Property="Foreground" Value="{DynamicResource Accent.Brush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <!-- Per-asset loading spinner — shown while this constituent is being fetched/computed. -->
                                                    <ctl:Spinner Diameter="13" Thickness="2"
                                                                 ArcBrush="{DynamicResource Accent.Brush}" TrackBrush="#1FFFFFFF"
                                                                 HorizontalAlignment="Left" VerticalAlignment="Center"
                                                                 ToolTip="{Binding LoadStatusText}"
                                                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </Grid>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Symbol}" FontWeight="SemiBold"
                                                                   FontFamily="Consolas, Cascadia Mono, monospace" FontSize="12.5"
                                                                   Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center" />
                                                        <!-- Terminal-state glyph once loaded (● real · ◷ synthetic · ∅ none). -->
                                                        <TextBlock Text="{Binding LoadGlyph}" FontSize="8" Margin="4,0,0,0" VerticalAlignment="Center"
                                                                   Foreground="{Binding LoadGlyphHex, Converter={StaticResource StringToBrushConverter}}" />
                                                    </StackPanel>
                                                    <!-- Status caption: queued / loading… / synthetic / no data (hidden once ready). -->
                                                    <TextBlock Text="{Binding LoadStatusText}" FontSize="8.5" Margin="0,-1,0,0"
                                                               Foreground="{Binding LoadGlyphHex, Converter={StaticResource StringToBrushConverter}}"
                                                               Visibility="{Binding ShowLoadStatus, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </StackPanel>

                                                <TextBlock Grid.Column="2" Text="{Binding WeightText}" TextAlignment="Right" Margin="0,0,8,0"
                                                           Foreground="{DynamicResource Text.Secondary}" FontSize="11.5" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Text="{Binding ScoreText}" TextAlignment="Right" Margin="0,0,8,0"
                                                           FontWeight="SemiBold" FontSize="11.5" VerticalAlignment="Center"
                                                           Foreground="{Binding ScoreHex, Converter={StaticResource StringToBrushConverter}}" />

                                                <Border Grid.Column="4" CornerRadius="8" Padding="8,1" HorizontalAlignment="Left" Margin="6,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Background="{Binding TintHex, Converter={StaticResource StringToBrushConverter}}">
                                                    <TextBlock Text="{Binding DirectionText}" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{Binding ScoreHex, Converter={StaticResource StringToBrushConverter}}" />
                                                </Border>

                                                <ItemsControl Grid.Column="5" ItemsSource="{Binding Cells}" Margin="2,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="1.5,1" CornerRadius="3" MinHeight="22"
                                                                    Background="{Binding TintHex, Converter={StaticResource StringToBrushConverter}}"
                                                                    ToolTip="{Binding Label}">
                                                                <TextBlock Text="{Binding Text}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           FontSize="10.5" FontFamily="Consolas, Cascadia Mono, monospace"
                                                                           Foreground="{Binding TextHex, Converter={StaticResource StringToBrushConverter}}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Grid.Column="6" Text="{Binding ContribText}" TextAlignment="Right" Margin="0,0,4,0"
                                                           FontWeight="SemiBold" FontSize="11.5" VerticalAlignment="Center"
                                                           FontFamily="Consolas, Cascadia Mono, monospace"
                                                           Foreground="{Binding ScoreHex, Converter={StaticResource StringToBrushConverter}}" />
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <!-- Drill-down: every indicator's result on every timeframe. -->
                                    <Border Background="#070707" BorderBrush="#15FFFFFF" BorderThickness="0,0,0,1"
                                            Padding="34,6,12,10"
                                            Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <!-- timeframe header for the matrix -->
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="78" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="INDICATOR" Style="{StaticResource HeaderText}" FontSize="9" />
                                                <ItemsControl Grid.Column="1"
                                                              ItemsSource="{Binding DataContext.TimeframeHeaders, RelativeSource={RelativeSource AncestorType={x:Type mah:MetroWindow}}}"
                                                              Margin="2,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Style="{StaticResource HeaderText}" FontSize="9"
                                                                       TextAlignment="Center" HorizontalAlignment="Stretch" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>

                                            <!-- one row per indicator -->
                                            <ItemsControl ItemsSource="{Binding IndicatorMatrix}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="78" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="10.5"
                                                                       Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" />
                                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}" Margin="2,0">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Margin="1.5,0.5" CornerRadius="2" MinHeight="18"
                                                                                Background="{Binding TintHex, Converter={StaticResource StringToBrushConverter}}"
                                                                                ToolTip="{Binding ToolTip}">
                                                                            <TextBlock Text="{Binding Arrow}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                       FontSize="10"
                                                                                       Foreground="{Binding TextHex, Converter={StaticResource StringToBrushConverter}}" />
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="No indicator data for this constituent yet."
                                                       Foreground="{DynamicResource Text.Secondary}" FontSize="10.5" Margin="0,2,0,0"
                                                       Visibility="{Binding HasMatrix, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
