<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target: portable VM + descriptor on net9.0 (Avalonia view); WPF node-graph window on
         the windows leg. See Strategies.OrnsteinUhlenbeck for the template. -->
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Description>Index Regime Graph â€” runs the Advanced Market Regime indicator stack across every constituent of an index, blends each stock's eight timeframes for a chosen horizon, weights by index membership, and sums to a composite up/down direction.</Description>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <!-- Plugin references ONLY the DaxAlgo SDK — the same Phase B boundary SigmaIcFlow uses.
       DaxAlgo.Sdk.Wpf transitively provides the headless contract (DaxAlgo.Sdk -> TradingTerminal.Core,
       incl. Core.MarketData.AdvancedRegime + Core.Quant) and the WPF UI bases (TradingTerminal.UI /
       .UI.Core, incl. ScottPlot.WPF). NO host-internal (Infrastructure) reference: the strategy only
       consumes the Core IAdvancedRegimeProvider interface; the host registers its impl. MahApps is the
       plugin's own UI-toolkit dependency (its window XAML uses MetroWindow). -->
  <ItemGroup>
    <ProjectReference Include="..\..\Sdk\DaxAlgo.Sdk.Wpf\DaxAlgo.Sdk.Wpf.csproj" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0-windows7.0'">
    <PackageReference Include="Avalonia" Version="11.2.1" />
    <Compile Remove="IndexRegimeGraphWindow.xaml.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <!-- Plugin manifest — shipped next to the DLL when this strategy is packaged as an external plugin
       (the host reads plugin.json before loading the assembly). -->
  <ItemGroup>
    <None Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
