<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.Strategies.IndexRegimeGraph.AvaloniaUi.IndexRegimeGraphAvaloniaWindow"
        Width="720" Height="560"
        Background="{DynamicResource Background.Primary}"
        Title="Index Regime Graph">
  <!-- Functional cross-platform view binding the portable VM. The faithful pan/zoom node-graph +
       per-constituent heatmap table is a later parity pass; this opens the strategy and shows the
       live composite direction on Windows and Linux. -->
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="Index Regime Graph" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding ValidationError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Continue" Command="{Binding ContinueCommand}"/>
      <Button Content="Start" Command="{Binding StartCommand}"/>
      <Button Content="Arm / disarm" Command="{Binding ToggleAlgoCommand}"/>
      <Button Content="Stop" Command="{Binding StopCommand}"/>
    </StackPanel>

    <StackPanel Spacing="8" Margin="0,12,0,0">
      <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Index family" VerticalAlignment="Center" Margin="0,0,8,6"/>
        <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding Families}" SelectedItem="{Binding SelectedFamily}">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Horizon" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                  ItemsSource="{Binding Horizons}" SelectedItem="{Binding SelectedHorizon}"/>
      </Grid>

      <Border Background="{DynamicResource Background.Surface}" BorderBrush="{DynamicResource Border.Brush}"
              BorderThickness="1" CornerRadius="3" Padding="12" Margin="0,8,0,0">
        <StackPanel Spacing="4">
          <TextBlock Text="Composite regime" FontWeight="SemiBold" Foreground="{DynamicResource Text.Header}"/>
          <TextBlock Text="{Binding CompositeDirection}" FontSize="22" FontWeight="Bold"/>
          <TextBlock Text="{Binding CompositePercent, StringFormat='Composite tilt: {0:+0.0;-0.0;0.0}%'}"/>
          <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0">
            <TextBlock Text="{Binding BullishCount, StringFormat='Bullish: {0}'}" Foreground="{DynamicResource Bullish.Brush}"/>
            <TextBlock Text="{Binding BearishCount, StringFormat='Bearish: {0}'}" Foreground="{DynamicResource Bearish.Brush}"/>
            <TextBlock Text="{Binding ConstituentsReady, StringFormat='Ready: {0}'}" Foreground="{DynamicResource Text.Secondary}"/>
            <TextBlock Text="{Binding ConstituentsTotal, StringFormat='/ {0}'}" Foreground="{DynamicResource Text.Secondary}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </DockPanel>
</Window>
