я╗┐<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target so the (portable) strategy VM + descriptor compile for Linux/Avalonia on the
         net9.0 leg, while the WPF window stays on the net9.0-windows7.0 leg. Template for porting
         the other 11 Strategies.* projects. -->
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Description>Ornstein-Uhlenbeck mean reversion - live signal-mode wrapper around the OrnsteinUhlenbeckStrategy backtest implementation.</Description>
  </PropertyGroup>

  <!-- WPF (window + MahApps) only on the Windows leg. -->
  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\windows\Core\TradingTerminal.Core\TradingTerminal.Core.csproj" />
    <ProjectReference Include="..\..\..\windows\Pipeline\TradingTerminal.Infrastructure\TradingTerminal.Infrastructure.csproj" />
    <!-- Portable VM layer (ViewModelBase, LiveSignalStrategyViewModelBase, router factory). -->
    <ProjectReference Include="..\..\..\windows\UI\TradingTerminal.UI.Core\TradingTerminal.UI.Core.csproj" />
  </ItemGroup>

  <!-- The WPF shell primitives (StrategyWindowBase, ScottPlot helpers) only on the Windows leg. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <ProjectReference Include="..\..\Shell\TradingTerminal.UI\TradingTerminal.UI.csproj" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <!-- The WPF window compiles only on the Windows leg. -->
  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0-windows7.0'">
    <Compile Remove="OrnsteinUhlenbeckStrategyWindow.xaml.cs" />
  </ItemGroup>

  <!-- ├втАЭтВм├втАЭтВм Cross-platform (Avalonia) view: net9.0 leg only ├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм├втАЭтВм
       The strategy ships its own Avalonia window (the counterpart to the WPF MetroWindow) so the
       Avalonia shell opens it through IStrategyFactory. The Avalonia package is referenced only on
       the net9.0 leg, so its XAML compiler (which globs **/*.axaml ├втВмтАЭ never the WPF .xaml) runs only
       here; the WPF Page compiler globs **/*.xaml only on the windows leg. The two never overlap. -->
  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0-windows7.0'">
    <PackageReference Include="Avalonia" Version="11.2.1" />
  </ItemGroup>

  <!-- On the WPF (windows) leg the Avalonia view's code-behind must not compile. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
