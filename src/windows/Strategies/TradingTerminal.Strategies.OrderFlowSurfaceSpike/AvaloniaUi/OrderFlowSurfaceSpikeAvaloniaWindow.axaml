<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="TradingTerminal.Strategies.OrderFlowSurfaceSpike.AvaloniaUi.OrderFlowSurfaceSpikeAvaloniaWindow"
        Width="760" Height="600"
        Background="{DynamicResource Background.Primary}"
        Title="Order Flow Surface Spike">
  <!-- Cross-platform view: the WPF window draws a HelixToolkit 3D height-map; here the same
       [slice × price-bin] Z-score grid renders as a ScottPlot.Avalonia heatmap (no GPU). A true 3D
       surface can replace this later via the GPU control. -->
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Spacing="4">
      <TextBlock Text="Order Flow Surface Spike" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Text.Header}"/>
      <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap"/>
      <TextBlock Text="{Binding ValidationError}" Foreground="{DynamicResource Danger.Brush}" TextWrapping="Wrap"/>
    </StackPanel>

    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
      <Button Content="Continue" Command="{Binding ContinueCommand}"/>
      <Button Content="Arm / disarm" Command="{Binding ToggleAlgoCommand}"/>
      <Button Content="Stop" Command="{Binding StopCommand}"/>
    </StackPanel>

    <Grid ColumnDefinitions="*,*" Margin="0,12,0,0">
      <StackPanel Grid.Column="0" Spacing="6" Margin="0,0,10,0">
        <TextBlock Text="Instrument" FontWeight="SemiBold"/>
        <TextBox Watermark="Search…" Text="{Binding InstrumentSearchText}"/>
        <ComboBox ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}" HorizontalAlignment="Stretch">
          <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="Surface parameters" FontWeight="SemiBold" Margin="0,10,0,0"/>
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="Ticks / slice" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="0,0,0,4" Value="{Binding TicksPerSlice}" Minimum="1"/>
          <TextBlock Grid.Row="1" Grid.Column="0" Text="Slices" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="1" Grid.Column="1" Margin="0,0,0,4" Value="{Binding NumSlices}" Minimum="1"/>
          <TextBlock Grid.Row="2" Grid.Column="0" Text="Price bin" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="2" Grid.Column="1" Margin="0,0,0,4" Value="{Binding PriceBinSize}" Increment="0.01"/>
          <TextBlock Grid.Row="3" Grid.Column="0" Text="Window bins" VerticalAlignment="Center" Margin="0,0,8,4"/>
          <NumericUpDown Grid.Row="3" Grid.Column="1" Margin="0,0,0,4" Value="{Binding WindowBins}" Minimum="1"/>
          <TextBlock Grid.Row="4" Grid.Column="0" Text="Spike σ" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <NumericUpDown Grid.Row="4" Grid.Column="1" Value="{Binding SpikeThreshold}" Increment="0.1"/>
        </Grid>
      </StackPanel>

      <Border Grid.Column="1" BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <sp:AvaPlot x:Name="SurfacePlot"/>
      </Border>
    </Grid>
  </DockPanel>
</Window>
