<mah:MetroWindow x:Class="TradingTerminal.Strategies.OrderFlowSurfaceSpike.OrderFlowSurfaceSpikeWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:helix="http://helix-toolkit.org/wpf"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.OrderFlowSurfaceSpike"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Order Flow Surface Spike"
                 Height="760" Width="1180"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button x:Name="RunStopButton"
                    Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- Setup form -->
        <uic:StrategySetupHost Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               Title="Order Flow Surface Spike"
                               Subtitle="ORDER FLOW · 3D SURFACE"
                               Tags="L1, Bars, Trade tape"
                               Description="Z-score surface over a rolling [slice × price-bin] matrix of signed order flow. Spikes in the latest slice trigger entries; reversion or TP/SL exits.">
                <StackPanel>
                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ticks / slice" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Num slices"    Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Bin size"      Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Window bins"   Margin="4,0,0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding TicksPerSlice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding NumSlices, UpdateSourceTrigger=PropertyChanged}"     Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding PriceBinSize, UpdateSourceTrigger=PropertyChanged}"  Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding WindowBins, UpdateSourceTrigger=PropertyChanged}"    Margin="4,0,0,0"/>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Spike Z" Margin="0,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Confirm ticks" Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Quantity"      Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="SL"            Margin="4,0,4,4"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="TP"            Margin="4,0,0,4"/>
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding SpikeThreshold, UpdateSourceTrigger=PropertyChanged}"   Margin="0,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding ConfirmationTicks, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"          Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="3" Text="{Binding StopLossPips, UpdateSourceTrigger=PropertyChanged}"      Margin="4,0,4,0"/>
                        <TextBox   Grid.Row="1" Grid.Column="4" Text="{Binding TakeProfitPips, UpdateSourceTrigger=PropertyChanged}"    Margin="4,0,0,0"/>
                    </Grid>

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
        </uic:StrategySetupHost>

        <!-- Surface view -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live tuning strip. Spike Z / confirm / qty / SL / TP are evaluated fresh on each
                 trade, so they're live while streaming. The slice/bin matrix is baked into the
                 calculator (Stop to edit, Start to rebuild). Z-height is render-only. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="TUNING" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Spike Z" Minimum="0.5" Maximum="10" Step="0.1" StringFormat="0.00"
                                          Value="{Binding SpikeThreshold, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="Confirm ticks" Minimum="1" Maximum="50" Step="1" StringFormat="0"
                                          Value="{Binding ConfirmationTicks, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="Quantity" Minimum="1" Maximum="1000" Step="1" StringFormat="0"
                                          Value="{Binding Quantity, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="SL (pips)" Minimum="0.1" Maximum="500" Step="1" StringFormat="0.#"
                                          Value="{Binding StopLossPips, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="TP (pips)" Minimum="0.1" Maximum="500" Step="1" StringFormat="0.#"
                                          Value="{Binding TakeProfitPips, Mode=TwoWay}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSlider Label="Z height ×" Minimum="0.4" Maximum="4" Step="0.1" SliderWidth="120"
                                         Value="{Binding SurfaceHeightScale, Mode=TwoWay}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="MATRIX (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Ticks/slice" Minimum="1" Maximum="5000" Step="10" StringFormat="0"
                                              Value="{Binding TicksPerSlice, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Num slices" Minimum="2" Maximum="200" Step="1" StringFormat="0"
                                              Value="{Binding NumSlices, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Bin size" Minimum="0.0001" Maximum="100" Step="0.01" StringFormat="0.####" SpinnerWidth="92"
                                              Value="{Binding PriceBinSize, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Window bins" Minimum="5" Maximum="201" Step="2" StringFormat="0"
                                              Value="{Binding WindowBins, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Slice:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding TicksPerSlice}" Margin="6,0,2,0"/><TextBlock Text="t ×" Margin="0,0,2,0"/>
                    <TextBlock Text="{Binding NumSlices}" Margin="0,0,16,0"/>
                    <TextBlock Text="Bin:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding PriceBinSize}" Margin="6,0,16,0"/>
                    <TextBlock Text="Z*:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding SpikeThreshold, StringFormat=F2}" Margin="6,0,16,0"/>
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Text.Secondary}"
                               Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <helix:HelixViewport3D x:Name="View3D"
                                       Grid.Column="0"
                                       ZoomExtentsWhenLoaded="True"
                                       ShowFrameRate="False"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="True"
                                       Background="#1E1E1E"
                                       CameraRotationMode="Trackball"
                                       IsHeadLightEnabled="True" />

            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource Background.Elevated}"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Trades:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding TradesSeen}" Margin="6,0,16,0"/>
                    <TextBlock Text="μ:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding CurrentMean, StringFormat=F2}" Margin="6,0,16,0"/>
                    <TextBlock Text="σ:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding CurrentStd, StringFormat=F2}" Margin="6,0,16,0"/>
                    <TextBlock Text="Latest Z:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding CurrentSpikeZ, StringFormat=+0.00;-0.00; 0.00}" Margin="6,0,16,0" FontWeight="SemiBold"/>
                    <TextBlock Text="Pos:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding PositionDisplay}" Margin="6,0,16,0"/>
                    <TextBlock Text="Signal:" Foreground="{DynamicResource Text.Secondary}"/>
                    <TextBlock Text="{Binding SignalLabel}" Margin="6,0,16,0"/>
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Warning.Brush}"
                               FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                </StackPanel>
            </Border>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
