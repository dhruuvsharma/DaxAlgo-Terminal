<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
    <!-- Emit HelixToolkit.Wpf.dll into bin so the host can stage this private dep into the plugin folder. -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <Description>Order-flow surface spike detector — 3D Z-score heightmap of [slice × price-bin] order-flow imbalance with real-time spike entries. Ships its own backtest engine (Engine/).</Description>
  </PropertyGroup>

  <!-- External plugin: references ONLY the DaxAlgo SDK. The engine (Engine/OrderFlowSurfaceSpikeStrategy)
       moved in from Infrastructure. HelixToolkit is a PRIVATE dep staged into the plugin folder by the
       host. See Strategies.SigmaIcFlow. -->
  <ItemGroup>
    <ProjectReference Include="..\..\Sdk\DaxAlgo.Sdk.Wpf\DaxAlgo.Sdk.Wpf.csproj" />
    <PackageReference Include="HelixToolkit.Wpf" Version="2.27.0" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <ItemGroup>
    <None Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
