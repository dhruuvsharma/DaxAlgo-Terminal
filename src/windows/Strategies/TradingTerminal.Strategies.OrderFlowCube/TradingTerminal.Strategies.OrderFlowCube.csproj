<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
    <!-- Emit HelixToolkit.Wpf.dll into bin so the host can stage this private dep into the plugin
         folder (nothing else in the host graph pulls it in). -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <Description>Order-flow regime cube — 2D phase-space view of CVD vs aggressor ratio with size-ratio color, live from the trade tape. Ships its own backtest engine (Engine/).</Description>
  </PropertyGroup>

  <!-- Ships as an EXTERNAL plugin: references ONLY the DaxAlgo SDK (the Phase B boundary). The engine
       (Engine/OrderFlowCubeStrategy) moved in from Infrastructure so the plugin is self-contained; it
       depends only on Core, which DaxAlgo.Sdk provides. HelixToolkit is a PRIVATE dep staged into the
       plugin folder by the host. See Strategies.SigmaIcFlow. -->
  <ItemGroup>
    <ProjectReference Include="..\..\Sdk\DaxAlgo.Sdk.Wpf\DaxAlgo.Sdk.Wpf.csproj" />
    <PackageReference Include="HelixToolkit.Wpf" Version="2.27.0" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <ItemGroup>
    <None Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
