<mah:MetroWindow x:Class="TradingTerminal.Strategies.OrderFlowCube.OrderFlowCubeWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:helix="http://helix-toolkit.org/wpf"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.OrderFlowCube"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Order Flow Cube"
                 Height="720" Width="1040"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button x:Name="RunStopButton"
                    Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- Setup form -->
        <uic:StrategySetupHost Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               Title="Order Flow Cube"
                               Subtitle="ORDER FLOW · 3D CUBE"
                               Tags="L1, Bars, Trade tape"
                               Description="Plots CVD imbalance (trend window) versus aggressor ratio (recent window) with size ratio as colour, in a rotatable 3D cube. Defaults: 50 / 500 / 2000 trades.">
                <StackPanel>
                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,16" />

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Recent (aggressor)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Trend (CVD)"        Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Baseline (size)"    Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding RecentWindow, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding TrendWindow, UpdateSourceTrigger=PropertyChanged}"  Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding BaselineWindow, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="|CVD| threshold"     Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Aggressor buy thresh" Margin="4,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Size ratio thresh"   Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding CvdThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding AggressorBuyThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="2" Text="{Binding SizeRatioThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                    </Grid>

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
        </uic:StrategySetupHost>

        <!-- Cube view -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live tuning strip. The regime thresholds are evaluated fresh on every trade, so
                 they take effect immediately while streaming. The trade-count windows are baked
                 into the calculator (Stop to edit, Start to rebuild). Size× ceiling is render-only. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <DockPanel>
                    <uic:StrategyChromeBar DockPanel.Dock="Right" SnapshotName="orderflow-cube"
                                           ShowBarsCsv="False" ShowSignalsCsv="False"
                                           HelpTitle="READING THE ORDER-FLOW CUBE">
                        <uic:StrategyChromeBar.ExtraActions>
                            <Button Style="{StaticResource App.IconButton}" Content="↧"
                                    Command="{Binding ExportTrailCsvCommand}"
                                    ToolTip="Export the phase-space trail (aggressor, CVD, size ratio) as CSV" />
                        </uic:StrategyChromeBar.ExtraActions>
                        <uic:StrategyChromeBar.HelpContent>
                            <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                                <Run FontWeight="SemiBold" Text="Phase space" /><Run Text=" — every trade updates three tape statistics: X = aggressor ratio (share of buyer-initiated trades), Y = CVD imbalance (signed volume vs baseline), Z = size ratio (recent avg trade size vs baseline). The glowing point is now; the trail is where the market has been." /><LineBreak />
                                <Run FontWeight="SemiBold" Text="Corners" /><Run Text=" — the top-far corner (high aggressor, positive CVD, big prints) is ACCUMULATION; the opposite corner is DISTRIBUTION. A trail drifting into a corner and staying is regime confirmation; bouncing through the middle is noise." /><LineBreak />
                                <Run FontWeight="SemiBold" Text="Signals" /><Run Text=" — fire when all three thresholds are crossed together. Thresholds apply live; the trade-count windows rebuild on Start." /><LineBreak />
                                <Run FontWeight="SemiBold" Text="Feed" /><Run Text=" — real tape on IB / Binance / Ironbeam / Simulated; other brokers fall back to synthetic L1-derived trades (degraded size axis)." />
                            </TextBlock>
                        </uic:StrategyChromeBar.HelpContent>
                    </uic:StrategyChromeBar>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="TUNING" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="|CVD| thr" Minimum="0.01" Maximum="0.99" Step="0.01" StringFormat="0.00"
                                          Value="{Binding CvdThreshold, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="Aggressor thr" Minimum="0.51" Maximum="0.99" Step="0.01" StringFormat="0.00"
                                          Value="{Binding AggressorBuyThreshold, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="Size ratio thr" Minimum="0.1" Maximum="6" Step="0.05" StringFormat="0.00"
                                          Value="{Binding SizeRatioThreshold, Mode=TwoWay}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSlider Label="Size× ceiling" Minimum="1" Maximum="6" Step="0.5" SliderWidth="120"
                                         Value="{Binding SizeAxisCeiling, Mode=TwoWay}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="WINDOWS (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Recent" Minimum="5" Maximum="5000" Step="10" StringFormat="0"
                                              Value="{Binding RecentWindow, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Trend" Minimum="5" Maximum="20000" Step="50" StringFormat="0"
                                              Value="{Binding TrendWindow, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Baseline" Minimum="5" Maximum="50000" Step="100" StringFormat="0" SpinnerWidth="92"
                                              Value="{Binding BaselineWindow, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="Recent:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding RecentWindow}" Margin="6,0,16,0" />
                    <TextBlock Text="Trend:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding TrendWindow}" Margin="6,0,16,0" />
                    <TextBlock Text="Baseline:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding BaselineWindow}" Margin="6,0,16,0" />
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Text.Secondary}"
                               Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <helix:HelixViewport3D x:Name="View3D"
                                       Grid.Column="0"
                                       ZoomExtentsWhenLoaded="True"
                                       ShowFrameRate="False"
                                       ShowCoordinateSystem="False"
                                       ShowViewCube="True"
                                       Background="#1E1E1E"
                                       CameraRotationMode="Trackball"
                                       IsHeadLightEnabled="True" />

            </Grid>

            <Border Grid.Row="2"
                    Background="{DynamicResource Background.Elevated}"
                    Padding="12,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CVD:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding CurrentCvd, StringFormat=F3, FallbackValue=—}" Margin="6,0,16,0" />
                    <TextBlock Text="Aggressor:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding CurrentAggressor, StringFormat=F3, FallbackValue=—}" Margin="6,0,16,0" />
                    <TextBlock Text="Size×:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding CurrentSizeRatio, StringFormat=F2, FallbackValue=—}" Margin="6,0,16,0" />
                    <TextBlock Text="Trades:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding TradesSeen}" Margin="6,0,16,0" />
                    <TextBlock Text="Regime:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding RegimeLabel}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Warning.Brush}"
                               FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                    <Border Style="{StaticResource Pill.Warn}" Margin="16,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="⏸ PAUSED" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
