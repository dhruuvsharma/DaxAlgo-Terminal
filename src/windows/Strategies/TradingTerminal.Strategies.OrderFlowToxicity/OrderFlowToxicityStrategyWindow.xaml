<ui:StrategyWindowBase x:Class="TradingTerminal.Strategies.OrderFlowToxicity.OrderFlowToxicityStrategyWindow"
                       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                       xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                       xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                       xmlns:ui="clr-namespace:TradingTerminal.UI;assembly=TradingTerminal.UI"
                       xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                       mc:Ignorable="d" Title="{Binding StrategyDisplayName}" Height="680" Width="1100" WindowStartupLocation="CenterOwner"
                       Background="{DynamicResource Background.Primary}" Foreground="{DynamicResource Text.Primary}">
    <mah:MetroWindow.LeftWindowCommands><mah:WindowCommands><Button Command="{Binding ToggleAlgoCommand}" Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource Strategy.RunStopButton}" /></mah:WindowCommands></mah:MetroWindow.LeftWindowCommands>
    <Grid>
        <uic:StrategySetupHost Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               Title="{Binding StrategyDisplayName}"
                               Subtitle="ORDER FLOW"
                               Tags="L1, Bars"
                               Description="Gauge VPIN-style flow toxicity and pause trading when one side persistently dominates. Tune the window and toxicity threshold.">
            <StackPanel>
                <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Instrument" />
                <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                      ItemsSource="{Binding Instruments}"
                                      SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                      Margin="0,0,0,12" />
                <Grid Margin="0,0,0,12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Window ticks" Margin="0,0,4,4" /><TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Toxicity threshold" Margin="4,0,0,4" />
                    <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding WindowTicks, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" /><TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding ToxicityThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Margin="4,0,0,0" />
                </Grid>
                <Grid Margin="0,0,0,16"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Hold ticks" Margin="0,0,4,4" /><TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Strategy.SetupFieldLabel}" Text="Quantity" Margin="4,0,0,4" />
                    <TextBox   Grid.Row="1" Grid.Column="0" Text="{Binding HoldTicks, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" /><TextBox   Grid.Row="1" Grid.Column="1" Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Margin="4,0,0,0" />
                </Grid>
                <Border Style="{StaticResource Strategy.SetupErrorBanner}" Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}"><TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" /></Border>
                <Button Content="Continue" Command="{Binding ContinueCommand}" HorizontalAlignment="Right" IsDefault="True" MinWidth="120" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
            </StackPanel>
        </uic:StrategySetupHost>
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Bars shown" Minimum="30" Maximum="600" Step="10" StringFormat="0"
                                          Value="{Binding ChartBarsShown, Mode=TwoWay}" />
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Y axis" FontSize="10" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                            <CheckBox Content="Auto" IsChecked="{Binding YAutoScale, Mode=TwoWay}" />
                        </StackPanel>
                        <uic:ParamSpinner Label="Y min" Minimum="0" Maximum="1" Step="0.0001" StringFormat="0.#####" SpinnerWidth="92"
                                          Value="{Binding YAxisMin, Mode=TwoWay}"
                                          IsEnabled="{Binding YAutoScale, Converter={StaticResource InverseBooleanConverter}}" />
                        <uic:ParamSpinner Label="Y max" Minimum="0" Maximum="1" Step="0.0001" StringFormat="0.#####" SpinnerWidth="92"
                                          Value="{Binding YAxisMax, Mode=TwoWay}"
                                          IsEnabled="{Binding YAutoScale, Converter={StaticResource InverseBooleanConverter}}" />
                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsStreaming, Converter={StaticResource InverseBooleanConverter}}">
                            <TextBlock Text="PARAMS (locked while streaming)" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <uic:ParamSpinner Label="Window ticks" Minimum="10" Maximum="5000" Step="10" StringFormat="0"
                                              Value="{Binding WindowTicks, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Toxicity thr" Minimum="0.5" Maximum="0.99" Step="0.01" StringFormat="0.00"
                                              Value="{Binding ToxicityThreshold, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Hold ticks" Minimum="1" Maximum="5000" Step="10" StringFormat="0"
                                              Value="{Binding HoldTicks, Mode=TwoWay}" />
                            <uic:ParamSpinner Label="Quantity" Minimum="1" Maximum="1000" Step="1" StringFormat="0"
                                              Value="{Binding Quantity, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Border Grid.Row="0" Style="{StaticResource Strategy.HeaderBar}"><StackPanel Orientation="Horizontal">
                <TextBlock Text="Symbol:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                <TextBlock Text="Tox:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding ToxicityThreshold, StringFormat=F2}" Margin="6,0,16,0" />
                <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
            </StackPanel></Border>
            <scottplot:WpfPlot x:Name="IndicatorPlot" Grid.Row="1" />
            <Border Grid.Row="2" Style="{StaticResource Strategy.FooterBar}"><StackPanel Orientation="Horizontal">
                <TextBlock Text="Bid:" Style="{StaticResource Strategy.DashLabel}" /><TextBlock Text="{Binding LastBid, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Text="  |  Ask:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" /><TextBlock Text="{Binding LastAsk, StringFormat=F4, FallbackValue=—}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Text="  |  Bars:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" /><TextBlock Text="{Binding Bars.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Text="  |  Signals:" Style="{StaticResource Strategy.DashLabel}" Margin="20,0,0,0" /><TextBlock Text="{Binding Signals.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold" Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}" Text="● ALGO ARMED" />
            </StackPanel></Border>
            </Grid>
        </DockPanel>
    </Grid>
</ui:StrategyWindowBase>
