<mah:MetroWindow x:Class="TradingTerminal.Strategies.CumulativeDelta.CumulativeDeltaWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
                 xmlns:local="clr-namespace:TradingTerminal.Strategies.CumulativeDelta"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Cumulative Delta Scalper"
                 Height="820" Width="1280"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">

    <mah:MetroWindow.Resources>
        <!-- Rounded card chrome (matches the Apex window) -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Background.Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style x:Key="CardHeader" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Background.Elevated}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border.Brush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="CornerRadius" Value="6,6,0,0" />
            <Setter Property="Padding" Value="8,4" />
        </Style>
        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Header}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CardStatus" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="DashLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Margin" Value="0,2,8,2" />
        </Style>
        <Style x:Key="DashValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,2,0,2" />
        </Style>
        <!-- Pass/fail row used by the gate + confirmation boards -->
        <DataTemplate x:Key="GateRowTemplate">
            <Grid Margin="0,1,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="10" FontWeight="Bold" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="✗" />
                            <Setter Property="Foreground" Value="{DynamicResource Bearish.Brush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Pass}" Value="True">
                                    <Setter Property="Text" Value="✓" />
                                    <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11"
                           Foreground="{DynamicResource Text.Primary}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="10" FontFamily="Consolas"
                           Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button Command="{Binding ToggleAlgoCommand}"
                    Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Padding="14,4"
                    Foreground="White"
                    FontWeight="SemiBold"
                    ToolTip="Arm or disarm the algo. Display-only when disarmed.">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.WindowCommands}">
                        <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                        <Setter Property="Content" Value="▶ Run" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAlgoRunning}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                <Setter Property="Content" Value="■ Stop" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <!-- ===== Setup form ===== -->
        <uic:StrategySetupHost Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                               Title="Cumulative Delta Scalper"
                               Subtitle="ORDER FLOW · CVD SCALPER"
                               Tags="L1, Bars, Trade tape"
                               Description="Trade-tape aggressor delta (with footprint clusters) summed over a sliding window of N candles; a bid-tick proxy fills in when no tape exists. Triggers on cumΔ crossing ±θ (adaptive σ-scaled θ by default), gated by up to six confirmations. Spread/ATR gates are in basis points, so any instrument works.">
                <StackPanel>
                    <TextBlock Text="Instrument" Margin="0,0,0,4" />
                    <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          Margin="0,0,0,12" />

                    <TextBlock Text="Chart timeframe (drives bar deltas + ATR + footprint)" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding TimeframeOptions}"
                              SelectedItem="{Binding SelectedTimeframe}"
                              Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Window size (bars)" Margin="0,0,4,4" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Threshold σ (adaptive)" Margin="4,0,0,4" />
                        <TextBox   Grid.Row="1" Grid.Column="0"
                                   Text="{Binding WindowSize, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,4,0" />
                        <TextBox   Grid.Row="1" Grid.Column="1"
                                   Text="{Binding ThresholdSigma, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                   Margin="4,0,0,0" />
                    </Grid>
                    <CheckBox Content="Adaptive threshold (θ = σ × stdev of recent cumΔ — recommended)"
                              IsChecked="{Binding AutoThreshold}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,12"
                          IsEnabled="{Binding AutoThreshold, Converter={StaticResource InverseBooleanConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Manual delta threshold (±)" VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBox   Grid.Column="1" Text="{Binding DeltaThreshold, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <!-- Sniper filters -->
                    <Expander Header="Sniper filters (confirmation gate)"
                              IsExpanded="True"
                              Margin="0,0,0,12">
                        <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Min confirmations (0–6)" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="EMA slope bars" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding MinConfirmations, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding EmaSlopeBars, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="ADX threshold" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Spread avg ×" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding AdxThreshold, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding SpreadAvgMultiplier, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Spread history size" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Max spread (bp of price)" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding SpreadHistorySize, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding MaxSpreadBp, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <CheckBox Content="Use HTF filter (15m EMA(50) — needed for confirmations 2 &amp; 3)"
                                      IsChecked="{Binding UseHtfFilter}" />
                        </StackPanel>
                    </Expander>

                    <!-- Volatility -->
                    <Expander Header="Volatility (ATR gate, basis points of price)"
                              Margin="0,0,0,12">
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Min ATR (bp)" Margin="0,0,4,4" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Max ATR (bp)" Margin="4,0,0,4" />
                            <TextBox   Grid.Row="1" Grid.Column="0"
                                       Text="{Binding MinAtrBp, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                       Margin="0,0,4,0" />
                            <TextBox   Grid.Row="1" Grid.Column="1"
                                       Text="{Binding MaxAtrBp, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                                       Margin="4,0,0,0" />
                        </Grid>
                    </Expander>

                    <!-- Sessions -->
                    <Expander Header="Sessions (GMT)"
                              Margin="0,0,0,12">
                        <StackPanel Margin="0,8,0,0">
                            <CheckBox Content="Use session filter"
                                      IsChecked="{Binding UseSessionFilter}" Margin="0,0,0,6" />
                            <CheckBox Content="Overlap only (London / NY overlap)"
                                      IsChecked="{Binding OverlapOnly}" Margin="0,0,0,8" />

                            <TextBlock Text="Overlap window" Foreground="{DynamicResource Text.Secondary}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding OverlapStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding OverlapStartMin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="2" Text="{Binding OverlapEndHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="3" Text="{Binding OverlapEndMin, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Content="Asia"
                                      IsChecked="{Binding UseAsiaSession}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding AsiaStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding AsiaEndHour, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Content="London"
                                      IsChecked="{Binding UseLondonSession}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding LondonStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding LondonEndHour, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <CheckBox Content="New York"
                                      IsChecked="{Binding UseNewYorkSession}" Margin="0,4,0,4" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewYorkStartHour, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="1" Text="{Binding NewYorkStartMin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0" />
                                <TextBox Grid.Column="2" Text="{Binding NewYorkEndHour, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <!-- Risk caps -->
                    <Expander Header="Risk caps"
                              Margin="0,0,0,16">
                        <StackPanel Margin="0,8,0,0">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Max daily signals" Margin="0,0,4,4" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Max signals / session" Margin="4,0,0,4" />
                                <TextBox   Grid.Row="1" Grid.Column="0"
                                           Text="{Binding MaxDailySignals, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="0,0,4,0" />
                                <TextBox   Grid.Row="1" Grid.Column="1"
                                           Text="{Binding MaxSignalsPerSession, UpdateSourceTrigger=PropertyChanged}"
                                           Margin="4,0,0,0" />
                            </Grid>
                            <TextBlock Text="Min seconds between signals" Margin="0,0,0,4" />
                            <TextBox Text="{Binding MinSecondsBetweenSignals, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Expander>

                    <Border Background="{DynamicResource Danger.Brush}"
                            Padding="10,6"
                            Margin="0,0,0,12"
                            Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                    </Border>

                    <Button Content="Continue"
                            Command="{Binding ContinueCommand}"
                            HorizontalAlignment="Right"
                            IsDefault="True"
                            MinWidth="120"
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
                </StackPanel>
        </uic:StrategySetupHost>

        <!-- ===== Running layout ===== -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Live tuning strip — every parameter is read fresh on each closed bar. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="TRIGGER" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Window (bars)" Minimum="2" Maximum="50" Step="1" StringFormat="0"
                                          Value="{Binding WindowSize, Mode=TwoWay}" />
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Threshold" FontSize="10" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                            <CheckBox Content="Auto σ" IsChecked="{Binding AutoThreshold, Mode=TwoWay}" VerticalAlignment="Center" />
                        </StackPanel>
                        <uic:ParamSpinner Label="θ σ-mult" Minimum="0.5" Maximum="5" Step="0.25" StringFormat="0.00"
                                          Value="{Binding ThresholdSigma, Mode=TwoWay}"
                                          IsEnabled="{Binding AutoThreshold}" />
                        <uic:ParamSpinner Label="θ manual ±" Minimum="1" Maximum="100000" Step="10" StringFormat="0"
                                          SpinnerWidth="84" Value="{Binding DeltaThreshold, Mode=TwoWay}"
                                          IsEnabled="{Binding AutoThreshold, Converter={StaticResource InverseBooleanConverter}}" />
                        <uic:ParamSpinner Label="Min conf" Minimum="0" Maximum="6" Step="1" StringFormat="0"
                                          Value="{Binding MinConfirmations, Mode=TwoWay}" />
                        <uic:ParamSpinner Label="ADX ≥" Minimum="0" Maximum="100" Step="0.5" StringFormat="0.0"
                                          Value="{Binding AdxThreshold, Mode=TwoWay}" />

                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <TextBlock Text="AXIS" Style="{StaticResource Strategy.ParamGroupLabel}" />
                        <uic:ParamSpinner Label="Bars shown" Minimum="30" Maximum="300" Step="10" StringFormat="0"
                                          Value="{Binding ChartBarsShown, Mode=TwoWay}" />
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="Price Y" FontSize="10" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                            <CheckBox Content="Auto" IsChecked="{Binding PriceAutoScale, Mode=TwoWay}" VerticalAlignment="Center" />
                        </StackPanel>
                        <uic:ParamSpinner Label="Y min" Minimum="0" Maximum="1000000" Step="0.0001" StringFormat="0.#####"
                                          SpinnerWidth="92" Value="{Binding PriceAxisMin, Mode=TwoWay}"
                                          IsEnabled="{Binding PriceAutoScale, Converter={StaticResource InverseBooleanConverter}}" />
                        <uic:ParamSpinner Label="Y max" Minimum="0" Maximum="1000000" Step="0.0001" StringFormat="0.#####"
                                          SpinnerWidth="92" Value="{Binding PriceAxisMax, Mode=TwoWay}"
                                          IsEnabled="{Binding PriceAutoScale, Converter={StaticResource InverseBooleanConverter}}" />

                        <Border Style="{StaticResource Strategy.ParamDivider}" />
                        <ToggleButton x:Name="MoreToggle" Content="More ▾" VerticalAlignment="Center" Padding="10,3" />
                        <Popup IsOpen="{Binding IsChecked, ElementName=MoreToggle}"
                               PlacementTarget="{Binding ElementName=MoreToggle}" Placement="Bottom"
                               StaysOpen="False" AllowsTransparency="True">
                            <Border Style="{StaticResource Strategy.ParamPopout}">
                                <StackPanel>
                                    <TextBlock Text="Advanced filters — all live" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <WrapPanel>
                                        <uic:ParamSpinner Label="EMA slope bars" Minimum="1" Maximum="50" Step="1" StringFormat="0"
                                                          Value="{Binding EmaSlopeBars, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Spread avg ×" Minimum="0.5" Maximum="10" Step="0.1" StringFormat="0.00"
                                                          Value="{Binding SpreadAvgMultiplier, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Spread hist" Minimum="1" Maximum="200" Step="1" StringFormat="0"
                                                          Value="{Binding SpreadHistorySize, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max spread bp" Minimum="0" Maximum="50" Step="0.5" StringFormat="0.0"
                                                          Value="{Binding MaxSpreadBp, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Min ATR bp" Minimum="0" Maximum="200" Step="0.5" StringFormat="0.0"
                                                          Value="{Binding MinAtrBp, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max ATR bp" Minimum="0" Maximum="500" Step="1" StringFormat="0.0"
                                                          Value="{Binding MaxAtrBp, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max daily" Minimum="1" Maximum="100" Step="1" StringFormat="0"
                                                          Value="{Binding MaxDailySignals, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Max / session" Minimum="1" Maximum="100" Step="1" StringFormat="0"
                                                          Value="{Binding MaxSignalsPerSession, Mode=TwoWay}" />
                                        <uic:ParamSpinner Label="Cooldown (s)" Minimum="0" Maximum="7200" Step="30" StringFormat="0"
                                                          SpinnerWidth="84" Value="{Binding MinSecondsBetweenSignals, Mode=TwoWay}" />
                                    </WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <CheckBox Content="HTF filter" IsChecked="{Binding UseHtfFilter}" Margin="0,0,12,0" />
                                        <CheckBox Content="Session filter" IsChecked="{Binding UseSessionFilter}" Margin="0,0,12,0" />
                                        <CheckBox Content="Overlap only" IsChecked="{Binding OverlapOnly}" Margin="0,0,12,0" />
                                        <CheckBox Content="Asia" IsChecked="{Binding UseAsiaSession}" Margin="0,0,12,0" />
                                        <CheckBox Content="London" IsChecked="{Binding UseLondonSession}" Margin="0,0,12,0" />
                                        <CheckBox Content="New York" IsChecked="{Binding UseNewYorkSession}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="TF:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding SelectedTimeframe}" Margin="6,0,16,0" />
                    <TextBlock Text="θ eff:" Foreground="{DynamicResource Text.Secondary}" />
                    <TextBlock Text="{Binding EffectiveThreshold}" Margin="6,0,16,0" FontFamily="Consolas" />
                    <Border Background="{DynamicResource Background.Elevated}" CornerRadius="3" Padding="6,1"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding FeedMode}" FontSize="10" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Warning.Brush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FeedMode}" Value="Real tape">
                                            <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Margin="20,0,0,0"
                               Foreground="{DynamicResource Text.Secondary}"
                               Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <!-- Main: charts (left) | splitter | dashboard (right, resizable) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="420" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="300" MinWidth="240" MaxWidth="520" />
                </Grid.ColumnDefinitions>

                <!-- Left: price / delta (shared time axis) / footprint -->
                <Grid Grid.Column="0" Margin="6,6,0,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"   MinHeight="160" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="170" MinHeight="100" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="160" MinHeight="90" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <TextBlock Style="{StaticResource CardTitle}" Text="PRICE" />
                            </Border>
                            <scottplot:WpfPlot x:Name="PricePlot" Grid.Row="1" Margin="1" />
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="1" Height="6" Margin="0,1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="Transparent"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                    <Border Grid.Row="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource CardTitle}" Text="DELTA — per-bar Δ + windowed cumΔ vs ±θ" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CardStatus}"
                                               Text="{Binding CumulativeDelta, StringFormat='cumΔ {0}'}" />
                                </Grid>
                            </Border>
                            <scottplot:WpfPlot x:Name="DeltaPlot" Grid.Row="1" Margin="1" />
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Row="3" Height="6" Margin="0,1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                  Background="Transparent"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows" ShowsPreview="False" />

                    <!-- Footprint cluster (tape mode — rendered in code-behind) -->
                    <Border Grid.Row="4" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource CardTitle}" Text="FOOTPRINT CLUSTER" />
                                    <TextBlock Grid.Column="1" x:Name="FootprintStatus" Style="{StaticResource CardStatus}"
                                               Text="awaiting trade tape" />
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" x:Name="FootprintScroll"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Canvas x:Name="FootprintCanvas"
                                        Background="{DynamicResource Background.Surface}"
                                        HorizontalAlignment="Left" VerticalAlignment="Top" />
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Column="1" Width="6" Margin="1,6"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="Transparent"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" ShowsPreview="False" />

                <!-- Right: live values, gates, confirmations, signal log -->
                <Grid Grid.Column="2" Margin="0,6,6,6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- LIVE -->
                    <Border Grid.Row="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <TextBlock Style="{StaticResource CardTitle}" Text="LIVE" />
                            </Border>
                            <Grid Grid.Row="1" Margin="8,4,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Bid / Ask" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding LastBid, StringFormat=F5, FallbackValue=—}" />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text=" / " />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding LastAsk, StringFormat=F5, FallbackValue=—}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Spread / avg" />
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding LastSpread, StringFormat=F5, FallbackValue=—}" />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text=" / " />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding AvgSpread, StringFormat=F5, FallbackValue=—}" />
                                </StackPanel>
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Live Δ (bar)" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashValueStyle}" Text="{Binding LiveDelta}" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Σ cumΔ (window)" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashValueStyle}" Text="{Binding CumulativeDelta}" />
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="θ effective (±)" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DashValueStyle}" Text="{Binding EffectiveThreshold}" />
                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="ATR(14) / EMA / ADX" />
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding LastAtr, StringFormat=F5, FallbackValue=—}" />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text=" · " />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding LastAdx, StringFormat=F1, FallbackValue=—}" />
                                </StackPanel>
                                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Session / today" />
                                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding ActiveSession}" />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text=" · " />
                                    <TextBlock Style="{StaticResource DashValueStyle}" Text="{Binding TodaySignalCount}" />
                                </StackPanel>
                                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource DashLabelStyle}" Text="Last conf" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource DashValueStyle}" Text="{Binding LastConfirmationScore}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- GATES -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,6,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource CardTitle}" Text="GATES" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CardStatus}" Text="{Binding GuardReason}" />
                                </Grid>
                            </Border>
                            <ItemsControl Grid.Row="1" Margin="8,4,8,6"
                                          ItemsSource="{Binding Gates}"
                                          ItemTemplate="{StaticResource GateRowTemplate}" />
                        </Grid>
                    </Border>

                    <!-- CONFIRMATIONS -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,6,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource CardTitle}" Text="CONFIRMATIONS" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CardStatus}">
                                        <Run Text="need" /><Run Text="{Binding MinConfirmations, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding MaxConfirmations, Mode=OneWay}" />
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <ItemsControl Grid.Row="1" Margin="8,4,8,6"
                                          ItemsSource="{Binding Confirmations}"
                                          ItemTemplate="{StaticResource GateRowTemplate}" />
                        </Grid>
                    </Border>

                    <!-- SIGNALS -->
                    <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,6,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /><RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Style="{StaticResource CardHeader}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource CardTitle}" Text="RECENT SIGNALS" />
                                    <TextBlock Grid.Column="1" Style="{StaticResource CardStatus}"
                                               Text="● ARMED" FontWeight="Bold"
                                               Foreground="{DynamicResource Warning.Brush}"
                                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                </Grid>
                            </Border>
                            <ListBox Grid.Row="1"
                                     Margin="4,2,4,4"
                                     ItemsSource="{Binding RecentSignals}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            </Grid>
        </DockPanel>
    </Grid>
</mah:MetroWindow>
