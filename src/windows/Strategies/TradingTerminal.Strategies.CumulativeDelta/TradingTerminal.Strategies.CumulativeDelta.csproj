<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
    <Description>Cumulative-delta scalper. Bid-tick rule per bar, sliding window of N bar-deltas, threshold-cross trigger, ATR + HTF EMA + session/spread/cooldown guards.</Description>
  </PropertyGroup>

  <!-- Ships as an EXTERNAL plugin: references ONLY the DaxAlgo SDK (the Phase B boundary).
       DaxAlgo.Sdk.Wpf transitively provides Core + the WPF UI bases (TradingTerminal.UI / .UI.Core,
       incl. ScottPlot.WPF). NO host-internal (Infrastructure) reference. See Strategies.SigmaIcFlow. -->
  <ItemGroup>
    <ProjectReference Include="..\..\Sdk\DaxAlgo.Sdk.Wpf\DaxAlgo.Sdk.Wpf.csproj" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <!-- Plugin manifest — staged next to the DLL so the host reads it before loading the assembly. -->
  <ItemGroup>
    <None Include="plugin.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Avalonia view files belong to the Linux tree only; never compiled on this WPF-only plugin. -->
  <ItemGroup>
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
