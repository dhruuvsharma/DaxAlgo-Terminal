п»ї<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Multi-target: portable VM + descriptor on net9.0; WPF window on the windows leg. See
         Strategies.OrnsteinUhlenbeck for the template. -->
    <TargetFramework>net9.0-windows7.0</TargetFramework>
    <Description>Sigma^-1.IC Order-Flow Optimizer - live signal-mode wrapper around the engine-side ApexScalperStrategy (11-signal weighted composite, regime classifier, isotonic entry gate, dynamic stops).</Description>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <UseWPF>true</UseWPF>
    <DefineConstants>$(DefineConstants);WINDOWS</DefineConstants>
  </PropertyGroup>

  <!-- Plugin references ONLY the DaxAlgo SDK вЂ” the Phase B boundary. DaxAlgo.Sdk.Wpf transitively
       provides the headless contract (DaxAlgo.Sdk -> TradingTerminal.Core, incl. Core.Quant) and the
       WPF UI bases (TradingTerminal.UI / .UI.Core, incl. ScottPlot.WPF). NO host-internal
       (Infrastructure) reference. This is exactly the surface a third-party plugin will compile
       against once the SDK ships as NuGet. MahApps is the plugin's own UI-toolkit dependency (its
       window XAML uses MetroWindow). -->
  <ItemGroup>
    <ProjectReference Include="..\..\Sdk\DaxAlgo.Sdk.Wpf\DaxAlgo.Sdk.Wpf.csproj" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0-windows7.0'">
    <Compile Remove="SigmaIcFlowStrategyWindow.xaml.cs" />
  </ItemGroup>

  <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Cross-platform (Avalonia) view: net9.0 leg only ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
       The strategy ships its own Avalonia window (counterpart to the WPF MetroWindow) so the Avalonia
       shell opens it through IStrategyFactory. The Avalonia package (referenced only on the net9.0
       leg) provides the .axaml compiler, which globs **/*.axaml and never the WPF .xaml. See
       Strategies.OrnsteinUhlenbeck / CumulativeDelta for the template. -->
  <ItemGroup Condition="'$(TargetFramework)' != 'net9.0-windows7.0'">
    <PackageReference Include="Avalonia" Version="11.2.1" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0-windows7.0'">
    <Compile Remove="AvaloniaUi\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="9.0.0" />
  </ItemGroup>

</Project>
