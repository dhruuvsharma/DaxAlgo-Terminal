<UserControl x:Class="TradingTerminal.Ai.MlFeatures.MlFeaturesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="950"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="ML features" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Load a parquet tick file, aggregate into N-tick bars, then label each candidate entry via López de Prado triple-barrier (first barrier touched: +1 / -1, timeout: 0). Exports the same CSV shape as the daxalgo-backtest features subcommand."
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Data" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Text="{Binding DataPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     FontFamily="Consolas" />
            <Button Grid.Column="2" Content="Browse…" Command="{Binding BrowseDataCommand}"
                    Padding="12,4" Margin="8,0,0,0" />
            <Button Grid.Column="3" Content="Compute" Command="{Binding ComputeCommand}"
                    IsEnabled="{Binding IsComputing, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="20,4" Margin="8,0,0,0" />
            <Button Grid.Column="4" Content="Export CSV…" Command="{Binding ExportCsvCommand}"
                    Padding="12,4" Margin="8,0,0,0" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="60" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"  Text="BarTicks"   VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox   Grid.Column="1"  Text="{Binding BarTicks, Mode=TwoWay}" />
            <TextBlock Grid.Column="3"  Text="VolWindow"  VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox   Grid.Column="4"  Text="{Binding VolWindow, Mode=TwoWay}" />
            <TextBlock Grid.Column="6"  Text="Upper"      VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox   Grid.Column="7"  Text="{Binding UpperBarrier, Mode=TwoWay}" />
            <TextBlock Grid.Column="9"  Text="Lower"      VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox   Grid.Column="10" Text="{Binding LowerBarrier, Mode=TwoWay}" />
            <TextBlock Grid.Column="12" Text="Timeout"    VerticalAlignment="Center" Margin="0,0,4,0" />
            <TextBox   Grid.Column="13" Text="{Binding TimeoutBars, Mode=TwoWay}" />
        </Grid>

        <Border Grid.Row="3" Padding="8" Margin="0,0,0,8"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontWeight="SemiBold" Text="Label distribution:" Margin="0,0,12,0" />
                <TextBlock Foreground="{DynamicResource Bullish.Brush}" Margin="0,0,16,0">
                    <Run Text="+1" />
                    <Run Text="{Binding PositiveCount}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Foreground="{DynamicResource Text.Secondary}" Margin="0,0,16,0">
                    <Run Text="0" />
                    <Run Text="{Binding NeutralCount}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Foreground="{DynamicResource Danger.Brush}">
                    <Run Text="-1" />
                    <Run Text="{Binding NegativeCount}" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Preview}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserResizeRows="False"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Timestamp UTC"   Binding="{Binding TimestampUtc, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160" />
                <DataGridTextColumn Header="Close"           Binding="{Binding Close, StringFormat=F6}" Width="100" />
                <DataGridTextColumn Header="LogReturn"       Binding="{Binding LogReturn, StringFormat=F8}" Width="120" />
                <DataGridTextColumn Header="RollingVol"      Binding="{Binding RollingVol, StringFormat=F8}" Width="120" />
                <DataGridTextColumn Header="QueueImbalance"  Binding="{Binding QueueImbalance, StringFormat=F4}" Width="120" />
                <DataGridTextColumn Header="Label"           Binding="{Binding Label}" Width="60" />
                <DataGridTextColumn Header="BarsToOutcome"   Binding="{Binding BarsToOutcome}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding Status}" Foreground="{DynamicResource Text.Secondary}" />
            <TextBlock Grid.Column="1" Foreground="{DynamicResource Text.Secondary}">
                <Run Text="Bars:" />
                <Run Text="{Binding BarsComputed}" />
            </TextBlock>
            <TextBlock Grid.ColumnSpan="2"
                       Text="{Binding ValidationError}"
                       Foreground="#E06C75"
                       TextWrapping="Wrap"
                       Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}}" />
        </Grid>
    </Grid>
</UserControl>
