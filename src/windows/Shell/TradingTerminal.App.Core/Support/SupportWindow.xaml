<mah:MetroWindow x:Class="TradingTerminal.App.Support.SupportWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Support the developer"
                 Width="520" Height="600"
                 ResizeMode="NoResize"
                 ShowInTaskbar="False"
                 WindowStartupLocation="CenterOwner"
                 Icon="pack://application:,,,/TradingTerminal.App.Core;component/Icon/DaxAlgoLogo.ico"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 FontFamily="{DynamicResource Font.Mono}"
                 FontSize="12">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Wordmark + version -->
            <RowDefinition Height="Auto" />  <!-- Thank-you -->
            <RowDefinition Height="Auto" />  <!-- Feedback label -->
            <RowDefinition Height="*" />     <!-- Feedback editor -->
            <RowDefinition Height="Auto" />  <!-- Status line -->
            <RowDefinition Height="Auto" />  <!-- Donate hint -->
            <RowDefinition Height="Auto" />  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Wordmark + version -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="DAXALGO"
                       Foreground="{DynamicResource Accent.Brush}"
                       FontWeight="Bold" FontSize="16" />
            <TextBlock Text=" TERMINAL"
                       Foreground="{DynamicResource Text.Primary}"
                       FontWeight="Bold" FontSize="16" Margin="0,0,10,0" />
            <TextBlock Text="{Binding Version}"
                       Foreground="{DynamicResource Text.Secondary}"
                       FontSize="12" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Thank-you -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ThankYouMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Text.Primary}"
                   Margin="0,0,0,18"
                   LineHeight="18" />

        <!-- Feedback label -->
        <TextBlock Grid.Row="2"
                   Text="Write to the developer"
                   Foreground="{DynamicResource Accent.Brush}"
                   FontWeight="Bold"
                   Margin="0,0,0,6" />

        <!-- Feedback editor -->
        <Border Grid.Row="3"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                Background="{DynamicResource Background.Elevated}">
            <TextBox Text="{Binding FeedbackText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent"
                     Foreground="{DynamicResource Text.Primary}"
                     BorderThickness="0"
                     Padding="8"
                     mah:TextBoxHelper.Watermark="Feature ideas, bugs, or just a hello — it all reaches me." />
        </Border>

        <!-- Status line -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Accent.Brush}"
                   Margin="0,8,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />

        <!-- Donate hint -->
        <Border Grid.Row="5"
                Background="{DynamicResource Background.Elevated}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                Padding="10"
                Margin="0,14,0,0">
            <TextBlock Text="{Binding DonateMessage}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Text.Secondary}"
                       FontSize="11" />
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="6" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="GitHub"
                    Command="{Binding OpenGitHubCommand}"
                    Padding="14,6"
                    Style="{DynamicResource MahApps.Styles.Button}" />

            <Button Grid.Column="2"
                    Content="Send to developer"
                    Command="{Binding SendFeedbackCommand}"
                    Padding="16,6"
                    Margin="0,0,8,0"
                    Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />

            <Button Grid.Column="3"
                    Content="Maybe later"
                    Command="{Binding CloseCommand}"
                    Padding="16,6"
                    IsCancel="True"
                    Style="{DynamicResource MahApps.Styles.Button}" />
        </Grid>
    </Grid>
</mah:MetroWindow>
