<UserControl x:Class="TradingTerminal.App.Authoring.AiProvidersSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2006"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="640">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </UserControl.Resources>
    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="AI providers" FontSize="16" FontWeight="Bold" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,10"
                   Text="The AI Strategy Builder uses a provider you choose. Installed agent CLIs (Claude Code, Codex) use their own login — no key here. For OpenAI / DeepSeek / xAI / OpenRouter / Anthropic, paste an API key; it's stored encrypted for your Windows user (DPAPI). Only your prompt and the SDK context pack are sent to the provider you pick." />
        <TextBlock DockPanel.Dock="Top" Text="{Binding Status}" Margin="0,0,0,10" FontStyle="Italic"
                   Foreground="{DynamicResource Text.Secondary}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Providers}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,8" Padding="10" CornerRadius="0"
                                BorderThickness="1" BorderBrush="{DynamicResource Border.Brush}"
                                Background="{DynamicResource Background.Secondary}">
                            <StackPanel>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" />
                                        <TextBlock Text="{Binding ProviderId, StringFormat=' ({0})'}"
                                                   Foreground="{DynamicResource Text.Secondary}" FontSize="11" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource Text.Highlight}" FontSize="11" VerticalAlignment="Center" />
                                </Grid>
                                <Grid Margin="0,6,0,0" Visibility="{Binding NeedsKey, Converter={StaticResource B2V}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Margin="0,0,6,0" VerticalContentAlignment="Center"
                                             Text="{Binding KeyInput, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Paste the API key. It's stored encrypted and this box is cleared on Save." />
                                    <Button Grid.Column="1" Content="Save" Padding="12,3" Margin="0,0,6,0"
                                            Command="{Binding DataContext.SaveKeyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="2" Content="Clear" Padding="12,3"
                                            Command="{Binding DataContext.ClearKeyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
