<UserControl x:Class="TradingTerminal.App.Archive.ArchiveActivityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}"
             d:DesignHeight="640" d:DesignWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Title -->
            <RowDefinition Height="Auto" />  <!-- Subtitle -->
            <RowDefinition Height="Auto" />  <!-- Instant offload bar -->
            <RowDefinition Height="Auto" />  <!-- Coverage header -->
            <RowDefinition Height="180" />   <!-- Coverage grid -->
            <RowDefinition Height="Auto" />  <!-- History header -->
            <RowDefinition Height="*" />     <!-- History grid -->
            <RowDefinition Height="Auto" />  <!-- Footer buttons + status -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Archive history"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,4" />
        <TextBlock Grid.Row="1"
                   Text="Every period of local market data, labelled by whether it's already on Telegram. Instant offload ships everything still pending (split into ≤2 GB parts, sha256-verified, then pruned locally)."
                   Foreground="{DynamicResource Text.Secondary}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <!-- Instant offload bar -->
        <Border Grid.Row="2"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="12,8"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Instant offload" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CoverageSummary}"
                               Foreground="{DynamicResource Text.Secondary}"
                               FontSize="11" Margin="0,2,0,0" />
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Offload all pending now"
                        Command="{Binding InstantOffloadCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                        Padding="16,6"
                        FontWeight="SemiBold"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
            </Grid>
        </Border>

        <TextBlock Grid.Row="3"
                   Text="Coverage"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Coverage}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Background="{DynamicResource Background.Primary}"
                  Foreground="{DynamicResource Text.Primary}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Period" Binding="{Binding PeriodLabel}" Width="120" />
                <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="200" />
                <DataGridTemplateColumn Header="Status" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="0" Padding="8,1" HorizontalAlignment="Left" Margin="0,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource Warning.Brush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Offloaded}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" Foreground="#000000" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Archive" Binding="{Binding ArchiveRef}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="5"
                   Text="Uploaded archives"
                   FontWeight="SemiBold"
                   Margin="0,12,0,4" />

        <DataGrid Grid.Row="6"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  Background="{DynamicResource Background.Primary}"
                  Foreground="{DynamicResource Text.Primary}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50" />
                <DataGridTextColumn Header="Period" Binding="{Binding PeriodLabel}" Width="100" />
                <DataGridTextColumn Header="Range" Binding="{Binding Range}" Width="180" />
                <DataGridTextColumn Header="Parts" Binding="{Binding Parts}" Width="60" />
                <DataGridTextColumn Header="Size" Binding="{Binding TotalBytesPretty}" Width="80" />
                <DataGridTextColumn Header="Quotes" Binding="{Binding RowsQuotes}" Width="80" />
                <DataGridTextColumn Header="Bars" Binding="{Binding RowsBars}" Width="80" />
                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="140" />
                <DataGridTextColumn Header="Uploaded" Binding="{Binding Uploaded}" Width="140" />
                <DataGridTextColumn Header="Local deleted" Binding="{Binding LocalDeleted}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="7"
                    Orientation="Horizontal"
                    Margin="0,12,0,0">
            <Button Content="Refresh"
                    Command="{Binding RefreshAsyncCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="14,4" Margin="0,0,8,0" />
            <Button Content="Restore selected"
                    Command="{Binding RestoreSelectedCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                    Padding="14,4" Margin="0,0,16,0" />
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Text.Secondary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />
        </StackPanel>
    </Grid>
</UserControl>
