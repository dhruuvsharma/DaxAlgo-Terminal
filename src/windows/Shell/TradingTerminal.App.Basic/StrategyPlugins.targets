<Project>

  <!--
    Strategy-plugin staging for THIS edition shell. Each edition shell (App / App.Basic /
    App.Intermediate) owns its own copy of this file — no cross-edition sharing; a change here must
    be applied to the other shells' copies too. Every first-party strategy ships as an EXTERNAL
    plugin, not a compile-time reference: build it (for ordering) but don't link it
    (ReferenceOutputAssembly=false), then the Stage* targets copy each DLL + pdb + plugin.json (and
    HelixToolkit for the 3D-cube plugins) into {OutDir}/plugins so PluginLoader discovers + loads
    them at runtime in their own collectible load context.

    Strategy ProjectReference paths are anchored to $(MSBuildThisFileDirectory) (this file lives in
    the shell project folder under src/windows/Shell/). The Stage targets locate the built output
    through $(DaxAlgoOutputBase) (set in Directory.Build.props).
  -->
  <ItemGroup>
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.SigmaIcFlow\TradingTerminal.Strategies.SigmaIcFlow.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.IndexRegimeGraph\TradingTerminal.Strategies.IndexRegimeGraph.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.CumulativeDelta\TradingTerminal.Strategies.CumulativeDelta.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.FilteredOrderFlow\TradingTerminal.Strategies.FilteredOrderFlow.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.OrderFlowCube\TradingTerminal.Strategies.OrderFlowCube.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.OrderFlowSurfaceSpike\TradingTerminal.Strategies.OrderFlowSurfaceSpike.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.ImbalanceHeatFront\TradingTerminal.Strategies.ImbalanceHeatFront.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.IndexKScoreSurface\TradingTerminal.Strategies.IndexKScoreSurface.csproj" ReferenceOutputAssembly="false" />
    <ProjectReference Include="$(MSBuildThisFileDirectory)..\..\Strategies\TradingTerminal.Strategies.OrderFlowPressureMap\TradingTerminal.Strategies.OrderFlowPressureMap.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!--
    Stage SigmaIcFlow as an external strategy plugin: copy its built DLL + manifest into
    {OutDir}/plugins/<assembly-name>/ (the loader's folder/<folder>.dll convention) so the app
    discovers it at runtime via PluginLoader. Runs after build; the SigmaIcFlow ProjectReference
    above (ReferenceOutputAssembly=false) guarantees it's built first.
  -->
  <Target Name="StageSigmaIcFlowPlugin" AfterTargets="Build">
    <PropertyGroup>
      <SigmaIcFlowOut>$(DaxAlgoOutputBase)src\windows\Strategies\TradingTerminal.Strategies.SigmaIcFlow\bin\$(Configuration)\$(TargetFramework)</SigmaIcFlowOut>
      <SigmaIcFlowPluginDir>$(OutDir)plugins\TradingTerminal.Strategies.SigmaIcFlow</SigmaIcFlowPluginDir>
    </PropertyGroup>
    <ItemGroup>
      <SigmaIcFlowPluginFiles Include="$(SigmaIcFlowOut)\TradingTerminal.Strategies.SigmaIcFlow.dll" />
      <SigmaIcFlowPluginFiles Include="$(SigmaIcFlowOut)\TradingTerminal.Strategies.SigmaIcFlow.pdb" />
      <SigmaIcFlowPluginFiles Include="$(SigmaIcFlowOut)\TradingTerminal.Strategies.SigmaIcFlow.deps.json" />
      <SigmaIcFlowPluginFiles Include="$(SigmaIcFlowOut)\plugin.json" />
    </ItemGroup>
    <Copy SourceFiles="@(SigmaIcFlowPluginFiles)" DestinationFolder="$(SigmaIcFlowPluginDir)" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Staged SigmaIcFlow plugin -> $(SigmaIcFlowPluginDir)" />
  </Target>

  <!--
    Stage IndexRegimeGraph as an external strategy plugin (mirrors StageSigmaIcFlowPlugin): copy its
    built DLL + manifest into {OutDir}/plugins/<assembly-name>/ so the app discovers it at runtime via
    PluginLoader. The IndexRegimeGraph ProjectReference above (ReferenceOutputAssembly=false) guarantees
    it's built first.
  -->
  <Target Name="StageIndexRegimeGraphPlugin" AfterTargets="Build">
    <PropertyGroup>
      <IndexRegimeGraphOut>$(DaxAlgoOutputBase)src\windows\Strategies\TradingTerminal.Strategies.IndexRegimeGraph\bin\$(Configuration)\$(TargetFramework)</IndexRegimeGraphOut>
      <IndexRegimeGraphPluginDir>$(OutDir)plugins\TradingTerminal.Strategies.IndexRegimeGraph</IndexRegimeGraphPluginDir>
    </PropertyGroup>
    <ItemGroup>
      <IndexRegimeGraphPluginFiles Include="$(IndexRegimeGraphOut)\TradingTerminal.Strategies.IndexRegimeGraph.dll" />
      <IndexRegimeGraphPluginFiles Include="$(IndexRegimeGraphOut)\TradingTerminal.Strategies.IndexRegimeGraph.pdb" />
      <IndexRegimeGraphPluginFiles Include="$(IndexRegimeGraphOut)\TradingTerminal.Strategies.IndexRegimeGraph.deps.json" />
      <IndexRegimeGraphPluginFiles Include="$(IndexRegimeGraphOut)\plugin.json" />
    </ItemGroup>
    <Copy SourceFiles="@(IndexRegimeGraphPluginFiles)" DestinationFolder="$(IndexRegimeGraphPluginDir)" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Staged IndexRegimeGraph plugin -> $(IndexRegimeGraphPluginDir)" />
  </Target>

  <!--
    Stage the remaining first-party strategies that ship as EXTERNAL plugins (same model as
    SigmaIcFlow/IndexRegimeGraph above, but batched). Each is referenced ReferenceOutputAssembly=false
    so it builds but is not linked; here its DLL + pdb + plugin.json are copied into
    {OutDir}/plugins/<assembly>/ for PluginLoader to discover at runtime. The 3D-cube plugins also
    carry HelixToolkit.Wpf as a PRIVATE dependency (nothing else in the host graph pulls it in), so it
    is copied alongside them and resolved from the plugin's own load-context folder.
  -->
  <ItemGroup>
    <StrategyPlugin Include="TradingTerminal.Strategies.CumulativeDelta" />
    <StrategyPlugin Include="TradingTerminal.Strategies.FilteredOrderFlow" />
    <StrategyPlugin Include="TradingTerminal.Strategies.OrderFlowPressureMap" />
    <StrategyPlugin Include="TradingTerminal.Strategies.OrderFlowCube" />
    <StrategyPlugin Include="TradingTerminal.Strategies.OrderFlowSurfaceSpike" />
    <StrategyPlugin Include="TradingTerminal.Strategies.ImbalanceHeatFront" />
    <StrategyPlugin Include="TradingTerminal.Strategies.IndexKScoreSurface" />
    <!-- HelixToolkit.Wpf is a PRIVATE dependency of the 3D-cube plugins and is pulled in by nothing
         else in the host graph, so it must be copied into each plugin's own folder for the ALC to
         resolve it at load time. -->
    <HelixStrategyPlugin Include="TradingTerminal.Strategies.OrderFlowCube" />
    <HelixStrategyPlugin Include="TradingTerminal.Strategies.OrderFlowSurfaceSpike" />
    <HelixStrategyPlugin Include="TradingTerminal.Strategies.ImbalanceHeatFront" />
    <HelixStrategyPlugin Include="TradingTerminal.Strategies.IndexKScoreSurface" />
  </ItemGroup>

  <Target Name="StageStrategyPlugins" AfterTargets="Build">
    <ItemGroup>
      <StrategyPluginFile Include="$(DaxAlgoOutputBase)src\windows\Strategies\%(StrategyPlugin.Identity)\bin\$(Configuration)\$(TargetFramework)\%(StrategyPlugin.Identity).dll">
        <PluginDir>$(OutDir)plugins\%(StrategyPlugin.Identity)</PluginDir>
      </StrategyPluginFile>
      <StrategyPluginFile Include="$(DaxAlgoOutputBase)src\windows\Strategies\%(StrategyPlugin.Identity)\bin\$(Configuration)\$(TargetFramework)\%(StrategyPlugin.Identity).pdb">
        <PluginDir>$(OutDir)plugins\%(StrategyPlugin.Identity)</PluginDir>
      </StrategyPluginFile>
      <!-- The deps.json drives AssemblyDependencyResolver inside the plugin's load context — without
           it a plugin-PRIVATE dependency (HelixToolkit.Wpf below) can only resolve via the loader's
           flat same-folder probe. Stage it so resolution follows the documented path. -->
      <StrategyPluginFile Include="$(DaxAlgoOutputBase)src\windows\Strategies\%(StrategyPlugin.Identity)\bin\$(Configuration)\$(TargetFramework)\%(StrategyPlugin.Identity).deps.json">
        <PluginDir>$(OutDir)plugins\%(StrategyPlugin.Identity)</PluginDir>
      </StrategyPluginFile>
      <StrategyPluginFile Include="$(DaxAlgoOutputBase)src\windows\Strategies\%(StrategyPlugin.Identity)\bin\$(Configuration)\$(TargetFramework)\plugin.json">
        <PluginDir>$(OutDir)plugins\%(StrategyPlugin.Identity)</PluginDir>
      </StrategyPluginFile>
      <StrategyPluginFile Condition="'@(HelixStrategyPlugin)' != ''" Include="$(DaxAlgoOutputBase)src\windows\Strategies\%(HelixStrategyPlugin.Identity)\bin\$(Configuration)\$(TargetFramework)\HelixToolkit.Wpf.dll">
        <PluginDir>$(OutDir)plugins\%(HelixStrategyPlugin.Identity)</PluginDir>
      </StrategyPluginFile>
    </ItemGroup>
    <Copy SourceFiles="@(StrategyPluginFile)" DestinationFolder="%(StrategyPluginFile.PluginDir)" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Staged strategy plugins -> $(OutDir)plugins" />
  </Target>

  <!--
    Pin the plugins this build shipped: hash every staged assembly into {OutDir}/plugins/plugins-trusted.json.
    That file is how the Curated trust policy accepts our OWN plugins without a code-signing certificate
    (see PluginTrustedHashes), and it is the integrity baseline — a shipped assembly modified afterwards
    no longer matches, and the loader quarantines the plugin as tampered instead of running rewritten code.
    DependsOnTargets guarantees every Stage* target has run, so the folders are complete before hashing.
    The script is SHARED (a build script, not shell code — it does not follow the x3 shell-copy rule).
  -->
  <Target Name="PinFirstPartyPlugins" AfterTargets="Build"
          DependsOnTargets="StageSigmaIcFlowPlugin;StageIndexRegimeGraphPlugin;StageStrategyPlugins">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(MSBuildThisFileDirectory)..\..\..\..\build\gen-trusted-plugins.ps1&quot; -PluginsRoot &quot;$(OutDir)plugins&quot;" />
  </Target>

</Project>
