<UserControl x:Class="TradingTerminal.App.Plugins.PluginManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             d:DesignWidth="860" d:DesignHeight="560">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Strategy plugins" FontSize="18" FontWeight="Bold" />
            <TextBlock Text="{Binding TrustPolicySummary}" Opacity="0.8" Margin="0,4,0,0" TextWrapping="Wrap" />
        </StackPanel>

        <!-- Restart banner — lifecycle changes (from either tab) only apply on the next start (loaded
             plugin assemblies are file-locked by their rooted load contexts). -->
        <Border Grid.Row="1" Margin="0,12,0,0" CornerRadius="4" Padding="10,7"
                Background="#22FFA500" BorderBrush="{DynamicResource Warning.Brush}" BorderThickness="1"
                Visibility="{Binding RestartRequired, Converter={StaticResource BoolToVis}}">
            <TextBlock FontWeight="SemiBold" TextWrapping="Wrap"
                       Text="Changes pending — restart DaxAlgo Terminal to apply them." />
        </Border>

        <TabControl Grid.Row="2" Margin="0,14,0,0" BorderThickness="0">
            <!-- ── Installed: every plugin the loader saw, with per-row lifecycle actions ──────────── -->
            <TabItem Header="Installed">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Button Content="Install plugin…" Command="{Binding InstallPluginCommand}" Padding="14,6" Margin="0,0,8,0" />
                        <Button Content="Open plugins folder" Command="{Binding OpenPluginsFolderCommand}" Padding="14,6" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Margin="0,10,0,0" Opacity="0.65" TextWrapping="Wrap" FontSize="11">
                        <Run Text="Plugins folder:  " /><Run Text="{Binding PluginsRoot, Mode=OneWay}" />
                    </TextBlock>

                    <GroupBox Grid.Row="2" Header="Plugins" Margin="0,14,0,0">
                        <ListView ItemsSource="{Binding Rows}" BorderThickness="0"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Status" Width="170">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusLabel}" FontWeight="SemiBold" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsProblem}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Warning.Brush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding StatusLabel}" Value="Loaded">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Name" Width="230">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Details" Width="260">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Opacity="0.85"
                                                           ToolTip="{Binding Detail}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Actions" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Enable" Padding="8,2" Margin="0,0,6,0" FontSize="11"
                                                            Visibility="{Binding CanEnable, Converter={StaticResource BoolToVis}}"
                                                            Command="{Binding DataContext.EnableCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Disable" Padding="8,2" Margin="0,0,6,0" FontSize="11"
                                                            Visibility="{Binding CanDisable, Converter={StaticResource BoolToVis}}"
                                                            Command="{Binding DataContext.DisableCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Uninstall" Padding="8,2" FontSize="11"
                                                            Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVis}}"
                                                            Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>

                    <TextBlock Grid.Row="3" Text="{Binding Status}" Margin="0,12,0,0" TextWrapping="Wrap" FontWeight="SemiBold" />

                    <TextBlock Grid.Row="4" Margin="0,10,0,0" Opacity="0.6" TextWrapping="Wrap" FontSize="11"
                               Text="Developing a strategy? Reference the DaxAlgo.Sdk / DaxAlgo.Sdk.Wpf packages, implement IStrategyPlugin (see samples/DaxAlgo.SamplePlugin), build, then Install it here or drop the folder into the plugins directory and restart. See docs/plugins.md." />
                </Grid>
            </TabItem>

            <!-- ── Catalog: the signed marketplace feed. Hidden unless a feed is configured. ────────── -->
            <TabItem Header="Catalog" Visibility="{Binding FeedConfigured, Converter={StaticResource BoolToVis}}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Search + refresh + update-all -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" VerticalContentAlignment="Center" Padding="8,6"
                                 Text="{Binding CatalogSearch, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                                 mah:TextBoxHelper.Watermark="Search plugins by name, publisher, or tag…"
                                 mah:TextBoxHelper.ClearTextButton="True" />
                        <Button Grid.Column="1" Content="Update all" Padding="14,6" Margin="8,0,0,0"
                                Command="{Binding UpdateAllCommand}"
                                IsEnabled="{Binding HasUpdates}" />
                        <Button Grid.Column="2" Content="Refresh" Padding="14,6" Margin="8,0,0,0"
                                Command="{Binding RefreshCatalogCommand}" />
                    </Grid>

                    <!-- Catalog cards -->
                    <ListBox Grid.Row="1" Margin="0,12,0,0" ItemsSource="{Binding CatalogItems}"
                             HorizontalContentAlignment="Stretch" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                                        CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" />
                                                <TextBlock Text="{Binding Publisher, StringFormat=' · {0}'}" Opacity="0.6" VerticalAlignment="Bottom" Margin="6,0,0,1" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Opacity="0.85" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding StateLabel}" FontSize="11" Margin="0,6,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CanUpdate}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource Warning.Brush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Revoked}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource Bearish.Brush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding RevokedReason}" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Foreground="{DynamicResource Bearish.Brush}"
                                                       Visibility="{Binding Revoked, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <Button Content="Install" Padding="16,6" MinWidth="90"
                                                    Visibility="{Binding CanInstall, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.InstallFromCatalogCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Update" Padding="16,6" MinWidth="90"
                                                    Visibility="{Binding CanUpdate, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.InstallFromCatalogCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2" Text="{Binding CatalogStatus}" Margin="0,10,0,0"
                               TextWrapping="Wrap" FontWeight="SemiBold" />
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
