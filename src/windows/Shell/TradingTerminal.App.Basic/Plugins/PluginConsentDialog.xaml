<mah:MetroWindow x:Class="TradingTerminal.App.Plugins.PluginConsentDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Unverified plugin"
                 Height="440" Width="560"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize"
                 ShowMaxRestoreButton="False" ShowMinButton="False"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Headline}"
                   FontSize="16" FontWeight="SemiBold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <!-- The honest part: what an in-process plugin can actually do. -->
        <Border Grid.Row="1"
                Background="{DynamicResource Background.Secondary}"
                BorderBrush="{DynamicResource Accent.Warning}"
                BorderThickness="1"
                CornerRadius="0"
                Padding="10"
                Margin="0,0,0,12">
            <TextBlock Text="A strategy plugin runs inside the terminal with full access to this process. It cannot be sandboxed: it can read your broker session, your saved credentials, and your market-data store. Only run plugins from a source you trust."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource Text.Primary}" />
        </Border>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="{Binding PublisherText}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding PathText}"
                       Foreground="{DynamicResource Text.Secondary}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding HashText}"
                       Foreground="{DynamicResource Text.Secondary}"
                       FontFamily="Consolas" FontSize="11"
                       Margin="0,2,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock Text="What this plugin's code reaches for:"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <ItemsControl ItemsSource="{Binding Capabilities}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource Text.Secondary}"
                                   Margin="0,1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Don't run it"
                    IsCancel="True" IsDefault="True"
                    Padding="16,5"
                    Margin="0,0,8,0" />
            <Button Content="Run this plugin"
                    Click="OnConsentClicked"
                    Padding="16,5" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
