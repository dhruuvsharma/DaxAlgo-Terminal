<mah:MetroWindow x:Class="TradingTerminal.App.Archive.TelegramPromptDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Telegram login"
                 Height="220" Width="420"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ShowMaxRestoreButton="False" ShowMinButton="False"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding HeaderText}"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <TextBlock Grid.Row="1"
                   Text="{Binding HelpText}"
                   Foreground="{DynamicResource Text.Secondary}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12" />

        <TextBox Grid.Row="2"
                 x:Name="InputBox"
                 Text="{Binding InputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 FontFamily="Consolas" FontSize="14"
                 VerticalAlignment="Top"
                 Padding="6,4" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    IsCancel="True"
                    Padding="16,4"
                    Margin="0,0,8,0" />
            <Button Content="OK"
                    IsDefault="True"
                    Click="OnOkClicked"
                    Padding="16,4" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
