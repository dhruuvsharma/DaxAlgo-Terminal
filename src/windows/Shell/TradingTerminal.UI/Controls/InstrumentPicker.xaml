<UserControl x:Class="TradingTerminal.UI.Controls.InstrumentPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             x:Name="Root">
    <UserControl.Resources>
        <!-- InstrumentTagsConverter can't be declared here: same-assembly XAML can't reference the
             converter type at markup-compile time (MC3074). It's instead registered once in
             Application.Current.Resources by the control's ctor, which the row template's
             StaticResource resolves via the standard app-level fallback. -->

        <!-- Dropdown row: clean symbol on the left, coloured pills on the right
             (broker · asset class · data types). The closed box is a text field (IsEditable), so the
             pills live here, on the rows, only. -->
        <DataTemplate x:Key="InstrumentRowTemplate">
            <DockPanel LastChildFill="True">
                <ItemsControl DockPanel.Dock="Right" VerticalAlignment="Center"
                              ItemsSource="{Binding Converter={StaticResource InstrumentTagsConverter}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Background}" CornerRadius="0"
                                    Padding="5,1" Margin="3,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Text}" Foreground="{Binding Foreground}"
                                           FontSize="10" FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                           Margin="0,0,10,0" TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <!--
      One editable ComboBox: type the instrument name, the drop-down filters as you go.

      IsTextSearchEnabled=False is load-bearing — WPF's built-in type-ahead would race the view-model's
      filter, snapping the selection to whatever prefix-matched mid-keystroke. TextSearch.TextPath makes
      a picked row render as its DisplayName in the text box (a SignalInstrument's record ToString()
      would otherwise leak into the UI). StaysOpenOnEdit keeps the list up while typing.

      Text is bound to SearchText, which the owning view-model filters ItemsSource by — so an empty box
      shows the whole universe and typing narrows it. InstrumentPickerFilter.Apply always keeps the
      selected row in the list, which is what stops the ComboBox from nulling its own selection as the
      user types.
    -->
    <ComboBox x:Name="Combo"
              IsEditable="True"
              IsTextSearchEnabled="False"
              StaysOpenOnEdit="True"
              TextSearch.TextPath="DisplayName"
              Text="{Binding SearchText, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=150}"
              ItemsSource="{Binding ItemsSource, ElementName=Root}"
              SelectedItem="{Binding SelectedInstrument, ElementName=Root, Mode=TwoWay}"
              ItemTemplate="{StaticResource InstrumentRowTemplate}"
              MaxDropDownHeight="{Binding MaxDropDownHeight, ElementName=Root}"
              mah:TextBoxHelper.Watermark="Type an instrument…"
              mah:TextBoxHelper.ClearTextButton="True" />
</UserControl>
