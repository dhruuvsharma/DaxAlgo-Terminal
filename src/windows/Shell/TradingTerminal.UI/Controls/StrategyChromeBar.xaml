<UserControl x:Class="TradingTerminal.UI.Controls.StrategyChromeBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Name="Root">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="ChromeBoolToVis" />
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- Named view presets (binds the host VM's preset surface by convention) -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                    Visibility="{Binding ShowPresets, ElementName=Root, Converter={StaticResource ChromeBoolToVis}}">
            <Border Style="{StaticResource App.ParamDivider}" />
            <TextBlock Text="PRESET" Style="{StaticResource App.GroupLabel}" />
            <ComboBox Width="130" IsEditable="True"
                      ItemsSource="{Binding PresetNames}"
                      SelectedItem="{Binding SelectedPreset}"
                      Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"
                      ToolTip="Pick a preset to apply it, or type a new name and press save. Presets remember view options, never the instrument." />
            <Button Style="{StaticResource App.IconButton}" Margin="6,0,0,0" Content="💾"
                    Command="{Binding SavePresetCommand}"
                    ToolTip="Save the current view options as a named preset" />
            <Button Style="{StaticResource App.IconButton}" Content="🗑"
                    Command="{Binding DeletePresetCommand}"
                    ToolTip="Delete the selected preset" />
            <Border Style="{StaticResource App.ParamDivider}" />
        </StackPanel>

        <ToggleButton Style="{StaticResource App.IconToggle}" Content="⏸"
                      IsChecked="{Binding IsPaused}"
                      Visibility="{Binding ShowPause, ElementName=Root, Converter={StaticResource ChromeBoolToVis}}"
                      ToolTip="Pause the display — the strategy and its feeds keep running underneath, resume is instant" />

        <!-- Window-specific action buttons (e.g. a bespoke CSV export) -->
        <ContentPresenter Content="{Binding ExtraActions, ElementName=Root}" VerticalAlignment="Center" />
        <Button Style="{StaticResource App.IconButton}" Content="↧"
                Command="{Binding ExportBarsCsvCommand}"
                Visibility="{Binding ShowBarsCsv, ElementName=Root, Converter={StaticResource ChromeBoolToVis}}"
                ToolTip="Export the live chart bars as CSV" />
        <Button Style="{StaticResource App.IconButton}" Content="▤"
                Command="{Binding ExportSignalsCsvCommand}"
                Visibility="{Binding ShowSignalsCsv, ElementName=Root, Converter={StaticResource ChromeBoolToVis}}"
                ToolTip="Export the signal tape as CSV" />
        <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                ToolTip="Save a PNG snapshot of this window" />
        <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?"
                      Margin="0" ToolTip="What am I looking at?" />

        <!-- Contextual help (anchored to the ? toggle; content supplied by the host window) -->
        <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
               HorizontalOffset="-330" VerticalOffset="6">
            <Border Style="{StaticResource App.Card}" Width="380" Padding="16"
                    Background="{DynamicResource Background.Elevated}">
                <StackPanel>
                    <TextBlock Text="{Binding HelpTitle, ElementName=Root}"
                               Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                    <ContentPresenter Content="{Binding HelpContent, ElementName=Root}" />
                </StackPanel>
            </Border>
        </Popup>
    </StackPanel>
</UserControl>
