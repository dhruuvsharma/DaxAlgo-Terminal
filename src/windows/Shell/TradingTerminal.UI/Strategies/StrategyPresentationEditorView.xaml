<Window x:Class="TradingTerminal.UI.Strategies.StrategyPresentationEditorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:uistrat="clr-namespace:TradingTerminal.UI.Strategies"
        Title="Edit strategy card"
        Width="580" Height="680"
        MinWidth="460" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource Background.Primary}"
        Foreground="{DynamicResource Text.Primary}"
        FontFamily="{DynamicResource Font.Mono}"
        FontSize="12">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="B2V" />
    </Window.Resources>

    <DockPanel Margin="16">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <Border Width="3" Height="15" Background="{DynamicResource Accent.Brush}" Margin="0,0,8,0" />
                <TextBlock Text="EDIT STRATEGY CARD" FontWeight="Bold" FontSize="13"
                           Foreground="{DynamicResource Text.Header}" VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock Margin="11,4,0,0" FontSize="11" Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap">
                <Run Text="Customises how this strategy appears in the catalog. Blank name/description fall back to the strategy's own. Id:" />
                <Run Text="{Binding StrategyId, Mode=OneWay}" Foreground="{DynamicResource Text.Highlight}" />
            </TextBlock>
        </StackPanel>

        <!-- Buttons -->
        <Grid DockPanel.Dock="Bottom" Margin="0,14,0,0">
            <Button Content="Reset to default" Padding="12,6" HorizontalAlignment="Left"
                    Command="{Binding ResetToDefaultCommand}"
                    ToolTip="Clear every override so the strategy's own name, description and tags show again." />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" IsCancel="True" />
                <Button Content="Save" Padding="20,6" IsDefault="True" Click="Save_Click"
                        Background="{DynamicResource Accent.Brush}" Foreground="{DynamicResource Background.Primary}" />
            </StackPanel>
        </Grid>

        <!-- Fields -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,4,0">

                <TextBlock Text="Name" FontWeight="SemiBold" Margin="0,0,0,3" />
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="Tags (comma-separated)" FontWeight="SemiBold" Margin="0,12,0,3" />
                <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Free-text labels shown as pills on the card, e.g. mean-reversion, intraday, HFT." />

                <TextBlock Text="Description" FontWeight="SemiBold" Margin="0,12,0,3" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="80" MaxHeight="180"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Text="Alpha-generating formula (optional)" FontWeight="SemiBold" Margin="0,12,0,3" />
                <TextBox Text="{Binding Formula, UpdateSourceTrigger=PropertyChanged}"
                         MinHeight="60" MaxHeight="160"
                         AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                         FontFamily="Consolas"
                         VerticalScrollBarVisibility="Auto"
                         ToolTip="The signal/alpha maths behind the strategy, e.g. z = (p - EMA_n(p)) / σ_n(p)." />

                <TextBlock Text="UI image (screenshot)" FontWeight="SemiBold" Margin="0,12,0,3" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Column="1" Content="Browse…" Padding="12,5" Margin="6,0,0,0"
                            Command="{Binding BrowseImageCommand}" />
                    <Button Grid.Column="2" Content="Clear" Padding="12,5" Margin="6,0,0,0"
                            Command="{Binding ClearImageCommand}" />
                </Grid>
                <TextBlock Margin="0,4,0,0" FontSize="10" Opacity="0.6" TextWrapping="Wrap"
                           Foreground="{DynamicResource Text.Secondary}"
                           Text="No image? The card shows the DaxAlgo logo instead." />

                <!-- Live preview — exactly what the catalog row will render. -->
                <uistrat:StrategyImageTile Margin="0,8,0,0" Height="150" Width="260"
                                           HorizontalAlignment="Left"
                                           ImagePath="{Binding ImagePath}" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
