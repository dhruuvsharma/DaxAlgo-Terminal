<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════
         GREEK — "Obsidian" (dark). The night-museum counterpart to GreekLight: warm basalt/obsidian
         stone for the surfaces (never a flat pure black — everything is tinted toward aged bronze),
         marble-ivory text, and the same terracotta/amphora accent, pushed a little brighter so it
         glows against the stone. P&L keeps the thematic laurel-olive up / Pompeiian-red down, with an
         antique-bronze-gold warning.

         Defines EXACTLY the same key set as Brushes.xaml so ThemeManager can hot-swap it in. The
         MahApps base is already dark, so — like the other dark palettes — this only re-pins the
         accent; the custom shell (fully token-driven) does the rest.
         ═══════════════════════════════════════════════════════════════════════════════════════ -->

    <!-- Backgrounds — warm obsidian canvas, dark-stone panels, raised bronze-stone cards -->
    <Color x:Key="Background.Primary.Color">#16130F</Color>
    <Color x:Key="Background.Surface.Color">#1E1A15</Color>
    <Color x:Key="Background.Elevated.Color">#27221B</Color>
    <Color x:Key="Border.Color">#3A332A</Color>

    <!-- Text — marble ivory, weathered-stone secondary, gold-ivory display headers -->
    <Color x:Key="Text.Primary.Color">#EDE6D8</Color>
    <Color x:Key="Text.Secondary.Color">#9C9081</Color>
    <Color x:Key="Text.Header.Color">#F0E6CF</Color>
    <Color x:Key="Text.Highlight.Color">#E8763F</Color>

    <!-- Semantic — glowing terracotta accent; laurel/Pompeiian P&L; bronze-gold warning -->
    <Color x:Key="Accent.Color">#E4652F</Color>
    <Color x:Key="Accent.Dim.Color">#B14E22</Color>
    <Color x:Key="Bullish.Color">#9CAA55</Color>
    <Color x:Key="Bearish.Color">#C6493F</Color>
    <Color x:Key="Danger.Color">#D34638</Color>
    <Color x:Key="Warning.Color">#D0A24A</Color>

    <!-- SolidColorBrush wrappers -->
    <SolidColorBrush x:Key="Background.Primary"  Color="{StaticResource Background.Primary.Color}" />
    <SolidColorBrush x:Key="Background.Surface"  Color="{StaticResource Background.Surface.Color}" />
    <SolidColorBrush x:Key="Background.Elevated" Color="{StaticResource Background.Elevated.Color}" />
    <SolidColorBrush x:Key="Border.Brush"        Color="{StaticResource Border.Color}" />
    <SolidColorBrush x:Key="Text.Primary"        Color="{StaticResource Text.Primary.Color}" />
    <SolidColorBrush x:Key="Text.Secondary"      Color="{StaticResource Text.Secondary.Color}" />
    <SolidColorBrush x:Key="Text.Header"         Color="{StaticResource Text.Header.Color}" />
    <SolidColorBrush x:Key="Text.Highlight"      Color="{StaticResource Text.Highlight.Color}" />
    <SolidColorBrush x:Key="Accent.Brush"        Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="Accent.Dim.Brush"    Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="Bullish.Brush"       Color="{StaticResource Bullish.Color}" />
    <SolidColorBrush x:Key="Bearish.Brush"       Color="{StaticResource Bearish.Color}" />
    <SolidColorBrush x:Key="Danger.Brush"        Color="{StaticResource Danger.Color}" />
    <SolidColorBrush x:Key="Warning.Brush"       Color="{StaticResource Warning.Color}" />

    <!-- Extra flat colours -->
    <Color x:Key="Surface.Hover.Color">#2C261E</Color>
    <Color x:Key="Border.Strong.Color">#4A4136</Color>
    <Color x:Key="Accent.Hover.Color">#F07B45</Color>

    <SolidColorBrush x:Key="Surface.Hover" Color="{StaticResource Surface.Hover.Color}" />
    <SolidColorBrush x:Key="Border.Strong" Color="{StaticResource Border.Strong.Color}" />
    <SolidColorBrush x:Key="Accent.Hover.Brush" Color="{StaticResource Accent.Hover.Color}" />

    <!-- Soft (alpha) semantic fills — for pills / chips / cell washes -->
    <SolidColorBrush x:Key="Accent.Soft"    Color="#26E4652F" />
    <SolidColorBrush x:Key="Bullish.Soft"   Color="#269CAA55" />
    <SolidColorBrush x:Key="Bearish.Soft"   Color="#26C6493F" />
    <SolidColorBrush x:Key="Warning.Soft"   Color="#26D0A24A" />
    <SolidColorBrush x:Key="Highlight.Soft" Color="#26E8763F" />

    <!-- Vertical surface gradients (chrome bars, panels, cards) — warm obsidian -->
    <LinearGradientBrush x:Key="Gradient.Chrome" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#221D17" Offset="0" />
        <GradientStop Color="#14110D" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Elevated" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#2A241C" Offset="0" />
        <GradientStop Color="#1B1712" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Surface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1C1813" Offset="0" />
        <GradientStop Color="#120F0B" Offset="1" />
    </LinearGradientBrush>

    <!-- Bronze-tinted header gradient (left→right) for card/section headers -->
    <LinearGradientBrush x:Key="Gradient.Header" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2A2117" Offset="0" />
        <GradientStop Color="#16110B" Offset="1" />
    </LinearGradientBrush>

    <!-- Terracotta gradients for primary buttons / active states -->
    <LinearGradientBrush x:Key="Gradient.Accent" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F07B45" Offset="0" />
        <GradientStop Color="#E4652F" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.AccentHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F58C59" Offset="0" />
        <GradientStop Color="#EC7038" Offset="1" />
    </LinearGradientBrush>

    <!-- Typographic constants — editorial sans for the museum chrome; mono for data columns. -->
    <FontFamily x:Key="Font.Base">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Data">Consolas, Cascadia Mono, Lucida Console</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas, Cascadia Mono, Lucida Console</FontFamily>

    <!-- ═══ AI-native accent family (violet→cyan) — consumed by Themes/AiStyles.xaml. ═══ -->
    <Color x:Key="Ai.Accent.Color">#A855F7</Color>
    <Color x:Key="Ai.Glow.Color">#8B5CF6</Color>
    <Color x:Key="Ai.Text.Color">#C4B5FD</Color>

    <SolidColorBrush x:Key="Ai.Accent.Brush" Color="{StaticResource Ai.Accent.Color}" />
    <SolidColorBrush x:Key="Ai.Glow.Brush"   Color="{StaticResource Ai.Glow.Color}" />
    <SolidColorBrush x:Key="Ai.Text.Brush"   Color="{StaticResource Ai.Text.Color}" />
    <SolidColorBrush x:Key="Ai.Soft"         Color="#268B5CF6" />

    <LinearGradientBrush x:Key="Gradient.Ai" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7C3AED" Offset="0" />
        <GradientStop Color="#A855F7" Offset="0.5" />
        <GradientStop Color="#22D3EE" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.AiGlass" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2E7C3AED" Offset="0" />
        <GradientStop Color="#1F22D3EE" Offset="1" />
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════
         MahApps accent override (terracotta). Lives in the palette so a hot-swap re-skins every
         MahApps accent surface. White ideal foreground: white text on the terracotta accent is
         legible; the dark base already supplies dark native surfaces.
         ═══════════════════════════════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"  Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent2" Color="#EC7038" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent3" Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent4" Color="#80E4652F" />
    <SolidColorBrush x:Key="MahApps.Brushes.Highlight" Color="#F07B45" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource Accent.Color}" />
    <Color x:Key="MahApps.Colors.Accent">#E4652F</Color>
    <Color x:Key="MahApps.Colors.Highlight">#F07B45</Color>
    <Color x:Key="MahApps.Colors.IdealForeground">#FFFFFF</Color>
    <SolidColorBrush x:Key="MahApps.Brushes.IdealForeground" Color="#FFFFFF" />

    <!-- Menus, context menus, window titles, DataGrid selection (keys verified vs MahApps 2.4.10). -->
    <SolidColorBrush x:Key="MahApps.Brushes.Menu.Background" Color="#1B1712" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.Background" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.SubMenu.Background" Color="#27221B" />
    <SolidColorBrush x:Key="MahApps.Brushes.SubMenu.Border" Color="#4A4136" />
    <SolidColorBrush x:Key="MahApps.Brushes.ContextMenu.Background" Color="#27221B" />
    <SolidColorBrush x:Key="MahApps.Brushes.ContextMenu.Border" Color="#4A4136" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.SelectionFill" Color="#26E4652F" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.SelectionStroke" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.TopMenuItem.PressedFill" Color="#2C261E" />
    <SolidColorBrush x:Key="MahApps.Brushes.TopMenuItem.PressedStroke" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.TopMenuItem.SelectionStroke" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.Foreground.Disabled" Color="#6A6154" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.GlyphPanel.Disabled" Color="#6A6154" />
    <SolidColorBrush x:Key="MahApps.Brushes.Separator" Color="#3A332A" />
    <SolidColorBrush x:Key="MahApps.Brushes.WindowTitle" Color="#1B1712" />
    <SolidColorBrush x:Key="MahApps.Brushes.WindowTitle.NonActive" Color="#16130F" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Background" Color="#26E4652F" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Background.MouseOver" Color="#33E4652F" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Background.Inactive" Color="#1AE4652F" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Text" Color="#EDE6D8" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Text.MouseOver" Color="#EDE6D8" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Text.Inactive" Color="#EDE6D8" />

</ResourceDictionary>
