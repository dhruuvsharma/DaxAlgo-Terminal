<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════
         DAXALGO LIGHT — the light counterpart of DaxAlgo Dark. TradingView light-mode values:
         white canvas, cool blue-grey panels, the same electric-blue accent and green/red P&L.
         Sans UI font, mono reserved for data.

         Like GreekLight, this palette runs on the MahApps *Dark* base, so it also flips the core
         native surfaces (window / control / flyout background + foreground) to light — the custom
         shell is fully token-driven, so everything else follows automatically. Same key set as
         Brushes.xaml (plus the shared Ai.* / Font.* additions).
         ═══════════════════════════════════════════════════════════════════════════════════════ -->

    <!-- Backgrounds — white canvas, cool panel wash, white elevated cards -->
    <Color x:Key="Background.Primary.Color">#FFFFFF</Color>
    <Color x:Key="Background.Surface.Color">#F0F3FA</Color>
    <Color x:Key="Background.Elevated.Color">#FFFFFF</Color>
    <Color x:Key="Border.Color">#E0E3EB</Color>

    <!-- Text — near-black primary, muted grey secondary -->
    <Color x:Key="Text.Primary.Color">#131722</Color>
    <Color x:Key="Text.Secondary.Color">#787B86</Color>
    <Color x:Key="Text.Header.Color">#0C111D</Color>
    <Color x:Key="Text.Highlight.Color">#1E53E5</Color>

    <!-- Semantic — TV blue accent; teal-green up / signal-red down; darkened amber warning -->
    <Color x:Key="Accent.Color">#2962FF</Color>
    <Color x:Key="Accent.Dim.Color">#93ADF2</Color>
    <Color x:Key="Bullish.Color">#089981</Color>
    <Color x:Key="Bearish.Color">#F23645</Color>
    <Color x:Key="Danger.Color">#D8232F</Color>
    <Color x:Key="Warning.Color">#B26A00</Color>

    <!-- SolidColorBrush wrappers -->
    <SolidColorBrush x:Key="Background.Primary"  Color="{StaticResource Background.Primary.Color}" />
    <SolidColorBrush x:Key="Background.Surface"  Color="{StaticResource Background.Surface.Color}" />
    <SolidColorBrush x:Key="Background.Elevated" Color="{StaticResource Background.Elevated.Color}" />
    <SolidColorBrush x:Key="Border.Brush"        Color="{StaticResource Border.Color}" />
    <SolidColorBrush x:Key="Text.Primary"        Color="{StaticResource Text.Primary.Color}" />
    <SolidColorBrush x:Key="Text.Secondary"      Color="{StaticResource Text.Secondary.Color}" />
    <SolidColorBrush x:Key="Text.Header"         Color="{StaticResource Text.Header.Color}" />
    <SolidColorBrush x:Key="Text.Highlight"      Color="{StaticResource Text.Highlight.Color}" />
    <SolidColorBrush x:Key="Accent.Brush"        Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="Accent.Dim.Brush"    Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="Bullish.Brush"       Color="{StaticResource Bullish.Color}" />
    <SolidColorBrush x:Key="Bearish.Brush"       Color="{StaticResource Bearish.Color}" />
    <SolidColorBrush x:Key="Danger.Brush"        Color="{StaticResource Danger.Color}" />
    <SolidColorBrush x:Key="Warning.Brush"       Color="{StaticResource Warning.Color}" />

    <!-- Extra flat colours -->
    <Color x:Key="Surface.Hover.Color">#E2E8F2</Color>
    <Color x:Key="Border.Strong.Color">#C1C7D4</Color>
    <Color x:Key="Accent.Hover.Color">#1E53E5</Color>

    <SolidColorBrush x:Key="Surface.Hover" Color="{StaticResource Surface.Hover.Color}" />
    <SolidColorBrush x:Key="Border.Strong" Color="{StaticResource Border.Strong.Color}" />
    <SolidColorBrush x:Key="Accent.Hover.Brush" Color="{StaticResource Accent.Hover.Color}" />

    <!-- Soft (alpha) semantic fills — pastel over white -->
    <SolidColorBrush x:Key="Accent.Soft"    Color="#262962FF" />
    <SolidColorBrush x:Key="Bullish.Soft"   Color="#26089981" />
    <SolidColorBrush x:Key="Bearish.Soft"   Color="#26F23645" />
    <SolidColorBrush x:Key="Warning.Soft"   Color="#26B26A00" />
    <SolidColorBrush x:Key="Highlight.Soft" Color="#261E53E5" />

    <!-- Vertical surface gradients — near-flat light -->
    <LinearGradientBrush x:Key="Gradient.Chrome" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#F4F6FB" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Elevated" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0" />
        <GradientStop Color="#F7F9FD" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Surface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FAFBFE" Offset="0" />
        <GradientStop Color="#F0F3FA" Offset="1" />
    </LinearGradientBrush>

    <!-- Blue-washed header gradient (left→right) for card/section headers -->
    <LinearGradientBrush x:Key="Gradient.Header" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#E8EFFF" Offset="0" />
        <GradientStop Color="#F6F9FF" Offset="1" />
    </LinearGradientBrush>

    <!-- Blue gradients for primary buttons / active states -->
    <LinearGradientBrush x:Key="Gradient.Accent" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3D74FF" Offset="0" />
        <GradientStop Color="#2962FF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.AccentHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5C8AFF" Offset="0" />
        <GradientStop Color="#3D74FF" Offset="1" />
    </LinearGradientBrush>

    <!-- Typographic constants — sans for UI chrome, mono strictly for data columns -->
    <FontFamily x:Key="Font.Base">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Data">Consolas, Cascadia Mono, Lucida Console</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas, Cascadia Mono, Lucida Console</FontFamily>

    <!-- ═══ AI-native accent family — deepened for contrast on light surfaces. ═══ -->
    <Color x:Key="Ai.Accent.Color">#7C3AED</Color>
    <Color x:Key="Ai.Glow.Color">#7C3AED</Color>
    <Color x:Key="Ai.Text.Color">#6D28D9</Color>

    <SolidColorBrush x:Key="Ai.Accent.Brush" Color="{StaticResource Ai.Accent.Color}" />
    <SolidColorBrush x:Key="Ai.Glow.Brush"   Color="{StaticResource Ai.Glow.Color}" />
    <SolidColorBrush x:Key="Ai.Text.Brush"   Color="{StaticResource Ai.Text.Color}" />
    <SolidColorBrush x:Key="Ai.Soft"         Color="#1F7C3AED" />

    <LinearGradientBrush x:Key="Gradient.Ai" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6D28D9" Offset="0" />
        <GradientStop Color="#9333EA" Offset="0.5" />
        <GradientStop Color="#0891B2" Offset="1" />
    </LinearGradientBrush>
    <!-- Frosted glass wash for AI panels on light surfaces. -->
    <LinearGradientBrush x:Key="Gradient.AiGlass" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#217C3AED" Offset="0" />
        <GradientStop Color="#140891B2" Offset="1" />
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════
         MahApps overrides — blue accent + light native surface flip (same trick as GreekLight:
         we run on the MahApps Dark base, so the core theme/control/flyout surfaces are re-pinned
         to light here). White ideal foreground on the blue accent.
         ═══════════════════════════════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"  Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent2" Color="#3D74FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent3" Color="#7E9BEF" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent4" Color="#802962FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.Highlight" Color="#1E53E5" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource Accent.Color}" />
    <Color x:Key="MahApps.Colors.Accent">#2962FF</Color>
    <Color x:Key="MahApps.Colors.Highlight">#1E53E5</Color>
    <Color x:Key="MahApps.Colors.IdealForeground">#FFFFFF</Color>
    <SolidColorBrush x:Key="MahApps.Brushes.IdealForeground" Color="#FFFFFF" />

    <!-- Core light theme surfaces (flip the Dark base's native chrome to white/ink) -->
    <Color x:Key="MahApps.Colors.ThemeBackground">#FFFFFF</Color>
    <Color x:Key="MahApps.Colors.ThemeForeground">#131722</Color>
    <SolidColorBrush x:Key="MahApps.Brushes.ThemeBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MahApps.Brushes.ThemeForeground" Color="#131722" />
    <SolidColorBrush x:Key="MahApps.Brushes.Control.Background" Color="#FFFFFF" />
    <SolidColorBrush x:Key="MahApps.Brushes.Flyout.Background" Color="#F0F3FA" />
    <SolidColorBrush x:Key="MahApps.Brushes.Flyout.Foreground" Color="#131722" />

</ResourceDictionary>
