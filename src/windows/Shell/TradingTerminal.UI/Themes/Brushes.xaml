<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Bloomberg-inspired palette: pure black canvas, amber/orange chrome,
         saturated green/red for P&L, cyan for secondary highlights. -->

    <!-- Backgrounds -->
    <Color x:Key="Background.Primary.Color">#000000</Color>
    <Color x:Key="Background.Surface.Color">#0A0A0A</Color>
    <Color x:Key="Background.Elevated.Color">#141414</Color>
    <Color x:Key="Border.Color">#2A2A2A</Color>

    <!-- Text -->
    <Color x:Key="Text.Primary.Color">#E8E8E8</Color>
    <Color x:Key="Text.Secondary.Color">#8A8A8A</Color>
    <Color x:Key="Text.Header.Color">#FFB000</Color>
    <Color x:Key="Text.Highlight.Color">#00BFFF</Color>

    <!-- Semantic -->
    <Color x:Key="Accent.Color">#FF8C00</Color>
    <Color x:Key="Accent.Dim.Color">#A65A00</Color>
    <Color x:Key="Bullish.Color">#00C853</Color>
    <Color x:Key="Bearish.Color">#FF1744</Color>
    <Color x:Key="Danger.Color">#FF1744</Color>
    <Color x:Key="Warning.Color">#FFD600</Color>

    <!-- SolidColorBrush wrappers -->
    <SolidColorBrush x:Key="Background.Primary"  Color="{StaticResource Background.Primary.Color}" />
    <SolidColorBrush x:Key="Background.Surface"  Color="{StaticResource Background.Surface.Color}" />
    <SolidColorBrush x:Key="Background.Elevated" Color="{StaticResource Background.Elevated.Color}" />
    <SolidColorBrush x:Key="Border.Brush"        Color="{StaticResource Border.Color}" />
    <SolidColorBrush x:Key="Text.Primary"        Color="{StaticResource Text.Primary.Color}" />
    <SolidColorBrush x:Key="Text.Secondary"      Color="{StaticResource Text.Secondary.Color}" />
    <SolidColorBrush x:Key="Text.Header"         Color="{StaticResource Text.Header.Color}" />
    <SolidColorBrush x:Key="Text.Highlight"      Color="{StaticResource Text.Highlight.Color}" />
    <SolidColorBrush x:Key="Accent.Brush"        Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="Accent.Dim.Brush"    Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="Bullish.Brush"       Color="{StaticResource Bullish.Color}" />
    <SolidColorBrush x:Key="Bearish.Brush"       Color="{StaticResource Bearish.Color}" />
    <SolidColorBrush x:Key="Danger.Brush"        Color="{StaticResource Danger.Color}" />
    <SolidColorBrush x:Key="Warning.Brush"       Color="{StaticResource Warning.Color}" />

    <!-- ===================================================================================
         Premium-terminal depth tokens (added for the v2 fancy theme). All additive — existing
         keys above are untouched, so every window keeps working while opting into the richer set.
         =================================================================================== -->

    <!-- Extra flat colours -->
    <Color x:Key="Surface.Hover.Color">#1C1C1C</Color>
    <Color x:Key="Border.Strong.Color">#3A3A3A</Color>
    <Color x:Key="Accent.Hover.Color">#FFA733</Color>

    <SolidColorBrush x:Key="Surface.Hover" Color="{StaticResource Surface.Hover.Color}" />
    <SolidColorBrush x:Key="Border.Strong" Color="{StaticResource Border.Strong.Color}" />
    <SolidColorBrush x:Key="Accent.Hover.Brush" Color="{StaticResource Accent.Hover.Color}" />

    <!-- Soft (alpha) semantic fills — for pills / chips / cell washes -->
    <SolidColorBrush x:Key="Accent.Soft"   Color="#26FF8C00" />
    <SolidColorBrush x:Key="Bullish.Soft"  Color="#2600C853" />
    <SolidColorBrush x:Key="Bearish.Soft"  Color="#26FF1744" />
    <SolidColorBrush x:Key="Warning.Soft"  Color="#26FFD600" />
    <SolidColorBrush x:Key="Highlight.Soft" Color="#2600BFFF" />

    <!-- Vertical surface gradients (chrome bars, panels, cards) -->
    <LinearGradientBrush x:Key="Gradient.Chrome" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1A1A" Offset="0" />
        <GradientStop Color="#0C0C0C" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Elevated" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E1E1E" Offset="0" />
        <GradientStop Color="#121212" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Surface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#121212" Offset="0" />
        <GradientStop Color="#080808" Offset="1" />
    </LinearGradientBrush>

    <!-- Amber-tinted header gradient (left→right) for card/section headers -->
    <LinearGradientBrush x:Key="Gradient.Header" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2A1E07" Offset="0" />
        <GradientStop Color="#130D03" Offset="1" />
    </LinearGradientBrush>

    <!-- Accent gradients for primary buttons / active states -->
    <LinearGradientBrush x:Key="Gradient.Accent" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFA733" Offset="0" />
        <GradientStop Color="#FF8C00" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.AccentHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFBB55" Offset="0" />
        <GradientStop Color="#FF9A1A" Offset="1" />
    </LinearGradientBrush>

    <!-- Typographic constants -->
    <FontFamily x:Key="Font.Mono">Consolas, Cascadia Mono, Lucida Console</FontFamily>

    <!-- ===================================================================================
         MahApps accent override (amber). Lives in the PALETTE (not Dark.xaml) so that swapping
         the palette dictionary at runtime — see ThemeManager — also re-skins every MahApps accent
         (selection, focus ring, checkbox tick, toggle, tab underline, progress bar, scrollbar
         thumb). MahApps reads these via DynamicResource and this dictionary merges after MahApps,
         so our values win app-wide.
         =================================================================================== -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"  Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent2" Color="#FF9A1A" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent3" Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent4" Color="#80FF8C00" />
    <SolidColorBrush x:Key="MahApps.Brushes.Highlight" Color="#FF9A1A" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource Accent.Color}" />
    <Color x:Key="MahApps.Colors.Accent">#FF8C00</Color>
    <Color x:Key="MahApps.Colors.Highlight">#FF9A1A</Color>

</ResourceDictionary>
