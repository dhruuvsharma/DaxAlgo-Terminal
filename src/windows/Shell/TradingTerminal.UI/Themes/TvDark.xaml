<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════
         DAXALGO DARK — the default palette. TradingView-grade minimalism: a deep blue-grey canvas
         (never pure black), flat panels one step lighter, restrained hairline borders, a single
         electric-blue interactive accent, and classic green/red P&L. UI text is a proportional
         sans (Font.Base); monospace is reserved for DATA (Font.Data / Font.Mono) so numeric
         columns stay aligned without the whole app reading like a code editor.

         Defines the shared DaxAlgo token contract consumed by the structural styles. TvLight.xaml
         carries the same contract plus the MahApps light-surface overrides it needs.
         ═══════════════════════════════════════════════════════════════════════════════════════ -->

    <!-- Backgrounds — TV canvas #131722, panel #1E222D, raised chrome one step lighter -->
    <Color x:Key="Background.Primary.Color">#131722</Color>
    <Color x:Key="Background.Surface.Color">#1E222D</Color>
    <Color x:Key="Background.Elevated.Color">#262B38</Color>
    <Color x:Key="Border.Color">#2A2E39</Color>

    <!-- Text — soft off-white primary, muted grey secondary, bright neutral headers -->
    <Color x:Key="Text.Primary.Color">#D1D4DC</Color>
    <Color x:Key="Text.Secondary.Color">#787B86</Color>
    <Color x:Key="Text.Header.Color">#EAECEF</Color>
    <Color x:Key="Text.Highlight.Color">#4C8FFF</Color>

    <!-- Semantic — TV blue accent; teal-green up / signal-red down; amber warning -->
    <Color x:Key="Accent.Color">#2962FF</Color>
    <Color x:Key="Accent.Dim.Color">#1E4BC8</Color>
    <Color x:Key="Bullish.Color">#089981</Color>
    <Color x:Key="Bearish.Color">#F23645</Color>
    <Color x:Key="Danger.Color">#F23645</Color>
    <Color x:Key="Warning.Color">#F7A600</Color>

    <!-- SolidColorBrush wrappers -->
    <SolidColorBrush x:Key="Background.Primary"  Color="{StaticResource Background.Primary.Color}" />
    <SolidColorBrush x:Key="Background.Surface"  Color="{StaticResource Background.Surface.Color}" />
    <SolidColorBrush x:Key="Background.Elevated" Color="{StaticResource Background.Elevated.Color}" />
    <SolidColorBrush x:Key="Border.Brush"        Color="{StaticResource Border.Color}" />
    <SolidColorBrush x:Key="Text.Primary"        Color="{StaticResource Text.Primary.Color}" />
    <SolidColorBrush x:Key="Text.Secondary"      Color="{StaticResource Text.Secondary.Color}" />
    <SolidColorBrush x:Key="Text.Header"         Color="{StaticResource Text.Header.Color}" />
    <SolidColorBrush x:Key="Text.Highlight"      Color="{StaticResource Text.Highlight.Color}" />
    <SolidColorBrush x:Key="Accent.Brush"        Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="Accent.Dim.Brush"    Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="Bullish.Brush"       Color="{StaticResource Bullish.Color}" />
    <SolidColorBrush x:Key="Bearish.Brush"       Color="{StaticResource Bearish.Color}" />
    <SolidColorBrush x:Key="Danger.Brush"        Color="{StaticResource Danger.Color}" />
    <SolidColorBrush x:Key="Warning.Brush"       Color="{StaticResource Warning.Color}" />

    <!-- Extra flat colours -->
    <Color x:Key="Surface.Hover.Color">#2A2E39</Color>
    <Color x:Key="Border.Strong.Color">#3A404E</Color>
    <Color x:Key="Accent.Hover.Color">#4C8FFF</Color>

    <SolidColorBrush x:Key="Surface.Hover" Color="{StaticResource Surface.Hover.Color}" />
    <SolidColorBrush x:Key="Border.Strong" Color="{StaticResource Border.Strong.Color}" />
    <SolidColorBrush x:Key="Accent.Hover.Brush" Color="{StaticResource Accent.Hover.Color}" />

    <!-- Soft (alpha) semantic fills — for pills / chips / cell washes -->
    <SolidColorBrush x:Key="Accent.Soft"    Color="#262962FF" />
    <SolidColorBrush x:Key="Bullish.Soft"   Color="#26089981" />
    <SolidColorBrush x:Key="Bearish.Soft"   Color="#26F23645" />
    <SolidColorBrush x:Key="Warning.Soft"   Color="#26F7A600" />
    <SolidColorBrush x:Key="Highlight.Soft" Color="#264C8FFF" />

    <!-- Vertical surface gradients — kept NEAR-FLAT on purpose: consumers of the gradient keys
         get the minimal TradingView look without every window being rewritten. -->
    <LinearGradientBrush x:Key="Gradient.Chrome" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1C202B" Offset="0" />
        <GradientStop Color="#161A24" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Elevated" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#262B38" Offset="0" />
        <GradientStop Color="#20242F" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.Surface" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1E29" Offset="0" />
        <GradientStop Color="#151924" Offset="1" />
    </LinearGradientBrush>

    <!-- Blue-washed header gradient (left→right) for card/section headers -->
    <LinearGradientBrush x:Key="Gradient.Header" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#223052" Offset="0" />
        <GradientStop Color="#1A2030" Offset="1" />
    </LinearGradientBrush>

    <!-- Blue gradients for primary buttons / active states -->
    <LinearGradientBrush x:Key="Gradient.Accent" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#3D74FF" Offset="0" />
        <GradientStop Color="#2962FF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="Gradient.AccentHover" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#5C8AFF" Offset="0" />
        <GradientStop Color="#3D74FF" Offset="1" />
    </LinearGradientBrush>

    <!-- Typographic constants — sans for UI chrome, mono strictly for data columns -->
    <FontFamily x:Key="Font.Base">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Font.Data">Consolas, Cascadia Mono, Lucida Console</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas, Cascadia Mono, Lucida Console</FontFamily>

    <!-- ═══ AI-native accent family — the violet→cyan signature that marks AI features.
         Consumed by Themes/AiStyles.xaml (badges, glass cards, hero button, animated borders). ═══ -->
    <Color x:Key="Ai.Accent.Color">#A855F7</Color>
    <Color x:Key="Ai.Glow.Color">#8B5CF6</Color>
    <Color x:Key="Ai.Text.Color">#C4B5FD</Color>

    <SolidColorBrush x:Key="Ai.Accent.Brush" Color="{StaticResource Ai.Accent.Color}" />
    <SolidColorBrush x:Key="Ai.Glow.Brush"   Color="{StaticResource Ai.Glow.Color}" />
    <SolidColorBrush x:Key="Ai.Text.Brush"   Color="{StaticResource Ai.Text.Color}" />
    <SolidColorBrush x:Key="Ai.Soft"         Color="#268B5CF6" />

    <LinearGradientBrush x:Key="Gradient.Ai" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#7C3AED" Offset="0" />
        <GradientStop Color="#A855F7" Offset="0.5" />
        <GradientStop Color="#22D3EE" Offset="1" />
    </LinearGradientBrush>
    <!-- Translucent glass wash for AI panels — lets the surface beneath ghost through. -->
    <LinearGradientBrush x:Key="Gradient.AiGlass" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2E7C3AED" Offset="0" />
        <GradientStop Color="#1F22D3EE" Offset="1" />
    </LinearGradientBrush>

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════
         MahApps accent override (electric blue). Lives in the palette so a hot-swap re-skins
         every MahApps accent surface (selection, focus ring, checkbox tick, toggle, tab
         underline, progress bar, scrollbar thumb). White ideal foreground on the blue accent.
         ═══════════════════════════════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="MahApps.Brushes.Accent"  Color="{StaticResource Accent.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent2" Color="#3D74FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent3" Color="{StaticResource Accent.Dim.Color}" />
    <SolidColorBrush x:Key="MahApps.Brushes.Accent4" Color="#802962FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.Highlight" Color="#1E53E5" />
    <SolidColorBrush x:Key="MahApps.Brushes.AccentBase" Color="{StaticResource Accent.Color}" />
    <Color x:Key="MahApps.Colors.Accent">#2962FF</Color>
    <Color x:Key="MahApps.Colors.Highlight">#1E53E5</Color>
    <Color x:Key="MahApps.Colors.IdealForeground">#FFFFFF</Color>
    <SolidColorBrush x:Key="MahApps.Brushes.IdealForeground" Color="#FFFFFF" />

    <!-- Menus, context menus, window titles, DataGrid selection — MahApps templates read these
         via DynamicResource; without pinning them the dropdowns stay MahApps-native black and
         ignore the theme. Key names verified against MahApps.Metro 2.4.10 Dark.Blue.xaml. -->
    <SolidColorBrush x:Key="MahApps.Brushes.Menu.Background" Color="#161A24" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.Background" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.SubMenu.Background" Color="#262B38" />
    <SolidColorBrush x:Key="MahApps.Brushes.SubMenu.Border" Color="#3A404E" />
    <SolidColorBrush x:Key="MahApps.Brushes.ContextMenu.Background" Color="#262B38" />
    <SolidColorBrush x:Key="MahApps.Brushes.ContextMenu.Border" Color="#3A404E" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.SelectionFill" Color="#262962FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.SelectionStroke" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.TopMenuItem.PressedFill" Color="#2A2E39" />
    <SolidColorBrush x:Key="MahApps.Brushes.TopMenuItem.PressedStroke" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.TopMenuItem.SelectionStroke" Color="Transparent" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.Foreground.Disabled" Color="#50535E" />
    <SolidColorBrush x:Key="MahApps.Brushes.MenuItem.GlyphPanel.Disabled" Color="#50535E" />
    <SolidColorBrush x:Key="MahApps.Brushes.Separator" Color="#2A2E39" />
    <SolidColorBrush x:Key="MahApps.Brushes.WindowTitle" Color="#161A24" />
    <SolidColorBrush x:Key="MahApps.Brushes.WindowTitle.NonActive" Color="#131722" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Background" Color="#262962FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Background.MouseOver" Color="#332962FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Background.Inactive" Color="#1A2962FF" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Text" Color="#D1D4DC" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Text.MouseOver" Color="#D1D4DC" />
    <SolidColorBrush x:Key="MahApps.Brushes.DataGrid.Selection.Text.Inactive" Color="#D1D4DC" />

</ResourceDictionary>
