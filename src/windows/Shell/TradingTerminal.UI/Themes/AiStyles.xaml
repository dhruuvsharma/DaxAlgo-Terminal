<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===================================================================================
         AI-NATIVE VISUAL LANGUAGE — structural layer, theme-agnostic. Every AI-powered feature
         (Vibe Quant, Paper Lab, chart-ML predictors, AI providers) is marked with this shared
         violet→cyan language: gradient badges, glass panels, glow, and a slowly sweeping
         gradient border. Solid fills / text / soft washes come from the palette's Ai.* tokens
         (Theme-Studio-editable); the ANIMATED sweep brushes inside templates use fixed brand
         hues — animating a freezable requires a per-instance, non-DynamicResource brush, and
         the AI signature is intentionally constant across themes.

         Perf notes: sweeps run at 24 fps on 1–2 on-screen elements; glow is a small-radius
         DropShadowEffect on single Borders (never inside virtualized list rows).
         =================================================================================== -->

    <!-- ===== AI badge: small gradient tag, e.g. next to a feature title. Sharp like the rest
         of the app — rounding is sanctioned only INSIDE the Vibe Quant window (the hero button
         below + everything in VibeQuantStyles.xaml, issue #29). ===== -->
    <Style x:Key="Ai.Badge" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.Ai}" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>
    <Style x:Key="Ai.BadgeText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Drop-in MenuItem.Icon chip (x:Shared=False → each menu item gets its own instance):
         <MenuItem.Icon><StaticResource ResourceKey="Ai.MenuIconChip" /></MenuItem.Icon> -->
    <Border x:Key="Ai.MenuIconChip" x:Shared="False"
            Style="{StaticResource Ai.Badge}" Padding="4,0"
            HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Style="{StaticResource Ai.BadgeText}" Text="AI" FontSize="8" />
    </Border>

    <!-- Gradient-ink text for AI feature titles / links. -->
    <Style x:Key="Ai.TextAccent" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Gradient.Ai}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Soft AI pill — same geometry as the catalog's tag pills (radius 3), violet family.
         Used for the research-paper tag and the AI-NATIVE brand chip. -->
    <Style x:Key="Ai.Pill" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Ai.Soft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Ai.Accent.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="5,1" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ===== Static glass card: translucent violet→cyan wash + gradient hairline + soft glow.
         Drop on any Border wrapping AI content (settings groups, result panes). ===== -->
    <Style x:Key="Ai.GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Gradient.AiGlass}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Gradient.Ai}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#8B5CF6" BlurRadius="18" ShadowDepth="0" Opacity="0.30" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Animated glass panel: same glass, but the gradient border sweeps slowly around
         the panel forever. Wrap content in a ContentControl with this style. ===== -->
    <Style x:Key="Ai.GlassPanel" TargetType="ContentControl">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border CornerRadius="0" BorderThickness="1.2"
                            Background="{DynamicResource Gradient.AiGlass}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <LinearGradientBrush.RelativeTransform>
                                    <RotateTransform x:Name="GlassSweep" CenterX="0.5" CenterY="0.5" Angle="0" />
                                </LinearGradientBrush.RelativeTransform>
                                <GradientStop Color="#7C3AED" Offset="0" />
                                <GradientStop Color="#A855F7" Offset="0.5" />
                                <GradientStop Color="#22D3EE" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#8B5CF6" BlurRadius="18" ShadowDepth="0" Opacity="0.30" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlassSweep"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:10"
                                                     RepeatBehavior="Forever"
                                                     Timeline.DesiredFrameRate="24" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Hero button — the flagship AI entry point (the floating Vibe Quant button).
         Glass over an elevated backing (text stays legible on every theme), sweeping gradient
         ring, violet glow that breathes up on hover, gentle press scale. ===== -->
    <Style x:Key="Ai.HeroButton" TargetType="Button">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{DynamicResource Text.Primary}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="HeroZoom" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <!-- backing: keeps content readable over any catalog content beneath -->
                        <Border CornerRadius="24" Opacity="0.86"
                                Background="{DynamicResource Background.Elevated}">
                            <Border.Effect>
                                <DropShadowEffect x:Name="HeroGlow" Color="#8B5CF6"
                                                  BlurRadius="26" ShadowDepth="0" Opacity="0.55" />
                            </Border.Effect>
                        </Border>
                        <!-- glass fill + sweeping gradient ring -->
                        <Border CornerRadius="24" BorderThickness="1.5" Padding="18,11"
                                Background="{DynamicResource Gradient.AiGlass}"
                                SnapsToDevicePixels="True">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <LinearGradientBrush.RelativeTransform>
                                        <RotateTransform x:Name="HeroSweep" CenterX="0.5" CenterY="0.5" Angle="0" />
                                    </LinearGradientBrush.RelativeTransform>
                                    <GradientStop Color="#7C3AED" Offset="0" />
                                    <GradientStop Color="#A855F7" Offset="0.5" />
                                    <GradientStop Color="#22D3EE" Offset="1" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HeroSweep"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360" Duration="0:0:8"
                                                     RepeatBehavior="Forever"
                                                     Timeline.DesiredFrameRate="24" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HeroGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.95" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleX"
                                                         To="1.03" Duration="0:0:0.15" />
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleY"
                                                         To="1.03" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HeroGlow" Storyboard.TargetProperty="Opacity"
                                                         To="0.55" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleX"
                                                         To="0.97" Duration="0:0:0.05" />
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleY"
                                                         To="0.97" Duration="0:0:0.05" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="HeroZoom" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
