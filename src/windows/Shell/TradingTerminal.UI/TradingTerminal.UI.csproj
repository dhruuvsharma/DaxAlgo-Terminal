<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <UseWPF>true</UseWPF>
    <Description>Shared UI primitives: ViewModelBase, dark theme, controls.</Description>
  </PropertyGroup>

  <!-- NuGet contract package in the plugin-SDK dependency chain (DaxAlgo.Sdk.Wpf depends on this).
       Versioned in lockstep with the SDK (DaxAlgoSdkVersion), NOT the app release version.
       AGPL-3.0 — only the DaxAlgo.Sdk* facades are MIT. -->
  <PropertyGroup>
    <Version>$(DaxAlgoSdkVersion)</Version>
    <PackageLicenseExpression>AGPL-3.0-only</PackageLicenseExpression>
    <PackageTags>daxalgo;trading;plugin;sdk;contract;wpf</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\windows\Core\TradingTerminal.Core\TradingTerminal.Core.csproj" />
    <!-- Portable VM layer (ViewModelBase, live-strategy VM bases, Activity Log sink, â€¦) shared
         with the Avalonia head. Brings CommunityToolkit.Mvvm / Logging.Abstractions / Reactive
         transitively, so they're not repeated below. -->
    <ProjectReference Include="..\..\..\windows\UI\TradingTerminal.UI.Core\TradingTerminal.UI.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- AvalonEdit (MIT) backs the Vibe Quant workbench editor (Controls/CodeEditor). It rides the
         SDK contract chain like everything else in this package — small and license-compatible. -->
    <PackageReference Include="AvalonEdit" Version="6.3.0.90" />
    <PackageReference Include="MahApps.Metro" Version="2.4.10" />
    <PackageReference Include="ScottPlot.WPF" Version="5.0.55" />
  </ItemGroup>

  <ItemGroup>
    <!-- The editor's theme-neutral C# highlighting (colors legible on dark AND light surfaces). -->
    <EmbeddedResource Include="Controls\CSharpVibeQuant.xshd" />
  </ItemGroup>

  <!-- Brand marks, linked from the repo-root assets folder (the single source of truth) so every
       edition shell and this library render the SAME high-res logo. The per-shell .ico is a 32px
       app/window icon — upscaling it onto a catalog tile is what made the mark look pixelated. -->
  <ItemGroup>
    <Resource Include="..\..\..\..\assets\DaxAlgoLogo-BackgroundLess.png" Link="Assets\DaxAlgoLogo-BackgroundLess.png" />
    <Resource Include="..\..\..\..\assets\DaxAlgoLogo.png" Link="Assets\DaxAlgoLogo.png" />
  </ItemGroup>

  <ItemGroup>
    <Page Update="Themes\Brushes.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Themes\Dark.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
    <Page Update="Themes\StrategyShellStyles.xaml">
      <Generator>MSBuild:Compile</Generator>
      <SubType>Designer</SubType>
    </Page>
  </ItemGroup>

</Project>
