<UserControl x:Class="TradingTerminal.App.Notifications.NotificationsSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}"
             d:DesignHeight="500" d:DesignWidth="600">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Notifications"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,4" />
            <TextBlock Text="Send strategy signals to Telegram and/or a Discord channel. Each transport is independent — enable either, both, or neither."
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16" />

            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16"
                    Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Telegram"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <CheckBox Content="Enabled"
                              IsChecked="{Binding TelegramEnabled, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <TextBlock Text="Bot token" Margin="0,0,0,4" />
                    <TextBox Text="{Binding TelegramBotToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Chat ID  (numeric for users/groups, or @channelname)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding TelegramChatId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <CheckBox Content="Also send idle (unarmed) signals"
                              IsChecked="{Binding IncludeIdleSignals, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Discord"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <CheckBox Content="Enabled"
                              IsChecked="{Binding DiscordEnabled, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <TextBlock Text="Webhook URL  (Edit Channel → Integrations → Webhooks → Copy URL)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding DiscordWebhookUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Username override (optional)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding DiscordUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <CheckBox Content="Also send idle (unarmed) signals"
                              IsChecked="{Binding DiscordIncludeIdleSignals, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Local LLM commentary (Ollama)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Adds a one-line LLM commentary to every signal notification, generated by a local Ollama instance (ollama.ai). Free, runs entirely on your machine, no API key. Skipped silently when unreachable."
                               Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />

                    <CheckBox Content="Enabled"
                              IsChecked="{Binding OllamaEnabled, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <TextBlock Text="Endpoint  (default Ollama is http://localhost:11434)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding OllamaEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Model tag  (e.g. llama3.2, phi3.5, mistral — must be `ollama pull`-ed first)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding OllamaModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Timeout (seconds)  — keep ≤ 5 so a slow LLM doesn't backlog the dispatcher" Margin="0,0,0,4" />
                    <TextBox Text="{Binding OllamaTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="System prompt  (optional — overrides the built-in concise-annotator prompt)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding OllamaSystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             Height="60"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource Border.Brush}"
                    BorderThickness="1"
                    CornerRadius="0"
                    Padding="16"
                    Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="AI Market Analyst (cloud LLM)"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <TextBlock Text="Runs a multi-agent LangGraph analyst (indicator → pattern → trend → decision) through a local Python sidecar. Bring your own API key for OpenAI / Anthropic / Qwen / MiniMax. The key is stored DPAPI-encrypted on disk, never in plain JSON."
                               Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />

                    <CheckBox Content="Enabled"
                              IsChecked="{Binding AiAnalystEnabled, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <TextBlock Text="Sidecar endpoint  (default http://127.0.0.1:8765)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding AiAnalystEndpoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Provider" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AiAnalystProviders}"
                              SelectedItem="{Binding AiAnalystProvider, Mode=TwoWay}"
                              Margin="0,0,0,12" />

                    <TextBlock Text="API key  (stored DPAPI-encrypted under %LOCALAPPDATA%; never in appsettings.json)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding AiAnalystApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Text/reasoning model  (e.g. gpt-4o, claude-3-5-sonnet, qwen-max)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding AiAnalystModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <TextBlock Text="Vision model  (used by the pattern + trend agents)" Margin="0,0,0,4" />
                    <TextBox Text="{Binding AiAnalystVisionModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Consolas"
                             Margin="0,0,0,12" />

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Bar count per run" Margin="0,0,0,4" />
                            <TextBox Text="{Binding AiAnalystBarCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Per-run timeout (seconds)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding AiAnalystTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" />
                        </StackPanel>
                    </Grid>

                    <CheckBox Content="Append the AI Analyst verdict line to every signal notification"
                              IsChecked="{Binding AiAnalystIncludeInEnricher, Mode=TwoWay}"
                              ToolTip="When enabled, Telegram/Discord signals carry an extra line like '🤖 AI Analyst: Long (conf 72%, R:R 2.1) — Bull Flag'." />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Margin="0,16,0,0">
                <Button Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="16,6"
                        Margin="0,0,8,0" />
                <Button Content="Send test"
                        Command="{Binding SendTestCommand}"
                        Padding="16,6" />
            </StackPanel>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource Text.Secondary}"
                       TextWrapping="Wrap"
                       Margin="0,12,0,0"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
