<UserControl x:Class="TradingTerminal.Ai.MarketAnalyst.AiAnalystView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top: controls -->
        <Border Grid.Row="0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Symbol" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Text="{Binding SelectedSymbol, UpdateSourceTrigger=PropertyChanged}"
                         MinWidth="100" Margin="0,0,12,0" />

                <TextBlock Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox ItemsSource="{Binding Timeframes}"
                          SelectedItem="{Binding SelectedTimeframe}"
                          MinWidth="80" Margin="0,0,12,0" />

                <TextBlock Text="Bars" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Text="{Binding BarCount}" MinWidth="60" Margin="0,0,12,0" />

                <Button Content="Analyze"
                        Command="{Binding AnalyzeCommand}"
                        IsEnabled="{Binding IsAvailable}"
                        Padding="12,4" Margin="0,0,6,0"
                        ToolTip="Fetches recent bars from the active broker and runs the AI analyst graph." />
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsRunning}"
                        Padding="12,4" Margin="0,0,6,0" />
                <Button Content="Clear history"
                        Command="{Binding ClearHistoryCommand}"
                        Padding="12,4" Margin="0,0,12,0" />

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource Danger.Brush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Middle: three columns (indicator / pattern / trend) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Indicator -->
            <Border Grid.Column="0" Margin="0,0,4,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                    Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Indicators"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="0,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding LatestReport.Indicator.Summary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding LatestReport.Indicator.Values}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,1,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Key}"
                                                       Foreground="{DynamicResource Text.Secondary}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value, StringFormat=F4}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Pattern -->
            <Border Grid.Column="1" Margin="2,0,2,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                    Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Pattern"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="0,0,0,8" />
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding LatestReport.Pattern.PatternName}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LatestReport.Pattern.Confidence, StringFormat='conf {0:P0}'}"
                                   Foreground="{DynamicResource Text.Secondary}" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding LatestReport.Pattern.Reasoning}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Text.Secondary}"
                               Margin="0,4,0,8" />
                    <Image Source="{Binding LatestReport.PatternChartPngBase64,
                                            Converter={StaticResource Base64ToImageSourceConverter}}"
                           Stretch="Uniform" />
                </DockPanel>
            </Border>

            <!-- Trend -->
            <Border Grid.Column="2" Margin="4,0,0,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                    Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Trend"
                               FontWeight="SemiBold" FontSize="14"
                               Margin="0,0,0,8" />
                    <Grid DockPanel.Dock="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding LatestReport.Trend.Direction}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LatestReport.Trend.Slope, StringFormat='slope {0:F4}'}"
                                   Foreground="{DynamicResource Text.Secondary}" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding LatestReport.Trend.Reasoning}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource Text.Secondary}"
                               Margin="0,4,0,8" />
                    <Image Source="{Binding LatestReport.TrendChartPngBase64,
                                            Converter={StaticResource Base64ToImageSourceConverter}}"
                           Stretch="Uniform" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- Bottom: verdict strip -->
        <Border Grid.Row="2" Margin="0,8,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Verdict badge -->
                <Border Grid.Column="0" Padding="14,8" CornerRadius="3" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource Background.Elevated}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LatestReport.Decision}" Value="Long">
                                    <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding LatestReport.Decision}" Value="Short">
                                    <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding LatestReport.Decision}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#1E1E1E" />
                </Border>

                <!-- Justification + numbers -->
                <StackPanel Grid.Column="1" Margin="14,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LatestReport.Justification}"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Foreground="{DynamicResource Text.Secondary}">
                            <Run Text="Horizon:" />
                            <Run Text="{Binding LatestReport.ForecastHorizon}" />
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" Margin="14,0,0,0">
                            <Run Text="R:R" />
                            <Run Text="{Binding LatestReport.RiskRewardRatio, StringFormat=F2}" />
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" Margin="14,0,0,0">
                            <Run Text="Confidence" />
                            <Run Text="{Binding LatestReport.Confidence, StringFormat=P0}" />
                        </TextBlock>
                        <TextBlock Foreground="{DynamicResource Text.Secondary}" Margin="14,0,0,0">
                            <Run Text="Elapsed" />
                            <Run Text="{Binding LatestReport.ElapsedMs}" />
                            <Run Text="ms" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- Activity indicator -->
                <mah:ProgressRing xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                                  Grid.Column="2"
                                  IsActive="{Binding IsRunning}"
                                  Width="32" Height="32"
                                  VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
