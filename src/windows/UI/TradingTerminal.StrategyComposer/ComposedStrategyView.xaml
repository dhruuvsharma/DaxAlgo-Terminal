<UserControl x:Class="TradingTerminal.StrategyComposer.ComposedStrategyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             xmlns:converters="clr-namespace:TradingTerminal.UI.Converters;assembly=TradingTerminal.UI"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <!-- Self-contained converters: this control is hosted by whatever opens an authored strategy, so it
         must not rely on a shell's App.xaml resource set the way in-tree plugin windows do. -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <!-- ── Setup form (before IsConfigured) — the shared hero chrome, instrument-only: an authored
             view-model's tunables live in its kernel, not in this generic form. ─────────────────── -->
        <uic:StrategySetupHost x:Name="Setup"
                               Visibility="{Binding IsConfigured, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Style="{StaticResource Strategy.SetupFieldLabel}" Text="Instrument" />
                <uic:InstrumentPicker SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                      ItemsSource="{Binding Instruments}"
                                      SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                      Margin="0,0,0,16" />

                <Border Style="{StaticResource Strategy.SetupErrorBanner}"
                        Visibility="{Binding ValidationError, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding ValidationError}" Foreground="White" TextWrapping="Wrap" />
                </Border>

                <Button Content="Continue" Command="{Binding ContinueCommand}" HorizontalAlignment="Right"
                        IsDefault="True" MinWidth="120"
                        Style="{DynamicResource MahApps.Styles.Button.Square.Accent}" />
            </StackPanel>
        </uic:StrategySetupHost>

        <!-- ── Runtime dashboard ────────────────────────────────────────────────────────────────── -->
        <DockPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">

            <!-- Param strip: stream controls + arm/disarm + the shared chrome bar. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.ParamStrip}">
                <DockPanel>
                    <uic:StrategyChromeBar x:Name="Chrome" DockPanel.Dock="Right"
                                           HelpTitle="READING THIS WINDOW" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="STREAM" Style="{StaticResource Strategy.ParamGroupLabel}" />
                            <Button Content="■ Stop" Command="{Binding StopCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                    Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button Content="▶ Start" Command="{Binding StartCommand}" VerticalAlignment="Center" Padding="10,3" Margin="0,0,6,0"
                                    Visibility="{Binding IsStreaming, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            <Button Command="{Binding ToggleAlgoCommand}" Style="{StaticResource Strategy.RunStopButton}"
                                    VerticalAlignment="Center" Margin="0,0,6,0" />
                            <Border Style="{StaticResource Strategy.ParamDivider}" />
                            <Border Background="{DynamicResource Background.Tertiary}" CornerRadius="0"
                                    Padding="8,2" VerticalAlignment="Center" ToolTip="This strategy shipped no view of its own; the host composed this window from its declared data requirement.">
                                <TextBlock Text="AI-AUTHORED · COMPOSED WINDOW" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Text.Secondary}" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Header bar: what it trades + the live quote + status. -->
            <Border DockPanel.Dock="Top" Style="{StaticResource Strategy.HeaderBar}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Symbol:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="Bid:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding LastBid, StringFormat=0.#####, FallbackValue=—, TargetNullValue=—}" Margin="6,0,12,0" />
                    <TextBlock Text="Ask:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding LastAsk, StringFormat=0.#####, FallbackValue=—, TargetNullValue=—}" Margin="6,0,12,0" />
                    <TextBlock Text="Mid:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding LastMid, StringFormat=0.#####, FallbackValue=—, TargetNullValue=—}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    <TextBlock Text="Ticks:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding TicksSeen, StringFormat=N0}" Margin="6,0,16,0" />
                    <StackPanel x:Name="TapeStat" Orientation="Horizontal">
                        <TextBlock Text="Tape:" Style="{StaticResource Strategy.DashLabel}" />
                        <TextBlock Text="{Binding TradeTapeAvailable}" Margin="6,0,16,0" FontWeight="SemiBold" />
                    </StackPanel>
                    <TextBlock Margin="12,0,0,0" Foreground="{DynamicResource Text.Secondary}" Text="{Binding Status}" />
                </StackPanel>
            </Border>

            <!-- Footer: counts + state pills. -->
            <Border DockPanel.Dock="Bottom" Style="{StaticResource Strategy.FooterBar}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Signals:" Style="{StaticResource Strategy.DashLabel}" />
                    <TextBlock Text="{Binding Signals.Count}" Margin="6,0,0,0" Style="{StaticResource Strategy.DashValue}" />
                    <TextBlock Margin="20,0,0,0" Foreground="{DynamicResource Warning.Brush}" FontWeight="SemiBold"
                               Visibility="{Binding IsAlgoRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Text="● ALGO ARMED" />
                    <Border Style="{StaticResource Pill.Warn}" Margin="16,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding IsPaused, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="⏸ PAUSED" FontSize="10" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Signal feed: every entry the kernel emitted through the signal router, newest last. -->
            <Border DockPanel.Dock="Bottom" Height="150" BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource Border.Primary}">
                <ListView ItemsSource="{Binding Signals}" BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          VirtualizingPanel.IsVirtualizing="True">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Time" Width="110" DisplayMemberBinding="{Binding TimeText}" />
                            <GridViewColumn Header="Side" Width="60">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SideText}" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{DynamicResource Bullish.Brush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SideText}" Value="SELL">
                                                            <Setter Property="Foreground" Value="{DynamicResource Bearish.Brush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Type" Width="80" DisplayMemberBinding="{Binding TypeText}" />
                            <GridViewColumn Header="Qty" Width="60" DisplayMemberBinding="{Binding Quantity}" />
                            <GridViewColumn Header="Price" Width="100" DisplayMemberBinding="{Binding Price, StringFormat=0.#####}" />
                            <GridViewColumn Header="Mid" Width="100" DisplayMemberBinding="{Binding Mid, StringFormat=0.#####}" />
                            <GridViewColumn Header="Note" Width="420" DisplayMemberBinding="{Binding Note}" />
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Center: the data panels, composed in code from the descriptor's DataRequirement.
                 An L1-only strategy has no panel to show — the quote card takes the space instead. -->
            <Grid x:Name="PanelHost">
                <StackPanel x:Name="QuoteCard" Visibility="Collapsed"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding SelectedInstrument.DisplayName}" FontSize="22" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <StackPanel Margin="18,0">
                            <TextBlock Text="BID" FontSize="11" Foreground="{DynamicResource Text.Secondary}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LastBid, StringFormat=0.#####, FallbackValue=—, TargetNullValue=—}"
                                       FontSize="30" Foreground="{DynamicResource Bullish.Brush}" />
                        </StackPanel>
                        <StackPanel Margin="18,0">
                            <TextBlock Text="MID" FontSize="11" Foreground="{DynamicResource Text.Secondary}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LastMid, StringFormat=0.#####, FallbackValue=—, TargetNullValue=—}"
                                       FontSize="30" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Margin="18,0">
                            <TextBlock Text="ASK" FontSize="11" Foreground="{DynamicResource Text.Secondary}" HorizontalAlignment="Center" />
                            <TextBlock Text="{Binding LastAsk, StringFormat=0.#####, FallbackValue=—, TargetNullValue=—}"
                                       FontSize="30" Foreground="{DynamicResource Bearish.Brush}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="This strategy consumes L1 quotes only — its signals land in the feed below."
                               Margin="0,14,0,0" FontSize="11.5" Foreground="{DynamicResource Text.Secondary}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </DockPanel>
    </Grid>
</UserControl>
