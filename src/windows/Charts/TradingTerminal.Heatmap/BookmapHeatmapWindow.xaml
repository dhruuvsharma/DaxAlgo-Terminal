<mah:MetroWindow x:Class="TradingTerminal.Heatmap.BookmapHeatmapWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 mc:Ignorable="d"
                 Title="Bookmap + VolBook"
                 Width="1280" Height="820"
                 MinWidth="980" MinHeight="600"
                 TitleCharacterCasing="Normal"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}"
                 d:DesignHeight="820" d:DesignWidth="1280">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- title -->
            <RowDefinition Height="Auto" />   <!-- feature toolbar -->
            <RowDefinition Height="*" />      <!-- body: picker + surface -->
            <RowDefinition Height="Auto" />   <!-- status -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Bookmap + VolBook" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Live microstructure surface — L2 liquidity heatmap (teal bid / red ask, brighter = more resting size), trade dots (green buy / red sell, sized by volume; large lots outlined, refilling icebergs ringed), SVP (session range volume profile, POC + value area), developing VWAP, a CVD panel with per-column delta bars, CAV (cumulative average volume), and COB (the current order-book column) down the right edge, with a hover crosshair. Pause to scrub history; scroll-wheel to zoom price, double-click to reset. Needs L2; volume features need the tape."
                       Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,0" />
        </StackPanel>

        <!-- Feature toolbar -->
        <Border Grid.Row="1" Margin="0,10,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10,6">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Timeframe" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox ItemsSource="{Binding Timeframes}" SelectedItem="{Binding SelectedTimeframe}"
                          DisplayMemberPath="Label" Width="78" Margin="0,0,18,0" VerticalAlignment="Center" />

                <Border Width="1" Margin="0,0,18,0" Background="{DynamicResource Border.Brush}" />

                <CheckBox Content="SVP" IsChecked="{Binding ShowVolumeProfile}" ToolTip="Session Range Volume Profile" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="COB" IsChecked="{Binding ShowOrderBook}" ToolTip="Current Order Book (DOM column)" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="CAV" IsChecked="{Binding ShowCav}" ToolTip="Cumulative Average Volume" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="VWAP" IsChecked="{Binding ShowVwap}" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="Value area" IsChecked="{Binding ShowValueArea}" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="CVD panel" IsChecked="{Binding ShowCvdPanel}" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="Trade dots" IsChecked="{Binding ShowTradeDots}" Margin="0,0,14,0" VerticalAlignment="Center" />
                <CheckBox Content="Large lots / icebergs" IsChecked="{Binding HighlightLargeLots}" Margin="0,0,18,0" VerticalAlignment="Center" />

                <Border Width="1" Margin="0,0,18,0" Background="{DynamicResource Border.Brush}" />

                <ToggleButton Content="⏸ Pause" IsChecked="{Binding IsPaused}" Padding="10,2" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBlock Text="History" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <Slider Width="240" Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1"
                        Value="{Binding ScrubPosition}" IsEnabled="{Binding IsPaused}"
                        VerticalAlignment="Center" Margin="0,0,18,0" />

                <Border Width="1" Margin="0,0,18,0" Background="{DynamicResource Border.Brush}" />

                <TextBlock Text="PRESET" Style="{StaticResource App.GroupLabel}" VerticalAlignment="Center" />
                <ComboBox Width="120" IsEditable="True" VerticalAlignment="Center"
                          ItemsSource="{Binding PresetNames}"
                          SelectedItem="{Binding SelectedPreset}"
                          Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Pick a preset to apply it, or type a new name and press save" />
                <Button Style="{StaticResource App.IconButton}" Margin="6,0,0,0" Content="💾"
                        Command="{Binding SavePresetCommand}"
                        ToolTip="Save the current view options (timeframe + overlay toggles) as a named preset" />
                <Button Style="{StaticResource App.IconButton}" Content="🗑"
                        Command="{Binding DeletePresetCommand}"
                        ToolTip="Delete the selected preset" />
                <Button Style="{StaticResource App.IconButton}" Content="▤"
                        Command="{Binding ExportProfileCsvCommand}"
                        ToolTip="Export the session volume profile (price, buy, sell — with POC / value-area header) as CSV" />
                <Button Style="{StaticResource App.IconButton}" Content="↧"
                        Command="{Binding ExportFlowCsvCommand}"
                        ToolTip="Export the per-column flow series (buy/sell volume, CVD, VWAP, CAV) as CSV" />
                <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                        ToolTip="Save a PNG snapshot of this window" />
                <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?" Margin="0"
                              ToolTip="What am I looking at?" />
            </WrapPanel>
        </Border>

        <!-- Contextual help (anchored to the ? toggle) -->
        <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
               HorizontalOffset="-350" VerticalOffset="6">
            <Border Style="{StaticResource App.Card}" Width="400" Padding="16"
                    Background="{DynamicResource Background.Elevated}">
                <StackPanel>
                    <TextBlock Text="READING BOOKMAP + VOLBOOK" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                        <Run FontWeight="SemiBold" Text="Heatmap" /><Run Text=" — resting L2 size per price row over time (teal bid / red ask, brighter = heavier). Persistent hot bands are walls; bands that vanish as price approaches were likely spoofed." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="Dots" /><Run Text=" — prints sized by volume (green buy / red sell). Outlined = large lot (≥5× mean size); ringed = iceberg (the same price/size refilling repeatedly)." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="SVP / VWAP / value area" /><Run Text=" — the session volume-at-price histogram with POC and the 70% value-area band, plus the developing VWAP track." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="CVD panel" /><Run Text=" — cumulative volume delta with per-column buy/sell bars: divergence between CVD and price flags absorption." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="COB / CAV" /><Run Text=" — the live DOM column down the right edge and the cumulative-average-volume strip." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="Playback" /><Run Text=" — Pause freezes the view and unlocks the History scrub slider over the retained columns; scroll-wheel zooms price, double-click resets." />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Body -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />   <!-- instrument picker -->
                <ColumnDefinition Width="*" />     <!-- surface -->
            </Grid.ColumnDefinitions>

            <!-- Instrument picker -->
            <Border Grid.Column="0" Margin="0,0,12,0"
                    Background="{DynamicResource Background.Surface}"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Instrument" FontWeight="SemiBold" Margin="2,0,0,6" />
                    <TextBox Grid.Row="1"
                             Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                             mah:TextBoxHelper.Watermark="filter symbols…"
                             mah:TextBoxHelper.ClearTextButton="True"
                             Margin="0,0,0,6" />
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Instruments}"
                             SelectedItem="{Binding SelectedInstrument}"
                             DisplayMemberPath="DisplayName"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>

            <!-- Surface: a single immediate-mode element draws the whole view (heatmap bitmap + all
                 overlays + crosshair) through one DrawingContext for performance. -->
            <Border x:Name="SurfaceHost" Grid.Column="1"
                    Background="#0A0A0F"
                    BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                    ClipToBounds="True" />

            <!-- Empty state until the first depth column lands (drawn over the surface host) -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                        MaxWidth="420" IsHitTestVisible="False">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ColumnsFilled}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="▦" FontSize="42" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Text.Secondary}" Opacity="0.5" />
                <TextBlock Text="Awaiting depth" FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,6,0,4"
                           Foreground="{DynamicResource Text.Primary}" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5"
                           Foreground="{DynamicResource Text.Secondary}"
                           Text="The surface fills as L2 snapshots stream in; volume features (SVP, VWAP, CVD, dots) need a trade tape on top. Depth-capable feeds: the keyless crypto tiles (Binance, Bybit, Kraken, OKX, Coinbase), cTrader, Ironbeam and Upstox." />
            </StackPanel>
        </Grid>

        <!-- Status -->
        <Border Grid.Row="3" Margin="0,10,0,0"
                Background="{DynamicResource Background.Surface}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Margin="0,0,16,0">
                    <Run Text="Bid " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding BestBid, StringFormat=N2, TargetNullValue=—}" Foreground="#26A69A" />
                </TextBlock>
                <TextBlock Grid.Column="1" Margin="0,0,16,0">
                    <Run Text="Ask " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding BestAsk, StringFormat=N2, TargetNullValue=—}" Foreground="#EF5350" />
                </TextBlock>
                <TextBlock Grid.Column="2" Margin="0,0,16,0">
                    <Run Text="Mid " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding Mid, StringFormat=N2, TargetNullValue=—}" />
                </TextBlock>
                <TextBlock Grid.Column="3" Margin="0,0,16,0">
                    <Run Text="Spread " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding Spread, StringFormat=N2, TargetNullValue=—}" />
                </TextBlock>
                <TextBlock Grid.Column="4" Margin="0,0,16,0">
                    <Run Text="Last " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding LastPrice, StringFormat=N2, TargetNullValue=—}" />
                </TextBlock>
                <TextBlock Grid.Column="5" Margin="0,0,16,0">
                    <Run Text="VWAP " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding VwapDisplay, StringFormat=N2, TargetNullValue=—}" Foreground="#FFC107" />
                </TextBlock>
                <TextBlock Grid.Column="6" Margin="0,0,16,0">
                    <Run Text="CVD " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding CvdDisplay, StringFormat=N0}" Foreground="#4DD0E1" />
                </TextBlock>
                <TextBlock Grid.Column="7" Margin="0,0,16,0">
                    <Run Text="Vol " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding TotalVolumeDisplay, StringFormat=N0}" />
                </TextBlock>
                <TextBlock Grid.Column="8" Margin="0,0,16,0">
                    <Run Text="CAV " Foreground="{DynamicResource Text.Secondary}" />
                    <Run Text="{Binding CavDisplay, StringFormat=N0}" Foreground="#82B1FF" />
                </TextBlock>
                <TextBlock Grid.Column="9" Text="{Binding Status}"
                           Foreground="{DynamicResource Text.Secondary}"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
