<mah:MetroWindow x:Class="TradingTerminal.OrderBook.OrderBookWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:TradingTerminal.OrderBook"
                 mc:Ignorable="d"
                 Title="Order Book"
                 Height="800" Width="1060"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <!-- The window is a frame: everything it shows lives in OrderBookPanel, which strategy windows
         embed too (with the chrome and the ML switched off). "Full" is what makes this the standalone
         tool: toolbar, analytics, ML forecast, heatmap, ladder, options rail and status line, all on. -->
    <local:OrderBookPanel Features="{x:Static local:OrderBookPanelFeatures.Full}" />
</mah:MetroWindow>
