<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TradingTerminal.OrderBook.AvaloniaUi.OrderBookAvaloniaWindow"
        Width="560" Height="720"
        Background="{StaticResource Background.Primary}"
        Title="Order Book">
  <Window.Resources>
    <SolidColorBrush x:Key="AskBar" Color="#33FF4D4D"/>
    <SolidColorBrush x:Key="BidBar" Color="#3340D060"/>
  </Window.Resources>
  <DockPanel Margin="12">
    <StackPanel DockPanel.Dock="Top" Spacing="6">
      <TextBlock Text="Order Book (L2 depth)" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Text.Header}"/>
      <ComboBox MinWidth="240" ItemsSource="{Binding Instruments}" SelectedItem="{Binding SelectedInstrument}">
        <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding DisplayName}"/></DataTemplate></ComboBox.ItemTemplate>
      </ComboBox>
      <TextBlock Text="{Binding Status}" Foreground="{StaticResource Text.Secondary}" TextWrapping="Wrap"/>
      <UniformGrid Columns="4">
        <TextBlock Text="{Binding BestBid, StringFormat='Bid {0:0.##}'}" Foreground="#40D060"/>
        <TextBlock Text="{Binding BestAsk, StringFormat='Ask {0:0.##}'}" Foreground="#FF4D4D"/>
        <TextBlock Text="{Binding Spread, StringFormat='Spr {0:0.###}'}" Foreground="{StaticResource Text.Secondary}"/>
        <TextBlock Text="{Binding Mid, StringFormat='Mid {0:0.##}'}" Foreground="{StaticResource Text.Primary}"/>
        <TextBlock Text="{Binding Microprice, StringFormat='µPx {0:0.###}'}" Foreground="{StaticResource Text.Secondary}"/>
        <TextBlock Text="{Binding ImbalanceCumText, StringFormat='Imb {0}'}" Foreground="{StaticResource Text.Secondary}"/>
        <TextBlock Text="{Binding BookSkewText, StringFormat='Skew {0}'}" Foreground="{StaticResource Text.Secondary}"/>
        <TextBlock Text="{Binding CumulativeDelta, StringFormat='CVD {0}'}" Foreground="{StaticResource Text.Secondary}"/>
      </UniformGrid>
    </StackPanel>

    <Grid RowDefinitions="*,Auto,*" Margin="0,8,0,0">
      <!-- Asks (top, descending toward the spread) -->
      <Border Grid.Row="0" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <ItemsControl ItemsSource="{Binding Asks}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="80,80,*" Height="20">
                <TextBlock Grid.Column="0" Text="{Binding Price, StringFormat='0.##'}" Foreground="#FF6B6B" Margin="4,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Size}" Foreground="{StaticResource Text.Primary}" Margin="4,0"/>
                <ProgressBar Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding BarFraction}"
                             Foreground="{StaticResource AskBar}" Background="Transparent" Margin="4,2"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <Border Grid.Row="1" Background="{StaticResource Background.Surface}" Padding="4,2">
        <TextBlock Text="{Binding Spread, StringFormat='— spread {0:0.###} —'}" HorizontalAlignment="Center"
                   Foreground="{StaticResource Accent.Brush}"/>
      </Border>

      <!-- Bids (bottom) -->
      <Border Grid.Row="2" BorderBrush="{StaticResource Border.Brush}" BorderThickness="1" CornerRadius="3">
        <ItemsControl ItemsSource="{Binding Bids}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid ColumnDefinitions="80,80,*" Height="20">
                <TextBlock Grid.Column="0" Text="{Binding Price, StringFormat='0.##'}" Foreground="#5BE08A" Margin="4,0"/>
                <TextBlock Grid.Column="1" Text="{Binding Size}" Foreground="{StaticResource Text.Primary}" Margin="4,0"/>
                <ProgressBar Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding BarFraction}"
                             Foreground="{StaticResource BidBar}" Background="Transparent" Margin="4,2"/>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>
    </Grid>
  </DockPanel>
</Window>
