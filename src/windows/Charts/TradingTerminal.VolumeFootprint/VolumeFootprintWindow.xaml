<mah:MetroWindow x:Class="TradingTerminal.VolumeFootprint.VolumeFootprintWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:TradingTerminal.VolumeFootprint"
                 mc:Ignorable="d"
                 Title="Volume Footprint"
                 Height="820" Width="1180"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <!-- The window is a frame: everything it shows lives in VolumeFootprintPanel, which strategy windows
         embed too (usually with the chrome, the fits and the ML switched off). "Full" is what makes this
         the standalone tool: every overlay and forecast on. -->
    <local:VolumeFootprintPanel Features="{x:Static local:VolumeFootprintPanelFeatures.Full}" />
</mah:MetroWindow>
