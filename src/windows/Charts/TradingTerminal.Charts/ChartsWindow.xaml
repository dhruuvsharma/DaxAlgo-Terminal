<mah:MetroWindow x:Class="TradingTerminal.Charts.ChartsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:local="clr-namespace:TradingTerminal.Charts"
                 mc:Ignorable="d"
                 Title="Charts"
                 Height="820" Width="1280"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <!-- The window is a frame: everything it shows lives in ChartsPanel, which strategy windows embed too
         (usually with the chrome off). "Full" is what makes this the standalone tool. -->
    <local:ChartsPanel Features="{x:Static local:ChartsPanelFeatures.Full}" />
</mah:MetroWindow>
