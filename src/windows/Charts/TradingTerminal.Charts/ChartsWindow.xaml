<mah:MetroWindow x:Class="TradingTerminal.Charts.ChartsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
                 mc:Ignorable="d"
                 Title="Charts"
                 Height="820" Width="1280"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: instrument + timeframe + indicator toggles -->
        <Border Grid.Row="0"
                Background="{DynamicResource Background.Elevated}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,0,0,1"
                Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Symbol" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                <TextBox Width="150"
                         Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="Search…"
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,6,0" />
                <ComboBox Width="220"
                          ItemsSource="{Binding Instruments}"
                          SelectedItem="{Binding SelectedInstrument}"
                          DisplayMemberPath="DisplayName"
                          MaxDropDownHeight="420" Margin="0,0,16,0" />

                <TextBlock Text="Timeframe" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                <ComboBox Width="80"
                          ItemsSource="{Binding Timeframes}"
                          SelectedItem="{Binding SelectedTimeframe}"
                          DisplayMemberPath="Label" Margin="0,0,16,0" />

                <CheckBox Content="SMA(20)" IsChecked="{Binding ShowSma}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <CheckBox Content="EMA(50)" IsChecked="{Binding ShowEma}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <CheckBox Content="RSI(14)" IsChecked="{Binding ShowRsi}" VerticalAlignment="Center" Margin="0,0,10,0" />
                <CheckBox Content="MACD"    IsChecked="{Binding ShowMacd}" VerticalAlignment="Center" Margin="0,0,10,0" />
            </StackPanel>
        </Border>

        <wv2:WebView2 Grid.Row="1" x:Name="Web" />

        <Border Grid.Row="2"
                Background="{DynamicResource Background.Elevated}"
                BorderBrush="{DynamicResource Border.Brush}" BorderThickness="0,1,0,0"
                Padding="8,3">
            <TextBlock Text="{Binding Status}" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
        </Border>
    </Grid>
</mah:MetroWindow>
