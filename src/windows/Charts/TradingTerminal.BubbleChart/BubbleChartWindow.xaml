<mah:MetroWindow x:Class="TradingTerminal.BubbleChart.BubbleChartWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
                 mc:Ignorable="d"
                 Title="Bubble Heatmap (experimental — Bookmap style)"
                 Height="760" Width="1180"
                 WindowStartupLocation="CenterOwner"
                 Background="{DynamicResource Background.Primary}"
                 Foreground="{DynamicResource Text.Primary}">
    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </mah:MetroWindow.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar: instrument + time-column width + view toggles + presets/actions. -->
        <Border Grid.Row="0" Style="{StaticResource App.HeaderBar}">
            <Border.Resources>
                <Style x:Key="ToolLabel" TargetType="TextBlock">
                    <Setter Property="Foreground" Value="{DynamicResource Text.Secondary}" />
                    <Setter Property="FontSize" Value="11" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Margin" Value="0,0,6,0" />
                </Style>
            </Border.Resources>
            <DockPanel LastChildFill="True">
                <!-- ── Actions (right): presets · pause · export · help ── -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PRESET" Style="{StaticResource App.GroupLabel}" />
                    <ComboBox Width="110" IsEditable="True"
                              ItemsSource="{Binding PresetNames}"
                              SelectedItem="{Binding SelectedPreset}"
                              Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}"
                              ToolTip="Pick a preset to apply it, or type a new name and press save" />
                    <Button Style="{StaticResource App.IconButton}" Margin="6,0,0,0" Content="💾"
                            Command="{Binding SavePresetCommand}"
                            ToolTip="Save the current view options as a named preset" />
                    <Button Style="{StaticResource App.IconButton}" Content="🗑"
                            Command="{Binding DeletePresetCommand}"
                            ToolTip="Delete the selected preset" />
                    <ToggleButton Style="{StaticResource App.IconToggle}" Content="⏸"
                                  IsChecked="{Binding IsPaused}"
                                  ToolTip="Pause the display — the book and tape keep rolling underneath, resume is instant" />
                    <Button Style="{StaticResource App.IconButton}" Content="◍"
                            Command="{Binding ExportTradesCsvCommand}"
                            ToolTip="Export the recent prints (time, price, size, side, large-lot flag) as CSV" />
                    <Button Style="{StaticResource App.IconButton}" Content="↧"
                            Command="{Binding ExportBookCsvCommand}"
                            ToolTip="Export the column series (time, best bid, best ask) as CSV" />
                    <Button Style="{StaticResource App.IconButton}" Content="📷" Click="ExportPng_Click"
                            ToolTip="Save a PNG snapshot of this window" />
                    <ToggleButton x:Name="HelpToggle" Style="{StaticResource App.IconToggle}" Content="?" Margin="0"
                                  ToolTip="What am I looking at?" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Instrument" Style="{StaticResource ToolLabel}" />
                    <uic:InstrumentPicker Width="260"
                                          ShowSearch="True"
                                          ItemsSource="{Binding Instruments}"
                                          SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                          SearchText="{Binding InstrumentSearchText, Mode=TwoWay}"
                                          MaxDropDownHeight="460" Margin="0,0,12,0" />

                    <TextBlock Text="Column" Style="{StaticResource ToolLabel}" />
                    <ComboBox Width="84" VerticalAlignment="Center"
                              ItemsSource="{Binding Timeframes}"
                              SelectedItem="{Binding SelectedTimeframe}"
                              DisplayMemberPath="Label" />

                    <TextBlock Text="Window" Style="{StaticResource ToolLabel}" Margin="12,0,6,0" />
                    <ComboBox Width="70" VerticalAlignment="Center"
                              ItemsSource="{Binding RetainedOptions}"
                              SelectedItem="{Binding RetainedColumns}"
                              ToolTip="Columns of history kept and drawn" />

                    <Border Width="1" Background="{DynamicResource Border.Brush}" Margin="14,3" />
                    <CheckBox Content="Bubbles" IsChecked="{Binding ShowBubbles}" VerticalAlignment="Center"
                              Margin="0,0,10,0" />
                    <CheckBox Content="Large lots only" IsChecked="{Binding LargeOnly}" VerticalAlignment="Center"
                              ToolTip="Show only prints ≥5× the rolling mean size" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Contextual help (anchored to the ? toggle) -->
        <Popup PlacementTarget="{Binding ElementName=HelpToggle}" Placement="Bottom"
               IsOpen="{Binding IsChecked, ElementName=HelpToggle}" AllowsTransparency="True"
               HorizontalOffset="-330" VerticalOffset="6">
            <Border Style="{StaticResource App.Card}" Width="380" Padding="16"
                    Background="{DynamicResource Background.Elevated}">
                <StackPanel>
                    <TextBlock Text="READING THE BUBBLE HEATMAP" Style="{StaticResource App.SectionHeader}" Margin="0,0,0,8" />
                    <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="{DynamicResource Text.Primary}" LineHeight="17">
                        <Run FontWeight="SemiBold" Text="Heatmap" /><Run Text=" — time × price resting L2 liquidity: dark = thin, blue → teal → yellow → red = increasingly heavy resting size. Walls show up as hot horizontal bands; pulls/refills as bands appearing and vanishing." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="Bubbles" /><Run Text=" — executed prints, sized by volume: green = aggressive buying, red = aggressive selling. Watch for big bubbles landing ON a hot band — absorption — versus bands vanishing before price arrives — spoofy liquidity." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="Large lots" /><Run Text=" — white-ringed bubbles are prints ≥5× the rolling mean size; the large-lots-only toggle isolates them." /><LineBreak />
                        <Run FontWeight="SemiBold" Text="Column" /><Run Text=" — the wall-clock width of one heatmap column; smaller = finer time resolution, larger = more history on screen." />
                    </TextBlock>
                </StackPanel>
            </Border>
        </Popup>

        <!-- The HeatmapBubbleSurface is inserted into this grid in code-behind (avoids the
             same-assembly XAML MC3074 issue), behind the floating read-out. -->
        <Grid Grid.Row="1" x:Name="ChartArea">
            <!-- Empty state: no columns yet (either still connecting, or the broker has no L2) -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="400"
                        IsHitTestVisible="False">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ColumnsFilled}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="◉" FontSize="42" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Text.Secondary}" Opacity="0.5" />
                <TextBlock Text="Awaiting depth" FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,6,0,4"
                           Foreground="{DynamicResource Text.Primary}" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="11.5"
                           Foreground="{DynamicResource Text.Secondary}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="The liquidity heatmap fills as L2 snapshots stream in — give it a few columns." />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NoDepth}" Value="True">
                                    <Setter Property="Text" Value="This broker serves no L2 depth, so the heatmap stays empty. Pick a depth-capable feed — the keyless crypto tiles (Binance, Bybit, Kraken, OKX, Coinbase), cTrader, Ironbeam or Upstox." />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,18,0"
                    Background="#E6121620" Opacity="0.96"
                    BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4"
                    Padding="11,8" MinWidth="184">
                <Border.Resources>
                    <Style x:Key="Lbl" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#9E9E9E" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="Margin" Value="0,1,14,1" />
                    </Style>
                    <Style x:Key="Val" TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#E0E0E0" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="FontFamily" Value="Consolas" />
                        <Setter Property="TextAlignment" Value="Right" />
                        <Setter Property="Margin" Value="0,1,0,1" />
                    </Style>
                </Border.Resources>
                <StackPanel>
                    <TextBlock Text="BOOKMAP" FontSize="10" FontWeight="SemiBold" Foreground="#9E9E9E" Margin="0,0,0,6" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Best ask" Style="{StaticResource Lbl}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding BestAsk, StringFormat=N2, TargetNullValue=—}" Style="{StaticResource Val}" Foreground="#FF5A57" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Best bid" Style="{StaticResource Lbl}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BestBid, StringFormat=N2, TargetNullValue=—}" Style="{StaticResource Val}" Foreground="#3DD98A" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Last" Style="{StaticResource Lbl}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastPrice, StringFormat=N2, TargetNullValue=—}" Style="{StaticResource Val}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Trades" Style="{StaticResource Lbl}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TradeCount}" Style="{StaticResource Val}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Columns" Style="{StaticResource Lbl}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ColumnsFilled}" Style="{StaticResource Val}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Legend + status -->
        <Border Grid.Row="2" Style="{StaticResource App.FooterBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="liquidity" FontSize="11" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <Border Width="120" Height="11" VerticalAlignment="Center" Margin="0,0,4,0" BorderBrush="#33FFFFFF" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#0A0C1A" />
                                <GradientStop Offset="0.36" Color="#166EC8" />
                                <GradientStop Offset="0.56" Color="#16C0B0" />
                                <GradientStop Offset="0.72" Color="#D8CC28" />
                                <GradientStop Offset="1" Color="#F63B32" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="thin → heavy" FontSize="11" Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center" Margin="0,0,14,0" />
                    <Ellipse Width="11" Height="11" Fill="#E63DD98A" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="buy" FontSize="11" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,10,0" />
                    <Ellipse Width="11" Height="11" Fill="#E6FF5A57" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="sell" FontSize="11" Foreground="{DynamicResource Text.Secondary}" Margin="0,0,10,0" />
                    <Ellipse Width="11" Height="11" Fill="#552A2A2A" Stroke="#FFFFFF" StrokeThickness="1.4" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBlock Text="large print · size = volume" FontSize="11" Foreground="{DynamicResource Text.Secondary}" />
                </StackPanel>
                <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="11"
                           Foreground="{DynamicResource Text.Secondary}" VerticalAlignment="Center"
                           TextAlignment="Right" />
                <Border Grid.Column="2" Style="{StaticResource Pill.Warn}" Margin="8,0,0,0"
                        Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏸ PAUSED" FontSize="10" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</mah:MetroWindow>
