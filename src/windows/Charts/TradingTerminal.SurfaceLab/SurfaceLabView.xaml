<UserControl x:Class="TradingTerminal.SurfaceLab.SurfaceLabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:helix="http://helix-toolkit.org/wpf"
             xmlns:sp="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             xmlns:uic="clr-namespace:TradingTerminal.UI.Controls;assembly=TradingTerminal.UI"
             xmlns:local="clr-namespace:TradingTerminal.SurfaceLab"
             mc:Ignorable="d"
             d:DesignHeight="820" d:DesignWidth="1500"
             Background="{DynamicResource Background.Primary}"
             Foreground="{DynamicResource Text.Primary}">

    <UserControl.Resources>
        <!-- One reusable editor for all four axes: searchable grouped dropdown, range inputs
             (parameter sweeps / linear bins only), and the custom formula bar on Z / Color. -->
        <DataTemplate x:Key="AxisEditorTemplate">
            <StackPanel Margin="0,4,0,2">
                <StackPanel.Resources>
                    <CollectionViewSource x:Key="AxisOptions" Source="{Binding Options}">
                        <CollectionViewSource.GroupDescriptions>
                            <PropertyGroupDescription PropertyName="Category" />
                        </CollectionViewSource.GroupDescriptions>
                    </CollectionViewSource>
                </StackPanel.Resources>

                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="search variables…"
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,0,6" />

                <ComboBox ItemsSource="{Binding Source={StaticResource AxisOptions}}"
                          SelectedItem="{Binding SelectedOption}"
                          MaxDropDownHeight="420"
                          Margin="0,0,0,6">
                    <ComboBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource Accent.Brush}"
                                               Margin="4,6,0,2" />
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ComboBox.GroupStyle>
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Grid Visibility="{Binding IsRangeEditable, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Min" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Max" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Step" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                    <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Min, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Max, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding Step, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <StackPanel Visibility="{Binding SupportsFormula, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBox Text="{Binding CustomFormula, UpdateSourceTrigger=PropertyChanged, Delay=200}"
                             mah:TextBoxHelper.Watermark="custom formula (overrides metric)…"
                             mah:TextBoxHelper.ClearTextButton="True"
                             FontFamily="Consolas, Cascadia Mono, monospace" />
                    <TextBlock Text="Operators + − * / ^ · Log() Exp() Sqrt() Abs() Max() Min() Avg() Sum() · variables are statistic ids (avgret, medret, stdret, count, probup, vol, var95, var99, cvar95, skew, kurtosis, zscore, npdf, ncdf, autocorr1, amihud)"
                               FontSize="10" Foreground="{DynamicResource Text.Secondary}"
                               TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="330" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="390" />
        </Grid.ColumnDefinitions>

        <!-- ══ Left: configuration ══════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource Background.Surface}">
            <StackPanel Margin="12">
                <TextBlock Text="3D Surface Lab" FontSize="17" FontWeight="SemiBold" />
                <TextBlock Text="Seasonality and cross-sectional return-statistics surfaces — one-shot over history, or live on streaming market data."
                           Foreground="{DynamicResource Text.Secondary}" TextWrapping="Wrap" Margin="0,2,0,10" />

                <TextBlock Text="SURFACE MODE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Brush}" Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding Modes}"
                          SelectedItem="{Binding SelectedMode}"
                          DisplayMemberPath="Label" />
                <TextBlock Text="{Binding SelectedMode.Description}"
                           Foreground="{DynamicResource Text.Secondary}" FontSize="11"
                           TextWrapping="Wrap" Margin="0,4,0,10" />

                <TextBlock Text="DATA" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Brush}" Margin="0,4,0,4" />
                <TextBox Text="{Binding InstrumentSearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}"
                         mah:TextBoxHelper.Watermark="filter symbols…"
                         mah:TextBoxHelper.ClearTextButton="True"
                         Margin="0,0,0,6" />
                <uic:InstrumentPicker ShowSearch="False"
                                      ItemsSource="{Binding Instruments}"
                                      SelectedInstrument="{Binding SelectedInstrument, Mode=TwoWay}"
                                      MaxDropDownHeight="420"
                                      Margin="0,0,0,6" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Timeframe" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Bars" FontSize="10"
                               Foreground="{DynamicResource Text.Secondary}" Margin="0,0,0,2" />
                    <ComboBox Grid.Row="1" Grid.Column="0"
                              ItemsSource="{Binding Timeframes}"
                              SelectedItem="{Binding SelectedTimeframe}"
                              DisplayMemberPath="Label" />
                    <TextBox Grid.Row="1" Grid.Column="2"
                             Text="{Binding BarCount, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <Expander Header="X AXIS" IsExpanded="True">
                    <ContentControl Content="{Binding XAxis}" ContentTemplate="{StaticResource AxisEditorTemplate}" />
                </Expander>
                <Expander Header="Y AXIS" IsExpanded="True" Margin="0,4,0,0">
                    <ContentControl Content="{Binding YAxis}" ContentTemplate="{StaticResource AxisEditorTemplate}" />
                </Expander>
                <Expander Header="Z AXIS (HEIGHT)" IsExpanded="True" Margin="0,4,0,0">
                    <ContentControl Content="{Binding ZAxis}" ContentTemplate="{StaticResource AxisEditorTemplate}" />
                </Expander>
                <Expander Header="COLOR (W)" IsExpanded="True" Margin="0,4,0,0">
                    <ContentControl Content="{Binding WAxis}" ContentTemplate="{StaticResource AxisEditorTemplate}" />
                </Expander>

                <Border Background="{DynamicResource Danger.Brush}" Padding="8,6" Margin="0,10,0,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap" FontSize="11" />
                </Border>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="GENERATE SURFACE"
                            Command="{Binding GenerateCommand}"
                            IsEnabled="{Binding CanGenerate}"
                            ToolTip="One-shot build over stored/historical bars."
                            Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"
                            Padding="0,8" FontWeight="SemiBold" />
                    <Button Grid.Column="2" Content="✕" ToolTip="Cancel"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Padding="10,8" />
                </Grid>

                <Button Command="{Binding ToggleLiveCommand}"
                        Margin="0,8,0,0" Padding="0,8" FontWeight="SemiBold"
                        Foreground="White"
                        ToolTip="Seed from history, then rebuild the surface continuously from streaming quotes/trades.">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                            <Setter Property="Background" Value="{DynamicResource Bullish.Brush}" />
                            <Setter Property="Content" Value="● GO LIVE" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLive}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Danger.Brush}" />
                                    <Setter Property="Content" Value="■ STOP LIVE" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock Text="{Binding LiveStatus}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Bullish.Brush}" TextWrapping="Wrap" Margin="0,6,0,0"
                           Visibility="{Binding IsLive, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <mah:MetroProgressBar IsIndeterminate="True" Margin="0,8,0,0"
                                      Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Text="{Binding RunStatus}" Foreground="{DynamicResource Text.Secondary}"
                           FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" />
            </StackPanel>
        </ScrollViewer>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="{DynamicResource Border.Brush}" />

        <!-- ══ Center: 3D surface (orbit = drag, zoom = wheel, pan = shift-drag) ═══════════════ -->
        <Grid Grid.Column="2">
            <helix:HelixViewport3D x:Name="View3D"
                                   ZoomExtentsWhenLoaded="True"
                                   ShowFrameRate="False"
                                   ShowCoordinateSystem="False"
                                   ShowViewCube="True"
                                   Background="#1E1E1E"
                                   CameraRotationMode="Trackball"
                                   IsHeadLightEnabled="True" />
            <TextBlock Text="Configure the axes on the left and press GENERATE SURFACE."
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#88FFFFFF" FontSize="13"
                       Visibility="{Binding HasResult, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
        </Grid>

        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="{DynamicResource Border.Brush}" />

        <!-- ══ Right: analytics & slicing ══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource Background.Surface}">
            <StackPanel Margin="12">
                <TextBlock Text="DISPLAY" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Brush}" Margin="0,0,0,6" />
                <CheckBox IsChecked="{Binding ShowPeakMarker}"
                          Content="Peak finder (pin the global maximum)" />
                <CheckBox IsChecked="{Binding RobustnessColorMode}" Margin="0,6,0,0"
                          Content="Robustness heatmap (green = plateau, red = spike)"
                          ToolTip="Colors each cell by the gradient to its neighbors instead of by the W statistic. Smooth plateaus are stable effects; isolated spikes are likely noise/outliers." />
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Height ×" VerticalAlignment="Center"
                               Foreground="{DynamicResource Text.Secondary}" FontSize="11" />
                    <Slider Width="140" Minimum="0.3" Maximum="3" Value="{Binding HeightScale}"
                            Margin="8,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding HeightScale, StringFormat=0.0}" Margin="6,0,0,0"
                               VerticalAlignment="Center" FontSize="11" />
                </StackPanel>

                <Separator Margin="0,12,0,10" />

                <TextBlock Text="SURFACE STATS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Brush}" Margin="0,0,0,6" />
                <TextBlock Text="Global max" FontSize="10" Foreground="{DynamicResource Text.Secondary}" />
                <TextBlock Text="{Binding GlobalMaxText}" FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="12" TextWrapping="Wrap" Margin="0,1,0,6" />
                <TextBlock Text="Global min" FontSize="10" Foreground="{DynamicResource Text.Secondary}" />
                <TextBlock Text="{Binding GlobalMinText}" FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="12" TextWrapping="Wrap" Margin="0,1,0,6" />
                <TextBlock Text="Grid" FontSize="10" Foreground="{DynamicResource Text.Secondary}" />
                <TextBlock Text="{Binding CellCountText}" FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="12" Margin="0,1,0,0" />

                <Separator Margin="0,12,0,10" />

                <TextBlock Text="2D SLICE VIEWER" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Brush}" Margin="0,0,0,6" />
                <StackPanel IsEnabled="{Binding HasResult}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="X slice" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text.Secondary}" Width="46" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="{Binding SliceXMax}"
                                Value="{Binding SliceXIndex}" IsSnapToTickEnabled="True" TickFrequency="1"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SliceXLabel}" FontSize="11" Width="64"
                                   TextAlignment="Right" VerticalAlignment="Center"
                                   FontFamily="Consolas, Cascadia Mono, monospace" />
                    </Grid>
                    <!-- Cross-section along Y at the fixed X above. -->
                    <sp:WpfPlot x:Name="SliceXPlot" Height="150" Margin="0,4,0,10" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Y slice" FontSize="11" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Text.Secondary}" Width="46" />
                        <Slider Grid.Column="1" Minimum="0" Maximum="{Binding SliceYMax}"
                                Value="{Binding SliceYIndex}" IsSnapToTickEnabled="True" TickFrequency="1"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding SliceYLabel}" FontSize="11" Width="64"
                                   TextAlignment="Right" VerticalAlignment="Center"
                                   FontFamily="Consolas, Cascadia Mono, monospace" />
                    </Grid>
                    <!-- Cross-section along X at the fixed Y above. -->
                    <sp:WpfPlot x:Name="SliceYPlot" Height="150" Margin="0,4,0,0" />
                </StackPanel>

                <Separator Margin="0,12,0,10" />
                <TextBlock Text="PEAK" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource Accent.Brush}" Margin="0,0,0,4" />
                <TextBlock Text="{Binding PeakLocationText}" FontFamily="Consolas, Cascadia Mono, monospace"
                           FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
